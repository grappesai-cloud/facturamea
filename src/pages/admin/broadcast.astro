---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { broadcasts, users } from '../../db/schema';
import { sql, desc, eq } from 'drizzle-orm';

async function safe<T>(p: Promise<T>, fb: T) { try { return await p; } catch { return fb; } }

const recent = await safe(
  db.select({
    id: broadcasts.id, title: broadcasts.title, segment: broadcasts.segment,
    sendEmail: broadcasts.sendEmail, recipientsCount: broadcasts.recipientsCount,
    sentAt: broadcasts.sentAt, sentByName: users.name,
  }).from(broadcasts).leftJoin(users, eq(broadcasts.sentBy, users.id))
    .orderBy(desc(broadcasts.sentAt)).limit(20),
  []
);

const segments = [
  { value: 'all',           label: 'Toţi utilizatorii' },
  { value: 'transportator', label: 'Doar transportatori' },
  { value: 'intermediar',   label: 'Doar intermediari / expeditori' },
  { value: 'client_direct', label: 'Doar clienţi direcţi' },
  { value: 'partener',      label: 'Doar parteneri' },
  { value: 'tier:premium',  label: 'Abonament Premium' },
  { value: 'tier:cargo',    label: 'Abonament Cargo' },
  { value: 'tier:sprinter', label: 'Abonament Sprinter' },
];

const inputCls = 'w-full px-4 py-2.5 bg-white border border-[#E8E8E4] rounded-xl text-[13px] focus:border-[#0A0A0A] focus:outline-none transition-colors';
const fmt = (d: any) => d ? new Date(d).toLocaleString('ro-RO') : '—';
---

<AdminLayout title="Broadcast" activeTab="broadcast">
  <div class="mb-6">
    <h2 class="text-[22px] font-bold tracking-[-0.02em]">Broadcast notificări</h2>
    <p class="text-[13px] text-[#6B6B68] mt-1">Trimite o notificare în-app (şi opţional email) către un segment de utilizatori.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <form id="broadcast-form" class="lg:col-span-2 space-y-4 p-6 bg-white border border-[#E8E8E4] rounded-xl">
      <div id="broadcast-banner" class="hidden flex items-start gap-2 px-4 py-3 rounded-xl text-[13px]"></div>
      <div>
        <label class="block text-[12px] font-medium mb-1.5">Segment</label>
        <select name="segment" required class={inputCls}>
          {segments.map((s) => <option value={s.value}>{s.label}</option>)}
        </select>
        <p id="recipient-preview" class="text-[11px] text-[#6B6B68] mt-1.5">Estimare destinatari: —</p>
      </div>
      <div>
        <label class="block text-[12px] font-medium mb-1.5">Titlu (max 200)</label>
        <input name="title" required maxlength="200" placeholder="ex. Mentenanţă programată sâmbătă" class={inputCls} />
      </div>
      <div>
        <label class="block text-[12px] font-medium mb-1.5">Mesaj</label>
        <textarea name="body" required rows="6" placeholder="Conţinut mesaj — markdown simplu OK" class={inputCls + ' resize-y'}></textarea>
      </div>
      <div>
        <label class="flex items-center gap-2 text-[13px]">
          <input type="checkbox" name="sendEmail" class="w-4 h-4 accent-[#FF5C00]" />
          <span>Trimite şi email (Resend)</span>
        </label>
      </div>
      <div class="pt-2">
        <button type="submit" id="send-btn" class="px-6 py-3 bg-[#0A0A0A] hover:bg-[#1A1A1A] disabled:bg-[#A8A8A4] text-white font-semibold rounded-xl text-[13px] transition-colors">
          Trimite broadcast
        </button>
        <p class="text-[11px] text-[#6B6B68] mt-2">⚠️ Acţiunea e ireversibilă şi notifică oameni reali.</p>
      </div>
    </form>

    <div class="bg-white border border-[#E8E8E4] rounded-xl overflow-hidden h-fit">
      <div class="px-5 py-3 border-b border-[#E8E8E4]"><p class="text-[11px] uppercase tracking-[0.16em] text-[#6B6B68] font-medium">Istoric (ultimele 20)</p></div>
      <div class="divide-y divide-[#E8E8E4] max-h-[600px] overflow-y-auto">
        {recent.length === 0 ? (
          <div class="px-5 py-8 text-center text-[12px] text-[#6B6B68]">Fără broadcast-uri</div>
        ) : recent.map((b) => (
          <div class="px-5 py-3">
            <p class="text-[13px] font-semibold truncate">{b.title}</p>
            <p class="text-[11px] text-[#6B6B68] mt-1">
              {b.segment} · {b.recipientsCount ?? '?'} destinatari{b.sendEmail ? ' · email' : ''}
            </p>
            <p class="text-[10px] text-[#A8A8A4] mt-1">{fmt(b.sentAt)} · {b.sentByName ?? 'admin'}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('broadcast-form') as HTMLFormElement;
    const btn = document.getElementById('send-btn') as HTMLButtonElement;
    const banner = document.getElementById('broadcast-banner')!;
    const preview = document.getElementById('recipient-preview')!;

    async function refreshPreview() {
      const seg = (form.elements.namedItem('segment') as HTMLSelectElement).value;
      try {
        const res = await fetch(`/api/admin/broadcast?preview=1&segment=${encodeURIComponent(seg)}`);
        const data = await res.json();
        preview.textContent = `Estimare destinatari: ${data.count?.toLocaleString() ?? '—'}`;
      } catch { preview.textContent = 'Estimare destinatari: —'; }
    }
    (form.elements.namedItem('segment') as HTMLSelectElement | null)?.addEventListener('change', refreshPreview);
    refreshPreview();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const body = {
        segment: fd.get('segment'),
        title: fd.get('title'),
        body: fd.get('body'),
        sendEmail: fd.get('sendEmail') === 'on',
      };
      const ok = confirm(`Confirmă trimiterea către segmentul "${body.segment}"?`);
      if (!ok) return;
      btn.disabled = true; btn.textContent = 'Se trimite...';
      banner.classList.add('hidden');
      try {
        const res = await fetch('/api/admin/broadcast', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (!res.ok) {
          banner.className = 'flex items-start gap-2 px-4 py-3 rounded-xl text-[13px] bg-white border border-[#B91C1C]/30 text-[#B91C1C]';
          banner.textContent = data.error || 'Eroare';
        } else {
          banner.className = 'flex items-start gap-2 px-4 py-3 rounded-xl text-[13px] bg-white border border-[#15803D]/30 text-[#15803D]';
          banner.textContent = `Trimis către ${data.recipientsCount} utilizatori.`;
          form.reset();
          setTimeout(() => window.location.reload(), 1500);
        }
      } catch (err) {
        banner.className = 'flex items-start gap-2 px-4 py-3 rounded-xl text-[13px] bg-white border border-[#B91C1C]/30 text-[#B91C1C]';
        banner.textContent = 'Eroare reţea';
      } finally {
        btn.disabled = false; btn.textContent = 'Trimite broadcast';
      }
    });
  </script>
</AdminLayout>
