---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { appLicenses, companies } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';

// Read-only revenue view. Shown to full admins AND to viewer (partner) accounts.
// Strictly: company name + the lifetime payment (800 RON). No actions, no edits.

const ron = (cents: number | null) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON', maximumFractionDigits: 0 }).format((cents || 0) / 100);

const dt = (d: Date | null) =>
  d ? new Intl.DateTimeFormat('ro-RO', { day: '2-digit', month: 'short', year: 'numeric' }).format(new Date(d)) : '—';

let payments: Array<{
  companyName: string | null; amountCents: number | null; status: string; activatedAt: Date | null;
}> = [];

try {
  payments = await db
    .select({
      companyName: companies.name,
      amountCents: appLicenses.amountCents,
      status: appLicenses.status,
      activatedAt: appLicenses.activatedAt,
    })
    .from(appLicenses)
    .leftJoin(companies, eq(appLicenses.companyId, companies.id))
    .where(eq(appLicenses.plan, 'lifetime'))
    .orderBy(desc(appLicenses.activatedAt));
} catch {
  payments = [];
}

const active = payments.filter((p) => p.status === 'active');
const totalCents = active.reduce((s, p) => s + (p.amountCents || 0), 0);

const statusLabel: Record<string, { label: string; cls: string }> = {
  active:   { label: 'Activă',   cls: 'bg-[#2E9E6A]/15 text-[#2E9E6A]' },
  canceled: { label: 'Revocată', cls: 'bg-[#DC4B41]/15 text-[#DC4B41]' },
  expired:  { label: 'Expirată', cls: 'bg-white/10 text-[#A8BED2]' },
};
---

<AdminLayout title="Încasări" activeTab="incasari">
  <div class="mb-6">
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white">Încasări licențe</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">Companiile care au achiziționat licența lifetime (800 RON).</p>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-8 max-w-2xl">
    <div class="rounded-2xl bg-white/5 p-5">
      <p class="text-[11px] uppercase tracking-[0.14em] text-[#5E7385] font-semibold">Licențe active</p>
      <p class="text-[28px] font-bold tracking-[-0.02em] mt-1 text-white">{active.length}</p>
    </div>
    <div class="rounded-2xl bg-white/5 p-5">
      <p class="text-[11px] uppercase tracking-[0.14em] text-[#5E7385] font-semibold">Total încasat</p>
      <p class="text-[28px] font-bold tracking-[-0.02em] mt-1 text-[#E1FB15]">{ron(totalCents)}</p>
    </div>
  </div>

  <p class="text-[13px] text-[#8FA6BC] mb-3">{payments.length} licențe lifetime</p>

  <div class="rounded-2xl bg-white/5 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-[13px]">
        <thead>
          <tr class="text-left text-[11px] uppercase tracking-wider text-[#8FA6BC] border-b border-white/10">
            <th class="px-5 py-3 font-semibold">Companie</th>
            <th class="px-5 py-3 font-semibold text-right">Plată</th>
            <th class="px-5 py-3 font-semibold">Status</th>
            <th class="px-5 py-3 font-semibold">Data</th>
          </tr>
        </thead>
        <tbody>
          {payments.length === 0 && (
            <tr><td colspan="4" class="px-5 py-10 text-center text-[#8FA6BC]">Nicio încasare încă.</td></tr>
          )}
          {payments.map((p) => {
            const s = statusLabel[p.status] || statusLabel.expired;
            return (
              <tr class="border-b border-white/5 last:border-0">
                <td class="px-5 py-3 font-semibold text-white">{p.companyName || '—'}</td>
                <td class="px-5 py-3 text-right tabular-nums text-white">{ron(p.amountCents)}</td>
                <td class="px-5 py-3"><span class={`px-2 py-0.5 rounded-full text-[11px] font-semibold ${s.cls}`}>{s.label}</span></td>
                <td class="px-5 py-3 text-[#A8BED2]">{dt(p.activatedAt)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
