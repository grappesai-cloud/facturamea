---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { siteBanner } from '../../db/schema';
import { desc } from 'drizzle-orm';

let banners: typeof siteBanner.$inferSelect[] = [];
try { banners = await db.select().from(siteBanner).orderBy(desc(siteBanner.createdAt)); } catch {}

const inputCls = 'w-full px-4 py-2.5 bg-white border border-[#E3EAF1] rounded-xl text-[13px] focus:border-[#0A2238] focus:outline-none transition-colors';
const fmt = (d: any) => d ? new Date(d).toLocaleString('ro-RO') : '—';
---

<AdminLayout title="Banner global" activeTab="banner">
  <div class="mb-6">
    <h2 class="text-[22px] font-bold tracking-[-0.02em]">Banner global</h2>
    <p class="text-[13px] text-[#46627A] mt-1">O singură anunţare activă la un moment dat. Apare pe toate paginile pentru toţi utilizatorii.</p>
  </div>

  <form id="banner-form" class="p-5 bg-white border border-[#E3EAF1] rounded-xl mb-6 space-y-3 max-w-2xl">
    <div>
      <label class="block text-[12px] font-medium mb-1.5">Mesaj</label>
      <textarea name="message" required rows="2" class={inputCls} placeholder="ex. Mentenanţă programată sâmbătă 02:00–04:00."></textarea>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div>
        <label class="block text-[12px] font-medium mb-1.5">Severitate</label>
        <select name="severity" class={inputCls}>
          <option value="info">Info</option>
          <option value="warning">Warning</option>
          <option value="critical">Critical</option>
        </select>
      </div>
      <div>
        <label class="block text-[12px] font-medium mb-1.5">Începe (opţional)</label>
        <input type="datetime-local" name="startsAt" class={inputCls} />
      </div>
      <div>
        <label class="block text-[12px] font-medium mb-1.5">Termină (opţional)</label>
        <input type="datetime-local" name="endsAt" class={inputCls} />
      </div>
    </div>
    <button type="submit" class="px-5 py-2.5 bg-[#0A2238] hover:bg-[#1A1A1A] text-white font-semibold rounded-xl text-[13px] transition-colors">
      Activează banner
    </button>
    <p class="text-[11px] text-[#46627A]">Crearea unui banner nou dezactivează automat banner-ul curent.</p>
  </form>

  <div class="bg-white border border-[#E3EAF1] rounded-xl overflow-hidden">
    <div class="px-5 py-3 border-b border-[#E3EAF1]"><p class="text-[11px] uppercase tracking-[0.16em] text-[#46627A] font-medium">Istoric</p></div>
    <div class="divide-y divide-[#E3EAF1]">
      {banners.length === 0 ? (
        <div class="px-5 py-8 text-center text-[12px] text-[#46627A]">Niciun banner.</div>
      ) : banners.map((b) => (
        <div class="px-5 py-3">
          <div class="flex items-start justify-between gap-3">
            <p class="text-[13px] flex-1">{b.message}</p>
            <span class:list={['px-2 py-0.5 text-[10px] uppercase tracking-wider font-semibold rounded-full shrink-0',
              b.active ? 'bg-[#15803D] text-white' : 'bg-[#E3EAF1] text-[#46627A]']}>
              {b.active ? 'Activ' : 'Inactiv'}
            </span>
          </div>
          <p class="text-[11px] text-[#46627A] mt-1">{b.severity} · {fmt(b.startsAt)} → {fmt(b.endsAt)} · creat {fmt(b.createdAt)}</p>
          {b.active && (
            <button data-deactivate={b.id} class="mt-2 text-[12px] text-[#B91C1C] hover:underline">Dezactivează</button>
          )}
        </div>
      ))}
    </div>
  </div>

  <script>
    document.getElementById('banner-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      await fetch('/api/admin/banner', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: fd.get('message'),
          severity: fd.get('severity'),
          startsAt: fd.get('startsAt') || null,
          endsAt: fd.get('endsAt') || null,
        }),
      });
      window.location.reload();
    });

    document.querySelectorAll('[data-deactivate]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-deactivate');
        await fetch(`/api/admin/banner/${id}`, { method: 'DELETE' });
        window.location.reload();
      });
    });
  </script>
</AdminLayout>
