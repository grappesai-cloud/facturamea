---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { invoices, subscriptions, companies, orders } from '../../db/schema';
import { sql, and, eq, gte, lt } from 'drizzle-orm';

const monthAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
const yearStart = new Date(new Date().getFullYear(), 0, 1);

async function safe<T>(p: Promise<T>, fb: T): Promise<T> { try { return await p; } catch { return fb; } }

const [paidThisMonth, paidYTD, allInvoices, overdue, draft] = await Promise.all([
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` })
    .from(invoices).where(and(eq(invoices.status, 'paid'), gte(invoices.paidAt, monthAgo))), [{ c: 0, t: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` })
    .from(invoices).where(and(eq(invoices.status, 'paid'), gte(invoices.paidAt, yearStart))), [{ c: 0, t: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` }).from(invoices), [{ c: 0, t: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` })
    .from(invoices).where(and(eq(invoices.status, 'overdue'))), [{ c: 0, t: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` })
    .from(invoices).where(eq(invoices.status, 'issued')), [{ c: 0, t: 0 }]),
]);

// Active subscriptions per tier
let tiers: { tier: string; c: number }[] = [];
try {
  const r = await db.execute(sql`SELECT subscription_tier AS tier, COUNT(*)::int AS c FROM companies GROUP BY 1 ORDER BY c DESC`);
  tiers = ((r as any).rows ?? r) as any;
} catch {}

// Top 10 customers by revenue (RON)
let topCustomers: { id: string; name: string; total: number }[] = [];
try {
  const r = await db.execute(sql`
    SELECT c.id, c.name, COALESCE(SUM(i.total_cents), 0)::int AS total
    FROM companies c
    JOIN invoices i ON i.company_id = c.id AND i.status = 'paid'
    GROUP BY c.id, c.name
    ORDER BY total DESC
    LIMIT 10
  `);
  topCustomers = ((r as any).rows ?? r) as any;
} catch {}

// Aging buckets — overdue invoices grouped by days late
let aging: { bucket: string; c: number; total: number }[] = [];
try {
  const r = await db.execute(sql`
    SELECT
      CASE
        WHEN due_at > NOW() - INTERVAL '7 days' THEN '0-7 zile'
        WHEN due_at > NOW() - INTERVAL '30 days' THEN '8-30 zile'
        WHEN due_at > NOW() - INTERVAL '60 days' THEN '31-60 zile'
        ELSE 'peste 60 zile'
      END AS bucket,
      COUNT(*)::int AS c,
      COALESCE(SUM(total_cents), 0)::int AS total
    FROM invoices
    WHERE status IN ('issued', 'overdue') AND due_at < NOW()
    GROUP BY 1
    ORDER BY MIN(due_at)
  `);
  aging = ((r as any).rows ?? r) as any;
} catch {}

const ron = (cents: number) => (cents / 100).toLocaleString('ro-RO', { maximumFractionDigits: 0 });

const tierLabels: Record<string, string> = { free: 'Free', sprinter: 'Sprinter', cargo: 'Cargo', premium: 'Premium' };
---

<AdminLayout title="Finance" activeTab="finance">
  <div class="mb-6">
    <h2 class="text-[22px] font-bold tracking-[-0.02em]">Finance</h2>
    <p class="text-[13px] text-[#46627A] mt-1">MRR, încasări, clienţi top, aging facturi.</p>
  </div>

  <!-- Hero numbers -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-[#E3EAF1] border border-[#E3EAF1] rounded-xl overflow-hidden mb-8">
    <div class="bg-white px-5 py-5">
      <p class="text-[10px] uppercase tracking-[0.16em] text-[#46627A] font-medium">Încasat 30 zile</p>
      <p class="text-[28px] font-bold mt-2 leading-none tabular-nums">{ron(paidThisMonth[0]?.t ?? 0)} <span class="text-[14px] text-[#46627A] font-medium">RON</span></p>
      <p class="text-[11px] text-[#46627A] mt-1">{paidThisMonth[0]?.c} facturi</p>
    </div>
    <div class="bg-white px-5 py-5">
      <p class="text-[10px] uppercase tracking-[0.16em] text-[#46627A] font-medium">Încasat YTD</p>
      <p class="text-[28px] font-bold mt-2 leading-none tabular-nums">{ron(paidYTD[0]?.t ?? 0)} <span class="text-[14px] text-[#46627A] font-medium">RON</span></p>
      <p class="text-[11px] text-[#46627A] mt-1">{paidYTD[0]?.c} facturi</p>
    </div>
    <div class="bg-white px-5 py-5">
      <p class="text-[10px] uppercase tracking-[0.16em] text-[#46627A] font-medium">Restant</p>
      <p class="text-[28px] font-bold mt-2 leading-none tabular-nums text-[#B45309]">{ron(overdue[0]?.t ?? 0)}</p>
      <p class="text-[11px] text-[#46627A] mt-1">{overdue[0]?.c} facturi</p>
    </div>
    <div class="bg-white px-5 py-5">
      <p class="text-[10px] uppercase tracking-[0.16em] text-[#46627A] font-medium">Emise neîncasate</p>
      <p class="text-[28px] font-bold mt-2 leading-none tabular-nums">{ron(draft[0]?.t ?? 0)}</p>
      <p class="text-[11px] text-[#46627A] mt-1">{draft[0]?.c} facturi</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-white border border-[#E3EAF1] rounded-xl overflow-hidden">
      <div class="px-5 py-3 border-b border-[#E3EAF1]"><p class="text-[11px] uppercase tracking-[0.16em] text-[#46627A] font-medium">Companii pe abonament</p></div>
      <div class="divide-y divide-[#E3EAF1]">
        {tiers.length === 0 ? (
          <div class="px-5 py-6 text-center text-[12px] text-[#46627A]">Fără date</div>
        ) : tiers.map((t) => (
          <div class="px-5 py-3 flex items-center justify-between text-[13px]">
            <span class="font-medium">{tierLabels[t.tier] || t.tier}</span>
            <span class="font-semibold tabular-nums">{t.c}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-white border border-[#E8E8E4] rounded-xl overflow-hidden">
      <div class="px-5 py-3 border-b border-[#E8E8E4]"><p class="text-[11px] uppercase tracking-[0.16em] text-[#6B6B68] font-medium">Vechime facturi restante</p></div>
      <div class="divide-y divide-[#E8E8E4]">
        {aging.length === 0 ? (
          <div class="px-5 py-6 text-center text-[12px] text-[#46627A]">Fără restanţe</div>
        ) : aging.map((a) => (
          <div class="px-5 py-3 flex items-center justify-between text-[13px]">
            <span class="font-medium">{a.bucket}</span>
            <span class="text-right">
              <span class="font-semibold tabular-nums">{ron(a.total)} RON</span>
              <span class="text-[#46627A] ml-2">({a.c})</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="bg-white border border-[#E3EAF1] rounded-xl overflow-hidden">
    <div class="px-5 py-3 border-b border-[#E3EAF1]"><p class="text-[11px] uppercase tracking-[0.16em] text-[#46627A] font-medium">Top 10 clienţi după venit</p></div>
    {topCustomers.length === 0 ? (
      <div class="px-5 py-8 text-center text-[12px] text-[#46627A]">Fără date</div>
    ) : (
      <div class="divide-y divide-[#E3EAF1]">
        {topCustomers.map((c, i) => (
          <a href={`/admin/companies?id=${c.id}`} class="px-5 py-3 flex items-center justify-between text-[13px] hover:bg-[#FCFCFA] transition-colors">
            <span class="flex items-center gap-3">
              <span class="text-[#A8BED2] font-mono w-6 text-right">{i + 1}.</span>
              <span class="font-medium">{c.name}</span>
            </span>
            <span class="font-semibold tabular-nums">{ron(c.total)} RON</span>
          </a>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
