---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { invoices, subscriptions, companies, orders } from '../../db/schema';
import { sql, and, eq, gte, lt } from 'drizzle-orm';

const monthAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
const yearStart = new Date(new Date().getFullYear(), 0, 1);

async function safe<T>(p: Promise<T>, fb: T): Promise<T> { try { return await p; } catch { return fb; } }

const [paidThisMonth, paidYTD, allInvoices, overdue, draft] = await Promise.all([
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` })
    .from(invoices).where(and(eq(invoices.status, 'paid'), gte(invoices.paidAt, monthAgo))), [{ c: 0, t: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` })
    .from(invoices).where(and(eq(invoices.status, 'paid'), gte(invoices.paidAt, yearStart))), [{ c: 0, t: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` }).from(invoices), [{ c: 0, t: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` })
    .from(invoices).where(and(eq(invoices.status, 'overdue'))), [{ c: 0, t: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int`, t: sql<number>`COALESCE(SUM(total_cents), 0)::int` })
    .from(invoices).where(eq(invoices.status, 'issued')), [{ c: 0, t: 0 }]),
]);

// Active subscriptions per tier
let tiers: { tier: string; c: number }[] = [];
try {
  const r = await db.execute(sql`SELECT subscription_tier AS tier, COUNT(*)::int AS c FROM companies GROUP BY 1 ORDER BY c DESC`);
  tiers = ((r as any).rows ?? r) as any;
} catch {}

// Top 10 customers by revenue (RON)
let topCustomers: { id: string; name: string; total: number }[] = [];
try {
  const r = await db.execute(sql`
    SELECT c.id, c.name, COALESCE(SUM(i.total_cents), 0)::int AS total
    FROM companies c
    JOIN invoices i ON i.company_id = c.id AND i.status = 'paid'
    GROUP BY c.id, c.name
    ORDER BY total DESC
    LIMIT 10
  `);
  topCustomers = ((r as any).rows ?? r) as any;
} catch {}

// Aging buckets — overdue invoices grouped by days late
let aging: { bucket: string; c: number; total: number }[] = [];
try {
  const r = await db.execute(sql`
    SELECT
      CASE
        WHEN due_at > NOW() - INTERVAL '7 days' THEN '0-7 zile'
        WHEN due_at > NOW() - INTERVAL '30 days' THEN '8-30 zile'
        WHEN due_at > NOW() - INTERVAL '60 days' THEN '31-60 zile'
        ELSE 'peste 60 zile'
      END AS bucket,
      COUNT(*)::int AS c,
      COALESCE(SUM(total_cents), 0)::int AS total
    FROM invoices
    WHERE status IN ('issued', 'overdue') AND due_at < NOW()
    GROUP BY 1
    ORDER BY MIN(due_at)
  `);
  aging = ((r as any).rows ?? r) as any;
} catch {}

const ron = (cents: number) => (cents / 100).toLocaleString('ro-RO', { maximumFractionDigits: 0 });

const tierLabels: Record<string, string> = { free: 'Free', sprinter: 'Sprinter', cargo: 'Cargo', premium: 'Premium' };
---

<AdminLayout title="Finance" activeTab="finance">
  <div class="mb-6">
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white">Finance</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">MRR, încasări, clienţi top, aging facturi.</p>
  </div>

  <!-- Hero numbers -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-3">
    <div class="rounded-2xl bg-white/5 p-4 sm:p-5">
      <p class="text-[12px] font-medium text-[#8FA6BC]">Încasat 30 zile</p>
      <p class="text-[22px] sm:text-[28px] font-bold mt-1.5 leading-none tabular-nums text-white whitespace-nowrap">{ron(paidThisMonth[0]?.t ?? 0)} <span class="text-[13px] text-[#8FA6BC] font-semibold">RON</span></p>
      <p class="text-[12px] text-[#8FA6BC] mt-1.5">{paidThisMonth[0]?.c} facturi</p>
    </div>
    <div class="rounded-2xl bg-white/5 p-4 sm:p-5">
      <p class="text-[12px] font-medium text-[#8FA6BC]">Încasat YTD</p>
      <p class="text-[22px] sm:text-[28px] font-bold mt-1.5 leading-none tabular-nums text-[#2E9E6A] whitespace-nowrap">{ron(paidYTD[0]?.t ?? 0)} <span class="text-[13px] text-[#2E9E6A]/70 font-semibold">RON</span></p>
      <p class="text-[12px] text-[#8FA6BC] mt-1.5">{paidYTD[0]?.c} facturi</p>
    </div>
    <div class="rounded-2xl bg-white/5 p-4 sm:p-5">
      <p class="text-[12px] font-medium text-[#8FA6BC]">Restant</p>
      <p class="text-[22px] sm:text-[28px] font-bold mt-1.5 leading-none tabular-nums text-[#DC4B41] whitespace-nowrap">{ron(overdue[0]?.t ?? 0)} <span class="text-[13px] text-[#DC4B41]/70 font-semibold">RON</span></p>
      <p class="text-[12px] text-[#8FA6BC] mt-1.5">{overdue[0]?.c} facturi</p>
    </div>
    <div class="rounded-2xl bg-white/5 p-4 sm:p-5">
      <p class="text-[12px] font-medium text-[#8FA6BC]">Emise neîncasate</p>
      <p class="text-[22px] sm:text-[28px] font-bold mt-1.5 leading-none tabular-nums text-[#E8A33C] whitespace-nowrap">{ron(draft[0]?.t ?? 0)} <span class="text-[13px] text-[#E8A33C]/70 font-semibold">RON</span></p>
      <p class="text-[12px] text-[#8FA6BC] mt-1.5">{draft[0]?.c} facturi</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 mb-3">
    <div class="rounded-2xl bg-white/5 overflow-hidden">
      <div class="px-5 py-4 border-b border-white/10"><p class="text-[13px] font-semibold text-white">Companii pe abonament</p></div>
      <div class="divide-y divide-white/5">
        {tiers.length === 0 ? (
          <div class="px-5 py-8 text-center text-[13px] text-[#8FA6BC]">Fără date</div>
        ) : tiers.map((t) => (
          <div class="px-5 py-3 flex items-center justify-between text-[13px]">
            <span class="font-medium text-white">{tierLabels[t.tier] || t.tier}</span>
            <span class="font-semibold tabular-nums text-[#A8BED2]">{t.c}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="rounded-2xl bg-white/5 overflow-hidden">
      <div class="px-5 py-4 border-b border-white/10"><p class="text-[13px] font-semibold text-white">Vechime facturi restante</p></div>
      <div class="divide-y divide-white/5">
        {aging.length === 0 ? (
          <div class="px-5 py-8 text-center text-[13px] text-[#8FA6BC]">Fără restanţe</div>
        ) : aging.map((a) => (
          <div class="px-5 py-3 flex items-center justify-between text-[13px] gap-3">
            <span class="font-medium text-white">{a.bucket}</span>
            <span class="text-right whitespace-nowrap">
              <span class="font-semibold tabular-nums text-white">{ron(a.total)} RON</span>
              <span class="text-[#8FA6BC] ml-2">({a.c})</span>
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="rounded-2xl bg-white/5 overflow-hidden">
    <div class="px-5 py-4 border-b border-white/10"><p class="text-[13px] font-semibold text-white">Top 10 clienţi după venit</p></div>
    {topCustomers.length === 0 ? (
      <div class="px-5 py-10 text-center text-[13px] text-[#8FA6BC]">Fără date</div>
    ) : (
      <div class="divide-y divide-white/5">
        {topCustomers.map((c, i) => (
          <a href={`/admin/companies?id=${c.id}`} class="px-5 py-3 flex items-center justify-between text-[13px] hover:bg-white/[0.03] transition-colors gap-3">
            <span class="flex items-center gap-3 min-w-0">
              <span class="text-[#5E7385] font-mono w-6 text-right shrink-0">{i + 1}.</span>
              <span class="font-medium text-white truncate">{c.name}</span>
            </span>
            <span class="font-semibold tabular-nums text-[#A8BED2] shrink-0 whitespace-nowrap">{ron(c.total)} RON</span>
          </a>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
