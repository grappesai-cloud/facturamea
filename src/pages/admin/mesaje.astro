---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listSupportMessages } from '../../lib/support';

const messages = await listSupportMessages().catch(() => []);
const newCount = messages.filter((m) => m.status === 'new').length;

const fmt = (d: string | Date | null) => {
  if (!d) return '';
  try { return new Date(d).toLocaleString('ro-RO', { timeZone: 'Europe/Bucharest', day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }); }
  catch { return String(d); }
};
const SOURCE_LABEL: Record<string, string> = { app: 'Din aplicație', contact: 'Pagina /contact' };
---

<AdminLayout title="Mesaje" activeTab="mesaje">
  <div class="mb-6">
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white">Mesaje suport</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">
      Mesaje trimise din aplicație („Ajutor") și din pagina publică /contact. Nu se trimite niciun email — totul ajunge aici.
      {newCount > 0 && <span class="ml-1 text-[#E1FB15] font-semibold">{newCount} noi</span>}
    </p>
  </div>

  {messages.length === 0 ? (
    <div class="rounded-2xl bg-white/5 px-5 py-12 text-center text-[14px] text-[#8FA6BC]">Niciun mesaj încă.</div>
  ) : (
    <ul class="space-y-3">
      {messages.map((m) => (
        <li
          data-msg-id={m.id}
          data-status={m.status}
          class:list={['rounded-2xl p-5 ring-1 transition-colors', m.status === 'new' ? 'bg-white/[0.06] ring-[#E1FB15]/25' : 'bg-white/[0.03] ring-white/10 opacity-70']}
        >
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class:list={['inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold', m.status === 'new' ? 'bg-[#E1FB15]/15 text-[#E1FB15]' : 'bg-[#2E9E6A]/15 text-[#2E9E6A]']}>
                  {m.status === 'new' ? 'Nou' : 'Rezolvat'}
                </span>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-white/10 text-[#A8BED2]">{SOURCE_LABEL[m.source] || m.source}</span>
                {m.topic && <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-[#34A0A4]/15 text-[#34A0A4]">{m.topic}</span>}
                <span class="text-[12px] text-[#8FA6BC]">{fmt(m.createdAt)}</span>
              </div>
              <p class="text-[14px] text-white whitespace-pre-wrap break-words">{m.message}</p>
              <p class="text-[12px] text-[#8FA6BC] mt-2">
                {m.name ? `${m.name} · ` : ''}
                {m.email ? <a href={`mailto:${m.email}`} class="text-[#34A0A4] hover:underline">{m.email}</a> : 'fără email'}
                {m.userId ? ' · cont logat' : ''}
              </p>
            </div>
            <button
              type="button"
              data-resolve={m.id}
              data-next={m.status === 'new' ? 'resolved' : 'new'}
              class="shrink-0 px-3 py-1.5 rounded-full text-[12px] font-semibold bg-white/10 text-white hover:bg-white/15 transition-colors whitespace-nowrap"
            >
              {m.status === 'new' ? 'Marchează rezolvat' : 'Redeschide'}
            </button>
          </div>
        </li>
      ))}
    </ul>
  )}
</AdminLayout>

<script is:inline>
  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-resolve]');
    if (!btn) return;
    const id = btn.getAttribute('data-resolve');
    const next = btn.getAttribute('data-next');
    btn.disabled = true; btn.textContent = '...';
    try {
      const r = await fetch('/api/admin/support', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, status: next }),
      });
      if (!r.ok) throw new Error('fail');
      location.reload();
    } catch {
      btn.disabled = false; btn.textContent = next === 'resolved' ? 'Marchează rezolvat' : 'Redeschide';
      alert('Nu am putut actualiza. Încearcă din nou.');
    }
  });
</script>
