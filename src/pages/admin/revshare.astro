---
import AdminLayout from '../../layouts/AdminLayout.astro';
import RevShareAdmin from '../../components/admin/RevShareAdmin';
import { isStripeConfigured } from '../../lib/stripe';

const stripeOk = isStripeConfigured();
---

<AdminLayout title="Revenue share" activeTab="revshare">
  <div class="mb-6">
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white">Revenue share asociat</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">Împarte automat un procent din fiecare vânzare către contul Connect al asociatului care a făcut frontend-ul.</p>
  </div>

  {!stripeOk ? (
    <div class="rounded-2xl bg-[#DC4B41]/15 text-[#DC4B41] px-5 py-4 text-[13px]">Stripe nu e configurat (lipsește STRIPE_SECRET_KEY). Setează-l în Coolify înainte.</div>
  ) : (
    <RevShareAdmin client:only="react" />
  )}
</AdminLayout>
