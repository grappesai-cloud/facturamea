---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { companies, appLicenses } from '../../db/schema';
import { like, or, desc, eq } from 'drizzle-orm';

const q = Astro.url.searchParams.get('q') || '';
const where = q ? or(like(companies.name, `%${q}%`), like(companies.cui, `%${q}%`)) : undefined;

let companyList: Array<{
  id: string; name: string; cui: string | null; city: string | null; country: string;
  createdAt: Date | null; plan: string | null; status: string | null;
}> = [];
try {
  companyList = await db
    .select({
      id: companies.id,
      name: companies.name,
      cui: companies.cui,
      city: companies.city,
      country: companies.country,
      createdAt: companies.createdAt,
      plan: appLicenses.plan,
      status: appLicenses.status,
    })
    .from(companies)
    .leftJoin(appLicenses, eq(appLicenses.companyId, companies.id))
    .where(where)
    .orderBy(desc(companies.createdAt))
    .limit(80);
} catch {
  companyList = [];
}

const planLabel: Record<string, { label: string; cls: string }> = {
  lifetime: { label: 'Lifetime', cls: 'bg-[#E7F7EC] text-[#15803D]' },
  trial: { label: 'Trial', cls: 'bg-[#FFF7E6] text-[#B45309]' },
};
const fmt = (d: any) => d ? new Date(d).toLocaleDateString('ro-RO', { day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'Europe/Bucharest' }) : '-';
---

<AdminLayout title="Companii" activeTab="companies">
  <div class="mb-6">
    <form method="GET" class="flex gap-3 max-w-xl">
      <input type="text" name="q" value={q} placeholder="Caută după nume sau CUI..." class="flex-1 h-11 px-4 bg-white border border-[#E3EAF1] rounded-full text-[14px] text-[#07090f] placeholder:text-[#A8BED2] focus:border-[#07090f] focus:outline-none transition-colors" />
      <button type="submit" class="h-11 px-6 bg-[#1A759F] hover:bg-[#168AAD] text-white font-semibold rounded-xl text-[13px] transition-colors">Caută</button>
    </form>
    <p class="text-[13px] text-[#46627A] mt-2">{companyList.length} companii</p>
  </div>

  <div class="bg-white border border-[#E3EAF1] rounded-2xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-[13px]">
        <thead>
          <tr class="text-left text-[11px] uppercase tracking-wider text-[#8FA6BC] border-b border-[#E3EAF1]">
            <th class="px-5 py-2.5 font-medium">Companie</th>
            <th class="px-5 py-2.5 font-medium">CUI</th>
            <th class="px-5 py-2.5 font-medium">Locație</th>
            <th class="px-5 py-2.5 font-medium">Licență</th>
            <th class="px-5 py-2.5 font-medium">Creată</th>
            <th class="px-5 py-2.5 font-medium text-right">Acțiuni</th>
          </tr>
        </thead>
        <tbody>
          {companyList.map((c) => {
            const pl = c.plan ? (planLabel[c.plan] || { label: c.plan, cls: 'bg-[#E3EAF1] text-[#46627A]' }) : null;
            return (
              <tr class="border-b border-[#F6F6F2] hover:bg-[#EDF1F5] transition-colors">
                <td class="px-5 py-3 font-medium text-[#07090f]">{c.name}</td>
                <td class="px-5 py-3 font-mono text-[12px] text-[#46627A]">{c.cui || '-'}</td>
                <td class="px-5 py-3 text-[#46627A]">{c.city ? `${c.city}, ` : ''}{c.country}</td>
                <td class="px-5 py-3">
                  {pl ? (
                    <span class={`inline-block px-2 py-0.5 rounded-md text-[11px] font-medium ${pl.cls}`}>{pl.label}{c.status && c.status !== 'active' ? ` · ${c.status}` : ''}</span>
                  ) : (
                    <span class="text-[12px] text-[#A8BED2]">fără licență</span>
                  )}
                </td>
                <td class="px-5 py-3 text-[#46627A]">{fmt(c.createdAt)}</td>
                <td class="px-5 py-3 text-right">
                  <a href={`/admin/licente?company=${c.id}`} class="inline-block px-3 py-1.5 text-[12px] font-medium text-[#1A759F] hover:bg-[#FFF3EC] rounded-lg transition-colors">Acordă licență</a>
                </td>
              </tr>
            );
          })}
          {companyList.length === 0 && (
            <tr><td colspan="6" class="px-5 py-12 text-center text-[14px] text-[#46627A]">Nicio companie găsită.</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
