---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { users, freight, orders, waitlistSignups } from '../../db/schema';
import { sql } from 'drizzle-orm';

const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);

async function dailySeries(table: any, dateCol: any) {
  try {
    const r = await db.execute(sql`
      SELECT TO_CHAR(${dateCol}, 'YYYY-MM-DD') AS d, COUNT(*)::int AS c
      FROM ${table}
      WHERE ${dateCol} >= ${thirtyDaysAgo}
      GROUP BY 1 ORDER BY 1
    `);
    return ((r as any).rows ?? r ?? []) as { d: string; c: number }[];
  } catch { return [] as { d: string; c: number }[]; }
}

const [signups, freightSeries, orderSeries, waitlistSeries] = await Promise.all([
  dailySeries(users, users.createdAt),
  dailySeries(freight, freight.createdAt),
  dailySeries(orders, orders.createdAt),
  dailySeries(waitlistSignups, waitlistSignups.createdAt),
]);

let topRoutes: { route: string; c: number }[] = [];
try {
  const r = await db.execute(sql`
    SELECT (loading_country || ' → ' || unloading_country) AS route, COUNT(*)::int AS c
    FROM freight
    WHERE created_at >= ${thirtyDaysAgo}
    GROUP BY 1 ORDER BY c DESC LIMIT 10
  `);
  topRoutes = ((r as any).rows ?? r ?? []) as { route: string; c: number }[];
} catch {}

const [waitlistTotal] = await db.select({ c: sql<number>`COUNT(*)::int` }).from(waitlistSignups);
const [registered] = await db.select({ c: sql<number>`COUNT(*)::int` }).from(users);
const conversionPct = waitlistTotal?.c ? Math.round(((registered?.c ?? 0) / waitlistTotal.c) * 100) : 0;

function sparkline(series: { d: string; c: number }[], w = 280, h = 50): string {
  if (series.length === 0) return '<div class="h-12 flex items-center justify-center text-[11px] text-[#A8BED2]">Date insuficiente</div>';
  const max = Math.max(...series.map((s) => s.c), 1);
  const stepX = w / Math.max(series.length - 1, 1);
  const points = series.map((s, i) => `${i * stepX},${h - (s.c / max) * (h - 6) - 3}`).join(' ');
  return `<svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="none" class="w-full h-12"><polyline fill="none" stroke="#34A0A4" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" points="${points}"/></svg>`;
}

const series = [
  { label: 'Înscrieri utilizatori', total: signups.reduce((a, b) => a + b.c, 0), data: signups },
  { label: 'Marfă publicată',       total: freightSeries.reduce((a, b) => a + b.c, 0), data: freightSeries },
  { label: 'Comenzi create',        total: orderSeries.reduce((a, b) => a + b.c, 0), data: orderSeries },
  { label: 'Waitlist signups',      total: waitlistSeries.reduce((a, b) => a + b.c, 0), data: waitlistSeries },
];
---

<AdminLayout title="Analytics" activeTab="analytics">
  <div class="mb-6">
    <p class="text-[12px] uppercase tracking-[0.16em] text-[#34A0A4] font-semibold">Ultimele 30 zile</p>
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white mt-1">Activitate platformă</h1>
  </div>

  <div class="mb-3 p-5 sm:p-6 rounded-2xl bg-white/5">
    <p class="text-[12px] font-medium text-[#8FA6BC] mb-4">Funnel waitlist → cont activ</p>
    <div class="flex items-center gap-4 sm:gap-6">
      <div>
        <p class="text-[28px] sm:text-[32px] font-bold tabular-nums text-white leading-none">{waitlistTotal?.c ?? 0}</p>
        <p class="text-[12px] text-[#8FA6BC] mt-1.5">Waitlist</p>
      </div>
      <svg class="w-5 h-5 text-[#5E7385] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <div>
        <p class="text-[28px] sm:text-[32px] font-bold tabular-nums text-white leading-none">{registered?.c ?? 0}</p>
        <p class="text-[12px] text-[#8FA6BC] mt-1.5">Înregistraţi</p>
      </div>
      <span class="text-[#5E7385]">·</span>
      <div>
        <p class="text-[28px] sm:text-[32px] font-bold tabular-nums text-[#E1FB15] leading-none">{conversionPct}%</p>
        <p class="text-[12px] text-[#8FA6BC] mt-1.5">conversie</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 mb-3">
    {series.map((s) => (
      <div class="p-5 sm:p-6 rounded-2xl bg-white/5">
        <div class="flex items-baseline justify-between mb-3">
          <p class="text-[12px] font-medium text-[#8FA6BC]">{s.label}</p>
          <p class="text-[22px] font-bold tabular-nums text-white">{s.total.toLocaleString()}</p>
        </div>
        <div set:html={sparkline(s.data)} />
        <div class="flex justify-between text-[10px] text-[#5E7385] mt-2 tabular-nums">
          <span>{s.data[0]?.d ?? ''}</span>
          <span>{s.data[s.data.length - 1]?.d ?? ''}</span>
        </div>
      </div>
    ))}
  </div>

  <div class="rounded-2xl bg-white/5 overflow-hidden">
    <div class="px-5 py-4 border-b border-white/10">
      <p class="text-[13px] font-semibold text-white">Top rute (după volum marfă, 30z)</p>
    </div>
    {topRoutes.length === 0 ? (
      <div class="px-5 py-10 text-center text-[13px] text-[#8FA6BC]">Nu există suficiente date încă</div>
    ) : (
      <div class="divide-y divide-white/5">
        {topRoutes.map((r, i) => (
          <div class="px-5 py-3 flex items-center justify-between text-[13px]">
            <span class="flex items-center gap-3 min-w-0">
              <span class="text-[#5E7385] font-mono w-6 text-right shrink-0">{i + 1}.</span>
              <span class="font-medium text-white truncate">{r.route}</span>
            </span>
            <span class="font-semibold tabular-nums text-[#A8BED2] shrink-0 ml-3">{r.c}</span>
          </div>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
