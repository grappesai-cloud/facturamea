---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { appLicenses, companies } from '../../db/schema';
import { eq, desc, asc } from 'drizzle-orm';

const preselect = Astro.url.searchParams.get('company') || '';

const ron = (cents: number | null) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON', maximumFractionDigits: 0 }).format((cents || 0) / 100);

let licenseList: Array<{
  id: string; companyId: string; companyName: string | null; plan: string; status: string;
  trialEndsAt: Date | null; activatedAt: Date | null; amountCents: number | null; updatedAt: Date | null;
}> = [];
let companyOptions: Array<{ id: string; name: string }> = [];

try {
  licenseList = await db
    .select({
      id: appLicenses.id,
      companyId: appLicenses.companyId,
      companyName: companies.name,
      plan: appLicenses.plan,
      status: appLicenses.status,
      trialEndsAt: appLicenses.trialEndsAt,
      activatedAt: appLicenses.activatedAt,
      amountCents: appLicenses.amountCents,
      updatedAt: appLicenses.updatedAt,
    })
    .from(appLicenses)
    .leftJoin(companies, eq(appLicenses.companyId, companies.id))
    .orderBy(desc(appLicenses.updatedAt));
} catch {
  licenseList = [];
}

try {
  companyOptions = await db.select({ id: companies.id, name: companies.name }).from(companies).orderBy(asc(companies.name)).limit(500);
} catch {
  companyOptions = [];
}

const planLabel: Record<string, { label: string; cls: string }> = {
  lifetime: { label: 'Lifetime', cls: 'bg-[#2E9E6A]/15 text-[#2E9E6A]' },
  trial: { label: 'Trial', cls: 'bg-[#E8A33C]/15 text-[#E8A33C]' },
};
const statusLabel: Record<string, string> = { active: 'Activă', expired: 'Expirată', canceled: 'Revocată' };
const fmt = (d: any) => d ? new Date(d).toLocaleDateString('ro-RO', { day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'Europe/Bucharest' }) : '-';
---

<AdminLayout title="Licențe" activeTab="licente">
  <div class="mb-6">
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white">Licențe</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">Acordă, revocă și rambursează licențe lifetime.</p>
  </div>

  <!-- Grant lifetime -->
  <div class="rounded-2xl bg-white/5 p-5 sm:p-6 mb-6 max-w-2xl">
    <h3 class="text-[15px] font-semibold text-white mb-1">Acordă licență lifetime</h3>
    <p class="text-[13px] text-[#8FA6BC] mb-4">Acordare manuală (white-label). Compania primește acces permanent imediat.</p>
    <div id="grant-error" class="hidden mb-3 px-4 py-3 rounded-xl bg-[#DC4B41]/15 text-[13px] text-[#DC4B41]"></div>
    <form id="grant-form" class="flex flex-col sm:flex-row gap-3">
      <select name="companyId" required class="flex-1 h-11 px-3 rounded-xl bg-white/5 text-[14px] text-white ring-1 ring-white/10 focus:ring-[#34A0A4]/50 focus:outline-none transition-all">
        <option value="">Alege compania...</option>
        {companyOptions.map((c) => (
          <option value={c.id} selected={c.id === preselect}>{c.name}</option>
        ))}
      </select>
      <button type="submit" class="h-11 px-6 bg-[#E1FB15] hover:bg-[#D2EA0E] text-[#07090f] font-bold rounded-full text-[13.5px] transition-colors shrink-0">Acordă lifetime</button>
    </form>
  </div>

  <p class="text-[13px] text-[#8FA6BC] mb-3">{licenseList.length} licențe</p>

  <!-- Desktop table -->
  <div class="hidden sm:block rounded-2xl bg-white/5 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-[13px]">
        <thead>
          <tr class="text-left text-[11px] uppercase tracking-wider text-[#8FA6BC] border-b border-white/10">
            <th class="px-5 py-3 font-semibold">Companie</th>
            <th class="px-5 py-3 font-semibold">Plan</th>
            <th class="px-5 py-3 font-semibold">Status</th>
            <th class="px-5 py-3 font-semibold">Trial până</th>
            <th class="px-5 py-3 font-semibold text-right">Sumă</th>
            <th class="px-5 py-3 font-semibold">Actualizat</th>
            <th class="px-5 py-3 font-semibold text-right">Acțiuni</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          {licenseList.map((l) => {
            const pl = planLabel[l.plan] || { label: l.plan, cls: 'bg-white/10 text-[#A8BED2]' };
            return (
              <tr class="hover:bg-white/[0.03] transition-colors">
                <td class="px-5 py-3.5 font-semibold text-white whitespace-nowrap">{l.companyName || l.companyId}</td>
                <td class="px-5 py-3.5"><span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-semibold ${pl.cls}`}>{pl.label}</span></td>
                <td class="px-5 py-3.5 text-[#A8BED2]">{statusLabel[l.status] || l.status}</td>
                <td class="px-5 py-3.5 text-[#A8BED2] tabular-nums whitespace-nowrap">{l.plan === 'trial' ? fmt(l.trialEndsAt) : '-'}</td>
                <td class="px-5 py-3.5 text-right font-semibold text-white tabular-nums whitespace-nowrap">{l.plan === 'lifetime' ? ron(l.amountCents) : '-'}</td>
                <td class="px-5 py-3.5 text-[#A8BED2] tabular-nums whitespace-nowrap">{fmt(l.updatedAt)}</td>
                <td class="px-5 py-3.5 text-right whitespace-nowrap">
                  <div class="flex items-center justify-end gap-1.5">
                    {l.plan === 'lifetime' && (
                      <button data-company-id={l.companyId} class="refund-btn px-3 py-1.5 text-[12px] font-semibold text-[#E8A33C] bg-[#E8A33C]/10 hover:bg-[#E8A33C]/20 rounded-full transition-colors">Refund</button>
                    )}
                    {l.status === 'active' ? (
                      <button data-company-id={l.companyId} class="revoke-btn px-3 py-1.5 text-[12px] font-semibold text-[#DC4B41] bg-[#DC4B41]/10 hover:bg-[#DC4B41]/20 rounded-full transition-colors">Revocă</button>
                    ) : (
                      <span class="text-[12px] text-[#5E7385]">-</span>
                    )}
                  </div>
                </td>
              </tr>
            );
          })}
          {licenseList.length === 0 && (
            <tr><td colspan="7" class="px-5 py-12 text-center text-[14px] text-[#8FA6BC]">Nicio licență încă.</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile cards -->
  <div class="sm:hidden space-y-2.5">
    {licenseList.length === 0 ? (
      <div class="rounded-2xl bg-white/5 py-10 text-center text-[14px] text-[#8FA6BC]">Nicio licență încă.</div>
    ) : licenseList.map((l) => {
      const pl = planLabel[l.plan] || { label: l.plan, cls: 'bg-white/10 text-[#A8BED2]' };
      return (
        <div class="rounded-2xl bg-white/5 p-4">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-[14px] font-semibold text-white truncate">{l.companyName || l.companyId}</p>
              <p class="text-[12px] text-[#8FA6BC] mt-0.5">{statusLabel[l.status] || l.status} · {l.plan === 'lifetime' ? ron(l.amountCents) : (l.plan === 'trial' ? `trial ${fmt(l.trialEndsAt)}` : '-')}</p>
            </div>
            <span class={`shrink-0 inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-semibold ${pl.cls}`}>{pl.label}</span>
          </div>
          {(l.plan === 'lifetime' || l.status === 'active') && (
            <div class="flex items-center gap-1.5 mt-3 pt-3 border-t border-white/10">
              {l.plan === 'lifetime' && (
                <button data-company-id={l.companyId} class="refund-btn px-3 py-1.5 text-[12px] font-semibold text-[#E8A33C] bg-[#E8A33C]/10 rounded-full transition-colors">Refund</button>
              )}
              {l.status === 'active' && (
                <button data-company-id={l.companyId} class="revoke-btn px-3 py-1.5 text-[12px] font-semibold text-[#DC4B41] bg-[#DC4B41]/10 rounded-full transition-colors">Revocă</button>
              )}
            </div>
          )}
        </div>
      );
    })}
  </div>

  <script>
    const grantForm = document.getElementById('grant-form') as HTMLFormElement | null;
    const grantError = document.getElementById('grant-error');
    grantForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const companyId = new FormData(grantForm).get('companyId');
      if (!companyId) return;
      try {
        const res = await fetch('/api/admin/licente', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ companyId }),
        });
        if (res.ok) { window.location.reload(); return; }
        const data = await res.json().catch(() => ({}));
        if (grantError) { grantError.textContent = data.error || 'Eroare'; grantError.classList.remove('hidden'); }
      } catch {
        if (grantError) { grantError.textContent = 'Eroare de conectare'; grantError.classList.remove('hidden'); }
      }
    });

    document.querySelectorAll('.revoke-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const companyId = (e.currentTarget as HTMLElement).dataset.companyId;
        if (!confirm('Sigur revoci această licență? Compania va pierde accesul.')) return;
        try {
          const res = await fetch('/api/admin/licente', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ companyId, action: 'revoke' }),
          });
          if (res.ok) window.location.reload();
          else alert('Eroare la revocare');
        } catch { alert('Eroare de conectare'); }
      });
    });

    document.querySelectorAll('.refund-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const companyId = (e.currentTarget as HTMLElement).dataset.companyId;
        if (!confirm('Rambursezi plata prin Stripe și dezactivezi licența. Continui?')) return;
        try {
          const res = await fetch('/api/admin/refund', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ companyId }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok) { alert(data.refunded ? 'Rambursat prin Stripe + licență dezactivată.' : 'Licență dezactivată (nicio plată Stripe de rambursat).'); window.location.reload(); }
          else alert(data.error || 'Eroare la rambursare');
        } catch { alert('Eroare de conectare'); }
      });
    });
  </script>
</AdminLayout>
