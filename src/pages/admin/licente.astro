---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { appLicenses, companies } from '../../db/schema';
import { eq, desc, asc } from 'drizzle-orm';

const preselect = Astro.url.searchParams.get('company') || '';

const ron = (cents: number | null) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON', maximumFractionDigits: 0 }).format((cents || 0) / 100);

let licenseList: Array<{
  id: string; companyId: string; companyName: string | null; plan: string; status: string;
  trialEndsAt: Date | null; activatedAt: Date | null; amountCents: number | null; updatedAt: Date | null;
}> = [];
let companyOptions: Array<{ id: string; name: string }> = [];

try {
  licenseList = await db
    .select({
      id: appLicenses.id,
      companyId: appLicenses.companyId,
      companyName: companies.name,
      plan: appLicenses.plan,
      status: appLicenses.status,
      trialEndsAt: appLicenses.trialEndsAt,
      activatedAt: appLicenses.activatedAt,
      amountCents: appLicenses.amountCents,
      updatedAt: appLicenses.updatedAt,
    })
    .from(appLicenses)
    .leftJoin(companies, eq(appLicenses.companyId, companies.id))
    .orderBy(desc(appLicenses.updatedAt));
} catch {
  licenseList = [];
}

try {
  companyOptions = await db.select({ id: companies.id, name: companies.name }).from(companies).orderBy(asc(companies.name)).limit(500);
} catch {
  companyOptions = [];
}

const planLabel: Record<string, { label: string; cls: string }> = {
  lifetime: { label: 'Lifetime', cls: 'bg-[#E7F7EC] text-[#15803D]' },
  trial: { label: 'Trial', cls: 'bg-[#FFF7E6] text-[#B45309]' },
};
const statusLabel: Record<string, string> = { active: 'Activă', expired: 'Expirată', canceled: 'Revocată' };
const fmt = (d: any) => d ? new Date(d).toLocaleDateString('ro-RO', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '-';
---

<AdminLayout title="Licențe" activeTab="licente">
  <!-- Grant lifetime -->
  <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5 mb-6 max-w-2xl">
    <h3 class="text-[14px] font-semibold text-[#0A0A0A] mb-1">Acordă licență lifetime</h3>
    <p class="text-[12px] text-[#6B6B68] mb-4">Acordare manuală (white-label). Compania primește acces permanent imediat.</p>
    <div id="grant-error" class="hidden mb-3 px-4 py-3 bg-white border border-[#B91C1C]/30 rounded-xl text-[13px] text-[#B91C1C]"></div>
    <form id="grant-form" class="flex flex-col sm:flex-row gap-3">
      <select name="companyId" required class="flex-1 h-11 px-3 bg-white border border-[#E8E8E4] rounded-xl text-[14px] text-[#0A0A0A] focus:border-[#0A0A0A] focus:outline-none transition-colors">
        <option value="">Alege compania...</option>
        {companyOptions.map((c) => (
          <option value={c.id} selected={c.id === preselect}>{c.name}</option>
        ))}
      </select>
      <button type="submit" class="h-11 px-6 bg-[#1A759F] hover:bg-[#168AAD] text-white font-semibold rounded-xl text-[13px] transition-colors shrink-0">Acordă lifetime</button>
    </form>
  </div>

  <p class="text-[13px] text-[#6B6B68] mb-3">{licenseList.length} licențe</p>

  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-[13px]">
        <thead>
          <tr class="text-left text-[11px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
            <th class="px-5 py-2.5 font-medium">Companie</th>
            <th class="px-5 py-2.5 font-medium">Plan</th>
            <th class="px-5 py-2.5 font-medium">Status</th>
            <th class="px-5 py-2.5 font-medium">Trial până</th>
            <th class="px-5 py-2.5 font-medium text-right">Sumă</th>
            <th class="px-5 py-2.5 font-medium">Actualizat</th>
            <th class="px-5 py-2.5 font-medium text-right">Acțiuni</th>
          </tr>
        </thead>
        <tbody>
          {licenseList.map((l) => {
            const pl = planLabel[l.plan] || { label: l.plan, cls: 'bg-[#F0F0EC] text-[#6B6B68]' };
            return (
              <tr class="border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors">
                <td class="px-5 py-3 font-medium text-[#0A0A0A]">{l.companyName || l.companyId}</td>
                <td class="px-5 py-3"><span class={`inline-block px-2 py-0.5 rounded-md text-[11px] font-medium ${pl.cls}`}>{pl.label}</span></td>
                <td class="px-5 py-3 text-[#6B6B68]">{statusLabel[l.status] || l.status}</td>
                <td class="px-5 py-3 text-[#6B6B68]">{l.plan === 'trial' ? fmt(l.trialEndsAt) : '-'}</td>
                <td class="px-5 py-3 text-right font-semibold text-[#0A0A0A]">{l.plan === 'lifetime' ? ron(l.amountCents) : '-'}</td>
                <td class="px-5 py-3 text-[#6B6B68]">{fmt(l.updatedAt)}</td>
                <td class="px-5 py-3 text-right">
                  {l.status === 'active' ? (
                    <button data-company-id={l.companyId} class="revoke-btn px-3 py-1.5 text-[12px] font-medium text-[#B91C1C] hover:bg-[#FDECEC] rounded-lg transition-colors">Revocă</button>
                  ) : (
                    <span class="text-[12px] text-[#A8A8A4]">-</span>
                  )}
                </td>
              </tr>
            );
          })}
          {licenseList.length === 0 && (
            <tr><td colspan="7" class="px-5 py-12 text-center text-[14px] text-[#6B6B68]">Nicio licență încă.</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    const grantForm = document.getElementById('grant-form') as HTMLFormElement | null;
    const grantError = document.getElementById('grant-error');
    grantForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const companyId = new FormData(grantForm).get('companyId');
      if (!companyId) return;
      try {
        const res = await fetch('/api/admin/licente', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ companyId }),
        });
        if (res.ok) { window.location.reload(); return; }
        const data = await res.json().catch(() => ({}));
        if (grantError) { grantError.textContent = data.error || 'Eroare'; grantError.classList.remove('hidden'); }
      } catch {
        if (grantError) { grantError.textContent = 'Eroare de conectare'; grantError.classList.remove('hidden'); }
      }
    });

    document.querySelectorAll('.revoke-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const companyId = (e.currentTarget as HTMLElement).dataset.companyId;
        if (!confirm('Sigur revoci această licență? Compania va pierde accesul.')) return;
        try {
          const res = await fetch('/api/admin/licente', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ companyId, action: 'revoke' }),
          });
          if (res.ok) window.location.reload();
          else alert('Eroare la revocare');
        } catch { alert('Eroare de conectare'); }
      });
    });
  </script>
</AdminLayout>
