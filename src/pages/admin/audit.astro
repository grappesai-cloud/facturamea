---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { auditLog, users } from '../../db/schema';
import { sql, eq, gte, and, like } from 'drizzle-orm';

const url = Astro.url;
const action = url.searchParams.get('action') || '';
const userQ = url.searchParams.get('user') || '';
const days = parseInt(url.searchParams.get('days') || '7', 10);
const limit = 200;

const since = new Date(Date.now() - days * 24 * 60 * 60 * 1000);
const conds: any[] = [gte(auditLog.createdAt, since)];
if (action) conds.push(eq(auditLog.action, action));

let rows: any[] = [];
try {
  const baseQuery = db.select({
    id: auditLog.id,
    action: auditLog.action,
    entityType: auditLog.entityType,
    entityId: auditLog.entityId,
    userId: auditLog.userId,
    userName: users.name,
    userEmail: users.email,
    ipAddress: auditLog.ipAddress,
    metadata: auditLog.metadata,
    createdAt: auditLog.createdAt,
  })
    .from(auditLog)
    .leftJoin(users, eq(auditLog.userId, users.id))
    .where(and(...conds))
    .orderBy(sql`${auditLog.createdAt} DESC`)
    .limit(limit);

  rows = await baseQuery;

  if (userQ) {
    rows = rows.filter((r) => (r.userName || '').toLowerCase().includes(userQ.toLowerCase()) || (r.userEmail || '').toLowerCase().includes(userQ.toLowerCase()));
  }
} catch (e) {
  console.error('audit query error', e);
}

// Distinct actions for the filter dropdown
let actions: string[] = [];
try {
  const r = await db.execute(sql`SELECT DISTINCT action FROM audit_log ORDER BY action`);
  actions = (((r as any).rows ?? r) as Array<{ action: string }>).map((x) => x.action);
} catch {}

const fmt = (d: any) => d ? new Date(d).toLocaleString('ro-RO', { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '—';
const inputCls = 'h-9 px-3 bg-white border border-[#E3EAF1] rounded-xl text-[13px] focus:border-[#0A2238] focus:outline-none transition-colors';
---

<AdminLayout title="Jurnal audit" activeTab="audit">
  <div class="mb-6">
    <h2 class="text-[22px] font-bold tracking-[-0.02em]">Jurnal audit</h2>
    <p class="text-[13px] text-[#46627A] mt-1">Toate acţiunile importante (login, post, bid, status change, admin).</p>
  </div>

  <form method="GET" class="flex flex-wrap gap-2 mb-4 p-3 bg-white border border-[#E3EAF1] rounded-xl">
    <select name="action" class={inputCls + ' min-w-[180px]'}>
      <option value="">Toate acţiunile</option>
      {actions.map((a) => <option value={a} selected={action === a}>{a}</option>)}
    </select>
    <input type="text" name="user" value={userQ} placeholder="Utilizator (nume sau email)" class={inputCls + ' flex-1 min-w-[200px]'} />
    <select name="days" class={inputCls}>
      {[1, 7, 30, 90].map((d) => <option value={d} selected={days === d}>Ultimele {d} {d === 1 ? 'zi' : 'zile'}</option>)}
    </select>
    <button type="submit" class="h-9 px-4 bg-[#0A2238] hover:bg-[#1A1A1A] text-white text-[13px] font-semibold rounded-xl transition-colors">Filtrează</button>
    <a href={`/api/admin/audit?days=${days}&action=${action}&format=csv`} class="h-9 px-4 bg-white border border-[#E3EAF1] hover:border-[#0A2238] text-[#0A2238] text-[13px] font-medium rounded-xl transition-colors flex items-center">CSV</a>
  </form>

  <p class="text-[11px] uppercase tracking-[0.16em] text-[#46627A] font-medium mb-3">{rows.length} {rows.length === 1 ? 'eveniment' : 'evenimente'}</p>

  <div class="bg-white border border-[#E3EAF1] rounded-xl overflow-hidden">
    <table class="w-full text-[12px]">
      <thead class="bg-[#EDF1F5] text-[10px] uppercase tracking-wider text-[#46627A]">
        <tr>
          <th class="px-4 py-2 text-left">Când</th>
          <th class="px-4 py-2 text-left">Acţiune</th>
          <th class="px-4 py-2 text-left">Utilizator</th>
          <th class="px-4 py-2 text-left">Entitate</th>
          <th class="px-4 py-2 text-left">IP</th>
          <th class="px-4 py-2 text-left">Metadata</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-[#E3EAF1]">
        {rows.map((r) => (
          <tr class="hover:bg-[#FCFCFA]">
            <td class="px-4 py-2 font-mono text-[#46627A] whitespace-nowrap">{fmt(r.createdAt)}</td>
            <td class="px-4 py-2 font-mono text-[#0A2238]">{r.action}</td>
            <td class="px-4 py-2">{r.userName ?? <span class="text-[#9FB8CC]">—</span>}</td>
            <td class="px-4 py-2 text-[#46627A]">{r.entityType ? `${r.entityType}/${(r.entityId || '').slice(0, 12)}…` : '—'}</td>
            <td class="px-4 py-2 font-mono text-[#9FB8CC]">{r.ipAddress ?? '—'}</td>
            <td class="px-4 py-2 text-[#46627A] truncate max-w-[260px]">{r.metadata ?? ''}</td>
          </tr>
        ))}
        {rows.length === 0 && (
          <tr><td colspan="6" class="px-4 py-12 text-center text-[#46627A]">Niciun eveniment găsit pentru filtrele selectate.</td></tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
