---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { auditLog, users } from '../../db/schema';
import { sql, eq, gte, and, like } from 'drizzle-orm';

const url = Astro.url;
const action = url.searchParams.get('action') || '';
const userQ = url.searchParams.get('user') || '';
const days = parseInt(url.searchParams.get('days') || '7', 10);
const limit = 200;

const since = new Date(Date.now() - days * 24 * 60 * 60 * 1000);
const conds: any[] = [gte(auditLog.createdAt, since)];
if (action) conds.push(eq(auditLog.action, action));

let rows: any[] = [];
try {
  const baseQuery = db.select({
    id: auditLog.id,
    action: auditLog.action,
    entityType: auditLog.entityType,
    entityId: auditLog.entityId,
    userId: auditLog.userId,
    userName: users.name,
    userEmail: users.email,
    ipAddress: auditLog.ipAddress,
    metadata: auditLog.metadata,
    createdAt: auditLog.createdAt,
  })
    .from(auditLog)
    .leftJoin(users, eq(auditLog.userId, users.id))
    .where(and(...conds))
    .orderBy(sql`${auditLog.createdAt} DESC`)
    .limit(limit);

  rows = await baseQuery;

  if (userQ) {
    rows = rows.filter((r) => (r.userName || '').toLowerCase().includes(userQ.toLowerCase()) || (r.userEmail || '').toLowerCase().includes(userQ.toLowerCase()));
  }
} catch (e) {
  console.error('audit query error', e);
}

// Distinct actions for the filter dropdown
let actions: string[] = [];
try {
  const r = await db.execute(sql`SELECT DISTINCT action FROM audit_log ORDER BY action`);
  actions = (((r as any).rows ?? r) as Array<{ action: string }>).map((x) => x.action);
} catch {}

const fmt = (d: any) => d ? new Date(d).toLocaleString('ro-RO', { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '—';
const inputCls = 'h-9 px-3 bg-white border border-[#E3EAF1] rounded-xl text-[13px] focus:border-[#07090f] focus:outline-none transition-colors';
---

<AdminLayout title="Jurnal audit" activeTab="audit">
  <div class="mb-6">
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white">Jurnal audit</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">Toate acţiunile importante (login, post, bid, status change, admin).</p>
  </div>

  <form method="GET" class="flex flex-wrap gap-2 mb-4">
    <select name="action" class={inputCls + ' min-w-[180px]'}>
      <option value="">Toate acţiunile</option>
      {actions.map((a) => <option value={a} selected={action === a}>{a}</option>)}
    </select>
    <input type="text" name="user" value={userQ} placeholder="Utilizator (nume sau email)" class={inputCls + ' flex-1 min-w-[200px] placeholder:text-[#8FA6BC]'} />
    <select name="days" class={inputCls}>
      {[1, 7, 30, 90].map((d) => <option value={d} selected={days === d}>Ultimele {d} {d === 1 ? 'zi' : 'zile'}</option>)}
    </select>
    <button type="submit" class="h-10 px-5 bg-[#E1FB15] hover:bg-[#D2EA0E] text-[#07090f] text-[13px] font-bold rounded-full transition-colors">Filtrează</button>
    <a href={`/api/admin/audit?days=${days}&action=${action}&format=csv`} class="h-10 px-5 bg-white/10 hover:bg-white/15 text-[#D7E5F0] text-[13px] font-semibold rounded-full transition-colors flex items-center">CSV</a>
  </form>

  <p class="text-[12px] text-[#8FA6BC] font-medium mb-3">{rows.length} {rows.length === 1 ? 'eveniment' : 'evenimente'}</p>

  <!-- Desktop table -->
  <div class="hidden md:block rounded-2xl bg-white/5 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-[12px]">
        <thead class="text-[10px] uppercase tracking-wider text-[#8FA6BC] border-b border-white/10">
          <tr>
            <th class="px-4 py-3 text-left font-semibold">Când</th>
            <th class="px-4 py-3 text-left font-semibold">Acţiune</th>
            <th class="px-4 py-3 text-left font-semibold">Utilizator</th>
            <th class="px-4 py-3 text-left font-semibold">Entitate</th>
            <th class="px-4 py-3 text-left font-semibold">IP</th>
            <th class="px-4 py-3 text-left font-semibold">Metadata</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          {rows.map((r) => (
            <tr class="hover:bg-white/[0.03] transition-colors">
              <td class="px-4 py-2.5 font-mono text-[#A8BED2] whitespace-nowrap">{fmt(r.createdAt)}</td>
              <td class="px-4 py-2.5 font-mono text-[#34A0A4] whitespace-nowrap">{r.action}</td>
              <td class="px-4 py-2.5 text-white whitespace-nowrap">{r.userName ?? <span class="text-[#5E7385]">—</span>}</td>
              <td class="px-4 py-2.5 text-[#A8BED2] whitespace-nowrap">{r.entityType ? `${r.entityType}/${(r.entityId || '').slice(0, 12)}…` : '—'}</td>
              <td class="px-4 py-2.5 font-mono text-[#5E7385] whitespace-nowrap">{r.ipAddress ?? '—'}</td>
              <td class="px-4 py-2.5 text-[#8FA6BC] truncate max-w-[260px]">{r.metadata ?? ''}</td>
            </tr>
          ))}
          {rows.length === 0 && (
            <tr><td colspan="6" class="px-4 py-12 text-center text-[#8FA6BC]">Niciun eveniment găsit pentru filtrele selectate.</td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Mobile cards -->
  <div class="md:hidden space-y-2">
    {rows.length === 0 ? (
      <div class="rounded-2xl bg-white/5 py-10 text-center text-[13px] text-[#8FA6BC]">Niciun eveniment găsit pentru filtrele selectate.</div>
    ) : rows.map((r) => (
      <div class="rounded-2xl bg-white/5 p-4">
        <div class="flex items-center justify-between gap-2">
          <span class="font-mono text-[12px] text-[#34A0A4] truncate">{r.action}</span>
          <span class="font-mono text-[11px] text-[#8FA6BC] shrink-0 whitespace-nowrap">{fmt(r.createdAt)}</span>
        </div>
        <p class="text-[12px] text-white mt-1.5">{r.userName ?? '—'}{r.entityType ? ` · ${r.entityType}/${(r.entityId || '').slice(0, 10)}…` : ''}</p>
        <p class="text-[11px] text-[#5E7385] mt-0.5 font-mono">{r.ipAddress ?? '—'}{r.metadata ? ` · ${String(r.metadata).slice(0, 60)}` : ''}</p>
      </div>
    ))}
  </div>
</AdminLayout>
