---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { featureFlags } from '../../db/schema';

let flags: typeof featureFlags.$inferSelect[] = [];
try { flags = await db.select().from(featureFlags); } catch {}

const inputCls = 'w-full px-4 py-2.5 bg-white border border-[#E3EAF1] rounded-xl text-[13px] focus:border-[#07090f] focus:outline-none transition-colors';
---

<AdminLayout title="Feature flags" activeTab="flags">
  <div class="mb-6">
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white">Feature flags</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">Toggle-uri pentru funcţii noi. Rollout-percent permite lansare gradată.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-3">
    <form id="new-flag" class="space-y-3 p-5 sm:p-6 rounded-2xl bg-white/5 h-fit">
      <p class="text-[13px] font-semibold text-white">Adaugă flag nou</p>
      <input name="key" required placeholder="key (ex. show_new_pricing)" class={inputCls + ' font-mono'} />
      <textarea name="description" rows="2" placeholder="Descriere scurtă (opţional)" class={inputCls + ' resize-y'}></textarea>
      <label class="flex items-center gap-2 text-[13px] text-[#D7E5F0]">
        <input type="checkbox" name="enabled" class="w-4 h-4 accent-[#34A0A4]" />
        <span>Activ</span>
      </label>
      <div>
        <label class="block text-[11px] text-[#8FA6BC] mb-1.5">Rollout %</label>
        <input type="number" name="rolloutPercent" min="0" max="100" value="100" class={inputCls} />
      </div>
      <button type="submit" class="w-full px-5 py-2.5 bg-[#E1FB15] hover:bg-[#D2EA0E] text-[#07090f] font-bold rounded-full text-[13.5px] transition-colors">Adaugă</button>
    </form>

    <div class="lg:col-span-2 rounded-2xl bg-white/5 overflow-hidden">
      <div class="px-5 py-4 border-b border-white/10"><p class="text-[13px] font-semibold text-white">Flag-uri existente ({flags.length})</p></div>
      <div class="divide-y divide-white/5">
        {flags.length === 0 ? (
          <div class="px-5 py-10 text-center text-[13px] text-[#8FA6BC]">Niciun flag definit încă.</div>
        ) : flags.map((f) => (
          <div class="px-5 py-3.5 flex items-center justify-between gap-3 flex-wrap">
            <div class="min-w-0">
              <p class="text-[13px] font-mono font-semibold text-white">{f.key}</p>
              {f.description && <p class="text-[11px] text-[#8FA6BC] mt-0.5 truncate">{f.description}</p>}
            </div>
            <div class="flex items-center gap-2.5 shrink-0">
              <span class:list={['px-2.5 py-0.5 text-[10px] uppercase tracking-wider font-semibold rounded-full', f.enabled ? 'bg-[#2E9E6A]/15 text-[#2E9E6A]' : 'bg-white/10 text-[#8FA6BC]']}>
                {f.enabled ? 'On' : 'Off'}
              </span>
              <span class="text-[12px] tabular-nums text-[#A8BED2]">{f.rolloutPercent}%</span>
              <button data-toggle={f.key} data-current={f.enabled} class="px-2.5 py-1 text-[12px] font-semibold rounded-full bg-white/10 text-[#D7E5F0] hover:bg-white/15 transition-colors">{f.enabled ? 'Dezactivează' : 'Activează'}</button>
              <button data-delete={f.key} class="px-2.5 py-1 text-[12px] font-semibold rounded-full text-[#DC4B41] bg-[#DC4B41]/10 hover:bg-[#DC4B41]/20 transition-colors">Şterge</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script>
    document.getElementById('new-flag')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      await fetch('/api/admin/flags', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          key: fd.get('key'),
          description: fd.get('description'),
          enabled: fd.get('enabled') === 'on',
          rolloutPercent: parseInt(String(fd.get('rolloutPercent') || '100'), 10),
        }),
      });
      window.location.reload();
    });

    document.querySelectorAll('[data-toggle]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const key = btn.getAttribute('data-toggle');
        const current = btn.getAttribute('data-current') === 'true';
        await fetch(`/api/admin/flags/${key}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ enabled: !current }),
        });
        window.location.reload();
      });
    });

    document.querySelectorAll('[data-delete]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const key = btn.getAttribute('data-delete');
        if (!confirm(`Şterg flag-ul "${key}"?`)) return;
        await fetch(`/api/admin/flags/${key}`, { method: 'DELETE' });
        window.location.reload();
      });
    });
  </script>
</AdminLayout>
