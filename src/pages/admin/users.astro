---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { users, companies } from '../../db/schema';
import { eq, like, or, desc, sql } from 'drizzle-orm';

const q = Astro.url.searchParams.get('q') || '';
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const limit = 25;
const offset = (page - 1) * limit;

const where = q
  ? or(like(users.name, `%${q}%`), like(users.email, `%${q}%`), like(users.platformId, `%${q}%`))
  : undefined;

let total = { count: 0 };
let userList: Array<{
  id: string; name: string; email: string; platformId: string; userType: string;
  isActive: boolean | null; isAdmin: boolean | null; companyId: string | null;
  companyName: string | null; createdAt: Date | null;
}> = [];

try {
  const [t] = await db.select({ count: sql<number>`COUNT(*)::int` }).from(users).where(where);
  total = t || { count: 0 };

  userList = await db
    .select({
      id: users.id,
      name: users.name,
      email: users.email,
      platformId: users.platformId,
      userType: users.userType,
      isActive: users.isActive,
      isAdmin: users.isAdmin,
      companyId: users.companyId,
      companyName: companies.name,
      createdAt: users.createdAt,
    })
    .from(users)
    .leftJoin(companies, eq(users.companyId, companies.id))
    .where(where)
    .orderBy(desc(users.createdAt))
    .limit(limit)
    .offset(offset);
} catch {
  userList = [];
}

const typeLabel: Record<string, string> = {
  transportator: 'Transportator',
  intermediar: 'Intermediar',
  client_direct: 'Client direct',
  partener: 'Partener',
  admin: 'Admin',
};
const fmt = (d: any) => d ? new Date(d).toLocaleDateString('ro-RO', { day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'Europe/Bucharest' }) : '-';
---

<AdminLayout title="Utilizatori" activeTab="users">
  <div class="mb-6">
    <form method="GET" class="flex gap-3 max-w-xl">
      <input type="text" name="q" value={q} placeholder="Caută după nume, email sau ID platformă..." class="flex-1 h-11 px-4 bg-white border border-[#E8E8E4] rounded-full text-[14px] text-[#0A0A0A] placeholder:text-[#A8A8A4] focus:border-[#0A0A0A] focus:outline-none transition-colors" />
      <button type="submit" class="h-11 px-6 bg-[#1A759F] hover:bg-[#168AAD] text-white font-semibold rounded-xl text-[13px] transition-colors">Caută</button>
    </form>
    <p class="text-[13px] text-[#6B6B68] mt-2">{total.count} utilizatori</p>
  </div>

  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-[13px]">
        <thead>
          <tr class="text-left text-[11px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
            <th class="px-5 py-2.5 font-medium">Utilizator</th>
            <th class="px-5 py-2.5 font-medium">ID</th>
            <th class="px-5 py-2.5 font-medium">Tip</th>
            <th class="px-5 py-2.5 font-medium">Companie</th>
            <th class="px-5 py-2.5 font-medium">Status</th>
            <th class="px-5 py-2.5 font-medium">Creat</th>
            <th class="px-5 py-2.5 font-medium text-right">Acțiuni</th>
          </tr>
        </thead>
        <tbody>
          {userList.map((u) => (
            <tr class="border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors">
              <td class="px-5 py-3">
                <p class="font-medium text-[#0A0A0A]">{u.name}</p>
                <p class="text-[11px] text-[#6B6B68]">{u.email}</p>
              </td>
              <td class="px-5 py-3 font-mono text-[12px] text-[#6B6B68]">
                {u.platformId}
                {u.isAdmin && <span class="ml-1 inline-block px-1.5 py-0.5 rounded-md bg-[#0A0A0A] text-white text-[9px] font-bold uppercase tracking-wider">Admin</span>}
              </td>
              <td class="px-5 py-3 text-[#6B6B68]">{typeLabel[u.userType] || u.userType}</td>
              <td class="px-5 py-3 text-[#6B6B68]">{u.companyName || '-'}</td>
              <td class="px-5 py-3">
                <span class={`inline-block px-2 py-0.5 rounded-md text-[11px] font-medium ${u.isActive ? 'bg-[#E7F7EC] text-[#15803D]' : 'bg-[#FDECEC] text-[#B91C1C]'}`}>{u.isActive ? 'Activ' : 'Inactiv'}</span>
              </td>
              <td class="px-5 py-3 text-[#6B6B68]">{fmt(u.createdAt)}</td>
              <td class="px-5 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <button data-user-id={u.id} data-action={u.isActive ? 'deactivate' : 'activate'} class="admin-action-btn px-2.5 py-1 text-[12px] font-medium rounded-lg border border-[#E8E8E4] text-[#6B6B68] hover:text-[#0A0A0A] hover:border-[#0A0A0A] transition-colors">
                    {u.isActive ? 'Dezactivează' : 'Activează'}
                  </button>
                  {!u.isAdmin && (
                    <button data-user-id={u.id} data-action="make-admin" class="admin-action-btn px-2.5 py-1 text-[12px] font-medium rounded-lg border border-[#B91C1C]/30 text-[#B91C1C] hover:bg-[#FDECEC] transition-colors">Fă admin</button>
                  )}
                  <button data-imp-user-id={u.id} class="impersonate-btn px-2.5 py-1 text-[12px] font-medium rounded-lg border border-[#1A759F]/30 text-[#1A759F] hover:bg-[#1A759F]/10 transition-colors">Impersonează</button>
                </div>
              </td>
            </tr>
          ))}
          {userList.length === 0 && (
            <tr><td colspan="7" class="px-5 py-12 text-center text-[14px] text-[#6B6B68]">Niciun utilizator găsit.</td></tr>
          )}
        </tbody>
      </table>
    </div>

    {total.count > limit && (
      <div class="px-6 py-4 border-t border-[#F0F0EC] flex items-center justify-center gap-3">
        {page > 1 && <a href={`/admin/users?q=${q}&page=${page - 1}`} class="px-3 py-1 text-[13px] border border-[#E8E8E4] rounded-lg text-[#6B6B68] hover:text-[#0A0A0A]">Anterior</a>}
        <span class="text-[13px] text-[#6B6B68]">Pagina {page}</span>
        {userList.length >= limit && <a href={`/admin/users?q=${q}&page=${page + 1}`} class="px-3 py-1 text-[13px] border border-[#E8E8E4] rounded-lg text-[#6B6B68] hover:text-[#0A0A0A]">Următor</a>}
      </div>
    )}
  </div>

  <script>
    document.querySelectorAll('.admin-action-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const el = e.currentTarget as HTMLElement;
        const userId = el.dataset.userId;
        const action = el.dataset.action;
        const labels: Record<string, string> = { deactivate: 'dezactivezi', activate: 'activezi', 'make-admin': 'faci admin pe' };
        if (!confirm(`Sigur vrei să ${labels[action!] || action} acest utilizator?`)) return;
        try {
          const res = await fetch('/api/admin/users', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId, action }),
          });
          if (res.ok) window.location.reload();
          else alert('Eroare');
        } catch { alert('Eroare de conectare'); }
      });
    });

    document.querySelectorAll('.impersonate-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const el = e.currentTarget as HTMLElement;
        const userId = el.dataset.impUserId;
        if (!confirm('Intri în contul acestui utilizator (mod impersonare). Vei putea ieși din banner-ul de sus.')) return;
        try {
          const res = await fetch('/api/admin/impersonate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId }),
          });
          if (res.ok) window.location.href = '/app';
          else alert('Nu am putut porni impersonarea');
        } catch { alert('Eroare de conectare'); }
      });
    });
  </script>
</AdminLayout>
