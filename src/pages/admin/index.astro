---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db } from '../../db';
import { users, companies, appLicenses } from '../../db/schema';
import { sql, eq, and, desc } from 'drizzle-orm';

async function safe<T>(p: Promise<T>, fallback: T): Promise<T> {
  try { return await p; } catch { return fallback; }
}

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON', maximumFractionDigits: 0 }).format((cents || 0) / 100);

const [
  companyCount, userCount, lifetimeActive, trialActive, lifetimeRevenue,
] = await Promise.all([
  safe(db.select({ c: sql<number>`COUNT(*)::int` }).from(companies), [{ c: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int` }).from(users), [{ c: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int` }).from(appLicenses).where(and(eq(appLicenses.plan, 'lifetime'), eq(appLicenses.status, 'active'))), [{ c: 0 }]),
  safe(db.select({ c: sql<number>`COUNT(*)::int` }).from(appLicenses).where(and(eq(appLicenses.plan, 'trial'), eq(appLicenses.status, 'active'))), [{ c: 0 }]),
  safe(db.select({ total: sql<number>`COALESCE(SUM(${appLicenses.amountCents}), 0)::int` }).from(appLicenses).where(eq(appLicenses.plan, 'lifetime')), [{ total: 0 }]),
]);

const recentCompanies = await safe(
  db.select({
    id: companies.id,
    name: companies.name,
    cui: companies.cui,
    city: companies.city,
    createdAt: companies.createdAt,
  }).from(companies).orderBy(desc(companies.createdAt)).limit(8),
  [] as { id: string; name: string; cui: string | null; city: string | null; createdAt: Date | null }[]
);

const stats = [
  { label: 'Companii',          value: (companyCount[0]?.c ?? 0).toLocaleString('ro-RO') },
  { label: 'Utilizatori',       value: (userCount[0]?.c ?? 0).toLocaleString('ro-RO') },
  { label: 'Licențe lifetime',  value: (lifetimeActive[0]?.c ?? 0).toLocaleString('ro-RO') },
  { label: 'Trial active',      value: (trialActive[0]?.c ?? 0).toLocaleString('ro-RO') },
];

const revenue = ron(lifetimeRevenue[0]?.total ?? 0);
const fmt = (d: any) => d ? new Date(d).toLocaleDateString('ro-RO', { day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'Europe/Bucharest' }) : '-';
---

<AdminLayout title="Tablou de bord" activeTab="dashboard">
  <div class="mb-6">
    <h1 class="text-[28px] sm:text-[36px] font-semibold tracking-[-0.03em] text-white">Tablou de bord</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">Privire de ansamblu asupra platformei — companii, utilizatori, licențe și venituri.</p>
  </div>

  <!-- Hero: lifetime revenue -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-3 mb-3">
    <div class="lg:col-span-2 p-5 sm:p-6 rounded-2xl bg-white/5">
      <p class="text-[12px] font-medium text-[#8FA6BC]">Venit licențe lifetime</p>
      <p class="text-[34px] sm:text-[40px] font-bold mt-2 leading-none tabular-nums text-[#E1FB15]">{revenue}</p>
      <p class="text-[13px] text-[#8FA6BC] mt-2">{lifetimeActive[0]?.c ?? 0} licențe lifetime active</p>
    </div>
    <div class="p-5 sm:p-6 rounded-2xl bg-white/5">
      <p class="text-[12px] font-medium text-[#8FA6BC] mb-3">Acțiuni rapide</p>
      <div class="space-y-1">
        {[
          { href: '/admin/licente', label: 'Acordă licență lifetime' },
          { href: '/admin/companies', label: 'Vezi companiile' },
          { href: '/admin/analytics', label: 'Analiză platformă' },
          { href: '/admin/audit', label: 'Jurnal audit' },
        ].map((a) => (
          <a href={a.href} class="group flex items-center justify-between gap-2 -mx-2 px-2 py-1.5 rounded-lg text-[13.5px] text-[#D7E5F0] hover:text-white hover:bg-white/5 transition-colors">
            <span>{a.label}</span>
            <svg class="w-3.5 h-3.5 text-[#4A6478] group-hover:text-[#34A0A4] group-hover:translate-x-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- KPI grid -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-3">
    {stats.map((s) => (
      <div class="rounded-2xl bg-white/5 p-4 sm:p-5">
        <p class="text-[12px] font-medium text-[#8FA6BC]">{s.label}</p>
        <p class="text-[26px] sm:text-[30px] font-bold text-white mt-1.5 leading-none tabular-nums">{s.value}</p>
      </div>
    ))}
  </div>

  <!-- Recent companies -->
  <div class="rounded-2xl bg-white/5 overflow-hidden">
    <div class="px-5 py-4 flex items-center justify-between border-b border-white/10">
      <h2 class="text-[14px] font-semibold text-white">Companii recente</h2>
      <a href="/admin/companies" class="inline-flex items-center gap-1 text-[12.5px] font-semibold text-[#34A0A4] hover:text-[#48c5c9] transition-colors">Vezi toate <span aria-hidden="true">→</span></a>
    </div>
    {recentCompanies.length === 0 ? (
      <div class="px-5 py-12 text-center text-[14px] text-[#8FA6BC]">Nicio companie încă.</div>
    ) : (
      <div class="divide-y divide-white/5">
        {recentCompanies.map((c) => (
          <div class="px-5 py-3.5 flex items-center justify-between gap-3">
            <div class="min-w-0">
              <p class="text-[13.5px] font-semibold text-white truncate">{c.name}</p>
              <p class="text-[12px] text-[#8FA6BC] truncate mt-0.5">{c.cui ? `CUI ${c.cui}` : 'fără CUI'}{c.city ? ` · ${c.city}` : ''}</p>
            </div>
            <p class="text-[12px] text-[#8FA6BC] shrink-0 tabular-nums">{fmt(c.createdAt)}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
