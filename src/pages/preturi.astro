---
import PublicLayout from '../layouts/PublicLayout.astro';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=600');
Astro.response.headers.set('Vary', 'Cookie');

const groups = [
  {
    title: 'Facturare',
    items: ['Facturi & proforme', 'Avize de însoțire', 'Chitanțe & încasări', 'Facturi recurente', 'Serii și numerotare automată', 'Facturi în RON și valută'],
  },
  {
    title: 'Fiscal / ANAF',
    items: ['e-Factura (trimitere în SPV)', 'e-Transport', 'SAF-T D406', 'Calcul TVA automat', 'Validare XML', 'Răspuns oficial salvat'],
  },
  {
    title: 'Gestiune',
    items: ['Gestiune stocuri', 'NIR (note de intrare-recepție)', 'Cheltuieli & furnizori', 'Stoc în timp real', 'Deductibilitate cheltuieli'],
  },
  {
    title: 'Vânzări',
    items: ['POS & casă de marcat', 'Bonuri și încasări numerar', 'Rapoarte vânzări', 'Rapoarte TVA', 'Solduri clienți'],
  },
  {
    title: 'Cont',
    items: ['Multi-utilizator & roluri', 'Login Google, Apple, email', 'Aplicații web, iOS, Android', 'Sincronizare în timp real', 'Actualizări fiscale incluse'],
  },
];

const planFeatures = [
  'Facturi, proforme, avize, chitanțe',
  'e-Factura ANAF + e-Transport',
  'SAF-T D406 generat automat',
  'Gestiune stocuri, NIR, cheltuieli',
  'POS & casă de marcat',
  'Facturi recurente',
  'Rapoarte vânzări, TVA, încasări',
  'Multi-utilizator cu roluri',
  'Aplicație web (iOS și Android în curând)',
];

const faq = [
  { q: 'Ce înseamnă licență pe viață?', a: 'Plătești o singură dată 700 RON și folosești facturamea fără limită de timp, fără abonament lunar sau anual.' },
  { q: 'Plata se face din aplicație?', a: 'Da. Te înregistrezi gratuit, explorezi aplicația și, când ești convins, faci plata o singură dată direct din cont.' },
  { q: 'Actualizările fiscale costă suplimentar?', a: 'Nu. Actualizările care țin pasul cu cerințele ANAF sunt incluse în licență.' },
  { q: 'Pot folosi aplicația pe mai multe dispozitive?', a: 'Da. Funcționează în web acum; aplicațiile native iOS și Android vin în curând, cu același cont, sincronizate în timp real.' },
];
---

<PublicLayout
  title="Prețuri"
  description="facturamea: 700 RON, o singură plată, licență pe viață. Toate funcțiile incluse, fără abonament lunar."
>
  <div class="text-center max-w-2xl mx-auto mb-12">
    <p class="text-xs uppercase tracking-[0.18em] text-[#FF5C00] font-semibold mb-3">Prețuri</p>
    <h1 class="text-4xl font-bold text-[#0A0A0A] tracking-[-0.02em] mb-3">Un singur preț, pentru totdeauna</h1>
    <p class="text-[#6B6B68] leading-relaxed">
      Fără abonament lunar. Plătești o dată și primești licență pe viață, cu toate funcțiile incluse.
    </p>
  </div>

  <!-- Plan card -->
  <div class="max-w-[560px] mx-auto mb-16">
    <div class="bg-white border-2 border-[#FF5C00]/40 rounded-2xl p-8 shadow-[0_24px_60px_-24px_rgba(255,92,0,0.3)] relative">
      <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-[#FF5C00] text-white text-xs font-bold rounded-full tracking-wide">LICENȚĂ PE VIAȚĂ</span>
      <div class="text-center mt-2">
        <div class="flex items-baseline justify-center gap-2">
          <span class="text-5xl font-bold text-[#0A0A0A] tracking-[-0.03em]">700 RON</span>
        </div>
        <p class="text-sm text-[#6B6B68] mt-1">o singură plată · fără abonament</p>
      </div>
      <ul class="space-y-2.5 text-sm text-[#0A0A0A] mt-7 mb-8">
        {planFeatures.map((f) => (
          <li class="flex items-start gap-2.5"><span class="text-[#FF5C00] font-bold mt-0.5">✓</span> {f}</li>
        ))}
      </ul>
      <a href="/auth/register" class="block text-center w-full px-6 py-3.5 bg-[#FF5C00] hover:bg-[#E04E00] text-white font-semibold rounded-xl shadow-lg shadow-[#FF5C00]/25 transition-all hover:-translate-y-0.5">
        Creează cont
      </a>
      <p class="text-center text-xs text-[#6B6B68] mt-3">Te înregistrezi gratuit, plata o faci din aplicație când ești gata.</p>
    </div>
  </div>

  <!-- Feature groups -->
  <div class="mb-16">
    <h2 class="text-2xl font-bold text-[#0A0A0A] tracking-[-0.02em] mb-2 text-center">Tot ce este inclus</h2>
    <p class="text-[#6B6B68] text-center mb-10">Fără pachete decupate. Toate funcțiile vin în aceeași licență.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {groups.map((g) => (
        <div class="bg-white border border-[#E8E8E4] rounded-2xl p-6">
          <h3 class="text-xs uppercase tracking-[0.16em] text-[#FF5C00] font-semibold mb-4">{g.title}</h3>
          <ul class="space-y-2 text-sm text-[#0A0A0A]">
            {g.items.map((it) => (
              <li class="flex items-start gap-2.5"><span class="text-[#FF5C00] font-bold mt-0.5">✓</span> {it}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Mini FAQ -->
  <div class="max-w-[760px] mx-auto mb-12">
    <h2 class="text-2xl font-bold text-[#0A0A0A] tracking-[-0.02em] mb-6 text-center">Întrebări despre licență</h2>
    <div class="space-y-3">
      {faq.map((item) => (
        <details class="bg-white rounded-xl border border-[#E8E8E4] group">
          <summary class="cursor-pointer px-5 py-4 font-medium text-[#0A0A0A] flex items-center justify-between gap-4 hover:bg-[#FAFAF8] rounded-xl transition-colors">
            {item.q}
            <span class="text-[#FF5C00] group-open:rotate-180 transition-transform shrink-0">▾</span>
          </summary>
          <div class="px-5 pb-4 text-sm text-[#6B6B68] leading-relaxed">{item.a}</div>
        </details>
      ))}
    </div>
  </div>

  <!-- Bottom CTA -->
  <div class="bg-[#0A0A0A] rounded-2xl p-8 text-center">
    <h3 class="text-xl font-bold text-white tracking-[-0.02em] mb-2">Gata să renunți la abonamentul lunar?</h3>
    <p class="text-[#A8A8A4] mb-5 text-sm">Creează-ți contul gratuit și emite prima factură astăzi.</p>
    <a href="/auth/register" class="inline-block px-6 py-3 bg-[#FF5C00] hover:bg-[#E04E00] text-white font-semibold rounded-xl transition-colors">
      Creează cont
    </a>
  </div>
</PublicLayout>
