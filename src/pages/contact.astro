---
import PublicLayout from '../layouts/PublicLayout.astro';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=600');
Astro.response.headers.set('Vary', 'Cookie');
---

<PublicLayout
  title="Contact"
  description="Ia legătura cu echipa facturamea. Răspundem la întrebări despre facturare, e-Factura și licență."
>
  <p class="text-xs uppercase tracking-[0.18em] text-[#FF5C00] font-semibold mb-3">Contact</p>
  <h1 class="text-4xl font-bold text-[#0A0A0A] tracking-[-0.02em] mb-2">Vorbește cu noi</h1>
  <p class="text-[#6B6B68] mb-10">Ai o întrebare despre facturare, e-Factura sau licență? Îți răspundem cât putem de repede.</p>

  <div class="grid md:grid-cols-2 gap-8">
    <div>
      <h2 class="text-xl font-bold text-[#0A0A0A] tracking-[-0.02em] mb-4">Date de contact</h2>
      <div class="space-y-4 text-[#0A0A0A]">
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 bg-[#FFF1E6] text-[#FF5C00] rounded-xl flex items-center justify-center shrink-0 text-lg">📧</div>
          <div>
            <p class="text-xs uppercase tracking-wide text-[#6B6B68] font-medium">Email general</p>
            <a href="mailto:contact@facturamea.com" class="text-[#FF5C00] hover:underline">contact@facturamea.com</a>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 bg-[#FFF1E6] text-[#FF5C00] rounded-xl flex items-center justify-center shrink-0 text-lg">🛟</div>
          <div>
            <p class="text-xs uppercase tracking-wide text-[#6B6B68] font-medium">Suport</p>
            <a href="mailto:support@facturamea.com" class="text-[#FF5C00] hover:underline">support@facturamea.com</a>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 bg-[#FFF1E6] text-[#FF5C00] rounded-xl flex items-center justify-center shrink-0 text-lg">💬</div>
          <div>
            <p class="text-xs uppercase tracking-wide text-[#6B6B68] font-medium">Întrebări frecvente</p>
            <a href="/faq" class="text-[#FF5C00] hover:underline">Vezi răspunsurile rapide</a>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-10 h-10 bg-[#FFF1E6] text-[#FF5C00] rounded-xl flex items-center justify-center shrink-0 text-lg">📍</div>
          <div>
            <p class="text-xs uppercase tracking-wide text-[#6B6B68] font-medium">Locație</p>
            <p>România</p>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-2xl p-6 border border-[#E8E8E4]">
      <h2 class="text-xl font-bold text-[#0A0A0A] tracking-[-0.02em] mb-4">Trimite-ne un mesaj</h2>
      <form id="contact-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-[#0A0A0A] mb-1">Nume</label>
          <input type="text" required name="name" class="w-full px-3 py-2.5 border border-[#E8E8E4] rounded-xl text-sm focus:ring-2 focus:ring-[#FF5C00] focus:border-transparent outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-[#0A0A0A] mb-1">Email</label>
          <input type="email" required name="email" class="w-full px-3 py-2.5 border border-[#E8E8E4] rounded-xl text-sm focus:ring-2 focus:ring-[#FF5C00] focus:border-transparent outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-[#0A0A0A] mb-1">Subiect</label>
          <select name="subject" class="w-full px-3 py-2.5 border border-[#E8E8E4] rounded-xl text-sm focus:ring-2 focus:ring-[#FF5C00] focus:border-transparent outline-none">
            <option>Întrebare generală</option>
            <option>Suport tehnic</option>
            <option>Facturare & licență</option>
            <option>e-Factura / ANAF</option>
            <option>Altele</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-[#0A0A0A] mb-1">Mesaj</label>
          <textarea required name="message" rows="5" class="w-full px-3 py-2.5 border border-[#E8E8E4] rounded-xl text-sm focus:ring-2 focus:ring-[#FF5C00] focus:border-transparent outline-none resize-none"></textarea>
        </div>
        <div id="contact-success" class="hidden bg-green-50 text-green-700 px-4 py-3 rounded-xl text-sm">Mulțumim! Am primit mesajul tău și îți răspundem cât de curând.</div>
        <div id="contact-error" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-xl text-sm">Nu am putut trimite acum. Mai încearcă o dată.</div>
        <button id="contact-submit" type="submit" class="w-full px-6 py-2.5 bg-[#FF5C00] hover:bg-[#E04E00] text-white font-semibold rounded-xl transition shadow-md disabled:opacity-60">
          Trimite mesajul
        </button>
      </form>
    </div>
  </div>

  <script>
    document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const success = document.getElementById('contact-success');
      const error = document.getElementById('contact-error');
      const btn = document.getElementById('contact-submit') as HTMLButtonElement | null;
      const f = e.target as HTMLFormElement;
      const data = Object.fromEntries(new FormData(f)) as Record<string, string>;
      success?.classList.add('hidden'); error?.classList.add('hidden');
      if (btn) { btn.disabled = true; btn.textContent = 'Se trimite…'; }
      try {
        const r = await fetch('/api/public/support', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: data.name, email: data.email, topic: data.subject, message: data.message, source: 'contact' }),
        });
        if (!r.ok) throw new Error('fail');
        f.reset();
        success?.classList.remove('hidden');
      } catch {
        error?.classList.remove('hidden');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Trimite mesajul'; }
      }
    });
  </script>
</PublicLayout>
