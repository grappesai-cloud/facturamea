---
import AppLayout from '../../../layouts/AppLayout.astro';
import AnalyticsDashboard from '../../../components/rapoarte/AnalyticsDashboard.tsx';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="Analitice" activeTab="rapoarte">
  <div class="mb-6 flex items-start justify-between gap-4 flex-wrap">
    <div>
      <p class="text-[13px] uppercase tracking-[0.14em] text-[#8A8A85] font-semibold">Rapoarte · Analitice</p>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A] mt-1">Analitice avansate</h1>
      <p class="text-[15px] text-[#6B6B68] mt-1">Facturat vs încasat, top clienți și produse, distribuția pe status și marja brută, pentru perioada aleasă.</p>
    </div>
    <a href="/app/facturare/rapoarte" class="text-[15px] text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la rapoarte</a>
  </div>

  <AnalyticsDashboard client:load />
</AppLayout>
