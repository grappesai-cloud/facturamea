---
import AppLayout from '../../../layouts/AppLayout.astro';

const now = new Date();
const currentMonth = now.getMonth() + 1; // 1..12
const currentYear = now.getFullYear();

const months = [
  { v: 1, n: 'Ianuarie' }, { v: 2, n: 'Februarie' }, { v: 3, n: 'Martie' },
  { v: 4, n: 'Aprilie' }, { v: 5, n: 'Mai' }, { v: 6, n: 'Iunie' },
  { v: 7, n: 'Iulie' }, { v: 8, n: 'August' }, { v: 9, n: 'Septembrie' },
  { v: 10, n: 'Octombrie' }, { v: 11, n: 'Noiembrie' }, { v: 12, n: 'Decembrie' },
];
const years = Array.from({ length: 6 }, (_, i) => currentYear - i);
---

<AppLayout title="Declarații" activeTab="declaratii">
  <div class="mb-8 sm:mb-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Declarații fiscale</h1>
      <p class="text-[15px] text-[#A8BED2] mt-2 max-w-2xl">Generează fișierele pentru depunere la ANAF din facturile emise și cheltuieli. Validează rezultatul în PDF-ul inteligent ANAF înainte de depunere.</p>
    </div>
  </div>

  <!-- Period picker -->
  <div class="rounded-2xl p-5 bg-white/5 mb-6">
    <p class="text-[18px] font-bold text-white mb-3">Perioada de raportare</p>
    <div class="flex flex-col gap-3">
      <div class="flex gap-3">
        <div>
          <label class="block text-[13px] text-[#A8BED2] mb-1.5" for="decl-month">Luna</label>
          <select id="decl-month" class="rounded-xl bg-white/5 border border-white/[0.12] px-4 py-2.5 text-[14px] text-white focus:outline-none focus:border-[#E1FB15]/50 min-w-[160px] [color-scheme:dark]">
            {months.map((m) => (
              <option value={m.v} selected={m.v === currentMonth}>{m.n}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-[13px] text-[#A8BED2] mb-1.5" for="decl-year">An</label>
          <select id="decl-year" class="rounded-xl bg-white/5 border border-white/[0.12] px-4 py-2.5 text-[14px] text-white focus:outline-none focus:border-[#E1FB15]/50 min-w-[120px] [color-scheme:dark]">
            {years.map((y) => (
              <option value={y} selected={y === currentYear}>{y}</option>
            ))}
          </select>
        </div>
      </div>
      <p class="text-[12px] text-[#8FA6BC]">Declarațiile lunare se generează pentru luna și anul selectate.</p>
    </div>
  </div>

  <!-- Declaration cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <!-- D394 -->
    <div class="rounded-2xl p-5 bg-white/5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[20px] font-bold tracking-[-0.03em] text-white font-mono">D394</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/10 text-[#A8BED2]">XML</span>
      </div>
      <h3 class="text-[16px] font-bold text-white">Declarația informativă 394</h3>
      <p class="text-[13px] text-[#A8BED2] mt-1.5 flex-1">Livrările și achizițiile pe teritoriul național, grupate pe partener (CUI), cu baza impozabilă și TVA.</p>
      <button type="button" data-decl="d394" class="decl-dl mt-4 inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors disabled:opacity-50">
        <span class="decl-label">Descarcă</span>
      </button>
    </div>

    <!-- D300 -->
    <div class="rounded-2xl p-5 bg-white/5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[20px] font-bold tracking-[-0.03em] text-white font-mono">D300</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/10 text-[#A8BED2]">XML / CSV</span>
      </div>
      <h3 class="text-[16px] font-bold text-white">Decont TVA (D300)</h3>
      <p class="text-[13px] text-[#A8BED2] mt-1.5 flex-1">TVA colectată din facturi minus TVA deductibilă din cheltuieli, cu soldul de plată sau de recuperat.</p>
      <div class="mt-4 flex gap-2">
        <button type="button" data-decl="d300" class="decl-dl flex-1 inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors disabled:opacity-50">
          <span class="decl-label">Descarcă XML</span>
        </button>
        <button type="button" data-decl="d300-csv" class="decl-dl inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors disabled:opacity-50">
          <span class="decl-label">CSV</span>
        </button>
      </div>
    </div>

    <!-- SAF-T D406 link -->
    <div class="rounded-2xl p-5 bg-white/5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[20px] font-bold tracking-[-0.03em] text-white font-mono">D406</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/10 text-[#A8BED2]">SAF-T XML</span>
      </div>
      <h3 class="text-[16px] font-bold text-white">SAF-T (D406)</h3>
      <p class="text-[13px] text-[#A8BED2] mt-1.5 flex-1">Fișierul standard de audit fiscal pentru luna selectată (MasterFiles + facturi emise).</p>
      <button type="button" data-decl="d406" class="decl-dl mt-4 inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors disabled:opacity-50">
        <span class="decl-label">Descarcă</span>
      </button>
    </div>

    <!-- D390 (VIES) -->
    <div class="rounded-2xl p-5 bg-white/5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[20px] font-bold tracking-[-0.03em] text-white font-mono">D390</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/10 text-[#A8BED2]">XML</span>
      </div>
      <h3 class="text-[16px] font-bold text-white">Declarația 390 (VIES)</h3>
      <p class="text-[13px] text-[#A8BED2] mt-1.5 flex-1">Declarația recapitulativă a operațiunilor intracomunitare (livrări și achiziții), grupate pe codul de TVA al partenerului din UE.</p>
      <button type="button" data-decl="d390" class="decl-dl mt-4 inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors disabled:opacity-50">
        <span class="decl-label">Descarcă</span>
      </button>
    </div>

    <!-- D100 (impozit micro) -->
    <div class="rounded-2xl p-5 bg-white/5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[20px] font-bold tracking-[-0.03em] text-white font-mono">D100</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/10 text-[#A8BED2]">XML / CSV</span>
      </div>
      <h3 class="text-[16px] font-bold text-white">Impozit micro (D100)</h3>
      <p class="text-[13px] text-[#A8BED2] mt-1.5 flex-1">Impozitul pe veniturile microîntreprinderilor, declarat trimestrial. Se calculează pe cifra de afaceri din trimestrul lunii selectate.</p>
      <div class="mt-3">
        <label class="block text-[12px] text-[#8FA6BC] mb-1" for="d100-rate">Cota</label>
        <select id="d100-rate" class="rounded-xl bg-white/5 border border-white/[0.12] px-3 py-2 text-[13px] text-white focus:outline-none focus:border-[#E1FB15]/50 w-full [color-scheme:dark]">
          <option value="1">1% (cu salariat)</option>
          <option value="3">3% (fără salariat)</option>
        </select>
      </div>
      <div class="mt-3 flex gap-2">
        <button type="button" data-decl="d100" class="decl-dl flex-1 inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors disabled:opacity-50">
          <span class="decl-label">Descarcă XML</span>
        </button>
        <button type="button" data-decl="d100-csv" class="decl-dl inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors disabled:opacity-50">
          <span class="decl-label">CSV</span>
        </button>
      </div>
    </div>

    <!-- D212 (Declarația unică — PFA) -->
    <div class="rounded-2xl p-5 bg-white/5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[20px] font-bold tracking-[-0.03em] text-white font-mono">D212</span>
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-white/10 text-[#A8BED2]">XML / CSV</span>
      </div>
      <h3 class="text-[16px] font-bold text-white">Declarația unică (D212)</h3>
      <p class="text-[13px] text-[#A8BED2] mt-1.5 flex-1">Pentru PFA/II/IF în sistem real. Impozit pe venit anual (10%) calculat pe încasări minus cheltuieli deductibile, pentru anul selectat. CAS/CASS se confirmă cu contabilul (vezi CSV).</p>
      <div class="mt-4 flex gap-2">
        <button type="button" data-decl="d212" class="decl-dl flex-1 inline-flex items-center justify-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors disabled:opacity-50">
          <span class="decl-label">Descarcă XML</span>
        </button>
        <button type="button" data-decl="d212-csv" class="decl-dl inline-flex items-center justify-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors disabled:opacity-50">
          <span class="decl-label">CSV</span>
        </button>
      </div>
    </div>
  </div>

  <p id="decl-error" class="text-[13px] text-[#DC4B41] mt-4 hidden"></p>

  <div class="mt-8 text-[12px] text-[#8FA6BC] leading-relaxed max-w-3xl space-y-2">
    <p><strong class="text-[#A8BED2]">Ce depui, în funcție de tipul firmei:</strong></p>
    <ul class="list-disc pl-5 space-y-1">
      <li><strong class="text-[#A8BED2]">PFA / II / IF:</strong> D212 (anual). Dacă ești plătitor de TVA, în plus D300 / D394 / D390.</li>
      <li><strong class="text-[#A8BED2]">SRL micro, neplătitor de TVA:</strong> D100 (trimestrial). SAF-T (D406) după caz.</li>
      <li><strong class="text-[#A8BED2]">SRL plătitor de TVA:</strong> D300 + D394 (lunar/trimestrial), D390 dacă ai operațiuni intracomunitare, D406, plus D100 dacă ești micro.</li>
    </ul>
    <p><strong class="text-[#A8BED2]">Notă.</strong> Fișierele sunt generate automat din datele tale (facturi și cheltuieli înregistrate). Structura urmează declarațiile ANAF, dar versiunile schemei se schimbă periodic. Validează rezultatul în aplicația PDF inteligent ANAF înainte de depunere. Pentru PFA, impozitul se calculează pe încasări (contabilitate de casă); CAS/CASS depind de plafoane și se confirmă cu contabilul.</p>
  </div>
</AppLayout>

<script is:inline>
  document.addEventListener('astro:page-load', function () {
    const monthEl = document.getElementById('decl-month');
    const yearEl = document.getElementById('decl-year');
    const errEl = document.getElementById('decl-error');
    const d100RateEl = document.getElementById('d100-rate');
    function d100Rate() { return d100RateEl && d100RateEl.value === '3' ? '3' : '1'; }

    function endpointFor(kind, month, year) {
      const lastDay = new Date(Date.UTC(year, month, 0)).getUTCDate();
      const mm = String(month).padStart(2, '0');
      const from = year + '-' + mm + '-01';
      const to = year + '-' + mm + '-' + String(lastDay).padStart(2, '0');
      switch (kind) {
        case 'd394': return '/api/invoicing/reports/d394?month=' + month + '&year=' + year;
        case 'd300': return '/api/invoicing/reports/d300?month=' + month + '&year=' + year;
        case 'd300-csv': return '/api/invoicing/reports/d300?month=' + month + '&year=' + year + '&format=csv';
        case 'd406': return '/api/invoicing/reports/saft-d406?from=' + from + '&to=' + to + '&type=L';
        case 'd390': return '/api/invoicing/reports/d390?month=' + month + '&year=' + year;
        case 'd100': return '/api/invoicing/reports/d100?month=' + month + '&year=' + year + '&rate=' + d100Rate();
        case 'd100-csv': return '/api/invoicing/reports/d100?month=' + month + '&year=' + year + '&rate=' + d100Rate() + '&format=csv';
        case 'd212': return '/api/invoicing/reports/d212?year=' + year;
        case 'd212-csv': return '/api/invoicing/reports/d212?year=' + year + '&format=csv';
        default: return null;
      }
    }

    async function download(btn) {
      const kind = btn.getAttribute('data-decl');
      const month = parseInt(monthEl.value, 10);
      const year = parseInt(yearEl.value, 10);
      const endpoint = endpointFor(kind, month, year);
      if (!endpoint) return;

      const label = btn.querySelector('.decl-label');
      const original = label ? label.textContent : '';
      btn.disabled = true;
      if (label) label.textContent = 'Se generează...';
      errEl.classList.add('hidden');

      try {
        const res = await fetch(endpoint);
        if (!res.ok) {
          let msg = 'Eroare la generare (' + res.status + ')';
          try { const d = await res.json(); if (d && d.error) msg = d.error; } catch (e) {}
          errEl.textContent = msg;
          errEl.classList.remove('hidden');
          return;
        }
        const blob = await res.blob();
        const cd = res.headers.get('Content-Disposition') || '';
        const m = cd.match(/filename="?([^"]+)"?/);
        const fname = m ? m[1] : (kind + '_' + year + '_' + month + '.xml');
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fname;
        document.body.appendChild(a);
        a.click();
        a.remove();
        setTimeout(function () { URL.revokeObjectURL(url); }, 2000);
      } catch (e) {
        errEl.textContent = 'Eroare de conexiune. Încearcă din nou.';
        errEl.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        if (label) label.textContent = original;
      }
    }

    document.querySelectorAll('.decl-dl').forEach(function (btn) {
      if (btn.dataset.fmBound) return;
      btn.dataset.fmBound = '1';
      btn.addEventListener('click', function () { download(btn); });
    });
  });
</script>
