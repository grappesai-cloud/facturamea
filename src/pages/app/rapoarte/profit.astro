---
// Venituri-Cheltuieli (cont de profit simplificat). Deterministic, zero cost:
// venituri = vânzări nete (facturi live), cheltuieli = net pe categorii, în RON.
// All monetary calc stays on the server — the client only renders pre-formatted strings.
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { transportInvoices, expenses } from '../../../db/schema';
import { and, eq, gte, lte, notInArray } from 'drizzle-orm';
import { invoiceRonCents, expenseRonCents } from '../../../lib/invoicing';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON', maximumFractionDigits: 2 }).format((cents || 0) / 100);
// Split a RON-cents amount so the big number can carry a separate "RON" suffix,
// matching the dashboard / facturare report KPI look.
const fmt = (cents: number) => (cents / 100).toLocaleString('ro-RO', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

// ── Period ────────────────────────────────────────────────────────────────
const now = new Date();
const period = (Astro.url.searchParams.get('period') || 'year').toLowerCase();
let y = now.getUTCFullYear();
let fromD: Date, toD: Date, label: string;
const MONTHS = ['ianuarie', 'februarie', 'martie', 'aprilie', 'mai', 'iunie', 'iulie', 'august', 'septembrie', 'octombrie', 'noiembrie', 'decembrie'];
if (period === 'month') {
  fromD = new Date(Date.UTC(y, now.getUTCMonth(), 1));
  toD = new Date(Date.UTC(y, now.getUTCMonth() + 1, 0, 23, 59, 59));
  label = `${MONTHS[now.getUTCMonth()]} ${y}`;
} else if (period === 'prev-year') {
  y -= 1;
  fromD = new Date(Date.UTC(y, 0, 1));
  toD = new Date(Date.UTC(y, 11, 31, 23, 59, 59));
  label = `${y}`;
} else {
  fromD = new Date(Date.UTC(y, 0, 1));
  toD = new Date(Date.UTC(y, 11, 31, 23, 59, 59));
  label = `${y}`;
}
const fromStr = fromD.toISOString().slice(0, 10);
const toStr = toD.toISOString().slice(0, 10);

// ── Venituri: vânzări nete din facturi live (exclude ciornă/anulată/stornată) ──
let revenue = 0;
try {
  const invs = await db.select().from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    notInArray(transportInvoices.status, ['draft', 'voided', 'reversed']),
    gte(transportInvoices.issuedAt, fromD),
    lte(transportInvoices.issuedAt, toD),
  ));
  for (const inv of invs) revenue += invoiceRonCents(inv).subtotal;
} catch { /* leave 0 */ }

// ── Cheltuieli: net pe categorie ──
const CAT_LABELS: Record<string, string> = {
  utilitati: 'Utilități', chirie: 'Chirie', combustibil: 'Combustibil', servicii: 'Servicii',
  marfa: 'Marfă', salarii: 'Salarii', taxe: 'Taxe', altele: 'Altele',
};
const byCat = new Map<string, number>();
let expensesTotal = 0;
try {
  const exps = await db.select().from(expenses).where(and(
    eq(expenses.companyId, companyId),
    gte(expenses.issueDate, fromStr),
    lte(expenses.issueDate, toStr),
  ));
  for (const e of exps) {
    const net = expenseRonCents(e).net;
    const cat = e.category || 'neclasificate';
    byCat.set(cat, (byCat.get(cat) || 0) + net);
    expensesTotal += net;
  }
} catch { /* leave 0 */ }

const cats = [...byCat.entries()].map(([k, v]) => ({
  key: k, label: CAT_LABELS[k] || (k === 'neclasificate' ? 'Neclasificate' : k), cents: v,
  display: ron(v),
  pct: expensesTotal > 0 ? Math.round((v / expensesTotal) * 100) : 0,
})).sort((a, b) => b.cents - a.cents);

const profit = revenue - expensesTotal;
const marginPct = revenue > 0 ? Math.round((profit / revenue) * 100) : 0;

const presets = [
  { key: 'month', label: 'Luna curentă' },
  { key: 'year', label: 'Anul curent' },
  { key: 'prev-year', label: 'Anul trecut' },
];
---

<AppLayout title="Venituri și cheltuieli" activeTab="rapoarte">
  <!-- Header -->
  <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Venituri și cheltuieli</h1>
      <p class="text-[14px] text-[#A8BED2] mt-1">Profitul tău pe perioadă, dintr-o privire. <span class="capitalize">{label}</span>.</p>
    </div>
  </div>

  <!-- Period presets -->
  <div class="flex flex-wrap gap-2 mb-5">
    {presets.map((p) => (
      <a href={`/app/rapoarte/profit?period=${p.key}`}
         class:list={['px-4 py-1.5 rounded-full text-[13px] font-semibold transition-colors',
           period === p.key ? 'bg-[#E1FB15] text-[#07090f]' : 'bg-white/5 text-[#A8BED2] hover:bg-white/10']}>
        {p.label}
      </a>
    ))}
  </div>

  <!-- Headline KPI tiles -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-3">
    <div class="rounded-2xl p-4 sm:p-5 bg-white/5">
      <p class="text-[12px] sm:text-[13px] font-medium text-[#8FA6BC]">Venituri (net)</p>
      <p class="text-[19px] sm:text-[26px] font-bold tracking-[-0.03em] tabular-nums text-white mt-1.5 whitespace-nowrap">{fmt(revenue)} <span class="text-[13px] sm:text-[15px] text-[#8FA6BC] font-semibold">RON</span></p>
      <p class="text-[12px] text-[#8FA6BC] mt-1">Vânzări nete din facturi emise</p>
    </div>
    <div class="rounded-2xl p-4 sm:p-5 bg-white/5">
      <p class="text-[12px] sm:text-[13px] font-medium text-[#8FA6BC]">Cheltuieli (net)</p>
      <p class="text-[19px] sm:text-[26px] font-bold tracking-[-0.03em] tabular-nums text-[#E8A33C] mt-1.5 whitespace-nowrap">{fmt(expensesTotal)} <span class="text-[13px] sm:text-[15px] text-[#E8A33C]/70 font-semibold">RON</span></p>
      <p class="text-[12px] text-[#8FA6BC] mt-1">{cats.length} {cats.length === 1 ? 'categorie' : 'categorii'}</p>
    </div>
    <div class:list={['rounded-2xl p-4 sm:p-5', profit >= 0 ? 'bg-[#2E9E6A]/12 ring-1 ring-[#2E9E6A]/25' : 'bg-[#DC4B41]/12 ring-1 ring-[#DC4B41]/25']}>
      <p class="text-[12px] sm:text-[13px] font-medium text-[#8FA6BC]">{profit >= 0 ? 'Profit' : 'Pierdere'}</p>
      <p class:list={['text-[19px] sm:text-[26px] font-bold tracking-[-0.03em] tabular-nums mt-1.5 whitespace-nowrap', profit >= 0 ? 'text-[#2E9E6A]' : 'text-[#DC4B41]']}>{fmt(profit)} <span class:list={['text-[13px] sm:text-[15px] font-semibold', profit >= 0 ? 'text-[#2E9E6A]/70' : 'text-[#DC4B41]/70']}>RON</span></p>
      <p class="text-[12px] text-[#8FA6BC] mt-1">{revenue > 0 ? `Marjă ${marginPct}% din venituri` : 'Niciun venit în perioadă'}</p>
    </div>
  </div>

  <!-- Profit composition bar -->
  {(revenue > 0 || expensesTotal > 0) && (
    <div class="rounded-2xl bg-white/5 p-5 mb-3">
      <h2 class="text-[13px] font-semibold text-[#8FA6BC] uppercase tracking-wider mb-4">Compoziție</h2>
      <div class="space-y-3">
        <div>
          <div class="flex items-center justify-between gap-3 mb-1.5">
            <span class="text-[14px] text-white">Venituri</span>
            <span class="text-[13px] tabular-nums text-[#A8BED2]">{ron(revenue)}</span>
          </div>
          <div class="h-2.5 rounded-full bg-white/10 overflow-hidden">
            <div class="h-full rounded-full bg-[#2E9E6A]" style={`width:${revenue > 0 ? 100 : 0}%`}></div>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between gap-3 mb-1.5">
            <span class="text-[14px] text-white">Cheltuieli</span>
            <span class="text-[13px] tabular-nums text-[#A8BED2]">{ron(expensesTotal)}</span>
          </div>
          <div class="h-2.5 rounded-full bg-white/10 overflow-hidden">
            <div class="h-full rounded-full bg-[#E8A33C]" style={`width:${revenue > 0 ? Math.min(100, Math.round((expensesTotal / revenue) * 100)) : (expensesTotal > 0 ? 100 : 0)}%`}></div>
          </div>
        </div>
      </div>
    </div>
  )}

  <!-- Expense breakdown -->
  <div class="rounded-2xl bg-white/5 p-5">
    <h2 class="text-[16px] font-bold text-white mb-4">Cheltuieli pe categorii</h2>
    {cats.length === 0 ? (
      <div class="py-8 text-center">
        <p class="text-[14px] font-semibold text-white">Nicio cheltuială în această perioadă</p>
        <p class="text-[12px] text-[#8FA6BC] mt-0.5">Încearcă un alt interval de timp.</p>
      </div>
    ) : (
      <ul class="space-y-3.5">
        {cats.map((c) => (
          <li>
            <div class="flex items-center justify-between gap-3 mb-1.5">
              <span class="text-[14.5px] text-white truncate">{c.label}</span>
              <span class="text-[13.5px] tabular-nums text-[#A8BED2] shrink-0">{c.display} · {c.pct}%</span>
            </div>
            <div class="h-2 rounded-full bg-white/10 overflow-hidden">
              <div class="h-full rounded-full bg-[#E1FB15]" style={`width:${c.pct}%`}></div>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>

  <p class="mt-4 text-[12.5px] text-[#7E97AC]">
    Calcul simplificat: venituri = vânzări nete din facturile emise (fără TVA), cheltuieli = sumele nete pe categorii.
    Nu include impozitul pe profit/microîntreprindere. Pentru raportarea oficială folosește Contabilitate → Balanță.
  </p>
</AppLayout>
