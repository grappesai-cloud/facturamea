---
import AppLayout from '../../../layouts/AppLayout.astro';
import ImportWizard from '../../../components/import/ImportWizard.tsx';
import { db } from '../../../db';
import { importJobs } from '../../../db/schema';
import { desc, eq } from 'drizzle-orm';

const company = Astro.locals.company;
const companyId = company?.id;

let jobs: any[] = [];
if (companyId) {
  try {
    jobs = await db
      .select()
      .from(importJobs)
      .where(eq(importJobs.companyId, companyId))
      .orderBy(desc(importJobs.createdAt))
      .limit(15);
  } catch (e) {
    // DB not provisioned yet — render the wizard with an empty jobs list.
  }
}

const sourceLabels: Record<string, string> = {
  oblio: 'Oblio',
  smartbill: 'SmartBill',
  fgo: 'FGO',
  csv: 'CSV / Excel',
  json: 'JSON',
};
const entityLabels: Record<string, string> = {
  clients: 'Clienți',
  products: 'Produse',
  invoices: 'Facturi',
};
const statusLabels: Record<string, { label: string; cls: string }> = {
  pending: { label: 'În curs', cls: 'bg-[#FFF7E6] text-[#B45309]' },
  done: { label: 'Finalizat', cls: 'bg-[#E7F7EC] text-[#15803D]' },
  failed: { label: 'Eșuat', cls: 'bg-[#FDECEC] text-[#B91C1C]' },
};

const fmtDate = (d: Date | string | null) =>
  d ? new Intl.DateTimeFormat('ro-RO', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(d)) : '—';
---

<AppLayout title="Import date">
  <div class="mb-6">
    <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Import date</h1>
    <p class="text-[13px] text-[#6B6B68] mt-1 max-w-2xl">
      Adu-ți clienții, produsele și istoricul de facturi din Oblio, SmartBill, FGO sau dintr-un fișier
      CSV / Excel. Încarci fișierul, verifici maparea coloanelor, apoi confirmi importul.
    </p>
  </div>

  <ImportWizard client:load />

  <!-- Recent import jobs -->
  <div id="import-jobs" class="mt-6 bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    <div class="flex items-center justify-between px-5 py-3.5 border-b border-[#F0F0EC]">
      <h2 class="text-[14px] font-semibold text-[#0A0A0A]">Importuri recente</h2>
      <button id="jobs-refresh" type="button" class="text-[12px] font-medium text-[#6B6B68] hover:text-[#0A0A0A]">
        Reîmprospătează
      </button>
    </div>
    <div id="jobs-body">
      {jobs.length === 0 ? (
        <div class="px-5 py-12 text-center">
          <p class="text-[14px] text-[#6B6B68]">Niciun import încă.</p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-[13px]">
            <thead>
              <tr class="text-left text-[11px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
                <th class="px-5 py-2.5 font-medium">Data</th>
                <th class="px-5 py-2.5 font-medium">Sursă</th>
                <th class="px-5 py-2.5 font-medium">Tip</th>
                <th class="px-5 py-2.5 font-medium text-right">Importate</th>
                <th class="px-5 py-2.5 font-medium text-right">Erori</th>
                <th class="px-5 py-2.5 font-medium">Status</th>
              </tr>
            </thead>
            <tbody>
              {jobs.map((j) => {
                const st = statusLabels[j.status] || statusLabels.pending;
                return (
                  <tr class="border-b border-[#F6F6F2] last:border-0">
                    <td class="px-5 py-3 text-[#3D3D3A]">{fmtDate(j.createdAt)}</td>
                    <td class="px-5 py-3 text-[#0A0A0A]">{sourceLabels[j.source] || j.source || '—'}</td>
                    <td class="px-5 py-3 text-[#3D3D3A]">{entityLabels[j.entity] || j.entity || '—'}</td>
                    <td class="px-5 py-3 text-right font-semibold text-[#15803D]">{j.importedRows ?? 0}</td>
                    <td class="px-5 py-3 text-right text-[#B91C1C]">{j.errorRows ?? 0}</td>
                    <td class="px-5 py-3"><span class={`inline-block px-2 py-0.5 rounded-md text-[11px] font-medium ${st.cls}`}>{st.label}</span></td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</AppLayout>

<script>
  // Client-side refresh of the recent-jobs list (after a commit, or on click).
  const sourceLabels: Record<string, string> = { oblio: 'Oblio', smartbill: 'SmartBill', fgo: 'FGO', csv: 'CSV / Excel', json: 'JSON' };
  const entityLabels: Record<string, string> = { clients: 'Clienți', products: 'Produse', invoices: 'Facturi' };
  const statusLabels: Record<string, { label: string; cls: string }> = {
    pending: { label: 'În curs', cls: 'bg-[#FFF7E6] text-[#B45309]' },
    done: { label: 'Finalizat', cls: 'bg-[#E7F7EC] text-[#15803D]' },
    failed: { label: 'Eșuat', cls: 'bg-[#FDECEC] text-[#B91C1C]' },
  };
  const esc = (s: string) => String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  const fmtDate = (d: string | null) =>
    d ? new Intl.DateTimeFormat('ro-RO', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(d)) : '—';

  async function refreshJobs() {
    const body = document.getElementById('jobs-body');
    if (!body) return;
    try {
      const res = await fetch('/api/import/jobs');
      if (!res.ok) return;
      const { jobs } = await res.json();
      if (!Array.isArray(jobs) || jobs.length === 0) {
        body.innerHTML = '<div class="px-5 py-12 text-center"><p class="text-[14px] text-[#6B6B68]">Niciun import încă.</p></div>';
        return;
      }
      const rows = jobs.map((j: any) => {
        const st = statusLabels[j.status] || statusLabels.pending;
        return `<tr class="border-b border-[#F6F6F2] last:border-0">
          <td class="px-5 py-3 text-[#3D3D3A]">${esc(fmtDate(j.createdAt))}</td>
          <td class="px-5 py-3 text-[#0A0A0A]">${esc(sourceLabels[j.source] || j.source || '—')}</td>
          <td class="px-5 py-3 text-[#3D3D3A]">${esc(entityLabels[j.entity] || j.entity || '—')}</td>
          <td class="px-5 py-3 text-right font-semibold text-[#15803D]">${j.importedRows ?? 0}</td>
          <td class="px-5 py-3 text-right text-[#B91C1C]">${j.errorRows ?? 0}</td>
          <td class="px-5 py-3"><span class="inline-block px-2 py-0.5 rounded-md text-[11px] font-medium ${st.cls}">${esc(st.label)}</span></td>
        </tr>`;
      }).join('');
      body.innerHTML = `<div class="overflow-x-auto"><table class="w-full text-[13px]"><thead><tr class="text-left text-[11px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]"><th class="px-5 py-2.5 font-medium">Data</th><th class="px-5 py-2.5 font-medium">Sursă</th><th class="px-5 py-2.5 font-medium">Tip</th><th class="px-5 py-2.5 font-medium text-right">Importate</th><th class="px-5 py-2.5 font-medium text-right">Erori</th><th class="px-5 py-2.5 font-medium">Status</th></tr></thead><tbody>${rows}</tbody></table></div>`;
    } catch {}
  }

  document.getElementById('jobs-refresh')?.addEventListener('click', refreshJobs);
  window.addEventListener('import:done', () => { refreshJobs(); });
</script>
