---
import AppLayout from '../../../layouts/AppLayout.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { db } from '../../../db';
import { notifications } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
let items: any[] = [];
try {
  items = await db
    .select()
    .from(notifications)
    .where(eq(notifications.userId, user.id))
    .orderBy(desc(notifications.createdAt))
    .limit(50);
} catch { /* DB not ready */ }

const fmt = (d: any) => {
  if (!d) return '';
  try { return new Intl.DateTimeFormat('ro-RO', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }).format(new Date(d)); }
  catch { return ''; }
};
---

<AppLayout title="Notificări" activeTab="notificari">
  <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Notificări</h1>
      <p class="text-[14px] text-[#A8BED2] mt-2">Activitatea contului tău: facturi, încasări, e-Factura, sistem.</p>
    </div>
  </div>

  {items.length === 0 ? (
    <EmptyState title="Nicio notificare" description="Te anunțăm aici despre facturi, scadențe și ANAF.">
      <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/></svg>
    </EmptyState>
  ) : (
    <Fragment>
      <ul class="space-y-2.5">
        {items.slice(0, 3).map((n) => (
          <li>
            <a href={n.linkUrl || '#'} class="flex items-start gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
              <span class={`mt-1.5 w-2 h-2 rounded-full shrink-0 ${n.readAt ? 'bg-white/20' : 'bg-[#E1FB15]'}`}></span>
              <div class="min-w-0 flex-1">
                <p class="text-[14px] font-semibold text-white">{n.title}</p>
                {n.body && <p class="text-[13px] text-[#A8BED2] mt-0.5">{n.body}</p>}
              </div>
              <span class="text-[12px] text-[#8FA6BC] shrink-0 tabular-nums">{fmt(n.createdAt)}</span>
            </a>
          </li>
        ))}
      </ul>
      {items.length > 3 && (
        <details class="mt-2.5">
          <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({items.length})</summary>
          <ul class="space-y-2.5 mt-2.5">
            {items.slice(3).map((n) => (
              <li>
                <a href={n.linkUrl || '#'} class="flex items-start gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
                  <span class={`mt-1.5 w-2 h-2 rounded-full shrink-0 ${n.readAt ? 'bg-white/20' : 'bg-[#E1FB15]'}`}></span>
                  <div class="min-w-0 flex-1">
                    <p class="text-[14px] font-semibold text-white">{n.title}</p>
                    {n.body && <p class="text-[13px] text-[#A8BED2] mt-0.5">{n.body}</p>}
                  </div>
                  <span class="text-[12px] text-[#8FA6BC] shrink-0 tabular-nums">{fmt(n.createdAt)}</span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      )}
    </Fragment>
  )}
</AppLayout>
