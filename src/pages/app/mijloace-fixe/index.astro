---
import AppLayout from '../../../layouts/AppLayout.astro';
import AssetForm from '../../../components/mijloace-fixe/AssetForm.tsx';
import { db } from '../../../db';
import { fixedAssets } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

let assets: any[] = [];
try {
  assets = await db.select().from(fixedAssets)
    .where(eq(fixedAssets.companyId, companyId))
    .orderBy(desc(fixedAssets.createdAt))
    .limit(500);
} catch (e) { /* DB not provisioned */ }

const active = assets.filter((a) => a.status === 'active');
const totalValue = assets.reduce((s, a) => s + (a.valueCents || 0), 0);
const totalAccumulated = assets.reduce((s, a) => s + (a.accumulatedCents || 0), 0);
const totalRemaining = assets.reduce((s, a) => s + Math.max(0, (a.valueCents || 0) - (a.accumulatedCents || 0)), 0);

const METHOD_LABELS: Record<string, string> = {
  liniara: 'Liniară', degresiva: 'Degresivă', accelerata: 'Accelerată',
};

const now = new Date();
const defaultPeriod = `${now.getUTCFullYear()}-${String(now.getUTCMonth() + 1).padStart(2, '0')}`;
---

<AppLayout title="Mijloace fixe" activeTab="mijloace-fixe">
  <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Mijloace fixe și amortizare</h1>
      <p class="text-[15px] text-[#6B6B68] mt-1">Registrul mijloacelor fixe, amortizarea lunară și valoarea rămasă de recuperat.</p>
    </div>
  </div>

  <!-- KPI -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5">
      <p class="text-[13px] text-[#6B6B68]">Active</p>
      <p class="text-[26px] font-bold text-[#0A0A0A] mt-1 tabular-nums">{active.length}</p>
    </div>
    <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5">
      <p class="text-[13px] text-[#6B6B68]">Valoare totală</p>
      <p class="text-[22px] font-bold text-[#0A0A0A] mt-1 tabular-nums">{ron(totalValue)}</p>
    </div>
    <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5">
      <p class="text-[13px] text-[#6B6B68]">Amortizat</p>
      <p class="text-[22px] font-bold text-[#0A0A0A] mt-1 tabular-nums">{ron(totalAccumulated)}</p>
    </div>
    <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5">
      <p class="text-[13px] text-[#6B6B68]">Rămas de amortizat</p>
      <p class="text-[22px] font-bold text-[#FF5C00] mt-1 tabular-nums">{ron(totalRemaining)}</p>
    </div>
  </div>

  <!-- Actions: add asset + run depreciation -->
  <div class="flex flex-wrap items-end gap-3 mb-5">
    <div class="flex-1 min-w-[220px]">
      <AssetForm client:load />
    </div>
    <div class="flex items-end gap-2 px-4 py-3 bg-white border border-[#E8E8E4] rounded-2xl">
      <div>
        <label for="dep-period" class="block text-[13px] text-[#6B6B68] mb-1.5">Perioada</label>
        <input id="dep-period" type="month" value={defaultPeriod}
          class="h-11 px-3 border border-[#E8E8E4] rounded-xl text-[15px] bg-white" />
      </div>
      <button id="run-dep" class="px-4 h-11 rounded-xl bg-[#0A0A0A] text-white text-[14px] font-semibold hover:bg-[#1a1a1a]">
        Rulează amortizarea lunii
      </button>
    </div>
  </div>
  <p id="dep-msg" class="text-[14px] mb-4 hidden"></p>

  <!-- Assets list -->
  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    {assets.length === 0 ? (
      <div class="px-5 py-12 text-center text-[15px] text-[#6B6B68]">Niciun mijloc fix înregistrat. Adaugă primul mijloc fix mai sus.</div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-[14px]">
          <thead>
            <tr class="text-left text-[12px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
              <th class="px-5 py-3 font-medium">Denumire</th>
              <th class="px-5 py-3 font-medium">Nr. inventar</th>
              <th class="px-5 py-3 font-medium">Metodă</th>
              <th class="px-5 py-3 font-medium text-right">Valoare</th>
              <th class="px-5 py-3 font-medium text-right">Amortizat</th>
              <th class="px-5 py-3 font-medium text-right">Rămas</th>
              <th class="px-5 py-3 font-medium">Status</th>
            </tr>
          </thead>
          <tbody>
            {assets.map((a) => {
              const remaining = Math.max(0, (a.valueCents || 0) - (a.accumulatedCents || 0));
              const disposed = a.status === 'disposed';
              return (
                <tr class="border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors">
                  <td class="px-5 py-3.5">
                    <a href={`/app/mijloace-fixe/${a.id}`} class="font-semibold text-[#0A0A0A] hover:text-[#FF5C00]">{a.name}</a>
                    {a.category && <span class="block text-[13px] text-[#8A8A85]">{a.category}</span>}
                  </td>
                  <td class="px-5 py-3.5 text-[#3D3D3A] font-mono">{a.inventoryNumber || '—'}</td>
                  <td class="px-5 py-3.5 text-[#3D3D3A]">{METHOD_LABELS[a.method] || a.method || '—'}</td>
                  <td class="px-5 py-3.5 text-right font-semibold text-[#0A0A0A] tabular-nums">{ron(a.valueCents)}</td>
                  <td class="px-5 py-3.5 text-right text-[#3D3D3A] tabular-nums">{ron(a.accumulatedCents)}</td>
                  <td class="px-5 py-3.5 text-right font-semibold tabular-nums" style={remaining > 0 ? 'color:#FF5C00' : 'color:#15803D'}>{ron(remaining)}</td>
                  <td class="px-5 py-3.5">
                    <span class:list={['inline-block px-2.5 py-1 rounded-lg text-[13px] font-medium', disposed ? 'bg-[#F0F0EC] text-[#6B6B68]' : 'bg-[#E7F7EC] text-[#15803D]']}>
                      {disposed ? 'Casat' : 'Activ'}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <p class="mt-6 text-[13px] text-[#8A8A85] max-w-2xl leading-relaxed">
    Amortizarea se calculează lunar pe baza metodei și a duratei de utilizare. Rularea pentru o lună deja procesată nu produce înregistrări duplicate.
  </p>

  <script is:inline define:vars={{ defaultPeriod }}>
    (function () {
      const btn = document.getElementById('run-dep');
      const periodEl = document.getElementById('dep-period');
      const msg = document.getElementById('dep-msg');

      function show(text, ok) {
        msg.textContent = text;
        msg.className = 'text-[14px] mb-4 ' + (ok ? 'text-[#15803D]' : 'text-[#B91C1C]');
      }

      btn?.addEventListener('click', async function () {
        const period = (periodEl && periodEl.value) || defaultPeriod;
        const original = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Se rulează...';
        try {
          const res = await fetch('/api/mijloace-fixe/run-depreciation', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ period: period }),
          });
          const data = await res.json().catch(function () { return {}; });
          if (res.ok && data.ok) {
            const ron = new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((data.totalCents || 0) / 100);
            show('Amortizare rulată pentru ' + period + ': ' + data.processed + ' mijloace, total ' + ron + '. Reîncărcăm...', true);
            setTimeout(function () { window.location.reload(); }, 1200);
          } else {
            show(data.error || 'Eroare la rularea amortizării.', false);
            btn.disabled = false;
            btn.textContent = original;
          }
        } catch (e) {
          show('Eroare de conexiune.', false);
          btn.disabled = false;
          btn.textContent = original;
        }
      });
    })();
  </script>
</AppLayout>
