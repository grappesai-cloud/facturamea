---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { fixedAssets, depreciationEntries } from '../../../db/schema';
import { and, eq, desc } from 'drizzle-orm';
import { buildSchedule } from '../../../lib/depreciation';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;
const id = Astro.params.id!;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

let asset: any = null;
let entries: any[] = [];
try {
  const [a] = await db.select().from(fixedAssets)
    .where(and(eq(fixedAssets.id, id), eq(fixedAssets.companyId, companyId))).limit(1);
  asset = a || null;
  if (asset) {
    entries = await db.select().from(depreciationEntries)
      .where(eq(depreciationEntries.assetId, id))
      .orderBy(desc(depreciationEntries.period));
  }
} catch (e) { /* DB not provisioned */ }

if (!asset) return Astro.redirect('/app/mijloace-fixe');

const METHOD_LABELS: Record<string, string> = {
  liniara: 'Liniară', degresiva: 'Degresivă', accelerata: 'Accelerată',
};

const value = asset.valueCents || 0;
const accumulated = asset.accumulatedCents || 0;
const remaining = Math.max(0, value - accumulated);
const disposed = asset.status === 'disposed';

// Forward-looking schedule (full life) for the table.
const schedule = buildSchedule({
  valueCents: value,
  usefulLifeMonths: asset.usefulLifeMonths,
  method: asset.method,
  accumulatedCents: 0,
});
---

<AppLayout title={asset.name} activeTab="mijloace-fixe">
  <div class="mb-4">
    <a href="/app/mijloace-fixe" class="text-[15px] text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la mijloace fixe</a>
  </div>

  <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">{asset.name}</h1>
      <p class="text-[15px] text-[#6B6B68] mt-1">
        {asset.inventoryNumber ? `Nr. inventar ${asset.inventoryNumber} · ` : ''}{asset.category || 'Fără categorie'}
      </p>
    </div>
    <div class="flex items-center gap-2">
      <span class:list={['inline-block px-3 py-1.5 rounded-xl text-[14px] font-medium', disposed ? 'bg-[#F0F0EC] text-[#6B6B68]' : 'bg-[#E7F7EC] text-[#15803D]']}>
        {disposed ? 'Casat' : 'Activ'}
      </span>
      {!disposed && (
        <button id="dispose-btn" class="px-4 h-11 rounded-xl bg-white border border-[#E0E0DA] hover:border-[#B91C1C] text-[14px] font-semibold text-[#B91C1C]">Casează</button>
      )}
      {disposed && (
        <button id="reactivate-btn" class="px-4 h-11 rounded-xl bg-white border border-[#E0E0DA] hover:border-[#0A0A0A] text-[14px] font-semibold">Reactivează</button>
      )}
    </div>
  </div>

  <!-- Summary cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5">
      <p class="text-[13px] text-[#6B6B68]">Valoare de intrare</p>
      <p class="text-[20px] font-bold text-[#0A0A0A] mt-1 tabular-nums">{ron(value)}</p>
    </div>
    <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5">
      <p class="text-[13px] text-[#6B6B68]">Amortizat</p>
      <p class="text-[20px] font-bold text-[#0A0A0A] mt-1 tabular-nums">{ron(accumulated)}</p>
    </div>
    <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5">
      <p class="text-[13px] text-[#6B6B68]">Rămas</p>
      <p class="text-[20px] font-bold text-[#FF5C00] mt-1 tabular-nums">{ron(remaining)}</p>
    </div>
    <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5">
      <p class="text-[13px] text-[#6B6B68]">Metodă · Durată</p>
      <p class="text-[18px] font-bold text-[#0A0A0A] mt-1">{METHOD_LABELS[asset.method] || asset.method}</p>
      <p class="text-[13px] text-[#8A8A85]">{asset.usefulLifeMonths} luni{asset.acquisitionDate ? ` · achiziție ${asset.acquisitionDate}` : ''}</p>
    </div>
  </div>

  <!-- Booked depreciation entries -->
  <h2 class="text-[18px] font-bold text-[#0A0A0A] mb-3">Amortizări înregistrate</h2>
  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden mb-8">
    {entries.length === 0 ? (
      <div class="px-5 py-8 text-center text-[15px] text-[#6B6B68]">Nicio amortizare înregistrată încă. Rulează amortizarea din pagina de mijloace fixe.</div>
    ) : (
      <table class="w-full text-[14px]">
        <thead>
          <tr class="text-left text-[12px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
            <th class="px-5 py-3 font-medium">Perioada</th>
            <th class="px-5 py-3 font-medium text-right">Amortizare</th>
          </tr>
        </thead>
        <tbody>
          {entries.map((e) => (
            <tr class="border-b border-[#F6F6F2]">
              <td class="px-5 py-3 font-mono text-[#0A0A0A]">{e.period}</td>
              <td class="px-5 py-3 text-right font-semibold text-[#0A0A0A] tabular-nums">{ron(e.amountCents)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- Full planned schedule -->
  <h2 class="text-[18px] font-bold text-[#0A0A0A] mb-3">Plan de amortizare</h2>
  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    {schedule.length === 0 ? (
      <div class="px-5 py-8 text-center text-[15px] text-[#6B6B68]">Plan indisponibil.</div>
    ) : (
      <div class="overflow-x-auto max-h-[520px] overflow-y-auto">
        <table class="w-full text-[14px]">
          <thead class="sticky top-0 bg-white">
            <tr class="text-left text-[12px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
              <th class="px-5 py-3 font-medium">Luna</th>
              <th class="px-5 py-3 font-medium text-right">Amortizare</th>
              <th class="px-5 py-3 font-medium text-right">Cumulat</th>
              <th class="px-5 py-3 font-medium text-right">Rămas</th>
            </tr>
          </thead>
          <tbody>
            {schedule.map((r) => (
              <tr class="border-b border-[#F6F6F2]">
                <td class="px-5 py-2.5 text-[#3D3D3A] tabular-nums">{r.index}</td>
                <td class="px-5 py-2.5 text-right text-[#3D3D3A] tabular-nums">{ron(r.amountCents)}</td>
                <td class="px-5 py-2.5 text-right text-[#3D3D3A] tabular-nums">{ron(r.accumulatedCents)}</td>
                <td class="px-5 py-2.5 text-right text-[#3D3D3A] tabular-nums">{ron(r.remainingCents)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <script is:inline define:vars={{ assetId: id }}>
    (function () {
      async function patch(payload, confirmMsg) {
        if (confirmMsg && !confirm(confirmMsg)) return;
        try {
          const res = await fetch('/api/mijloace-fixe/' + assetId, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json().catch(function () { return {}; });
          if (res.ok && data.ok) { window.location.reload(); }
          else { alert(data.error || 'Eroare.'); }
        } catch (e) { alert('Eroare de conexiune.'); }
      }
      document.getElementById('dispose-btn')?.addEventListener('click', function () {
        patch({ dispose: true }, 'Sigur casezi acest mijloc fix? Nu va mai fi amortizat.');
      });
      document.getElementById('reactivate-btn')?.addEventListener('click', function () {
        patch({ reactivate: true });
      });
    })();
  </script>
</AppLayout>
