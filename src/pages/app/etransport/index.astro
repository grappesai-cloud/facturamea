---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { etransportDeclarations } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { getAnafStatus } from '../../../lib/anaf/tokens';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const anaf = await getAnafStatus(companyId).catch(() => ({ connected: false, cif: null as string | null }));

const ron = (cents: number | null) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

const fmtDate = (d: Date | string | null) => {
  if (!d) return '-';
  const date = new Date(d);
  return isNaN(date.getTime()) ? '-' : date.toLocaleDateString('ro-RO');
};

let rows: any[] = [];
try {
  rows = await db.select().from(etransportDeclarations)
    .where(eq(etransportDeclarations.companyId, companyId))
    .orderBy(desc(etransportDeclarations.createdAt))
    .limit(200);
} catch (e) { /* DB not provisioned */ }

function statusPill(status: string) {
  switch (status) {
    case 'sent': return { label: 'Trimisă', cls: 'bg-[#EAF2FF] text-[#1D4ED8]' };
    case 'confirmed': return { label: 'Confirmată', cls: 'bg-[#E7F7EC] text-[#15803D]' };
    case 'error': return { label: 'Eroare', cls: 'bg-[#FDECEC] text-[#B91C1C]' };
    default: return { label: 'Ciornă', cls: 'bg-[#F0F0EC] text-[#6B6B68]' };
  }
}
---

<AppLayout title="e-Transport" activeTab="etransport">
  <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">e-Transport (UIT)</h1>
      <p class="text-[15px] text-[#6B6B68] mt-1">Declară transporturile de marfă și obține codul UIT de la ANAF.</p>
    </div>
    <a href="/app/etransport/nou" class="inline-flex items-center gap-2 px-5 h-12 rounded-xl bg-[#FF5C00] text-white text-[15px] font-semibold hover:bg-[#e65300]">
      Declarație nouă
    </a>
  </div>

  {!anaf.connected && (
    <div class="mb-4 flex flex-wrap items-center gap-3 px-4 py-3 bg-[#FFF3E9] border border-[#FF5C00]/25 rounded-xl">
      <span class="w-2 h-2 rounded-full bg-[#FF5C00]"></span>
      <p class="text-[14px] text-[#0A0A0A]">Poți pregăti declarații ca ciorne. Pentru a le trimite la ANAF, conectează firma din <strong>Setări → Integrare ANAF</strong>.</p>
      <a href="/app/setari/integrari-anaf" class="text-[14px] font-semibold text-[#FF5C00] hover:underline ml-auto">Conectează →</a>
    </div>
  )}

  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    {rows.length === 0 ? (
      <div class="px-5 py-14 text-center">
        <p class="text-[16px] text-[#6B6B68]">Nicio declarație încă.</p>
        <a href="/app/etransport/nou" class="inline-block mt-3 text-[15px] font-semibold text-[#FF5C00] hover:underline">Creează prima declarație →</a>
      </div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-[15px]">
          <thead>
            <tr class="text-left text-[12px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
              <th class="px-5 py-3 font-medium">UIT</th>
              <th class="px-5 py-3 font-medium">Tip</th>
              <th class="px-5 py-3 font-medium">Expeditor → Destinatar</th>
              <th class="px-5 py-3 font-medium">Vehicul</th>
              <th class="px-5 py-3 font-medium">Data</th>
              <th class="px-5 py-3 font-medium text-right">Valoare</th>
              <th class="px-5 py-3 font-medium">Status</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((d) => {
              const pill = statusPill(d.status);
              return (
                <tr class="border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors">
                  <td class="px-5 py-4 font-mono font-semibold text-[#0A0A0A]">{d.uit || '-'}</td>
                  <td class="px-5 py-4 text-[#3D3D3A]">{d.operationType || '-'}</td>
                  <td class="px-5 py-4 text-[#3D3D3A] truncate max-w-[260px]">{d.senderName || '-'} → {d.recipientName || '-'}</td>
                  <td class="px-5 py-4 font-mono text-[14px] text-[#3D3D3A]">{d.vehiclePlate || '-'}</td>
                  <td class="px-5 py-4 text-[#3D3D3A]">{fmtDate(d.createdAt)}</td>
                  <td class="px-5 py-4 text-right font-semibold text-[#0A0A0A]">{ron(d.totalValueCents)}</td>
                  <td class="px-5 py-4">
                    <span class={`inline-block px-2.5 py-1 rounded-lg text-[13px] font-medium ${pill.cls}`}>{pill.label}</span>
                    {d.status === 'error' && d.errorText && (
                      <span class="block text-[13px] text-[#B91C1C] mt-1 truncate max-w-[260px]">{d.errorText}</span>
                    )}
                    {d.spvIndex && d.status !== 'confirmed' && d.status !== 'error' && (
                      <button class="check-status block mt-1 text-[13px] font-semibold text-[#FF5C00] hover:underline" data-id={d.id}>Verifică starea</button>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.check-status').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        if (!id) return;
        const original = btn.textContent;
        btn.textContent = 'Se verifică...';
        try {
          const r = await fetch(`/api/anaf/etransport/${id}`);
          const d = await r.json();
          if (d.ok) {
            window.location.reload();
          } else {
            btn.textContent = original;
            alert(d.error || 'Nu s-a putut verifica starea.');
          }
        } catch {
          btn.textContent = original;
          alert('Eroare de rețea.');
        }
      });
    });
  </script>
</AppLayout>
