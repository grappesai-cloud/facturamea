---
import AppLayout from '../../../layouts/AppLayout.astro';
import EtransportForm from '../../../components/anaf/EtransportForm';
import { getAnafStatus } from '../../../lib/anaf/tokens';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const anaf = await getAnafStatus(companyId).catch(() => ({ connected: false, cif: null as string | null }));
---

<AppLayout title="Declarație e-Transport" activeTab="etransport">
  <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Declarație e-Transport nouă</h1>
      <p class="text-[15px] text-[#6B6B68] mt-1">Completează datele transportului. La trimitere, ANAF îți alocă un cod UIT.</p>
    </div>
    <a href="/app/etransport" class="inline-flex items-center gap-2 px-3.5 h-11 rounded-xl bg-white border border-[#E0E0DA] hover:border-[#0A0A0A] text-[14px] font-semibold">
      ← Înapoi la listă
    </a>
  </div>

  {!anaf.connected && (
    <div class="mb-4 flex flex-wrap items-center gap-3 px-4 py-3 bg-[#FFF3E9] border border-[#FF5C00]/25 rounded-xl">
      <span class="w-2 h-2 rounded-full bg-[#FF5C00]"></span>
      <p class="text-[14px] text-[#0A0A0A]">ANAF neconectat: declarația se va salva ca ciornă. Conectează firma din <strong>Setări → Integrare ANAF</strong> pentru a o trimite.</p>
      <a href="/app/setari/integrari-anaf" class="text-[14px] font-semibold text-[#FF5C00] hover:underline ml-auto">Conectează →</a>
    </div>
  )}

  <EtransportForm client:load />
</AppLayout>
