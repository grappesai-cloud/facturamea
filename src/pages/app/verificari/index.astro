---
// Pre-ANAF checks: deterministic anomaly detection + upcoming fiscal deadlines.
// Catches likely mistakes before they hit a declaration. Zero cost, no AI.
import AppLayout from '../../../layouts/AppLayout.astro';
import { detectAnomalies } from '../../../lib/anomalies';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');

const anomalies = await detectAnomalies(user.companyId);
const highCount = anomalies.filter((a) => a.severity === 'high').length;

// Upcoming statutory deadlines (deterministic, RO). 25th = VAT/SAF-T/D390/D394.
const now = new Date();
const mk = (day: number, label: string) => {
  let d = new Date(now.getFullYear(), now.getMonth(), day);
  if (now.getDate() > day) d = new Date(now.getFullYear(), now.getMonth() + 1, day);
  const days = Math.ceil((d.getTime() - now.getTime()) / 86400000);
  return { label, date: d.toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', timeZone: 'Europe/Bucharest' }), days };
};
const deadlines = [
  mk(25, 'TVA (D300) · SAF-T (D406) · VIES (D390) · D394'),
  mk(25, 'Impozit pe venit / microîntreprindere'),
].sort((a, b) => a.days - b.days);

const TONE: Record<string, string> = {
  high: 'bg-[#DC4B41]/15 text-[#DC4B41]', warn: 'bg-[#E8A33C]/15 text-[#E8A33C]', info: 'bg-[#34A0A4]/15 text-[#34A0A4]',
};
const DOT: Record<string, string> = { high: 'bg-[#DC4B41]', warn: 'bg-[#E8A33C]', info: 'bg-[#34A0A4]' };
---

<AppLayout title="Verificări" activeTab="verificari">
  <div class="mb-6">
    <h1 class="text-[30px] sm:text-[38px] font-semibold tracking-[-0.03em] text-white">Verificări</h1>
    <p class="mt-1.5 text-[15px] text-[#7E97AC]">Prinde greșelile înainte să ajungă la ANAF.</p>
  </div>

  <!-- Fiscal deadlines -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
    {deadlines.map((d) => (
      <div class={`rounded-2xl p-4 ${d.days <= 5 ? 'bg-[#E8A33C]/10 ring-1 ring-[#E8A33C]/30' : 'bg-white/5'}`}>
        <p class="text-[13px] text-[#9FB8CC]">{d.label}</p>
        <p class="mt-1 text-[18px] font-bold text-white">{d.date} <span class="text-[13px] font-normal text-[#7E97AC]">· peste {d.days} {d.days === 1 ? 'zi' : 'zile'}</span></p>
      </div>
    ))}
  </div>

  <!-- Anomalies -->
  {anomalies.length === 0 ? (
    <div class="rounded-2xl bg-[#2E9E6A]/10 ring-1 ring-[#2E9E6A]/30 p-8 text-center">
      <p class="text-[18px] font-semibold text-[#2E9E6A]">✓ Nicio problemă găsită</p>
      <p class="text-[14px] text-[#9FB8CC] mt-1">Facturile, cheltuielile și TVA-ul arată în regulă.</p>
    </div>
  ) : (
    <>
      <div class="mb-3 flex items-center gap-2">
        <h2 class="text-[17px] font-bold text-white">{anomalies.length} {anomalies.length === 1 ? 'verificare' : 'verificări'} de atenționat</h2>
        {highCount > 0 && <span class="text-[12px] px-2.5 py-1 rounded-full bg-[#DC4B41]/15 text-[#DC4B41] font-semibold">{highCount} urgente</span>}
      </div>
      <ul class="space-y-2.5">
        {anomalies.map((a) => (
          <li class="rounded-2xl bg-white/5 hover:bg-white/[0.08] transition-colors p-4">
            <div class="flex items-start gap-3">
              <span class={`mt-1.5 shrink-0 w-2.5 h-2.5 rounded-full ${DOT[a.severity]}`}></span>
              <div class="min-w-0 flex-1">
                <p class="text-[15.5px] font-semibold text-white">{a.title}</p>
                <p class="text-[13.5px] text-[#9FB8CC] mt-0.5">{a.detail}</p>
              </div>
              {a.href && <a href={a.href} class={`shrink-0 text-[13px] px-3 py-1.5 rounded-full font-semibold ${TONE[a.severity]}`}>Rezolvă →</a>}
            </div>
          </li>
        ))}
      </ul>
    </>
  )}
</AppLayout>
