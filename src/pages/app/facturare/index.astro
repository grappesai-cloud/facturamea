---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { transportInvoices } from '../../../db/schema';
import { eq, sql, and, desc, lt, ne } from 'drizzle-orm';
import { isOverdue } from '../../../lib/dates';
import EmptyState from '../../../components/ui/EmptyState.astro';

const user = Astro.locals.user!;
const companyId = user.companyId;

async function safe<T>(p: Promise<T>, fb: T): Promise<T> { try { return await p; } catch { return fb; } }

// Kind filter — replaces the old per-type list pages (proforme/chitante/avize…).
// Picked via ?kind=… so old links can 302 here and deep-links keep working.
const KIND_FILTERS = [
  { value: 'all', label: 'Toate' },
  { value: 'factura', label: 'Facturi' },
  { value: 'proforma', label: 'Proforme' },
  { value: 'chitanta', label: 'Chitanțe' },
  { value: 'aviz', label: 'Avize' },
  { value: 'storno', label: 'Storno' },
] as const;
const rawKind = (Astro.url.searchParams.get('kind') || 'all').toLowerCase();
const activeKind = KIND_FILTERS.some((k) => k.value === rawKind) ? rawKind : 'all';
const activeKindLabel = KIND_FILTERS.find((k) => k.value === activeKind)?.label ?? 'Toate';

const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);

// KPI rollups — issued total this month, due-but-unpaid, overdue, paid this month.
const [issuedRow, openRow, overdueRow, paidRow] = companyId ? await Promise.all([
  safe(db.select({
    sum: sql<number>`COALESCE(SUM(${transportInvoices.totalCents}), 0)`,
    cnt: sql<number>`COUNT(*)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.issuedAt} >= ${monthStart}`,
    ne(transportInvoices.status, 'voided'),
  )), [{ sum: 0, cnt: 0 }]),
  safe(db.select({
    sum: sql<number>`COALESCE(SUM(${transportInvoices.totalCents} - ${transportInvoices.paidCents}), 0)`,
    cnt: sql<number>`COUNT(*)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.status} IN ('issued','sent','partial')`,
  )), [{ sum: 0, cnt: 0 }]),
  safe(db.select({
    sum: sql<number>`COALESCE(SUM(${transportInvoices.totalCents} - ${transportInvoices.paidCents}), 0)`,
    cnt: sql<number>`COUNT(*)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.status} IN ('issued','sent','partial')`,
    lt(transportInvoices.dueAt, now),
  )), [{ sum: 0, cnt: 0 }]),
  safe(db.select({
    sum: sql<number>`COALESCE(SUM(${transportInvoices.paidCents}), 0)`,
    cnt: sql<number>`COUNT(*)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.paidAt} >= ${monthStart}`,
  )), [{ sum: 0, cnt: 0 }]),
]) : [[{ sum: 0, cnt: 0 }], [{ sum: 0, cnt: 0 }], [{ sum: 0, cnt: 0 }], [{ sum: 0, cnt: 0 }]];

const recent = companyId ? await safe(
  db.select({
    id: transportInvoices.id,
    fullNumber: transportInvoices.fullNumber,
    kind: transportInvoices.kind,
    clientNameSnap: transportInvoices.clientNameSnap,
    totalCents: transportInvoices.totalCents,
    paidCents: transportInvoices.paidCents,
    currency: transportInvoices.currency,
    status: transportInvoices.status,
    issuedAt: transportInvoices.issuedAt,
    dueAt: transportInvoices.dueAt,
  })
    .from(transportInvoices)
    .where(activeKind === 'all'
      ? eq(transportInvoices.companyId, companyId)
      : and(eq(transportInvoices.companyId, companyId), eq(transportInvoices.kind, activeKind)))
    .orderBy(desc(transportInvoices.createdAt))
    .limit(activeKind === 'all' ? 10 : 100),
  [] as any[],
) : [];

// KPI rollups (facturat azi, e-Factura netrimise/erori, aging buckets) now live on
// the Reports page; the e-Factura netrimise/erori alert moved to Notificări.

function fmtMoney(cents: number, currency: string) {
  return `${(cents / 100).toLocaleString('ro-RO', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${currency}`;
}
// Compact (no decimals) — for the KPI cards so big numbers fit on one line on mobile.
function fmtMoney0(cents: number, currency = 'RON') {
  return `${Math.round((cents || 0) / 100).toLocaleString('ro-RO')} ${currency}`;
}

const kindLabel: Record<string, string> = {
  factura: 'Factură',
  proforma: 'Proformă',
  storno: 'Storno',
  chitanta: 'Chitanță',
  aviz: 'Aviz',
};

const statusTone: Record<string, string> = {
  draft: 'bg-white/10 text-[#A8BED2]',
  issued: 'bg-[#E8A33C]/15 text-[#E8A33C]',
  sent: 'bg-[#34A0A4]/15 text-[#34A0A4]',
  paid: 'bg-[#2E9E6A]/15 text-[#2E9E6A]',
  partial: 'bg-[#E8A33C]/15 text-[#E8A33C]',
  overdue: 'bg-[#DC4B41]/15 text-[#DC4B41]',
  disputed: 'bg-white/10 text-[#C8DAE8]',
  voided: 'bg-white/10 text-[#8FA6BC]',
  reversed: 'bg-white/10 text-[#8FA6BC]',
};

// Clean text labels — the colored pill + dot (see the badge below) convey the
// status at a glance, no emoji needed.
const statusLabel: Record<string, string> = {
  draft: 'Ciornă',
  issued: 'Emisă',
  sent: 'Trimisă',
  paid: 'Plătită',
  partial: 'Plătită parțial',
  overdue: 'Întârziată',
  disputed: 'Dispută',
  voided: 'Anulată',
  reversed: 'Stornată',
};
---

<AppLayout title="Facturare" activeTab="facturare">
  <!-- Header -->
  <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Facturare</h1>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <a href="/app/facturare/emite?kind=factura" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">+ Emite factură</a>
      <a href="/app/facturare/setari" aria-label="Personalizează factura" title="Designul facturii — șablon, logo, culoare, footer, ștampilă, previzualizare live" class="grid place-items-center w-11 h-11 rounded-full bg-white/10 text-white hover:bg-white/15 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.02-.397-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </a>
    </div>
  </div>

  {!companyId && (
    <div class="rounded-2xl p-4 mb-6 bg-[#E8A33C]/15">
      <p class="text-[13px] text-[#E8A33C]">Ai nevoie de o companie validată pentru a emite facturi. <a href="/app/setari" class="font-semibold text-[#E1FB15] hover:underline">Completează profilul →</a></p>
    </div>
  )}

  <!-- Shortcuts + document-type filter as inline expandable menus (one open at a time). -->
  <div class="mb-6 sm:mb-8" data-filterbar>
    <div class="flex flex-wrap gap-2">
      <button type="button" data-fb-toggle="sectiuni" aria-expanded="false" class="select-none inline-flex items-center gap-2 pl-3.5 pr-3 py-2 rounded-full bg-white/5 text-[13.5px] font-semibold text-[#A8BED2] hover:text-white hover:bg-white/10 transition-colors">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
        Secțiuni
        <svg data-fb-chev class="w-4 h-4 shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
      </button>
      <button type="button" data-fb-toggle="tip" aria-expanded="false" class="select-none inline-flex items-center gap-2 pl-3.5 pr-3 py-2 rounded-full bg-white/5 text-[13.5px] font-semibold text-[#A8BED2] hover:text-white hover:bg-white/10 transition-colors">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/></svg>
        Filtru: {activeKindLabel}
        <svg data-fb-chev class="w-4 h-4 shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
      </button>
    </div>

    <nav aria-label="Secțiuni facturare" data-fb-panel="sectiuni" hidden class="fm-reveal mt-2.5 grid grid-cols-2 sm:grid-cols-3 gap-2">
      {[
        { label: 'Clienți', href: '/app/facturare/clienti', icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z' },
        { label: 'Produse', href: '/app/facturare/produse', icon: 'M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9' },
        { label: 'Recurente', href: '/app/facturare/recurente', icon: 'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99' },
        { label: 'e-Factura', href: '/app/facturare/efactura', icon: 'M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z' },
        { label: 'Setări facturare', href: '/app/facturare/setari', icon: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.02-.397-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28zM15 12a3 3 0 11-6 0 3 3 0 016 0z' },
      ].map((l) => (
        <a href={l.href} class="inline-flex items-center gap-2 pl-3 pr-4 py-2.5 rounded-xl bg-white/5 text-[13px] font-semibold text-[#A8BED2] hover:text-white hover:bg-white/10 transition-colors">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d={l.icon}/></svg>
          {l.label}
        </a>
      ))}
    </nav>

    <nav aria-label="Tip document" data-fb-panel="tip" hidden class="fm-reveal mt-2.5 grid grid-cols-2 sm:grid-cols-3 gap-2">
      {KIND_FILTERS.map((k) => {
        const isActive = k.value === activeKind;
        const href = k.value === 'all' ? '/app/facturare' : `/app/facturare?kind=${k.value}`;
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class={`inline-flex items-center gap-2 pl-3 pr-4 py-2.5 rounded-xl text-[13px] font-semibold transition-colors ${isActive ? 'bg-[#E1FB15] text-[#07090f]' : 'bg-white/5 text-[#A8BED2] hover:text-white hover:bg-white/10'}`}
          >{k.label}</a>
        );
      })}
    </nav>
  </div>

  {/* Invoicing KPIs (Emis/De încasat/Întârziate/Încasat) now live on the Reports page.
      e-Factura netrimise/erori alert moved to Notificări. */}

  <!-- Recent invoices -->
  <div class="flex items-center justify-between gap-3 mb-3">
    <h2 class="text-[18px] font-bold text-white">{activeKind === 'all' ? 'Facturile recente' : activeKindLabel}</h2>
    {companyId && activeKind !== 'all' && (
      <a href={`/app/facturare/emite?kind=${activeKind}`} class="shrink-0 inline-flex items-center gap-1 px-4 py-2 rounded-full bg-white/10 text-white font-semibold text-[13px] hover:bg-white/15 transition-colors">+ Emite</a>
    )}
  </div>
  {recent.length === 0 ? (
    <EmptyState title={activeKind === 'all' ? 'Încă nicio factură' : `Niciun document de tip ${activeKindLabel.toLowerCase()}`} description="Emite primul document și apare aici.">
      <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      <a slot="action" href={activeKind === 'all' ? '/app/facturare/emite' : `/app/facturare/emite?kind=${activeKind}`} class="inline-flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Emite →</a>
    </EmptyState>
  ) : (
    <Fragment>
    <ul class="space-y-2.5" id="fact-list">
      {recent.map((inv, i) => {
        const overdue = ['issued', 'sent', 'partial'].includes(inv.status) && isOverdue(inv.dueAt);
        const effectiveStatus = overdue ? 'overdue' : inv.status;
        return (
          <li class={i >= 3 ? 'fm-extra' : undefined} hidden={i >= 3}>
            <a href={`/app/facturare/${inv.id}`} class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-semibold ${statusTone[effectiveStatus] ?? statusTone.draft}`}>
                    <span class="w-1.5 h-1.5 rounded-full bg-current shrink-0"></span>
                    {statusLabel[effectiveStatus] ?? effectiveStatus}
                  </span>
                  <span class="font-mono text-[12px] text-[#8FA6BC] tabular-nums truncate">{inv.fullNumber}</span>
                </div>
                <p class="text-[15px] text-white font-bold truncate mt-1.5">{inv.clientNameSnap}</p>
              </div>
              <div class="shrink-0 flex flex-col items-end gap-1 text-right">
                <p class="text-[15px] font-bold text-white tabular-nums whitespace-nowrap leading-none">{fmtMoney(inv.totalCents, inv.currency)}</p>
                <span class="text-[12px] text-[#8FA6BC] tabular-nums whitespace-nowrap">{inv.issuedAt ? new Date(inv.issuedAt).toLocaleDateString('ro-RO', { timeZone: 'Europe/Bucharest' }) : '—'}</span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
    {recent.length > 3 && (
      <button type="button" id="fact-seemore" data-shown="false" data-count={recent.length} class="mt-3 mx-auto w-fit flex items-center gap-2 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] active:scale-95 transition-all">
        <span data-seemore-label>Vezi toate ({recent.length})</span>
      </button>
    )}
    </Fragment>
  )}

</AppLayout>

<script>
  // Inline filter menus: clicking a toggle expands its panel below the row (pushing
  // content down), only one open at a time, and clicking outside closes everything.
  // Registered once globally (guard) so it survives view-transition swaps.
  if (!(window as any).__fmFilterbar) {
    (window as any).__fmFilterbar = true;
    const closeBar = (bar: Element) => {
      bar.querySelectorAll('[data-fb-panel]').forEach((p) => ((p as HTMLElement).hidden = true));
      bar.querySelectorAll('[data-fb-toggle]').forEach((t) => {
        t.setAttribute('aria-expanded', 'false');
        t.querySelector('[data-fb-chev]')?.classList.remove('rotate-180');
      });
    };
    document.addEventListener('click', (e) => {
      const toggle = (e.target as HTMLElement).closest('[data-fb-toggle]');
      if (toggle) {
        const bar = toggle.closest('[data-filterbar]');
        if (!bar) return;
        const key = toggle.getAttribute('data-fb-toggle');
        const panel = bar.querySelector(`[data-fb-panel="${key}"]`) as HTMLElement | null;
        const willOpen = !!panel?.hidden;
        closeBar(bar);
        if (panel && willOpen) {
          panel.hidden = false;
          toggle.setAttribute('aria-expanded', 'true');
          toggle.querySelector('[data-fb-chev]')?.classList.add('rotate-180');
        }
        return;
      }
      // Click outside any open filterbar → close it.
      document.querySelectorAll('[data-filterbar]').forEach((bar) => {
        if (!bar.contains(e.target as Node)) closeBar(bar);
      });
    });
  }
</script>

<script>
  // "Vezi toate" — expands the recent-invoice list in place (button stays at the
  // bottom), same behaviour as the Cheltuieli list. Delegated + guarded.
  if (!(window as any).__fmSeemore) {
    (window as any).__fmSeemore = true;
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('#fact-seemore') as HTMLElement | null;
      if (!btn) return;
      const willShow = btn.dataset.shown !== 'true';
      document.querySelectorAll('#fact-list .fm-extra').forEach((el) => { (el as HTMLElement).hidden = !willShow; });
      btn.dataset.shown = String(willShow);
      const label = btn.querySelector('[data-seemore-label]');
      if (label) label.textContent = willShow ? 'Arată mai puțin' : `Vezi toate (${btn.dataset.count})`;
    });
  }
</script>
