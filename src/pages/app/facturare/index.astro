---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { transportInvoices } from '../../../db/schema';
import { eq, sql, and, desc, lt, gte, isNull, ne } from 'drizzle-orm';

const user = Astro.locals.user!;
const companyId = user.companyId;

async function safe<T>(p: Promise<T>, fb: T): Promise<T> { try { return await p; } catch { return fb; } }

const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const yearStart = new Date(now.getFullYear(), 0, 1);

// KPI rollups — issued total this month, due-but-unpaid, overdue, paid this month.
const [issuedRow, openRow, overdueRow, paidRow] = companyId ? await Promise.all([
  safe(db.select({
    sum: sql<number>`COALESCE(SUM(${transportInvoices.totalCents}), 0)`,
    cnt: sql<number>`COUNT(*)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.issuedAt} >= ${monthStart}`,
    ne(transportInvoices.status, 'voided'),
  )), [{ sum: 0, cnt: 0 }]),
  safe(db.select({
    sum: sql<number>`COALESCE(SUM(${transportInvoices.totalCents} - ${transportInvoices.paidCents}), 0)`,
    cnt: sql<number>`COUNT(*)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.status} IN ('issued','sent','partial')`,
  )), [{ sum: 0, cnt: 0 }]),
  safe(db.select({
    sum: sql<number>`COALESCE(SUM(${transportInvoices.totalCents} - ${transportInvoices.paidCents}), 0)`,
    cnt: sql<number>`COUNT(*)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.status} IN ('issued','sent','partial')`,
    lt(transportInvoices.dueAt, now),
  )), [{ sum: 0, cnt: 0 }]),
  safe(db.select({
    sum: sql<number>`COALESCE(SUM(${transportInvoices.paidCents}), 0)`,
    cnt: sql<number>`COUNT(*)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.paidAt} >= ${monthStart}`,
  )), [{ sum: 0, cnt: 0 }]),
]) : [[{ sum: 0, cnt: 0 }], [{ sum: 0, cnt: 0 }], [{ sum: 0, cnt: 0 }], [{ sum: 0, cnt: 0 }]];

const recent = companyId ? await safe(
  db.select({
    id: transportInvoices.id,
    fullNumber: transportInvoices.fullNumber,
    kind: transportInvoices.kind,
    clientNameSnap: transportInvoices.clientNameSnap,
    totalCents: transportInvoices.totalCents,
    paidCents: transportInvoices.paidCents,
    currency: transportInvoices.currency,
    status: transportInvoices.status,
    issuedAt: transportInvoices.issuedAt,
    dueAt: transportInvoices.dueAt,
  })
    .from(transportInvoices)
    .where(eq(transportInvoices.companyId, companyId))
    .orderBy(desc(transportInvoices.createdAt))
    .limit(10),
  [] as any[],
) : [];

// Extra KPIs: facturat azi, e-Factura netrimise/erori, aging buckets, chart.
const [todayRow, efNetrimise, efErori, agingRows, chartInv, chartPay] = companyId ? await Promise.all([
  safe(db.select({ sum: sql<number>`COALESCE(SUM(${transportInvoices.totalCents}),0)`, cnt: sql<number>`COUNT(*)` })
    .from(transportInvoices).where(and(
      eq(transportInvoices.companyId, companyId), eq(transportInvoices.kind, 'factura'),
      gte(transportInvoices.issuedAt, todayStart), ne(transportInvoices.status, 'voided'),
    )), [{ sum: 0, cnt: 0 }]),
  safe(db.select({ cnt: sql<number>`COUNT(*)` }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId), eq(transportInvoices.kind, 'factura'),
    ne(transportInvoices.status, 'draft'), ne(transportInvoices.status, 'voided'),
    isNull(transportInvoices.efacturaStatus),
  )), [{ cnt: 0 }]),
  safe(db.select({ cnt: sql<number>`COUNT(*)` }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId),
    sql`(${transportInvoices.efacturaStatus} = 'rejected' OR ${transportInvoices.efacturaError} IS NOT NULL)`,
  )), [{ cnt: 0 }]),
  // Aging buckets for overdue receivables (1-15 / 16-30 / 30+ zile).
  safe(db.select({
    b1: sql<number>`COALESCE(SUM(CASE WHEN ${transportInvoices.dueAt} >= ${new Date(now.getTime() - 15 * 86400000)} THEN ${transportInvoices.totalCents} - ${transportInvoices.paidCents} ELSE 0 END),0)`,
    b2: sql<number>`COALESCE(SUM(CASE WHEN ${transportInvoices.dueAt} < ${new Date(now.getTime() - 15 * 86400000)} AND ${transportInvoices.dueAt} >= ${new Date(now.getTime() - 30 * 86400000)} THEN ${transportInvoices.totalCents} - ${transportInvoices.paidCents} ELSE 0 END),0)`,
    b3: sql<number>`COALESCE(SUM(CASE WHEN ${transportInvoices.dueAt} < ${new Date(now.getTime() - 30 * 86400000)} THEN ${transportInvoices.totalCents} - ${transportInvoices.paidCents} ELSE 0 END),0)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId), eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.status} IN ('issued','sent','partial')`, lt(transportInvoices.dueAt, now),
  )), [{ b1: 0, b2: 0, b3: 0 }]),
  // Monthly facturat (current year).
  safe(db.select({
    m: sql<number>`EXTRACT(MONTH FROM ${transportInvoices.issuedAt})`,
    sum: sql<number>`COALESCE(SUM(${transportInvoices.totalCents}),0)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId), eq(transportInvoices.kind, 'factura'),
    gte(transportInvoices.issuedAt, yearStart), ne(transportInvoices.status, 'voided'),
  )).groupBy(sql`EXTRACT(MONTH FROM ${transportInvoices.issuedAt})`), [] as any[]),
  // Monthly încasat (current year) — from invoices.paidCents, the same source the
  // dashboard uses, so "Încasat" matches everywhere (the payments table can be
  // empty when an invoice is marked paid directly).
  safe(db.select({
    m: sql<number>`EXTRACT(MONTH FROM ${transportInvoices.issuedAt})`,
    sum: sql<number>`COALESCE(SUM(${transportInvoices.paidCents}),0)`,
  }).from(transportInvoices).where(and(
    eq(transportInvoices.companyId, companyId), eq(transportInvoices.kind, 'factura'),
    gte(transportInvoices.issuedAt, yearStart), ne(transportInvoices.status, 'voided'),
  )).groupBy(sql`EXTRACT(MONTH FROM ${transportInvoices.issuedAt})`), [] as any[]),
]) : [[{ sum: 0, cnt: 0 }], [{ cnt: 0 }], [{ cnt: 0 }], [{ b1: 0, b2: 0, b3: 0 }], [], []];

// Build 12-month chart series.
const MONTHS = ['Ian', 'Feb', 'Mar', 'Apr', 'Mai', 'Iun', 'Iul', 'Aug', 'Sep', 'Oct', 'Noi', 'Dec'];
const invByMonth = new Map<number, number>(chartInv.map((r: any) => [Number(r.m), Number(r.sum)]));
const payByMonth = new Map<number, number>(chartPay.map((r: any) => [Number(r.m), Number(r.sum)]));
const chartData = MONTHS.map((label, i) => ({ label, fact: invByMonth.get(i + 1) || 0, inc: payByMonth.get(i + 1) || 0 }));
const chartMax = Math.max(1, ...chartData.map((d) => Math.max(d.fact, d.inc)));
const hasChartData = chartData.some((d) => d.fact > 0 || d.inc > 0);
const efNetrimiseCnt = efNetrimise[0]?.cnt ?? 0;
const efEroriCnt = efErori[0]?.cnt ?? 0;
const aging = agingRows[0] ?? { b1: 0, b2: 0, b3: 0 };

function fmtMoney(cents: number, currency: string) {
  return `${(cents / 100).toLocaleString('ro-RO', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ${currency}`;
}
// Compact (no decimals) — for the KPI cards so big numbers fit on one line on mobile.
function fmtMoney0(cents: number, currency = 'RON') {
  return `${Math.round((cents || 0) / 100).toLocaleString('ro-RO')} ${currency}`;
}

const kindLabel: Record<string, string> = {
  factura: 'Factură',
  proforma: 'Proformă',
  storno: 'Storno',
  chitanta: 'Chitanță',
};

const statusTone: Record<string, string> = {
  draft: 'bg-white/10 text-[#9FB8CC]',
  issued: 'bg-[#E8A33C]/15 text-[#E8A33C]',
  sent: 'bg-[#34A0A4]/15 text-[#34A0A4]',
  paid: 'bg-[#2E9E6A]/15 text-[#2E9E6A]',
  partial: 'bg-[#E8A33C]/15 text-[#E8A33C]',
  overdue: 'bg-[#DC4B41]/15 text-[#DC4B41]',
  disputed: 'bg-white/10 text-[#C8DAE8]',
  voided: 'bg-white/10 text-[#7C9AB4]',
  reversed: 'bg-white/10 text-[#7C9AB4]',
};

// Clean text labels — the colored pill + dot (see the badge below) convey the
// status at a glance, no emoji needed.
const statusLabel: Record<string, string> = {
  draft: 'Ciornă',
  issued: 'Emisă',
  sent: 'Trimisă',
  paid: 'Plătită',
  partial: 'Plătită parțial',
  overdue: 'Întârziată',
  disputed: 'Dispută',
  voided: 'Anulată',
  reversed: 'Stornată',
};
---

<AppLayout title="Facturare" activeTab="facturare">
  <!-- Header -->
  <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Facturare</h1>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <a href="/app/facturare/emite?kind=factura" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#0A2238] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">+ Factură</a>
      <a href="/app/facturare/emite?kind=proforma" class="px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">Proformă</a>
      <a href="/app/facturare/emite?kind=chitanta" class="px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">Chitanță</a>
      <a href="/app/facturare/emite?kind=storno" class="px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">Storno</a>
      <a href="/app/facturare/model" title="Designul facturii — șablon, logo, culoare, footer, ștampilă, previzualizare live" class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.9"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 11-4 0v-.09A1.65 1.65 0 008 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H2a2 2 0 110-4h.09A1.65 1.65 0 004 8a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H8a1.65 1.65 0 001-1.51V2a2 2 0 114 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06A1.65 1.65 0 0020 8v.09c.66.16 1.15.74 1.4 1.4"/></svg>
        Personalizează
      </a>
      {hasChartData && (
        <button type="button" id="toggle-chart" aria-expanded="false" class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.9"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 15l3-4 3 3 4-6"/></svg>
          Grafic
        </button>
      )}
    </div>
  </div>

  {!companyId && (
    <div class="rounded-2xl p-4 mb-6 bg-[#E8A33C]/15">
      <p class="text-[13px] text-[#E8A33C]">Ai nevoie de o companie validată pentru a emite facturi. <a href="/app/setari" class="font-semibold text-[#E1FB15] hover:underline">Completează profilul →</a></p>
    </div>
  )}

  <!-- Chart: facturat vs încasat (anul curent) — hidden by default, toggled by the Grafic button -->
  {hasChartData && (
    <div id="facturare-chart" class="hidden rounded-2xl p-5 sm:p-6 bg-white/5 mb-6">
      <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
        <h2 class="text-[18px] font-bold text-white">Facturi și încasări · {now.getFullYear()}</h2>
        <div class="flex gap-4 text-[12px] text-[#9FB8CC]">
          <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-[#34A0A4] inline-block"></span> Facturat</span>
          <span class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-sm bg-[#B5E48C] inline-block"></span> Încasat</span>
        </div>
      </div>
      <div class="flex items-end gap-1.5 h-44">
        {chartData.map((d) => (
          <div class="flex-1 flex flex-col items-center justify-end gap-1">
            <div class="w-full flex items-end justify-center gap-0.5 h-36">
              <div class="w-1/2 bg-[#34A0A4] rounded-t" style={`height: ${Math.max(1, (d.fact / chartMax) * 100)}%`} title={`Facturat: ${fmtMoney(d.fact, 'RON')}`}></div>
              <div class="w-1/2 bg-[#B5E48C] rounded-t" style={`height: ${Math.max(1, (d.inc / chartMax) * 100)}%`} title={`Încasat: ${fmtMoney(d.inc, 'RON')}`}></div>
            </div>
            <span class="text-[9px] text-[#7C9AB4]">{d.label}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Quick links (scrollable chips) -->
  <div class="flex gap-2 overflow-x-auto no-scrollbar -mx-1 px-1 mb-6">
    {[
      { label: 'Produse', href: '/app/facturare/produse' },
      { label: 'Recurente', href: '/app/facturare/recurente' },
      { label: 'Aging', href: '/app/facturare/rapoarte/aging' },
      { label: 'Rapoarte', href: '/app/facturare/rapoarte' },
      { label: 'Setări', href: '/app/facturare/setari' },
    ].map((l) => (
      <a href={l.href} class="shrink-0 px-4 py-2 rounded-full bg-white/5 text-[13px] font-semibold text-[#9FB8CC] hover:text-white hover:bg-white/10 transition-colors">{l.label}</a>
    ))}
  </div>

  <!-- Recent invoices -->
  <h2 class="text-[18px] font-bold text-white mb-3">Facturile recente</h2>
  {recent.length === 0 ? (
    <div class="rounded-2xl p-8 bg-white/5 text-center text-[13px] text-[#9FB8CC]">
      Încă n-ai emis nicio factură.
    </div>
  ) : (
    <Fragment>
    <ul class="space-y-2.5">
      {recent.slice(0, 3).map((inv) => {
        const due = inv.dueAt ? new Date(inv.dueAt) : null;
        const overdue = ['issued', 'sent', 'partial'].includes(inv.status) && due && due < now;
        const effectiveStatus = overdue ? 'overdue' : inv.status;
        return (
          <li>
            <a href={`/app/facturare/${inv.id}`} class="group flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-semibold ${statusTone[effectiveStatus] ?? statusTone.draft}`}>
                    <span class="w-1.5 h-1.5 rounded-full bg-current shrink-0"></span>
                    {statusLabel[effectiveStatus] ?? effectiveStatus}
                  </span>
                  <span class="font-mono text-[12px] text-[#7C9AB4] tabular-nums truncate">{inv.fullNumber}</span>
                </div>
                <p class="text-[15px] text-white font-bold truncate mt-1.5">{inv.clientNameSnap}</p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-[15px] font-bold text-white tabular-nums whitespace-nowrap">{fmtMoney(inv.totalCents, inv.currency)}</p>
                <p class="text-[12px] text-[#7C9AB4] mt-1">{inv.issuedAt ? new Date(inv.issuedAt).toLocaleDateString('ro-RO') : '—'}</p>
              </div>
              <div class="shrink-0 flex flex-col items-end gap-1.5">
                {inv.kind === 'factura' && !['paid', 'voided', 'draft', 'reversed'].includes(inv.status) && (
                  <span class="px-2.5 py-1 rounded-full bg-[#E1FB15] text-[#0A2238] text-[11px] font-bold whitespace-nowrap">Încasează</span>
                )}
                <span class="inline-flex items-center gap-0.5 text-[12px] font-semibold text-[#9FB8CC] group-hover:text-white transition-colors whitespace-nowrap">Detalii<svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
    {recent.length > 3 && (
      <a href="/app/facturare/rapoarte" class="mt-3 mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#0A2238] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate facturile</a>
    )}
    </Fragment>
  )}

  <script is:inline>
    (function () {
      var btn = document.getElementById('toggle-chart');
      var chart = document.getElementById('facturare-chart');
      if (!btn || !chart) return;
      btn.addEventListener('click', function () {
        var show = chart.classList.contains('hidden');
        chart.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(show));
        btn.classList.toggle('bg-white/15', show);
      });
    })();
  </script>
</AppLayout>
