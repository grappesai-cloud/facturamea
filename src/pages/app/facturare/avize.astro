---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { transportInvoices } from '../../../db/schema';
import { and, eq, desc } from 'drizzle-orm';
import EmptyState from '../../../components/ui/EmptyState.astro';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

let rows: any[] = [];
try {
  rows = await db
    .select()
    .from(transportInvoices)
    .where(and(eq(transportInvoices.companyId, companyId), eq(transportInvoices.kind, 'aviz')))
    .orderBy(desc(transportInvoices.createdAt))
    .limit(100);
} catch (e) {
  // DB not provisioned — render empty.
}

const statusLabels: Record<string, { label: string; cls: string }> = {
  draft: { label: 'Ciornă', cls: 'bg-white/10 text-[#A8BED2]' },
  issued: { label: 'Emis', cls: 'bg-[#34A0A4]/15 text-[#34A0A4]' },
  sent: { label: 'Trimis', cls: 'bg-[#34A0A4]/15 text-[#34A0A4]' },
  paid: { label: 'Facturat', cls: 'bg-[#2E9E6A]/15 text-[#2E9E6A]' },
  voided: { label: 'Anulat', cls: 'bg-white/10 text-[#8FA6BC]' },
};
---

<AppLayout title="Avize" activeTab="facturare">
  <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Avize de însoțire</h1>
      <p class="text-[14px] text-[#A8BED2] mt-1 max-w-2xl">Avizele de însoțire a mărfii emise către clienți.</p>
    </div>
    <a href="/app/facturare/emite" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">+ Emite document</a>
  </div>

  {rows.length === 0 ? (
    <EmptyState title="Niciun aviz" description="Emite un aviz de însoțire a mărfii.">
      <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.66-.81H14.25M16.5 18.75h-2.642m-3.6-13.5H3.375c-.621 0-1.125.504-1.125 1.125v9.75m12-9.75v9.75m0-9.75H14.25m2.25 9.75H10.5"/></svg>
      <a slot="action" href="/app/facturare/emite?kind=aviz" class="inline-flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Emite aviz →</a>
    </EmptyState>
  ) : (
    <Fragment>
    <ul class="space-y-2.5">
      {rows.slice(0, 3).map((inv) => {
        const st = statusLabels[inv.status] || statusLabels.draft;
        return (
          <li>
            <a href={`/app/facturare/${inv.id}`} class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-semibold ${st.cls}`}>{st.label}</span>
                  <span class="font-mono text-[12px] text-[#8FA6BC] tabular-nums truncate">{inv.fullNumber}</span>
                </div>
                <p class="text-[15px] text-white font-bold truncate mt-1.5">{inv.clientNameSnap}</p>
              </div>
              <p class="text-[15px] font-bold text-white tabular-nums shrink-0">{ron(inv.totalCents)}</p>
            </a>
          </li>
        );
      })}
    </ul>
    {rows.length > 3 && (
      <details class="mt-2.5">
        <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({rows.length})</summary>
        <ul class="space-y-2.5 mt-2.5">
          {rows.slice(3).map((inv) => {
            const st = statusLabels[inv.status] || statusLabels.draft;
            return (
              <li>
                <a href={`/app/facturare/${inv.id}`} class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2">
                      <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-semibold ${st.cls}`}>{st.label}</span>
                      <span class="font-mono text-[12px] text-[#8FA6BC] tabular-nums truncate">{inv.fullNumber}</span>
                    </div>
                    <p class="text-[15px] text-white font-bold truncate mt-1.5">{inv.clientNameSnap}</p>
                  </div>
                  <p class="text-[15px] font-bold text-white tabular-nums shrink-0">{ron(inv.totalCents)}</p>
                </a>
              </li>
            );
          })}
        </ul>
      </details>
    )}
    </Fragment>
  )}
</AppLayout>
