---
import AppLayout from '../../../layouts/AppLayout.astro';
import TvaRatesManager from '../../../components/invoicing/TvaRatesManager';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="Cote TVA" activeTab="facturare">
  <div class="mb-4">
    <a href="/app/facturare/setari" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la setări facturare</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Cote TVA</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Cotele de TVA pe care le poți selecta în pagina de emitere factură. Cota implicită se aplică automat liniilor noi.</p>

  <div class="max-w-4xl">
    <TvaRatesManager client:load />
  </div>
</AppLayout>
