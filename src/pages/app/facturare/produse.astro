---
import AppLayout from '../../../layouts/AppLayout.astro';
import ProductsManager from '../../../components/invoicing/ProductsManager';
import { db } from '../../../db';
import { invoiceProducts } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
const initial = user.companyId ? await db.select().from(invoiceProducts)
  .where(eq(invoiceProducts.companyId, user.companyId))
  .orderBy(desc(invoiceProducts.updatedAt))
  .limit(200) : [];
---

<AppLayout title="Produse & servicii" activeTab="facturare">
  <div class="mb-6 flex items-start justify-between gap-4 flex-wrap print:hidden">
    <div>
      <p class="th-eyebrow">Facturare</p>
      <h1 class="th-h1 mt-1">Produse & servicii</h1>
      <p class="text-sm text-[#6B6B68] mt-1">Nomenclator reutilizabil pentru linii de factură. Selectează un produs la emitere, prețul și TVA se completează automat.</p>
    </div>
    <a href="/app/facturare" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la facturare</a>
  </div>

  <ProductsManager initial={initial} client:load />
</AppLayout>
