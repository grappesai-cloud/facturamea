---
import AppLayout from '../../../layouts/AppLayout.astro';
import ProductsManager from '../../../components/invoicing/ProductsManager';
import { db } from '../../../db';
import { invoiceProducts } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
const initial = user.companyId ? await db.select().from(invoiceProducts)
  .where(eq(invoiceProducts.companyId, user.companyId))
  .orderBy(desc(invoiceProducts.updatedAt))
  .limit(200) : [];
---

<AppLayout title="Produse & servicii" activeTab="facturare">
  <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 print:hidden">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Produse & servicii</h1>
      <p class="text-[14px] text-[#9FB8CC] mt-1 max-w-2xl">Nomenclator reutilizabil pentru linii de factură. La emitere, prețul și TVA se completează automat.</p>
    </div>
  </div>

  <ProductsManager initial={initial} client:load />
</AppLayout>
