---
import AppLayout from '../../../layouts/AppLayout.astro';
import InvoiceEmitForm from '../../../components/invoicing/InvoiceEmitForm';
import { db } from '../../../db';
import { orders, freight, companies } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');

// e-Factura auto-send default for the "trimite acum" checkbox.
let efacturaAutoSend = false;
try {
  const [co] = await db.select({ auto: companies.efacturaAutoSend }).from(companies).where(eq(companies.id, user.companyId)).limit(1);
  efacturaAutoSend = !!co?.auto;
} catch {}

const kindParam = Astro.url.searchParams.get('kind') || 'factura';
const validKinds = ['factura', 'proforma', 'storno', 'chitanta'] as const;
type Kind = (typeof validKinds)[number];
const kind: Kind = (validKinds as readonly string[]).includes(kindParam) ? (kindParam as Kind) : 'factura';

const orderId = Astro.url.searchParams.get('order') || undefined;
const fromId = Astro.url.searchParams.get('from') || undefined;

// Prefill from an order (emit invoice directly from "Comenzile mele"): route +
// freight price feed into the first line.
let dossierPrefill: { displayId: string; route: string; priceTotal: number | null; currency?: string } | undefined;
if (orderId) {
  const [o] = await db.select().from(orders).where(eq(orders.id, orderId)).limit(1);
  if (o && (o.clientCompanyId === user.companyId || o.carrierCompanyId === user.companyId)) {
    const [f] = o.freightId ? await db.select().from(freight).where(eq(freight.id, o.freightId)).limit(1) : [undefined as any];
    const route = f ? `${f.loadingCityName ?? ''}${f.loadingCountry ? ', ' + f.loadingCountry : ''} → ${f.unloadingCityName ?? ''}${f.unloadingCountry ? ', ' + f.unloadingCountry : ''}` : '';
    dossierPrefill = {
      displayId: o.orderNumber,
      route,
      priceTotal: f?.priceTotal ?? null,
      currency: f?.currency ?? undefined,
    };
  }
}
---

<AppLayout title="Emitere document" activeTab="facturare">
  <div class="max-w-5xl">
    <InvoiceEmitForm kind={kind} orderId={orderId} fromId={fromId} dossierPrefill={dossierPrefill} efacturaAutoSend={efacturaAutoSend} anafConnected={Astro.locals.anafConnected ?? false} client:load />
  </div>
</AppLayout>
