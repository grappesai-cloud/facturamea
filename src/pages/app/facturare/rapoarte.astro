---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { transportInvoices, transportInvoicePayments, invoiceSeries } from '../../../db/schema';
import { and, eq, sql, desc, gte, lte, lt, ilike } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/facturare');
const cid = user.companyId;

const tab = (Astro.url.searchParams.get('tab') as ('facturi' | 'proforma' | 'incasari' | 'spv')) || 'facturi';
const q = Astro.url.searchParams.get('q')?.trim() || '';
const clientFilter = Astro.url.searchParams.get('client')?.trim() || '';
const seriesId = Astro.url.searchParams.get('series') || '';
const statusFilter = Astro.url.searchParams.get('status') || 'toate';

// Oblio-style status filter (the dropdown over "ce fel de facturi").
const STATUS_OPTIONS = [
  { id: 'toate', label: 'Toate facturile' },
  { id: 'nefinalizata', label: 'Nefinalizată' },
  { id: 'anulata', label: 'Anulată' },
  { id: 'termen_depasit', label: 'Termen depășit' },
  { id: 'incasata', label: 'Încasată' },
  { id: 'incasata_partial', label: 'Încasată parțial' },
  { id: 'neincasata', label: 'Neîncasată' },
  { id: 'storno', label: 'Storno' },
  { id: 'netrimise', label: 'Facturi netrimise' },
  { id: 'cu_erori', label: 'Facturi cu erori' },
];

// Date range. Default view = last 30 days (like Oblio/BursaTransport); presets
// for month/year/all, plus a custom interval. `from`/`to` without an explicit
// range = custom.
const rawFrom = Astro.url.searchParams.get('from') || '';
const rawTo = Astro.url.searchParams.get('to') || '';
const range = Astro.url.searchParams.get('range') || ((rawFrom || rawTo) ? 'custom' : '30d');
const isoDate = (d: Date) => d.toISOString().slice(0, 10);
let fromIso = rawFrom;
let toIso = rawTo;
if (range !== 'custom') {
  const now = new Date();
  toIso = isoDate(now);
  if (range === 'month') {
    fromIso = isoDate(new Date(now.getFullYear(), now.getMonth(), 1));
  } else if (range === 'year') {
    fromIso = isoDate(new Date(now.getFullYear(), 0, 1));
  } else if (range === 'all') {
    fromIso = ''; toIso = '';
  } else { // '30d' (and any unknown value)
    const d = new Date(now); d.setDate(d.getDate() - 30);
    fromIso = isoDate(d);
  }
}

const PRESETS = [
  { id: '30d', label: 'Ultimele 30 zile' },
  { id: 'month', label: 'Luna aceasta' },
  { id: 'year', label: 'Anul acesta' },
  { id: 'all', label: 'Tot' },
];
const presetHref = (r: string) =>
  `/app/facturare/rapoarte?tab=${tab}&range=${r}&q=${encodeURIComponent(q)}&client=${encodeURIComponent(clientFilter)}&series=${seriesId}&status=${statusFilter}`;

const seriesAll = await db.select().from(invoiceSeries).where(eq(invoiceSeries.companyId, cid));

async function safe<T>(p: Promise<T>, fb: T): Promise<T> { try { return await p; } catch { return fb; } }

let rows: any[] = [];
let totals = { count: 0, sum: 0, paid: 0 };
const fmt = (cents: number) => (cents / 100).toLocaleString('ro-RO', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

// Monthly buckets for the optional chart (facturi/proforma tabs).
let chart: { label: string; total: number; paid: number }[] = [];

if (tab === 'facturi' || tab === 'proforma') {
  const conds: any[] = [eq(transportInvoices.companyId, cid)];
  // "Storno" status option overrides the kind to show credit notes.
  const kindForTab = statusFilter === 'storno' ? 'storno' : (tab === 'proforma' ? 'proforma' : 'factura');
  conds.push(eq(transportInvoices.kind, kindForTab));
  if (q) conds.push(ilike(transportInvoices.fullNumber, `%${q}%`));
  if (clientFilter) conds.push(ilike(transportInvoices.clientNameSnap, `%${clientFilter}%`));
  if (seriesId) conds.push(eq(transportInvoices.seriesId, seriesId));
  if (fromIso) conds.push(gte(transportInvoices.issuedAt, new Date(fromIso)));
  if (toIso) conds.push(lte(transportInvoices.issuedAt, new Date(toIso + 'T23:59:59')));
  // Status filter (Oblio dropdown).
  const nowDate = new Date();
  switch (statusFilter) {
    case 'nefinalizata': conds.push(eq(transportInvoices.status, 'draft')); break;
    case 'anulata': conds.push(eq(transportInvoices.status, 'voided')); break;
    case 'termen_depasit':
      conds.push(sql`${transportInvoices.status} IN ('issued','sent','partial')`);
      conds.push(lt(transportInvoices.dueAt, nowDate));
      break;
    case 'incasata': conds.push(eq(transportInvoices.status, 'paid')); break;
    case 'incasata_partial': conds.push(eq(transportInvoices.status, 'partial')); break;
    case 'neincasata': conds.push(sql`${transportInvoices.status} IN ('issued','sent')`); break;
    case 'netrimise': conds.push(sql`${transportInvoices.efacturaStatus} IS NULL`); break;
    case 'cu_erori': conds.push(sql`(${transportInvoices.efacturaStatus} = 'rejected' OR ${transportInvoices.efacturaError} IS NOT NULL)`); break;
    // 'toate' and 'storno' → no extra status condition
  }
  rows = await safe(db.select().from(transportInvoices).where(and(...conds)).orderBy(desc(transportInvoices.issuedAt)).limit(500), [] as any[]);
  totals.count = rows.length;
  totals.sum = rows.reduce((a, r) => a + (r.totalCents || 0), 0);
  totals.paid = rows.reduce((a, r) => a + (r.paidCents || 0), 0);

  // Build monthly buckets (chronological) for the chart.
  const byMonth = new Map<string, { total: number; paid: number }>();
  for (const r of rows) {
    if (!r.issuedAt) continue;
    const d = new Date(r.issuedAt);
    const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
    const b = byMonth.get(key) || { total: 0, paid: 0 };
    b.total += r.totalCents || 0;
    b.paid += r.paidCents || 0;
    byMonth.set(key, b);
  }
  chart = [...byMonth.entries()].sort((a, b) => a[0].localeCompare(b[0])).map(([label, v]) => ({ label, ...v }));
} else if (tab === 'incasari') {
  const conds: any[] = [];
  if (fromIso) conds.push(gte(transportInvoicePayments.receivedAt, new Date(fromIso)));
  if (toIso) conds.push(lte(transportInvoicePayments.receivedAt, new Date(toIso + 'T23:59:59')));
  // join cu invoices ca să filtrăm pe companie
  rows = await safe(db.select({
    id: transportInvoicePayments.id,
    invoiceId: transportInvoicePayments.invoiceId,
    amountCents: transportInvoicePayments.amountCents,
    currency: transportInvoicePayments.currency,
    method: transportInvoicePayments.method,
    reference: transportInvoicePayments.reference,
    receivedAt: transportInvoicePayments.receivedAt,
    fullNumber: transportInvoices.fullNumber,
    clientName: transportInvoices.clientNameSnap,
  })
    .from(transportInvoicePayments)
    .innerJoin(transportInvoices, eq(transportInvoices.id, transportInvoicePayments.invoiceId))
    .where(and(eq(transportInvoices.companyId, cid), ...conds))
    .orderBy(desc(transportInvoicePayments.receivedAt))
    .limit(500), [] as any[]);
  totals.count = rows.length;
  totals.sum = rows.reduce((a, r) => a + (r.amountCents || 0), 0);
} else if (tab === 'spv') {
  rows = await safe(db.select().from(transportInvoices).where(and(
    eq(transportInvoices.companyId, cid),
    sql`${transportInvoices.efacturaStatus} IS NOT NULL`,
  )).orderBy(desc(transportInvoices.efacturaSubmittedAt)).limit(500), [] as any[]);
  totals.count = rows.length;
}
---

<AppLayout title="Rapoarte facturare" activeTab="facturare">
  <div class="mb-4">
    <a href="/app/facturare" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la facturare</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-4">Rapoarte facturare</h1>

  <!-- Tabs -->
  <div class="flex gap-2 mb-5 border-b border-[#E8E8E4]">
    {[
      { id: 'facturi', label: 'Facturi' },
      { id: 'proforma', label: 'Proforme' },
      { id: 'incasari', label: 'Încasări' },
      { id: 'spv', label: 'Documente SPV' },
    ].map((t) => (
      <a href={`/app/facturare/rapoarte?tab=${t.id}`}
         class:list={['px-4 py-2.5 text-sm font-medium transition-colors border-b-2',
           tab === t.id ? 'text-[#0A0A0A] border-[#FF5C00]' : 'text-[#6B6B68] hover:text-[#0A0A0A] border-transparent']}>
        {t.label}
      </a>
    ))}
  </div>

  <!-- Quick date presets -->
  <div class="flex flex-wrap gap-2 mb-3">
    {PRESETS.map((p) => (
      <a href={presetHref(p.id)}
         class:list={['px-3 py-1.5 rounded-full text-xs font-semibold border transition-colors',
           range === p.id
             ? 'bg-[#0A0A0A] text-white border-[#0A0A0A]'
             : 'bg-white text-[#3D3D3A] border-[#E8E8E4] hover:bg-[#FAFAF8]']}>
        {p.label}
      </a>
    ))}
    {range === 'custom' && (
      <span class="px-3 py-1.5 rounded-full text-xs font-semibold bg-[#0A0A0A] text-white border border-[#0A0A0A]">Interval custom</span>
    )}
  </div>

  <!-- Filters (sticky on scroll) -->
  <form method="GET" class="mb-4 grid grid-cols-1 md:grid-cols-6 gap-2 items-end sticky top-0 z-20 bg-[#FAFAF8] py-2 border-b border-[#E8E8E4]">
    <input type="hidden" name="tab" value={tab} />
    <input type="hidden" name="range" value="custom" />
    {(tab === 'facturi' || tab === 'proforma') && (
      <>
        <div>
          <label class="text-xs text-[#6B6B68] block mb-1">Caută serie/număr</label>
          <input name="q" value={q} placeholder="ex: TH 0012" class="w-full h-10 px-3 border border-[#E8E8E4] rounded-xl text-sm" />
        </div>
        <div>
          <label class="text-xs text-[#6B6B68] block mb-1">Client</label>
          <input name="client" value={clientFilter} placeholder="nume client" class="w-full h-10 px-3 border border-[#E8E8E4] rounded-xl text-sm" />
        </div>
        <div>
          <label class="text-xs text-[#6B6B68] block mb-1">Serie</label>
          <select name="series" class="w-full h-10 px-3 border border-[#E8E8E4] rounded-xl text-sm">
            <option value="">Toate</option>
            {seriesAll.filter((s) => s.kind === (tab === 'proforma' ? 'proforma' : 'factura')).map((s) => (
              <option value={s.id} selected={seriesId === s.id}>{s.prefix} — {s.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="text-xs text-[#6B6B68] block mb-1">Ce fel de facturi</label>
          <select name="status" class="w-full h-10 px-3 border border-[#E8E8E4] rounded-xl text-sm">
            {STATUS_OPTIONS.map((o) => (
              <option value={o.id} selected={statusFilter === o.id}>{o.label}</option>
            ))}
          </select>
        </div>
      </>
    )}
    <div>
      <label class="text-xs text-[#6B6B68] block mb-1">De la</label>
      <input type="date" name="from" value={fromIso} class="w-full h-10 px-3 border border-[#E8E8E4] rounded-xl text-sm" />
    </div>
    <div>
      <label class="text-xs text-[#6B6B68] block mb-1">Până la</label>
      <input type="date" name="to" value={toIso} class="w-full h-10 px-3 border border-[#E8E8E4] rounded-xl text-sm" />
    </div>
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-[#0A0A0A] text-white rounded-xl text-sm font-semibold">Filtrează</button>
      <a href={`/api/invoicing/reports/export?tab=${tab}&q=${encodeURIComponent(q)}&client=${encodeURIComponent(clientFilter)}&series=${seriesId}&status=${statusFilter}&from=${fromIso}&to=${toIso}`}
         class="px-4 py-2 bg-white border border-[#E8E8E4] rounded-xl text-sm font-medium hover:bg-[#FAFAF8]">⭳ Export CSV</a>
      <a href="/app/facturare/emite?kind=factura" class="px-4 py-2 bg-[#FF5C00] hover:bg-[#E04E00] text-white rounded-xl text-sm font-semibold">+ Factură</a>
    </div>
  </form>

  <!-- Totals strip -->
  <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-4">
    <div class="px-4 py-3 bg-white border border-[#E8E8E4] rounded-xl">
      <p class="text-[10px] uppercase tracking-wider text-[#6B6B68]">Rânduri</p>
      <p class="text-lg font-bold text-[#0A0A0A] tabular-nums">{totals.count}</p>
    </div>
    {tab !== 'spv' && (
      <div class="px-4 py-3 bg-white border border-[#E8E8E4] rounded-xl">
        <p class="text-[10px] uppercase tracking-wider text-[#6B6B68]">{tab === 'incasari' ? 'Total încasat' : 'Total facturat'}</p>
        <p class="text-lg font-bold text-[#0A0A0A] tabular-nums">{fmt(totals.sum)} RON</p>
      </div>
    )}
    {(tab === 'facturi' || tab === 'proforma') && (
      <div class="px-4 py-3 bg-white border border-[#E8E8E4] rounded-xl">
        <p class="text-[10px] uppercase tracking-wider text-[#6B6B68]">Plătit</p>
        <p class="text-lg font-bold text-[#16A34A] tabular-nums">{fmt(totals.paid)} RON</p>
      </div>
    )}
  </div>

  <!-- Optional chart: monthly facturat vs încasat -->
  {(tab === 'facturi' || tab === 'proforma') && chart.length > 1 && (
    <div class="bg-white border border-[#E8E8E4] rounded-xl p-4 mb-4">
      <p class="text-[10px] uppercase tracking-wider text-[#6B6B68] mb-3">Evoluție lunară · facturat vs încasat</p>
      {(() => {
        const max = Math.max(...chart.map((c) => c.total), 1);
        return (
          <div class="flex items-end gap-2 h-40">
            {chart.map((c) => (
              <div class="flex-1 flex flex-col items-center justify-end gap-1 group relative">
                <div class="w-full flex items-end justify-center gap-0.5 h-32">
                  <div class="w-1/2 bg-[#FF5C00] rounded-t" style={`height: ${Math.max(2, (c.total / max) * 100)}%`} title={`Facturat: ${fmt(c.total)} RON`}></div>
                  <div class="w-1/2 bg-[#16A34A] rounded-t" style={`height: ${Math.max(2, (c.paid / max) * 100)}%`} title={`Încasat: ${fmt(c.paid)} RON`}></div>
                </div>
                <span class="text-[9px] text-[#8A8A85] tabular-nums">{c.label.slice(2)}</span>
              </div>
            ))}
          </div>
        );
      })()}
      <div class="flex gap-4 mt-3 text-[11px] text-[#6B6B68]">
        <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-[#FF5C00] inline-block"></span> Facturat</span>
        <span class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-[#16A34A] inline-block"></span> Încasat</span>
      </div>
    </div>
  )}

  <!-- Table -->
  <div class="bg-white border border-[#E8E8E4] rounded-xl overflow-hidden">
    {rows.length === 0 ? (
      <p class="text-center py-10 text-sm text-[#6B6B68]">Niciun rezultat.</p>
    ) : (
      <table class="w-full text-sm">
        {(tab === 'facturi' || tab === 'proforma') && (
          <>
            <thead class="bg-[#FAFAF8]">
              <tr class="text-left text-[10px] uppercase tracking-wider text-[#6B6B68]">
                <th class="py-2 px-3">Serie/nr</th>
                <th class="py-2 px-3">Client</th>
                <th class="py-2 px-3">Data emiterii</th>
                <th class="py-2 px-3">Scadență</th>
                <th class="py-2 px-3 text-right">Total</th>
                <th class="py-2 px-3 text-right">Plătit</th>
                <th class="py-2 px-3">Status</th>
                <th class="py-2 px-3 w-10"></th>
              </tr>
            </thead>
            <tbody>
              {rows.map((r) => (
                <tr class="border-t border-[#FAFAF8] hover:bg-[#FAFAF8]/40">
                  <td class="py-2 px-3 font-mono">{r.fullNumber}</td>
                  <td class="py-2 px-3"><a href={`/app/facturare/${r.id}`} class="text-[#FF5C00] hover:underline">{r.clientNameSnap}</a></td>
                  <td class="py-2 px-3 tabular-nums">{r.issuedAt ? new Date(r.issuedAt).toLocaleDateString('ro-RO') : '—'}</td>
                  <td class="py-2 px-3 tabular-nums">{r.dueAt ? new Date(r.dueAt).toLocaleDateString('ro-RO') : '—'}</td>
                  <td class="py-2 px-3 text-right tabular-nums">{fmt(r.totalCents)} {r.currency}</td>
                  <td class="py-2 px-3 text-right tabular-nums">{fmt(r.paidCents)}</td>
                  <td class="py-2 px-3">{r.status}</td>
                  <td class="py-2 px-3 text-right">
                    <a href={`/app/facturare/${r.id}`} title="Deschide factura" aria-label="Deschide factura" class="inline-flex p-1.5 rounded-xl text-[#6B6B68] hover:bg-[#F0F0EC] hover:text-[#0A0A0A]">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </>
        )}
        {tab === 'incasari' && (
          <>
            <thead class="bg-[#FAFAF8]">
              <tr class="text-left text-[10px] uppercase tracking-wider text-[#6B6B68]">
                <th class="py-2 px-3">Data</th>
                <th class="py-2 px-3">Factură</th>
                <th class="py-2 px-3">Client</th>
                <th class="py-2 px-3">Metodă</th>
                <th class="py-2 px-3">Referință</th>
                <th class="py-2 px-3 text-right">Sumă</th>
              </tr>
            </thead>
            <tbody>
              {rows.map((r) => (
                <tr class="border-t border-[#FAFAF8] hover:bg-[#FAFAF8]/40">
                  <td class="py-2 px-3 tabular-nums">{new Date(r.receivedAt).toLocaleDateString('ro-RO')}</td>
                  <td class="py-2 px-3 font-mono"><a href={`/app/facturare/${r.invoiceId}`} class="text-[#FF5C00] hover:underline">{r.fullNumber}</a></td>
                  <td class="py-2 px-3">{r.clientName}</td>
                  <td class="py-2 px-3">{r.method ?? '—'}</td>
                  <td class="py-2 px-3">{r.reference ?? '—'}</td>
                  <td class="py-2 px-3 text-right tabular-nums">{fmt(r.amountCents)} {r.currency}</td>
                </tr>
              ))}
            </tbody>
          </>
        )}
        {tab === 'spv' && (
          <>
            <thead class="bg-[#FAFAF8]">
              <tr class="text-left text-[10px] uppercase tracking-wider text-[#6B6B68]">
                <th class="py-2 px-3">Factură</th>
                <th class="py-2 px-3">SPV index</th>
                <th class="py-2 px-3">Status SPV</th>
                <th class="py-2 px-3">Trimis la</th>
                <th class="py-2 px-3">Eroare</th>
              </tr>
            </thead>
            <tbody>
              {rows.map((r) => (
                <tr class="border-t border-[#FAFAF8] hover:bg-[#FAFAF8]/40">
                  <td class="py-2 px-3 font-mono"><a href={`/app/facturare/${r.id}`} class="text-[#FF5C00] hover:underline">{r.fullNumber}</a></td>
                  <td class="py-2 px-3 font-mono text-xs">{r.efacturaAnafId ?? '—'}</td>
                  <td class="py-2 px-3">{r.efacturaStatus}</td>
                  <td class="py-2 px-3 tabular-nums">{r.efacturaSubmittedAt ? new Date(r.efacturaSubmittedAt).toLocaleString('ro-RO') : '—'}</td>
                  <td class="py-2 px-3 text-xs text-red-600 truncate max-w-xs">{r.efacturaError ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </>
        )}
      </table>
    )}
  </div>
</AppLayout>
