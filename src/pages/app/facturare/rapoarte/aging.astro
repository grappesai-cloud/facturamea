---
import AppLayout from '../../../../layouts/AppLayout.astro';
import { db } from '../../../../db';
import { transportInvoices } from '../../../../db/schema';
import { and, eq, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
const cid = user.companyId;
const now = new Date();

interface Row {
  clientName: string;
  clientTaxId: string | null;
  bucketCurrent: number;
  bucket30: number;
  bucket60: number;
  bucket90: number;
  bucket90plus: number;
  total: number;
  invoiceCount: number;
}

const rows: Row[] = [];
const totals = { bucketCurrent: 0, bucket30: 0, bucket60: 0, bucket90: 0, bucket90plus: 0, total: 0, invoiceCount: 0 };

if (cid) {
  const open = await db.select().from(transportInvoices).where(and(
    eq(transportInvoices.companyId, cid),
    eq(transportInvoices.kind, 'factura'),
    sql`${transportInvoices.status} IN ('issued','sent','partial')`,
  ));
  const byClient = new Map<string, Row>();
  for (const inv of open) {
    const remaining = inv.totalCents - inv.paidCents;
    if (remaining <= 0) continue;
    const due = inv.dueAt ? new Date(inv.dueAt) : (inv.issuedAt ? new Date(inv.issuedAt) : now);
    const days = Math.floor((now.getTime() - due.getTime()) / 86400000);
    const key = inv.clientTaxIdSnap || inv.clientNameSnap;
    let r = byClient.get(key);
    if (!r) {
      r = { clientName: inv.clientNameSnap, clientTaxId: inv.clientTaxIdSnap,
            bucketCurrent: 0, bucket30: 0, bucket60: 0, bucket90: 0, bucket90plus: 0, total: 0, invoiceCount: 0 };
      byClient.set(key, r);
    }
    if      (days <= 0)  r.bucketCurrent += remaining;
    else if (days <= 30) r.bucket30      += remaining;
    else if (days <= 60) r.bucket60      += remaining;
    else if (days <= 90) r.bucket90      += remaining;
    else                 r.bucket90plus  += remaining;
    r.total += remaining; r.invoiceCount += 1;
  }
  rows.push(...Array.from(byClient.values()).sort((a, b) => b.total - a.total));
  for (const r of rows) {
    totals.bucketCurrent += r.bucketCurrent; totals.bucket30 += r.bucket30;
    totals.bucket60 += r.bucket60; totals.bucket90 += r.bucket90;
    totals.bucket90plus += r.bucket90plus; totals.total += r.total;
    totals.invoiceCount += r.invoiceCount;
  }
}

const fmt = (cents: number) => cents === 0 ? '—' : (cents / 100).toLocaleString('ro-RO', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
---

<AppLayout title="Aging — solduri clienți" activeTab="facturare">
  <div class="mb-6 flex items-start justify-between gap-4 flex-wrap print:hidden">
    <div>
      <p class="th-eyebrow">Facturare · Rapoarte</p>
      <h1 class="th-h1 mt-1">Aging clienți</h1>
      <p class="text-sm text-[#6B6B68] mt-1">Solduri restante grupate pe vechime. Bazat pe data scadenței facturilor neîncasate.</p>
    </div>
    <a href="/app/facturare" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la facturare</a>
  </div>

  <!-- KPI summary -->
  <div class="grid grid-cols-2 md:grid-cols-6 gap-2 mb-6">
    <div class="bg-white border border-[#E8E8E4] rounded-xl p-3">
      <p class="text-[10px] uppercase tracking-wider text-[#8A8A85]">Total restant</p>
      <p class="text-lg font-bold tabular-nums text-[#0A0A0A]">{fmt(totals.total)}</p>
      <p class="text-[10px] text-[#6B6B68]">{totals.invoiceCount} facturi</p>
    </div>
    <div class="bg-white border border-[#E8E8E4] rounded-xl p-3">
      <p class="text-[10px] uppercase tracking-wider text-[#16A34A]">În termen</p>
      <p class="text-lg font-bold tabular-nums">{fmt(totals.bucketCurrent)}</p>
    </div>
    <div class="bg-white border border-[#FEF3C7] rounded-xl p-3">
      <p class="text-[10px] uppercase tracking-wider text-[#B45309]">1-30 zile</p>
      <p class="text-lg font-bold tabular-nums">{fmt(totals.bucket30)}</p>
    </div>
    <div class="bg-white border border-[#FED7AA] rounded-xl p-3">
      <p class="text-[10px] uppercase tracking-wider text-[#9A3412]">31-60 zile</p>
      <p class="text-lg font-bold tabular-nums">{fmt(totals.bucket60)}</p>
    </div>
    <div class="bg-white border border-[#FCA5A5] rounded-xl p-3">
      <p class="text-[10px] uppercase tracking-wider text-[#B91C1C]">61-90 zile</p>
      <p class="text-lg font-bold tabular-nums">{fmt(totals.bucket90)}</p>
    </div>
    <div class="bg-white border border-[#7F1D1D] rounded-xl p-3">
      <p class="text-[10px] uppercase tracking-wider text-[#7F1D1D]">90+ zile</p>
      <p class="text-lg font-bold tabular-nums">{fmt(totals.bucket90plus)}</p>
    </div>
  </div>

  <!-- Aging table -->
  <div class="bg-white border border-[#E8E8E4] rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-[#FAFAF8]">
        <tr class="text-left text-[10px] uppercase tracking-wider text-[#8A8A85]">
          <th class="py-3 px-4">Client</th>
          <th class="py-3 px-4">CUI</th>
          <th class="py-3 px-4 text-right">În termen</th>
          <th class="py-3 px-4 text-right">1-30 z</th>
          <th class="py-3 px-4 text-right">31-60 z</th>
          <th class="py-3 px-4 text-right">61-90 z</th>
          <th class="py-3 px-4 text-right">90+ z</th>
          <th class="py-3 px-4 text-right">Total</th>
          <th class="py-3 px-4 text-right">#</th>
        </tr>
      </thead>
      <tbody>
        {rows.length === 0 && (
          <tr><td colspan="9" class="py-10 text-center text-[#8A8A85]">Niciun sold restant. 🎉</td></tr>
        )}
        {rows.map((r) => (
          <tr class="border-t border-[#F0F0EC]">
            <td class="py-3 px-4 font-medium text-[#0A0A0A]">{r.clientName}</td>
            <td class="py-3 px-4 text-xs text-[#6B6B68] font-mono">{r.clientTaxId ?? '—'}</td>
            <td class="py-3 px-4 text-right tabular-nums text-[#16A34A]">{fmt(r.bucketCurrent)}</td>
            <td class="py-3 px-4 text-right tabular-nums">{fmt(r.bucket30)}</td>
            <td class="py-3 px-4 text-right tabular-nums">{fmt(r.bucket60)}</td>
            <td class="py-3 px-4 text-right tabular-nums">{fmt(r.bucket90)}</td>
            <td class="py-3 px-4 text-right tabular-nums text-[#B91C1C]">{fmt(r.bucket90plus)}</td>
            <td class="py-3 px-4 text-right tabular-nums font-bold">{fmt(r.total)}</td>
            <td class="py-3 px-4 text-right text-[#6B6B68]">{r.invoiceCount}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AppLayout>
