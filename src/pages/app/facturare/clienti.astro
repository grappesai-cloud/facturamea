---
import AppLayout from '../../../layouts/AppLayout.astro';
import ClientsManager from '../../../components/invoicing/ClientsManager';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="Clienți" activeTab="facturare">
  <div class="mb-4">
    <a href="/app/facturare/setari" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la setări facturare</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Clienți</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Clienții externi (din afara platformei) către care emiți facturi. Pentru clienții facturamea, datele se preiau automat la emitere.</p>

  <div class="max-w-5xl">
    <ClientsManager client:load />
  </div>
</AppLayout>
