---
import AppLayout from '../../../layouts/AppLayout.astro';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');

// Languages available for the issued PDF document. Chosen per-invoice in the
// emit form (câmpul "Limbă"); the document template translates labels.
const LANGS = [
  { code: 'ro', name: 'Română', note: 'Limbă implicită', sample: 'Factură · Cumpărător · Total de plată' },
  { code: 'en', name: 'English', note: 'Pentru clienți externi', sample: 'Invoice · Buyer · Amount due' },
];
---

<AppLayout title="Limbi" activeTab="facturare">
  <div class="mb-8">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Limbi</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">Limba documentului PDF se alege la emitere, în câmpul „Limbă”. Etichetele se traduc automat.</p>
  </div>

  <ul class="max-w-3xl space-y-2.5">
    {LANGS.map((l) => (
      <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
        <span class="font-mono text-[11px] px-2 py-1 bg-white/10 text-[#A8BED2] rounded-lg uppercase">{l.code}</span>
        <div class="flex-1 min-w-0">
          <p class="text-[14px] font-bold text-white">{l.name}</p>
          <p class="text-[12px] text-[#A8BED2]">{l.sample}</p>
        </div>
        <span class="text-[12px] text-[#8FA6BC] shrink-0">{l.note}</span>
      </li>
    ))}
  </ul>
</AppLayout>
