---
import PrintLayout from '../../../../layouts/PrintLayout.astro';
import InvoiceDocument from '../../../../components/invoicing/InvoiceDocument.astro';
import { db } from '../../../../db';
import { transportInvoices, transportInvoiceLines, companies, invoiceModels } from '../../../../db/schema';
import { eq, asc } from 'drizzle-orm';
import QRCode from 'qrcode';

const user = Astro.locals.user!;
const id = Astro.params.id!;

const [invRow] = await db.select().from(transportInvoices).where(eq(transportInvoices.id, id)).limit(1);
if (!invRow || invRow.companyId !== user.companyId) {
  return new Response('Factură inexistentă', { status: 404 });
}

const lines = await db.select().from(transportInvoiceLines).where(eq(transportInvoiceLines.invoiceId, id)).orderBy(asc(transportInvoiceLines.position));
const [issuer] = await db.select().from(companies).where(eq(companies.id, invRow.companyId)).limit(1);
const [model] = invRow.modelId ? await db.select().from(invoiceModels).where(eq(invoiceModels.id, invRow.modelId)).limit(1) : [null];

const inv = { ...invRow, shippingText: null as string | null };

const kindLabel: Record<string, string> = { factura: 'Factură fiscală', proforma: 'Factură proformă', storno: 'Factură storno', chitanta: 'Chitanță' };

// QR (when the model enables it): encodes the public share link if present,
// else a compact reference payload.
let qrDataUrl: string | null = null;
if (model?.showQr) {
  const baseUrl = import.meta.env.PUBLIC_BASE_URL || process.env.PUBLIC_BASE_URL || 'https://facturamea.com';
  const payload = inv.shareToken
    ? `${baseUrl}/factura/${inv.shareToken}`
    : `${inv.fullNumber} | ${issuer?.name ?? ''} | ${(inv.totalCents / 100).toFixed(2)} ${inv.currency}`;
  qrDataUrl = await QRCode.toDataURL(payload, { margin: 1, width: 192 }).catch(() => null);
}
---

<PrintLayout title={`${kindLabel[inv.kind] ?? 'Document'} ${inv.fullNumber}`}>
  <InvoiceDocument inv={inv} lines={lines} issuer={issuer} model={model} qrDataUrl={qrDataUrl} />
</PrintLayout>
