---
import PrintLayout from '../../../../layouts/PrintLayout.astro';
import InvoiceDocument from '../../../../components/invoicing/InvoiceDocument.astro';
import { db } from '../../../../db';
import { transportInvoices, transportInvoiceLines, invoiceModels, orders, freight } from '../../../../db/schema';
import { eq, asc } from 'drizzle-orm';
import { loadIssuer } from '../../../../lib/invoicing';

const user = Astro.locals.user!;
const id = Astro.params.id!;

const [invRow] = await db.select().from(transportInvoices).where(eq(transportInvoices.id, id)).limit(1);
if (!invRow || invRow.companyId !== user.companyId) return Astro.redirect('/app/facturare');

const lines = await db.select().from(transportInvoiceLines).where(eq(transportInvoiceLines.invoiceId, id)).orderBy(asc(transportInvoiceLines.position));
const issuer = await loadIssuer(invRow.companyId);
const [model] = invRow.modelId ? await db.select().from(invoiceModels).where(eq(invoiceModels.id, invRow.modelId)).limit(1) : [null];

// Shipping details from the linked order (for the "date privind expediția" box).
let shippingText: string | null = null;
if (invRow.orderId) {
  const [o] = await db.select().from(orders).where(eq(orders.id, invRow.orderId)).limit(1);
  if (o) {
    const [f] = o.freightId ? await db.select().from(freight).where(eq(freight.id, o.freightId)).limit(1) : [null];
    const route = f ? `${f.loadingCityName ?? ''}${f.loadingCountry ? ', ' + f.loadingCountry : ''} → ${f.unloadingCityName ?? ''}${f.unloadingCountry ? ', ' + f.unloadingCountry : ''}` : '';
    shippingText = [route, o.vehiclePlate ? `Auto: ${o.vehiclePlate}` : '', o.driverName ? `Șofer: ${o.driverName}` : ''].filter(Boolean).join(' · ') || null;
  }
}
const inv = { ...invRow, shippingText };

const kindLabel: Record<string, string> = { factura: 'Factură fiscală', proforma: 'Factură proformă', storno: 'Factură storno', chitanta: 'Chitanță' };
---

<PrintLayout title={`${kindLabel[inv.kind] ?? 'Document'} ${inv.fullNumber}`}>
  <InvoiceDocument inv={inv} lines={lines} issuer={issuer} model={model} />
  <script is:inline>
    // When reached via the "PDF" button fallback, open the print dialog so the
    // user can Save as PDF directly.
    if (new URLSearchParams(location.search).get('autoprint') === '1') {
      window.addEventListener('load', () => setTimeout(() => window.print(), 400));
    }
  </script>
</PrintLayout>
