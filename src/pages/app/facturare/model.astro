---
import AppLayout from '../../../layouts/AppLayout.astro';
import ModelEditor from '../../../components/invoicing/ModelEditor';
import InvoicingSettings from '../../../components/invoicing/InvoicingSettings';
import { db } from '../../../db';
import { companies } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');

const [c] = await db.select({
  invoiceLogoUrl: companies.invoiceLogoUrl,
  invoiceStampUrl: companies.invoiceStampUrl,
  invoiceSignatureUrl: companies.invoiceSignatureUrl,
  invoiceFooterText: companies.invoiceFooterText,
  tvaAtCollection: companies.tvaAtCollection,
}).from(companies).where(eq(companies.id, user.companyId));
---

<AppLayout title="Design factură" activeTab="facturare">
  <div class="mb-8">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Design factură</h1>
    <p class="text-[14px] text-[#A8BED2] mt-1">Tot ce ține de aspectul facturilor, într-un singur loc — șablon, culoare, logo, footer, ștampilă și semnătură. Vezi schimbările în timp real și salvează designuri pe care le poți refolosi.</p>
  </div>

  <div class="max-w-6xl space-y-10">
    <!-- Design (per-template, with live preview + saved designs) -->
    <ModelEditor client:load />

    <!-- Company assets shared by all designs -->
    <section>
      <h2 class="text-[18px] font-bold text-white mb-1">Ștampilă, semnătură & regim TVA</h2>
      <p class="text-[13px] text-[#A8BED2] mb-4">Acestea se aplică pe toate designurile.</p>
      <InvoicingSettings initial={c || { invoiceLogoUrl: null, invoiceStampUrl: null, invoiceSignatureUrl: null, invoiceFooterText: null, tvaAtCollection: false }} client:load />
    </section>
  </div>
</AppLayout>
