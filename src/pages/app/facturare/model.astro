---
import AppLayout from '../../../layouts/AppLayout.astro';
import ModelEditor from '../../../components/invoicing/ModelEditor';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="Model factură" activeTab="facturare">
  <div class="mb-4">
    <a href="/app/facturare" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la facturare</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Model PDF factură</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Personalizează cum arată documentele PDF emise — aspect, culoare brand, logo, footer.</p>
  <div class="max-w-6xl">
    <ModelEditor client:load />
  </div>
</AppLayout>
