---
import AppLayout from '../../../layouts/AppLayout.astro';
import SeriesManager from '../../../components/invoicing/SeriesManager';
import InvoicingSettings from '../../../components/invoicing/InvoicingSettings';
import { db } from '../../../db';
import { companies } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');

const [c] = await db.select({
  invoiceLogoUrl: companies.invoiceLogoUrl,
  invoiceStampUrl: companies.invoiceStampUrl,
  invoiceSignatureUrl: companies.invoiceSignatureUrl,
  invoiceFooterText: companies.invoiceFooterText,
  tvaAtCollection: companies.tvaAtCollection,
}).from(companies).where(eq(companies.id, user.companyId));
---

<AppLayout title="Setări facturare" activeTab="facturare">
  <div class="mb-4">
    <a href="/app/facturare" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la facturare</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Setări facturare</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Branding, regim TVA, serii de documente, cote TVA, clienți și model factură.</p>

  <!-- Quick links to the dedicated nomenclatoare pages (Oblio-style) -->
  <div class="max-w-4xl grid grid-cols-2 md:grid-cols-5 gap-3 mb-8">
    <a href="/app/facturare/tva" class="th-card hover:bg-[#FAFAF8] transition-colors text-center py-4">
      <p class="text-sm font-semibold text-[#0A0A0A]">Cote TVA</p>
      <p class="text-[11px] text-[#6B6B68] mt-0.5">Normală, scutită...</p>
    </a>
    <a href="/app/facturare/clienti" class="th-card hover:bg-[#FAFAF8] transition-colors text-center py-4">
      <p class="text-sm font-semibold text-[#0A0A0A]">Clienți</p>
      <p class="text-[11px] text-[#6B6B68] mt-0.5">Clienți externi</p>
    </a>
    <a href="/app/facturare/produse" class="th-card hover:bg-[#FAFAF8] transition-colors text-center py-4">
      <p class="text-sm font-semibold text-[#0A0A0A]">Produse</p>
      <p class="text-[11px] text-[#6B6B68] mt-0.5">Catalog servicii</p>
    </a>
    <a href="/app/facturare/model" class="th-card hover:bg-[#FAFAF8] transition-colors text-center py-4">
      <p class="text-sm font-semibold text-[#0A0A0A]">Model factură</p>
      <p class="text-[11px] text-[#6B6B68] mt-0.5">Aspect PDF</p>
    </a>
    <a href="/app/facturare/limbi" class="th-card hover:bg-[#FAFAF8] transition-colors text-center py-4">
      <p class="text-sm font-semibold text-[#0A0A0A]">Limbi</p>
      <p class="text-[11px] text-[#6B6B68] mt-0.5">RO · EN</p>
    </a>
  </div>

  <div class="max-w-4xl space-y-8">
    <section>
      <h2 class="text-lg font-bold text-[#0A0A0A] mb-3">Branding & regim TVA</h2>
      <InvoicingSettings initial={c || { invoiceLogoUrl: null, invoiceStampUrl: null, invoiceSignatureUrl: null, invoiceFooterText: null, tvaAtCollection: false }} client:load />
    </section>

    <section>
      <h2 class="text-lg font-bold text-[#0A0A0A] mb-3">Serii de documente</h2>
      <p class="text-sm text-[#6B6B68] mb-4">Câte o serie pe tip (factură / proformă / storno / chitanță). Poți avea mai multe — o serie pentru comenzi TH și una pentru clienți externi.</p>
      <SeriesManager client:load />
    </section>
  </div>
</AppLayout>
