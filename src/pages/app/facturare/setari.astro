---
import AppLayout from '../../../layouts/AppLayout.astro';
import SeriesManager from '../../../components/invoicing/SeriesManager';
import ModelEditor from '../../../components/invoicing/ModelEditor';
import InvoicingSettings from '../../../components/invoicing/InvoicingSettings';
import { db } from '../../../db';
import { companies } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');

// Company assets shared by all designs (from the old model.astro page).
const [c] = await db.select({
  invoiceLogoUrl: companies.invoiceLogoUrl,
  invoiceStampUrl: companies.invoiceStampUrl,
  invoiceSignatureUrl: companies.invoiceSignatureUrl,
  invoiceFooterText: companies.invoiceFooterText,
  tvaAtCollection: companies.tvaAtCollection,
}).from(companies).where(eq(companies.id, user.companyId));

// Hub cards. Each maps to a panel id + the old #anchor so legacy links keep working.
// (Language is chosen per document at emit time, so there's no language setting here.)
const SECTIONS = [
  { id: 'serii', anchor: 'serii', title: 'Serii documente', desc: 'Factură, proformă, storno, chitanță — numerotarea ta.', icon: 'hash' },
  { id: 'model', anchor: 'model', title: 'Design factură', desc: 'Șablon, culoare, logo, ștampilă și semnătură.', icon: 'palette' },
];
---

<AppLayout title="Setări facturare" activeTab="facturare">
  <div class="max-w-3xl mx-auto" id="setari-root">
    <!-- ============ HEADER ============ -->
    <div class="mb-8 sm:mb-10">
      <h1 class="text-[26px] sm:text-[38px] font-semibold tracking-[-0.03em] text-white">Setări facturare</h1>
      <p class="text-[14px] text-[#A8BED2] mt-2 max-w-2xl">Serii de documente și designul facturii — alege ce vrei să configurezi.</p>
    </div>

    <!-- ============ OVERVIEW / HUB ============ -->
    <section data-panel="overview" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
        {SECTIONS.map((s) => (
          <button
            type="button"
            data-goto={s.id}
            class="group text-left flex items-center gap-4 rounded-2xl bg-white/5 ring-1 ring-white/10 hover:ring-white/25 hover:bg-white/[0.07] transition-all p-5 sm:p-6"
          >
            <span class="shrink-0 w-11 h-11 rounded-xl bg-[#E1FB15]/10 ring-1 ring-[#E1FB15]/20 grid place-items-center text-[#E1FB15]" data-icon={s.icon}>
              {s.icon === 'hash' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
              )}
              {s.icon === 'percent' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
              )}
              {s.icon === 'globe' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              )}
              {s.icon === 'palette' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
              )}
            </span>
            <span class="flex-1 min-w-0">
              <span class="block text-[15px] sm:text-[16px] font-bold text-white">{s.title}</span>
              <span class="block text-[12.5px] text-[#8FA6BC] mt-0.5 leading-snug">{s.desc}</span>
            </span>
            <svg class="shrink-0 text-[#8FA6BC] group-hover:text-white group-hover:translate-x-0.5 transition-all" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        ))}
      </div>
    </section>

    <!-- ============ SECTION PANELS ============ -->
    {SECTIONS.map((s) => (
      <section data-panel={s.id} id={s.anchor} hidden class="scroll-mt-24">
        <!-- Sub-header with back to overview -->
        <button type="button" data-back class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-[#A8BED2] hover:text-white transition-colors mb-6">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          Toate setările
        </button>

        {s.id === 'serii' && (
          <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 sm:p-8">
            <h2 class="text-[18px] font-bold text-white mb-1.5">Serii de documente</h2>
            <p class="text-[13px] text-[#A8BED2] mb-7 max-w-2xl leading-relaxed">Câte o serie pe tip (factură / proformă / storno / chitanță). Poți avea mai multe — una pentru comenzi TH și una pentru clienți externi.</p>
            <SeriesManager client:load />
          </div>
        )}



        {s.id === 'model' && (
          <div class="space-y-6">
            <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 sm:p-8">
              <h2 class="text-[18px] font-bold text-white mb-1.5">Design factură</h2>
              <p class="text-[13px] text-[#A8BED2] mb-7 max-w-2xl leading-relaxed">Tot ce ține de aspectul facturilor — șablon, culoare, logo, footer, ștampilă și semnătură. Vezi schimbările în timp real și salvează designuri pe care le poți refolosi.</p>
              <ModelEditor client:load />
            </div>
            <!-- Company assets shared by all designs -->
            <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-6 sm:p-8">
              <h3 class="text-[16px] font-bold text-white mb-1.5">Ștampilă, semnătură & regim TVA</h3>
              <p class="text-[13px] text-[#A8BED2] mb-6 max-w-2xl leading-relaxed">Acestea se aplică pe toate designurile.</p>
              <InvoicingSettings initial={c || { invoiceLogoUrl: null, invoiceStampUrl: null, invoiceSignatureUrl: null, invoiceFooterText: null, tvaAtCollection: false }} client:load />
            </div>
          </div>
        )}
      </section>
    ))}
  </div>

  <script is:inline>
    (function () {
      const root = document.getElementById('setari-root');
      if (!root) return;
      const panels = Array.from(root.querySelectorAll('[data-panel]'));
      const ids = panels.map((p) => p.getAttribute('data-panel'));

      function show(id) {
        const target = ids.includes(id) ? id : 'overview';
        panels.forEach((p) => { p.hidden = p.getAttribute('data-panel') !== target; });
        // Keep the URL hash in sync so deep-links / refresh land on the same panel.
        if (target === 'overview') {
          if (location.hash) history.replaceState(null, '', location.pathname + location.search);
        } else if (location.hash.slice(1) !== target) {
          history.replaceState(null, '', '#' + target);
        }
        window.scrollTo({ top: 0, behavior: 'auto' });
      }

      root.querySelectorAll('[data-goto]').forEach((btn) => {
        btn.addEventListener('click', () => show(btn.getAttribute('data-goto')));
      });
      root.querySelectorAll('[data-back]').forEach((btn) => {
        btn.addEventListener('click', () => show('overview'));
      });
      window.addEventListener('hashchange', () => show(location.hash.slice(1)));

      // Initial: respect #anchor (legacy links) else show the overview hub.
      show(location.hash.slice(1));
    })();
  </script>

  <style is:global>
    /* The live invoice preview (InvoicePreview.tsx) is paper — always a white
       sheet with dark ink, in BOTH the dark and light app themes. We out-specify
       the global dark-mode overrides in BaseLayout/AppLayout (including the
       inline-style catch-all `html.th-dark [style*="background:#fff"]`) by
       doubling the class so the sheet wins regardless of theme. */
    .fm-invoice-paper,
    html.th-dark .fm-invoice-paper.fm-invoice-paper,
    html.th-app-dark .fm-invoice-paper.fm-invoice-paper,
    html.th-light .fm-invoice-paper.fm-invoice-paper {
      background: #ffffff !important;
      color: #07090f !important;
      color-scheme: light;
    }
    /* Keep ink on every descendant unless it carries its own inline colour
       (inline styles outrank this selector, so coloured bands/totals/white text
       are untouched). */
    html.th-dark .fm-invoice-paper.fm-invoice-paper *:not([style*="color"]),
    html.th-app-dark .fm-invoice-paper.fm-invoice-paper *:not([style*="color"]),
    html.th-light .fm-invoice-paper.fm-invoice-paper *:not([style*="color"]) {
      color: #07090f;
    }
  </style>
</AppLayout>
