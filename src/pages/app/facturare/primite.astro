---
import AppLayout from '../../../layouts/AppLayout.astro';
import InboxManager from '../../../components/anaf/InboxManager';
import { db } from '../../../db';
import { efacturaInbox } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { getAnafStatus } from '../../../lib/anaf/tokens';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const anaf = await getAnafStatus(companyId).catch(() => ({ connected: false, cif: null as string | null }));

let rows: any[] = [];
try {
  rows = await db.select().from(efacturaInbox)
    .where(eq(efacturaInbox.companyId, companyId))
    .orderBy(desc(efacturaInbox.receivedAt), desc(efacturaInbox.createdAt))
    .limit(300);
} catch (e) { /* DB not provisioned */ }
---

<AppLayout title="Facturi primite" activeTab="primite">
  <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Facturi primite</h1>
      <p class="text-[14px] text-[#9FB8CC] mt-1">Adu facturile de la furnizori din SPV și importă-le ca cheltuieli.</p>
    </div>
    <a href="/app/setari/integrari-anaf" title={anaf.connected ? 'ANAF conectat' : 'Conectează ANAF'}
      class:list={['inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-[14px] font-semibold transition-colors', anaf.connected ? 'bg-[#2E9E6A]/15 text-[#2E9E6A]' : 'bg-white/10 text-white hover:bg-white/15']}>
      <span class:list={['w-2.5 h-2.5 rounded-full', anaf.connected ? 'bg-[#2E9E6A]' : 'bg-[#7C9AB4]']}></span>
      ANAF: {anaf.connected ? `conectat${anaf.cif ? ' · CIF ' + anaf.cif : ''}` : 'neconectat'}
    </a>
  </div>

  {!anaf.connected && (
    <div class="mb-6 flex flex-wrap items-center gap-3 rounded-2xl px-4 py-3 bg-[#E8A33C]/15">
      <span class="w-2 h-2 rounded-full bg-[#E8A33C]"></span>
      <p class="text-[14px] text-[#E8A33C]">Pentru a aduce facturile primite, conectează firma la ANAF din <strong>Setări → Integrare ANAF</strong>.</p>
      <a href="/app/setari/integrari-anaf" class="text-[14px] font-semibold text-[#E1FB15] hover:underline ml-auto">Conectează →</a>
    </div>
  )}

  <InboxManager initialRows={rows} connected={anaf.connected} client:load />
</AppLayout>
