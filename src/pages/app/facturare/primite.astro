---
import AppLayout from '../../../layouts/AppLayout.astro';
import InboxManager from '../../../components/anaf/InboxManager';
import { db } from '../../../db';
import { efacturaInbox } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { getAnafStatus } from '../../../lib/anaf/tokens';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const anaf = await getAnafStatus(companyId).catch(() => ({ connected: false, cif: null as string | null }));

let rows: any[] = [];
try {
  rows = await db.select().from(efacturaInbox)
    .where(eq(efacturaInbox.companyId, companyId))
    .orderBy(desc(efacturaInbox.receivedAt), desc(efacturaInbox.createdAt))
    .limit(300);
} catch (e) { /* DB not provisioned */ }
---

<AppLayout title="Facturi primite" activeTab="primite">
  <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Facturi primite (e-Factura)</h1>
      <p class="text-[15px] text-[#6B6B68] mt-1">Adu facturile primite de la furnizori din SPV și importă-le ca cheltuieli.</p>
    </div>
    <a href="/app/setari/integrari-anaf" title={anaf.connected ? 'ANAF conectat' : 'Conectează ANAF'}
      class:list={['inline-flex items-center gap-2 px-3.5 h-11 rounded-xl border text-[14px] font-semibold', anaf.connected ? 'bg-[#E7F7EC] border-[#15803D]/30 text-[#15803D]' : 'bg-white border-[#E0E0DA] text-[#6B6B68] hover:border-[#0A0A0A]']}>
      <span class:list={['w-2.5 h-2.5 rounded-full', anaf.connected ? 'bg-[#15803D]' : 'bg-[#C4C4BE]']}></span>
      ANAF: {anaf.connected ? `conectat${anaf.cif ? ' · CIF ' + anaf.cif : ''}` : 'neconectat'}
    </a>
  </div>

  {!anaf.connected && (
    <div class="mb-4 flex flex-wrap items-center gap-3 px-4 py-3 bg-[#FFF3E9] border border-[#FF5C00]/25 rounded-xl">
      <span class="w-2 h-2 rounded-full bg-[#FF5C00]"></span>
      <p class="text-[14px] text-[#0A0A0A]">Pentru a aduce facturile primite, conectează firma la ANAF din <strong>Setări → Integrare ANAF</strong>.</p>
      <a href="/app/setari/integrari-anaf" class="text-[14px] font-semibold text-[#FF5C00] hover:underline ml-auto">Conectează →</a>
    </div>
  )}

  <InboxManager initialRows={rows} connected={anaf.connected} client:load />
</AppLayout>
