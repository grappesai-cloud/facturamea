---
// Accountant cockpit — one screen across ALL the companies the user belongs to.
// Pure aggregation on our own Postgres (one grouped query per data source), zero
// external calls. Shows a per-firm traffic light of what needs attention so an
// accountant managing many clients sees the whole book at a glance.
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { userCompanyMemberships, companies, transportInvoices, expenses, bankTransactions, efacturaInbox, anafConnections } from '../../../db/schema';
import { and, eq, gt, inArray, isNull, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
const activeCompanyId = Astro.locals.company?.id ?? null;

// All companies this user is a member of.
const memberships = await db
  .select({
    companyId: userCompanyMemberships.companyId,
    name: companies.name,
    cui: companies.cui,
    role: userCompanyMemberships.role,
  })
  .from(userCompanyMemberships)
  .innerJoin(companies, eq(companies.id, userCompanyMemberships.companyId))
  .where(eq(userCompanyMemberships.userId, user.id))
  .orderBy(companies.name);

const ids = memberships.map((m) => m.companyId);

type Agg = Record<string, number>;
const empty: Agg = {};
const num = (v: unknown) => Number(v ?? 0) || 0;

// Each source is a single GROUP BY company_id query over only this user's firms.
let inv: Agg = empty, exp: Agg = empty, bank: Agg = empty, inbox: Agg = empty;
const anafOk = new Set<string>();

if (ids.length) {
  try {
    const rows = await db.select({
      companyId: transportInvoices.companyId,
      overdue: sql<number>`count(*) FILTER (WHERE ${transportInvoices.status} = 'overdue' OR (${transportInvoices.status} IN ('issued','sent','partial') AND ${transportInvoices.dueAt} < now()))`,
    }).from(transportInvoices)
      .where(and(inArray(transportInvoices.companyId, ids), eq(transportInvoices.kind, 'factura')))
      .groupBy(transportInvoices.companyId);
    inv = {}; for (const row of rows) inv[row.companyId] = num(row.overdue);
  } catch { /* leave zero */ }

  try {
    const rows = await db.select({
      companyId: expenses.companyId,
      unclassified: sql<number>`count(*) FILTER (WHERE ${expenses.category} IS NULL)`,
    }).from(expenses)
      .where(inArray(expenses.companyId, ids))
      .groupBy(expenses.companyId);
    exp = {}; for (const row of rows) exp[row.companyId] = num(row.unclassified);
  } catch { /* leave zero */ }

  try {
    const rows = await db.select({
      companyId: bankTransactions.companyId,
      unreconciled: sql<number>`count(*) FILTER (WHERE ${bankTransactions.reconciled} = false)`,
    }).from(bankTransactions)
      .where(inArray(bankTransactions.companyId, ids))
      .groupBy(bankTransactions.companyId);
    bank = {}; for (const row of rows) bank[row.companyId] = num(row.unreconciled);
  } catch { /* leave zero */ }

  try {
    const rows = await db.select({
      companyId: efacturaInbox.companyId,
      inboxNew: sql<number>`count(*) FILTER (WHERE ${efacturaInbox.status} = 'nou')`,
    }).from(efacturaInbox)
      .where(inArray(efacturaInbox.companyId, ids))
      .groupBy(efacturaInbox.companyId);
    inbox = {}; for (const row of rows) inbox[row.companyId] = num(row.inboxNew);
  } catch { /* leave zero */ }

  try {
    const rows = await db.select({ companyId: anafConnections.companyId })
      .from(anafConnections)
      .where(and(
        inArray(anafConnections.companyId, ids),
        inArray(anafConnections.scope, ['e-factura', 'spv']),
        isNull(anafConnections.revokedAt),
        gt(anafConnections.refreshExpiresAt, new Date()),
      ))
      .groupBy(anafConnections.companyId);
    for (const row of rows) anafOk.add(row.companyId);
  } catch { /* leave empty */ }
}

const ROLE_LABEL: Record<string, string> = { owner: 'Administrator', accountant: 'Contabil', operator: 'Operator', viewer: 'Vizualizare', admin: 'Administrator', member: 'Membru' };

const cards = memberships.map((m) => {
  const overdue = inv[m.companyId] || 0;
  const unclassified = exp[m.companyId] || 0;
  const unreconciled = bank[m.companyId] || 0;
  const inboxNew = inbox[m.companyId] || 0;
  const anaf = anafOk.has(m.companyId);
  const attention = overdue + unclassified + unreconciled + inboxNew;
  const tone = (!anaf || overdue > 0) ? 'red' : attention > 0 ? 'amber' : 'green';
  return { ...m, overdue, unclassified, unreconciled, inboxNew, anaf, attention, tone };
});

// Most-attention first; disconnected/overdue (red) float up, then amber by load, green last.
const order = { red: 0, amber: 1, green: 2 } as Record<string, number>;
cards.sort((a, b) => (order[a.tone] - order[b.tone]) || (b.attention - a.attention) || a.name.localeCompare(b.name));

const totals = cards.reduce((t, c) => ({
  needAttention: t.needAttention + (c.tone !== 'green' ? 1 : 0),
  inbox: t.inbox + c.inboxNew, bank: t.bank + c.unreconciled,
  exp: t.exp + c.unclassified, overdue: t.overdue + c.overdue,
}), { needAttention: 0, inbox: 0, bank: 0, exp: 0, overdue: 0 });

// Next statutory VAT deadline (25th of the month; rolls to next month after the 25th).
const today = new Date();
const dl = new Date(today.getFullYear(), today.getMonth(), 25);
if (today.getDate() > 25) dl.setMonth(dl.getMonth() + 1);
const daysToDl = Math.ceil((dl.getTime() - today.getTime()) / 86400000);
const dlStr = dl.toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', timeZone: 'Europe/Bucharest' });

const DOT: Record<string, string> = { red: 'bg-[#DC4B41]', amber: 'bg-[#E8A33C]', green: 'bg-[#2E9E6A]' };
---

<AppLayout title="Cockpit firme" activeTab="cockpit">
  <div class="mb-6">
    <h1 class="text-[30px] sm:text-[38px] font-semibold tracking-[-0.03em] text-white">Cockpit</h1>
    <p class="mt-1.5 text-[15px] text-[#7E97AC]">Toate firmele tale, într-o privire. {cards.length} {cards.length === 1 ? 'firmă' : 'firme'}.</p>
  </div>

  {cards.length === 0 ? (
    <div class="rounded-2xl bg-white/5 p-10 text-center text-[15px] text-[#7E97AC]">Nu ești membru în nicio firmă încă.</div>
  ) : (
    <>
      <!-- Roll-up strip -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
        <div class="rounded-2xl bg-white/5 p-4">
          <p class="text-[12px] uppercase tracking-wider text-[#7E97AC]">Firme de atenționat</p>
          <p class="mt-1 text-[26px] font-bold tabular-nums text-white">{totals.needAttention}</p>
        </div>
        <div class="rounded-2xl bg-white/5 p-4">
          <p class="text-[12px] uppercase tracking-wider text-[#7E97AC]">e-Facturi de importat</p>
          <p class="mt-1 text-[26px] font-bold tabular-nums text-white">{totals.inbox}</p>
        </div>
        <div class="rounded-2xl bg-white/5 p-4">
          <p class="text-[12px] uppercase tracking-wider text-[#7E97AC]">Bancă nereconciliată</p>
          <p class="mt-1 text-[26px] font-bold tabular-nums text-white">{totals.bank}</p>
        </div>
        <div class="rounded-2xl bg-white/5 p-4">
          <p class="text-[12px] uppercase tracking-wider text-[#7E97AC]">Cheltuieli neclasificate</p>
          <p class="mt-1 text-[26px] font-bold tabular-nums text-white">{totals.exp}</p>
        </div>
      </div>

      <!-- VAT deadline reminder -->
      <div class={`mb-5 px-4 py-3 rounded-2xl text-[13.5px] ${daysToDl <= 5 ? 'bg-[#E8A33C]/15 text-[#E8A33C]' : 'bg-white/5 text-[#9FB8CC]'}`}>
        Următoarea scadență TVA (D300/D394): <strong>{dlStr}</strong> · peste {daysToDl} {daysToDl === 1 ? 'zi' : 'zile'}.
      </div>

      <ul class="space-y-2.5">
        {cards.map((c) => (
          <li class={`group rounded-2xl bg-white/5 hover:bg-white/[0.08] transition-colors p-4 ${c.companyId === activeCompanyId ? 'ring-1 ring-[#E1FB15]/40' : ''}`}>
            <div class="flex items-center gap-3.5">
              <span class={`shrink-0 w-2.5 h-2.5 rounded-full ${DOT[c.tone]}`} title={c.tone === 'green' ? 'Totul în regulă' : c.tone === 'amber' ? 'Necesită atenție' : 'Urgent / ANAF deconectat'}></span>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <p class="text-[16px] font-semibold text-white truncate">{c.name}</p>
                  <span class="text-[11px] px-2 py-0.5 rounded-full bg-white/10 text-[#9FB8CC]">{ROLE_LABEL[c.role || 'member'] || c.role}</span>
                  {c.companyId === activeCompanyId && <span class="text-[11px] px-2 py-0.5 rounded-full bg-[#E1FB15]/15 text-[#E1FB15]">Firma activă</span>}
                </div>
                {c.cui && <p class="text-[12px] text-[#7E97AC] mt-0.5">CUI {c.cui}</p>}
              </div>
              <button
                type="button"
                class="fm-open shrink-0 px-4 py-2 rounded-full bg-[#E1FB15] text-[#0A2238] text-[13.5px] font-bold hover:bg-[#D2EA0E] disabled:opacity-50"
                data-company={c.companyId}
                data-active={c.companyId === activeCompanyId ? '1' : '0'}
              >{c.companyId === activeCompanyId ? 'Deschide' : 'Intră'}</button>
            </div>

            <div class="mt-3 flex flex-wrap gap-2 pl-6">
              {c.overdue > 0 && <span class="text-[12px] px-2.5 py-1 rounded-full bg-[#DC4B41]/15 text-[#DC4B41]">{c.overdue} facturi întârziate</span>}
              {c.inboxNew > 0 && <span class="text-[12px] px-2.5 py-1 rounded-full bg-[#34A0A4]/15 text-[#34A0A4]">{c.inboxNew} e-Facturi de importat</span>}
              {c.unreconciled > 0 && <span class="text-[12px] px-2.5 py-1 rounded-full bg-[#E8A33C]/15 text-[#E8A33C]">{c.unreconciled} tranzacții de reconciliat</span>}
              {c.unclassified > 0 && <span class="text-[12px] px-2.5 py-1 rounded-full bg-white/10 text-[#9FB8CC]">{c.unclassified} cheltuieli neclasificate</span>}
              {!c.anaf && <span class="text-[12px] px-2.5 py-1 rounded-full bg-[#DC4B41]/15 text-[#DC4B41]">ANAF deconectat</span>}
              {c.tone === 'green' && <span class="text-[12px] px-2.5 py-1 rounded-full bg-[#2E9E6A]/15 text-[#2E9E6A]">Totul în regulă</span>}
            </div>
          </li>
        ))}
      </ul>
    </>
  )}

  <script is:inline>
  document.querySelectorAll('.fm-open').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      var id = btn.getAttribute('data-company');
      // Already the active company → go straight in.
      if (btn.getAttribute('data-active') === '1') { window.location.href = '/app'; return; }
      btn.disabled = true;
      btn.textContent = 'Se deschide...';
      try {
        var res = await fetch('/api/companies/switch', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ companyId: id }),
        });
        if (res.ok) { window.location.href = '/app'; return; }
        var d = await res.json();
        alert(d.error || 'Nu am putut deschide firma.');
      } catch (e) {
        alert('Eroare de conexiune.');
      }
      btn.disabled = false;
      btn.textContent = 'Intră';
    });
  });
</script>
</AppLayout>
