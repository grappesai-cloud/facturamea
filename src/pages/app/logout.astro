---
// /app/logout — pagină de fallback pentru useri care tastează direct ruta.
// Logout-ul real se face POST către /api/auth/logout prin formularul din panoul profil.
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Deconectare — facturamea">
  <main class="min-h-screen flex items-center justify-center bg-[#EDF1F5] px-4" style="font-family:'Outfit',ui-sans-serif,system-ui,sans-serif">
    <div class="max-w-md w-full text-center bg-white rounded-[24px] ring-1 ring-black/[0.05] shadow-[0_24px_70px_-40px_rgba(16,42,67,0.4)] p-8 sm:p-10">
      <div class="w-14 h-14 mx-auto rounded-2xl bg-[#07090f] grid place-items-center text-white">
        <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H3m0 0l4-4m-4 4l4 4M16 4h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-2"/></svg>
      </div>
      <p class="text-[12px] uppercase tracking-wider text-[#1A759F] font-semibold mt-5">Cont</p>
      <h1 class="text-2xl font-extrabold text-[#07090f] tracking-[-0.02em] mt-1">Vrei să te deconectezi?</h1>
      <p class="text-[14px] text-[#46627A] mt-2">Sesiunea va fi închisă pe acest dispozitiv.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center mt-7">
        <form method="POST" action="/api/auth/logout">
          <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 rounded-full bg-[#07090f] text-white text-[14px] font-bold hover:bg-[#14304b] transition-colors">
            Da, deconectează-mă
          </button>
        </form>
        <a href="/app" class="inline-flex items-center justify-center px-6 py-3 rounded-full ring-1 ring-[#07090f]/15 text-[#07090f] text-[14px] font-semibold hover:bg-black/[0.04] transition-colors">
          Anulează
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
