---
// /app/logout — pagină de fallback pentru useri care tastează direct ruta.
// Logout-ul real se face POST către /api/auth/logout prin formularul din panoul profil.
// Aici afişăm doar un buton care declanşează acel POST + opţiune de a renunţa.
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Deconectare — facturamea">
  <main class="min-h-screen flex items-center justify-center bg-[#FAFAF8] px-4" style="font-family:'Inter',sans-serif">
    <div class="th-card th-card-lg max-w-md w-full text-center">
      <p class="th-eyebrow">Cont</p>
      <h1 class="th-h2 mt-2">Vrei să te deconectezi?</h1>
      <p class="text-[13px] text-[#6B6B68] mt-2">Sesiunea va fi închisă pe acest dispozitiv.</p>
      <div class="flex gap-3 justify-center mt-6">
        <form method="POST" action="/api/auth/logout">
          <button type="submit" class="px-5 py-2.5 rounded-xl bg-[#0A0A0A] hover:bg-[#2E2E2C] text-white text-[13px] font-semibold transition-colors">
            Da, deconectează-mă
          </button>
        </form>
        <a href="/app" class="px-5 py-2.5 rounded-xl bg-white border border-[#E8E8E4] hover:border-[#0A0A0A] text-[#0A0A0A] text-[13px] font-medium transition-colors">
          Anulează
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
