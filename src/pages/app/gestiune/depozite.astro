---
import AppLayout from '../../../layouts/AppLayout.astro';
import WarehousesManager from '../../../components/gestiune/WarehousesManager';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="Gestiuni" activeTab="stocuri">
  <div class="mb-4">
    <a href="/app/gestiune" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la stocuri</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Gestiuni</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Depozitele, magazinele și locațiile de custodie unde ții stocul.</p>

  <div class="max-w-4xl">
    <WarehousesManager client:load />
  </div>
</AppLayout>
