---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { stockLevels, invoiceProducts, warehouses } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);
const qty = (n: number) =>
  new Intl.NumberFormat('ro-RO', { maximumFractionDigits: 3 }).format(n || 0);

let rows: any[] = [];
let kpis = { products: 0, totalValueCents: 0, belowMin: 0 };

try {
  rows = await db
    .select({
      id: stockLevels.id,
      warehouseName: warehouses.name,
      productName: invoiceProducts.name,
      productCode: invoiceProducts.code,
      um: invoiceProducts.defaultUm,
      quantity: stockLevels.quantity,
      avgCostCents: stockLevels.avgCostCents,
      minQuantity: stockLevels.minQuantity,
    })
    .from(stockLevels)
    .leftJoin(invoiceProducts, eq(stockLevels.productId, invoiceProducts.id))
    .leftJoin(warehouses, eq(stockLevels.warehouseId, warehouses.id))
    .where(eq(stockLevels.companyId, companyId))
    .orderBy(desc(stockLevels.updatedAt))
    .limit(500);

  kpis.products = rows.length;
  kpis.totalValueCents = rows.reduce((s, r) => s + Math.round((Number(r.quantity) || 0) * (Number(r.avgCostCents) || 0)), 0);
  kpis.belowMin = rows.filter((r) => (Number(r.minQuantity) || 0) >= (Number(r.quantity) || 0)).length;
} catch (e) {
  // DB not provisioned — render empty.
}

// Precompute derived flags in the frontmatter (avoid comparison operators in
// the template, which the Astro JSX parser misreads as tag tokens).
const display = rows.map((r) => {
  const quantity = Number(r.quantity) || 0;
  const min = Number(r.minQuantity) || 0;
  return {
    ...r,
    low: min >= quantity,
    valueCents: Math.round(quantity * (Number(r.avgCostCents) || 0)),
  };
});

const cards = [
  { label: 'Produse în stoc', value: String(kpis.products), accent: 'text-[#0A0A0A]' },
  { label: 'Valoare totală stoc', value: ron(kpis.totalValueCents), accent: 'text-[#0A0A0A]' },
  { label: 'Produse sub minim', value: String(kpis.belowMin), accent: kpis.belowMin > 0 ? 'text-[#B91C1C]' : 'text-[#15803D]' },
];
---

<AppLayout title="Stocuri" activeTab="stocuri">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Stocuri</h1>
      <p class="text-[13px] text-[#6B6B68] mt-1">Situația curentă a stocurilor pe gestiuni.</p>
    </div>
    <div class="flex gap-2">
      <a href="/app/gestiune/nir" class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#FF5C00] hover:bg-[#E04E00] text-white text-[13px] font-semibold rounded-xl transition-colors">
        + Recepție (NIR)
      </a>
      <a href="/app/gestiune/depozite" class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-[#E8E8E4] hover:border-[#0A0A0A] text-[#0A0A0A] text-[13px] font-semibold rounded-xl transition-colors">
        Gestiuni
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
    {cards.map((c) => (
      <div class="bg-white border border-[#E8E8E4] rounded-2xl p-4">
        <p class="text-[11px] uppercase tracking-[0.12em] text-[#8A8A85] font-medium">{c.label}</p>
        <p class={`text-[22px] font-bold tracking-[-0.02em] mt-2 ${c.accent}`}>{c.value}</p>
      </div>
    ))}
  </div>

  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    <div class="flex items-center justify-between px-5 py-3.5 border-b border-[#F0F0EC]">
      <h2 class="text-[14px] font-semibold text-[#0A0A0A]">Produse în stoc</h2>
    </div>
    {rows.length === 0 ? (
      <div class="px-5 py-12 text-center">
        <p class="text-[14px] text-[#6B6B68]">Niciun stoc înregistrat încă.</p>
        <a href="/app/gestiune/nir" class="inline-block mt-3 text-[13px] font-semibold text-[#FF5C00] hover:underline">Înregistrează o recepție →</a>
      </div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-[13px]">
          <thead>
            <tr class="text-left text-[11px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
              <th class="px-5 py-2.5 font-medium">Produs</th>
              <th class="px-5 py-2.5 font-medium">Gestiune</th>
              <th class="px-5 py-2.5 font-medium text-right">Cantitate</th>
              <th class="px-5 py-2.5 font-medium text-right">Cost mediu</th>
              <th class="px-5 py-2.5 font-medium text-right">Valoare</th>
            </tr>
          </thead>
          <tbody>
            {display.map((r) => (
              <tr class={`border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors ${r.low ? 'bg-[#FDF3F3]' : ''}`}>
                <td class="px-5 py-3">
                  <span class="font-medium text-[#0A0A0A]">{r.productName || '—'}</span>
                  {r.productCode && <span class="font-mono text-xs text-[#6B6B68] ml-2">{r.productCode}</span>}
                  {r.low && <span class="ml-2 text-[10px] px-2 py-0.5 bg-[#FDECEC] text-[#B91C1C] rounded-full font-semibold">sub minim</span>}
                </td>
                <td class="px-5 py-3 text-[#3D3D3A]">{r.warehouseName || '—'}</td>
                <td class="px-5 py-3 text-right text-[#0A0A0A]">{qty(Number(r.quantity))} {r.um || ''}</td>
                <td class="px-5 py-3 text-right text-[#3D3D3A]">{ron(r.avgCostCents)}</td>
                <td class="px-5 py-3 text-right font-semibold text-[#0A0A0A]">{ron(r.valueCents)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AppLayout>
