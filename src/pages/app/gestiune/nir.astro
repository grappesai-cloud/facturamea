---
import AppLayout from '../../../layouts/AppLayout.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import ReceptionForm from '../../../components/gestiune/ReceptionForm';
import { db } from '../../../db';
import { receptions, suppliers } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

let rows: any[] = [];
try {
  rows = await db
    .select({
      id: receptions.id,
      nirNumber: receptions.nirNumber,
      supplierInvoiceNumber: receptions.supplierInvoiceNumber,
      supplierName: suppliers.name,
      receptionDate: receptions.receptionDate,
      totalCents: receptions.totalCents,
      status: receptions.status,
    })
    .from(receptions)
    .leftJoin(suppliers, eq(receptions.supplierId, suppliers.id))
    .where(eq(receptions.companyId, companyId))
    .orderBy(desc(receptions.createdAt))
    .limit(100);
} catch (e) {
  // DB not provisioned — render empty.
}

const statusBadge: Record<string, { label: string; cls: string }> = {
  draft: { label: 'Ciornă', cls: 'bg-white/10 text-[#A8BED2]' },
  posted: { label: 'Înregistrată', cls: 'bg-[#2E9E6A]/15 text-[#2E9E6A]' },
};
---

<AppLayout title="Recepții (NIR)" activeTab="stocuri">
  <div class="mb-8">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Recepții (NIR)</h1>
    <p class="text-[14px] text-[#A8BED2] mt-2">Notele de intrare recepție. La înregistrare, produsele intră automat pe stoc cu cost mediu ponderat.</p>
  </div>

  <h2 class="text-[18px] font-bold text-white mb-3">Recepții recente</h2>
  {rows.length === 0 ? (
    <div class="mb-8">
      <EmptyState title="Nicio recepție (NIR)" description="Înregistrează o recepție de marfă.">
        <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/></svg>
      </EmptyState>
    </div>
  ) : (
    <Fragment>
      <ul class="space-y-2.5 mb-8">
        {rows.slice(0, 3).map((r) => {
          const st = statusBadge[r.status] || statusBadge.draft;
          return (
            <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
              <div class="min-w-0 flex-1">
                <p class="font-bold text-white truncate">
                  <span class="font-mono">{r.nirNumber}</span>
                  <span class={`ml-2 inline-block px-2 py-0.5 rounded-full text-[11px] font-semibold ${st.cls}`}>{st.label}</span>
                </p>
                <p class="text-[13px] text-[#8FA6BC] mt-0.5 truncate">{r.supplierName || '—'}{r.supplierInvoiceNumber ? ` · fact. ${r.supplierInvoiceNumber}` : ''} · {r.receptionDate ? new Date(r.receptionDate).toLocaleDateString('ro-RO', { timeZone: 'Europe/Bucharest' }) : '—'}</p>
              </div>
              <p class="font-bold text-white tabular-nums shrink-0">{ron(r.totalCents)}</p>
              <button type="button" data-del-reception={r.id} aria-label="Anulează recepția" title="Anulează recepția (reversează stocul)" class="shrink-0 p-1.5 rounded-lg text-[#8FA6BC] hover:text-[#DC4B41] hover:bg-[#DC4B41]/10 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </li>
          );
        })}
      </ul>
      {rows.length > 3 && (
        <details class="mt-2.5 mb-8">
          <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({rows.length})</summary>
          <ul class="space-y-2.5 mt-2.5">
            {rows.slice(3).map((r) => {
              const st = statusBadge[r.status] || statusBadge.draft;
              return (
                <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
                  <div class="min-w-0 flex-1">
                    <p class="font-bold text-white truncate">
                      <span class="font-mono">{r.nirNumber}</span>
                      <span class={`ml-2 inline-block px-2 py-0.5 rounded-full text-[11px] font-semibold ${st.cls}`}>{st.label}</span>
                    </p>
                    <p class="text-[13px] text-[#8FA6BC] mt-0.5 truncate">{r.supplierName || '—'}{r.supplierInvoiceNumber ? ` · fact. ${r.supplierInvoiceNumber}` : ''} · {r.receptionDate ? new Date(r.receptionDate).toLocaleDateString('ro-RO', { timeZone: 'Europe/Bucharest' }) : '—'}</p>
                  </div>
                  <p class="font-bold text-white tabular-nums shrink-0">{ron(r.totalCents)}</p>
                  <button type="button" data-del-reception={r.id} aria-label="Anulează recepția" title="Anulează recepția (reversează stocul)" class="shrink-0 p-1.5 rounded-lg text-[#8FA6BC] hover:text-[#DC4B41] hover:bg-[#DC4B41]/10 transition-colors">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </li>
              );
            })}
          </ul>
        </details>
      )}
    </Fragment>
  )}

  <h2 class="text-[18px] font-bold text-white mb-3">Recepție nouă</h2>
  <ReceptionForm client:load />

  <script is:inline>
    document.addEventListener('astro:page-load', function () {
      if (document.documentElement.dataset.recDelBound) return;
      document.documentElement.dataset.recDelBound = '1';
      document.addEventListener('click', function (ev) {
        var btn = ev.target.closest ? ev.target.closest('[data-del-reception]') : null;
        if (!btn) return;
        ev.preventDefault();
        var id = btn.getAttribute('data-del-reception');
        if (!confirm('Anulezi această recepție? Stocul recepționat va fi scos înapoi.')) return;
        btn.disabled = true;
        fetch('/api/gestiune/receptions?id=' + encodeURIComponent(id), { method: 'DELETE' })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
          .then(function (res) { if (res.ok) window.location.reload(); else { alert(res.d.error || 'Eroare'); btn.disabled = false; } })
          .catch(function () { btn.disabled = false; });
      });
    });
  </script>
</AppLayout>
