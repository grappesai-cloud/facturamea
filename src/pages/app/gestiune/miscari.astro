---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { stockMovements, invoiceProducts, warehouses } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);
const qty = (n: number) =>
  new Intl.NumberFormat('ro-RO', { maximumFractionDigits: 3 }).format(n || 0);
const fmtDate = (d: any) => d ? new Date(d).toLocaleString('ro-RO', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';

let rows: any[] = [];
try {
  rows = await db
    .select({
      id: stockMovements.id,
      warehouseName: warehouses.name,
      productName: invoiceProducts.name,
      kind: stockMovements.kind,
      quantity: stockMovements.quantity,
      unitCostCents: stockMovements.unitCostCents,
      reason: stockMovements.reason,
      refType: stockMovements.refType,
      createdAt: stockMovements.createdAt,
    })
    .from(stockMovements)
    .leftJoin(invoiceProducts, eq(stockMovements.productId, invoiceProducts.id))
    .leftJoin(warehouses, eq(stockMovements.warehouseId, warehouses.id))
    .where(eq(stockMovements.companyId, companyId))
    .orderBy(desc(stockMovements.createdAt))
    .limit(200);
} catch (e) {
  // DB not provisioned — render empty.
}

const kindBadge: Record<string, { label: string; cls: string }> = {
  in: { label: 'Intrare', cls: 'bg-[#E7F7EC] text-[#15803D]' },
  out: { label: 'Ieșire', cls: 'bg-[#FDECEC] text-[#B91C1C]' },
  transfer: { label: 'Transfer', cls: 'bg-[#EAF2FF] text-[#1D4ED8]' },
  adjust: { label: 'Ajustare', cls: 'bg-[#FFF7E6] text-[#B45309]' },
};
---

<AppLayout title="Mișcări stoc" activeTab="stocuri">
  <div class="mb-4">
    <a href="/app/gestiune" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la stocuri</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Mișcări stoc</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Jurnalul tuturor intrărilor, ieșirilor, transferurilor și ajustărilor de stoc.</p>

  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    {rows.length === 0 ? (
      <div class="px-5 py-12 text-center text-sm text-[#6B6B68]">Nicio mișcare de stoc înregistrată încă.</div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-[13px]">
          <thead>
            <tr class="text-left text-[11px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
              <th class="px-5 py-2.5 font-medium">Data</th>
              <th class="px-5 py-2.5 font-medium">Tip</th>
              <th class="px-5 py-2.5 font-medium">Produs</th>
              <th class="px-5 py-2.5 font-medium">Gestiune</th>
              <th class="px-5 py-2.5 font-medium text-right">Cantitate</th>
              <th class="px-5 py-2.5 font-medium text-right">Cost unitar</th>
              <th class="px-5 py-2.5 font-medium">Motiv</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => {
              const k = kindBadge[r.kind] || { label: r.kind, cls: 'bg-[#F0F0EC] text-[#6B6B68]' };
              return (
                <tr class="border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors">
                  <td class="px-5 py-3 text-[#6B6B68] whitespace-nowrap">{fmtDate(r.createdAt)}</td>
                  <td class="px-5 py-3"><span class={`inline-block px-2 py-0.5 rounded-md text-[11px] font-medium ${k.cls}`}>{k.label}</span></td>
                  <td class="px-5 py-3 text-[#0A0A0A]">{r.productName || '—'}</td>
                  <td class="px-5 py-3 text-[#3D3D3A]">{r.warehouseName || '—'}</td>
                  <td class="px-5 py-3 text-right text-[#0A0A0A]">{qty(Number(r.quantity))}</td>
                  <td class="px-5 py-3 text-right text-[#3D3D3A]">{ron(r.unitCostCents)}</td>
                  <td class="px-5 py-3 text-[#6B6B68] truncate max-w-[200px]">{r.reason || '—'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AppLayout>
