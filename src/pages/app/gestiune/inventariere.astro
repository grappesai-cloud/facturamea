---
import AppLayout from '../../../layouts/AppLayout.astro';
import StockCountForm from '../../../components/gestiune-plus/StockCountForm';
import { db } from '../../../db';
import { stockCounts, warehouses } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

let rows: any[] = [];
try {
  rows = await db
    .select({
      id: stockCounts.id,
      number: stockCounts.number,
      warehouseName: warehouses.name,
      countDate: stockCounts.countDate,
      status: stockCounts.status,
    })
    .from(stockCounts)
    .leftJoin(warehouses, eq(stockCounts.warehouseId, warehouses.id))
    .where(eq(stockCounts.companyId, companyId))
    .orderBy(desc(stockCounts.createdAt))
    .limit(100);
} catch (e) {
  // DB not provisioned — render empty.
}

const statusBadge: Record<string, { label: string; cls: string }> = {
  draft: { label: 'În lucru', cls: 'bg-white/10 text-[#9FB8CC]' },
  finalized: { label: 'Finalizat', cls: 'bg-[#2E9E6A]/15 text-[#2E9E6A]' },
};
---

<AppLayout title="Inventariere" activeTab="stocuri">
  <div class="mb-8">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Inventariere</h1>
    <p class="text-[14px] text-[#9FB8CC] mt-2">Numără faptic stocul dintr-o gestiune. La finalizare, diferențele față de stocul scriptic se ajustează automat.</p>
  </div>

  <h2 class="text-[18px] font-bold text-white mb-3">Inventare recente</h2>
  {rows.length === 0 ? (
    <div class="rounded-2xl p-5 bg-white/5 text-center py-10 text-[13px] text-[#9FB8CC] mb-8">Niciun inventar încă.</div>
  ) : (
    <Fragment>
      <ul class="space-y-2.5 mb-8">
        {rows.slice(0, 3).map((r) => {
          const st = statusBadge[r.status] || statusBadge.draft;
          return (
            <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
              <div class="min-w-0 flex-1">
                <p class="font-bold text-white font-mono truncate">{r.number || '·'}</p>
                <p class="text-[13px] text-[#7C9AB4] mt-0.5">{r.warehouseName || '·'} · {r.countDate || '·'}</p>
              </div>
              <span class={`shrink-0 inline-block px-2.5 py-1 rounded-full text-[11px] font-semibold ${st.cls}`}>{st.label}</span>
            </li>
          );
        })}
      </ul>
      {rows.length > 3 && (
        <details class="mt-2.5 mb-8">
          <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#0A2238] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({rows.length})</summary>
          <ul class="space-y-2.5 mt-2.5">
            {rows.slice(3).map((r) => {
              const st = statusBadge[r.status] || statusBadge.draft;
              return (
                <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
                  <div class="min-w-0 flex-1">
                    <p class="font-bold text-white font-mono truncate">{r.number || '·'}</p>
                    <p class="text-[13px] text-[#7C9AB4] mt-0.5">{r.warehouseName || '·'} · {r.countDate || '·'}</p>
                  </div>
                  <span class={`shrink-0 inline-block px-2.5 py-1 rounded-full text-[11px] font-semibold ${st.cls}`}>{st.label}</span>
                </li>
              );
            })}
          </ul>
        </details>
      )}
    </Fragment>
  )}

  <h2 class="text-[18px] font-bold text-white mb-3">Inventar nou</h2>
  <StockCountForm client:load />
</AppLayout>
