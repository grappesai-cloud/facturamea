---
import AppLayout from '../../../layouts/AppLayout.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import StockCountForm from '../../../components/gestiune-plus/StockCountForm';
import { db } from '../../../db';
import { stockCounts, warehouses } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

let rows: any[] = [];
try {
  rows = await db
    .select({
      id: stockCounts.id,
      number: stockCounts.number,
      warehouseName: warehouses.name,
      countDate: stockCounts.countDate,
      status: stockCounts.status,
    })
    .from(stockCounts)
    .leftJoin(warehouses, eq(stockCounts.warehouseId, warehouses.id))
    .where(eq(stockCounts.companyId, companyId))
    .orderBy(desc(stockCounts.createdAt))
    .limit(100);
} catch (e) {
  // DB not provisioned — render empty.
}

const statusBadge: Record<string, { label: string; cls: string }> = {
  draft: { label: 'În lucru', cls: 'bg-white/10 text-[#A8BED2]' },
  finalized: { label: 'Finalizat', cls: 'bg-[#2E9E6A]/15 text-[#2E9E6A]' },
};
---

<AppLayout title="Inventariere" activeTab="stocuri">
  <div class="mb-8">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Inventariere</h1>
    <p class="text-[14px] text-[#A8BED2] mt-2">Numără faptic stocul dintr-o gestiune. La finalizare, diferențele față de stocul scriptic se ajustează automat.</p>
  </div>

  {rows.length === 0 ? (
    <Fragment>
      <h2 class="text-[18px] font-bold text-white mb-3">Inventar nou</h2>
      <div class="mb-8"><StockCountForm client:load /></div>
      <EmptyState title="Niciun inventar încă" description="Inventarele pornite vor apărea aici.">
        <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z"/></svg>
      </EmptyState>
    </Fragment>
  ) : (
    <Fragment>
      <h2 class="text-[18px] font-bold text-white mb-3">Inventare recente</h2>
      <ul class="space-y-2.5 mb-8">
        {rows.slice(0, 3).map((r) => {
          const st = statusBadge[r.status] || statusBadge.draft;
          return (
            <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
              <div class="min-w-0 flex-1">
                <p class="font-bold text-white font-mono truncate">{r.number || '·'}</p>
                <p class="text-[13px] text-[#8FA6BC] mt-0.5">{r.warehouseName || '·'} · {r.countDate || '·'}</p>
              </div>
              <span class={`shrink-0 inline-block px-2.5 py-1 rounded-full text-[11px] font-semibold ${st.cls}`}>{st.label}</span>
            </li>
          );
        })}
      </ul>
      {rows.length > 3 && (
        <details class="mt-2.5 mb-8">
          <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({rows.length})</summary>
          <ul class="space-y-2.5 mt-2.5">
            {rows.slice(3).map((r) => {
              const st = statusBadge[r.status] || statusBadge.draft;
              return (
                <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
                  <div class="min-w-0 flex-1">
                    <p class="font-bold text-white font-mono truncate">{r.number || '·'}</p>
                    <p class="text-[13px] text-[#8FA6BC] mt-0.5">{r.warehouseName || '·'} · {r.countDate || '·'}</p>
                  </div>
                  <span class={`shrink-0 inline-block px-2.5 py-1 rounded-full text-[11px] font-semibold ${st.cls}`}>{st.label}</span>
                </li>
              );
            })}
          </ul>
        </details>
      )}
      <h2 class="text-[18px] font-bold text-white mb-3">Inventar nou</h2>
      <StockCountForm client:load />
    </Fragment>
  )}
</AppLayout>
