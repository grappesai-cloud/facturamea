---
import AppLayout from '../../../layouts/AppLayout.astro';
import FiscalSettings from '../../../components/pos/FiscalSettings';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="POS · Aparat fiscal" activeTab="pos">
  <div class="mb-6 sm:mb-8 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Aparat fiscal</h1>
      <p class="text-[14px] text-[#9FB8CC] mt-2">Conectează casa de marcat (AMEF) la POS prin driverul local ErpNet.FP.</p>
    </div>
    <a href="/app/pos" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-white/10 text-white font-bold text-[14px] hover:bg-white/15 transition-colors">
      Înapoi la casă
    </a>
  </div>

  <FiscalSettings client:only="react" />
</AppLayout>
