---
import AppLayout from '../../../layouts/AppLayout.astro';
import PosTerminal from '../../../components/pos/PosTerminal';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="POS / Casă de marcat" activeTab="pos">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">POS / Casă de marcat</h1>
      <p class="text-[13px] text-[#6B6B68] mt-1">Vânzare rapidă la tejghea. Prețurile sunt cu TVA inclus.</p>
    </div>
    <a href="/app/pos/istoric" class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-[#E8E8E4] hover:border-[#0A0A0A] text-[#0A0A0A] text-[13px] font-semibold rounded-xl transition-colors">
      Istoric vânzări
    </a>
  </div>

  <PosTerminal client:load />
</AppLayout>
