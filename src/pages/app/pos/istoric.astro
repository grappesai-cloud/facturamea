---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { posSales } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);
const fmtDate = (d: any) => d ? new Date(d).toLocaleString('ro-RO', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';

let rows: any[] = [];
try {
  rows = await db
    .select()
    .from(posSales)
    .where(eq(posSales.companyId, companyId))
    .orderBy(desc(posSales.createdAt))
    .limit(100);
} catch (e) {
  // DB not provisioned — render empty.
}

const payLabel: Record<string, string> = { cash: 'Numerar', card: 'Card', mixed: 'Mixt' };
---

<AppLayout title="Istoric vânzări POS" activeTab="pos">
  <div class="mb-4">
    <a href="/app/pos" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la casa de marcat</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Istoric vânzări</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Bonurile emise la casa de marcat.</p>

  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    {rows.length === 0 ? (
      <div class="px-5 py-12 text-center text-sm text-[#6B6B68]">Nicio vânzare înregistrată încă.</div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-[13px]">
          <thead>
            <tr class="text-left text-[11px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC]">
              <th class="px-5 py-2.5 font-medium">Bon</th>
              <th class="px-5 py-2.5 font-medium">Data</th>
              <th class="px-5 py-2.5 font-medium">Plată</th>
              <th class="px-5 py-2.5 font-medium text-right">Subtotal</th>
              <th class="px-5 py-2.5 font-medium text-right">TVA</th>
              <th class="px-5 py-2.5 font-medium text-right">Total</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((s) => (
              <tr class="border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors">
                <td class="px-5 py-3 font-mono font-medium text-[#0A0A0A]">{s.receiptNumber}</td>
                <td class="px-5 py-3 text-[#6B6B68] whitespace-nowrap">{fmtDate(s.createdAt)}</td>
                <td class="px-5 py-3 text-[#3D3D3A]">{payLabel[s.paymentMethod] || s.paymentMethod}</td>
                <td class="px-5 py-3 text-right text-[#3D3D3A]">{ron(s.subtotalCents)}</td>
                <td class="px-5 py-3 text-right text-[#3D3D3A]">{ron(s.vatCents)}</td>
                <td class="px-5 py-3 text-right font-semibold text-[#0A0A0A]">{ron(s.totalCents)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AppLayout>
