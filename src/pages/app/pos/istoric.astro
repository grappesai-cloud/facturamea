---
import AppLayout from '../../../layouts/AppLayout.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { db } from '../../../db';
import { posSales } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);
const fmtDate = (d: any) => d ? new Date(d).toLocaleString('ro-RO', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';

let rows: any[] = [];
try {
  rows = await db
    .select()
    .from(posSales)
    .where(eq(posSales.companyId, companyId))
    .orderBy(desc(posSales.createdAt))
    .limit(100);
} catch (e) {
  // DB not provisioned — render empty.
}

const payLabel: Record<string, string> = { cash: 'Numerar', card: 'Card', mixed: 'Mixt' };

// Eticheta de fiscalizare pentru un bon (vine din aparatul fiscal, dacă e configurat).
const fiscal = (s: any): { text: string; cls: string } | null => {
  if (s.fiscalStatus === 'printed') return { text: s.fiscalReceiptNumber ? `Fiscal · ${s.fiscalReceiptNumber}` : 'Fiscal', cls: 'bg-[#2E9E6A]/15 text-[#46C28A]' };
  if (s.fiscalStatus === 'error') return { text: 'Fiscal eșuat', cls: 'bg-[#DC4B41]/15 text-[#E8736A]' };
  return null;
};
---

<AppLayout title="Istoric vânzări POS" activeTab="pos">

  <div class="mb-6 sm:mb-8">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Istoric vânzări</h1>
    <p class="text-[14px] text-[#A8BED2] mt-2">Bonurile emise la casa de marcat.</p>
  </div>

  {rows.length === 0 ? (
    <EmptyState title="Nicio vânzare" description="Vânzările din POS apar aici.">
      <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/></svg>
    </EmptyState>
  ) : (
    <Fragment>
      <ul class="space-y-2.5">
        {rows.slice(0, 3).map((s) => (
          <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
            <div class="min-w-0">
              <p class="font-mono font-bold text-white truncate">
                {s.receiptNumber}
                {fiscal(s) && <span class={`ml-2 align-middle inline-block px-2 py-0.5 rounded-full text-[11px] font-semibold ${fiscal(s)!.cls}`}>{fiscal(s)!.text}</span>}
              </p>
              <p class="text-[13px] text-[#8FA6BC] tabular-nums mt-0.5">
                {fmtDate(s.createdAt)} · {payLabel[s.paymentMethod] || s.paymentMethod}
              </p>
            </div>
            <div class="ml-auto text-right">
              <p class="font-bold text-white tabular-nums">{ron(s.totalCents)}</p>
              <p class="text-[13px] text-[#8FA6BC] tabular-nums mt-0.5">TVA {ron(s.vatCents)}</p>
            </div>
          </li>
        ))}
      </ul>
      {rows.length > 3 && (
        <details class="mt-2.5">
          <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({rows.length})</summary>
          <ul class="space-y-2.5 mt-2.5">
            {rows.slice(3).map((s) => (
              <li class="flex items-center gap-3 p-4 rounded-2xl bg-white/5 hover:bg-white/10 transition-colors">
                <div class="min-w-0">
                  <p class="font-mono font-bold text-white truncate">
                    {s.receiptNumber}
                    {fiscal(s) && <span class={`ml-2 align-middle inline-block px-2 py-0.5 rounded-full text-[11px] font-semibold ${fiscal(s)!.cls}`}>{fiscal(s)!.text}</span>}
                  </p>
                  <p class="text-[13px] text-[#8FA6BC] tabular-nums mt-0.5">
                    {fmtDate(s.createdAt)} · {payLabel[s.paymentMethod] || s.paymentMethod}
                  </p>
                </div>
                <div class="ml-auto text-right">
                  <p class="font-bold text-white tabular-nums">{ron(s.totalCents)}</p>
                  <p class="text-[13px] text-[#8FA6BC] tabular-nums mt-0.5">TVA {ron(s.vatCents)}</p>
                </div>
              </li>
            ))}
          </ul>
        </details>
      )}
    </Fragment>
  )}
</AppLayout>
