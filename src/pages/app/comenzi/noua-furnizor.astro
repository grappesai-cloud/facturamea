---
import AppLayout from '../../../layouts/AppLayout.astro';
import PurchaseOrderForm from '../../../components/comenzi/PurchaseOrderForm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="Comandă furnizor nouă" activeTab="comenzi">
  <div class="mb-4">
    <a href="/app/comenzi?tab=furnizori" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la comenzi</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Comandă furnizor nouă</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Înregistrează o comandă către un furnizor. La recepție, produsele intră automat pe stoc cu cost mediu ponderat.</p>

  <PurchaseOrderForm client:load />
</AppLayout>
