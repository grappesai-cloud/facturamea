---
import AppLayout from '../../../layouts/AppLayout.astro';
import SalesOrderForm from '../../../components/comenzi/SalesOrderForm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="Comandă client nouă" activeTab="comenzi">
  <div class="mb-4">
    <a href="/app/comenzi" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la comenzi</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Comandă client nouă</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Înregistrează o comandă de la un client. O poți transforma în factură oricând din lista de comenzi.</p>

  <SalesOrderForm client:load />
</AppLayout>
