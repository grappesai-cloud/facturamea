---
import AppLayout from '../../../layouts/AppLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import SeriesManager from '../../../components/invoicing/SeriesManager';
import { db } from '../../../db';
import { transportClauses } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;

if (user.userType !== 'intermediar' && user.userType !== 'client_direct') {
  return Astro.redirect('/app/setari');
}

const clauses = user.companyId
  ? await db.select().from(transportClauses).where(eq(transportClauses.companyId, user.companyId)).orderBy(transportClauses.sortOrder)
  : [];

const inputCls = 'w-full px-4 py-2.5 bg-white border border-[#E8E8E4] rounded-xl text-[14px] text-[#0A0A0A] placeholder:text-[#A8A8A4] focus:border-[#0A0A0A] focus:outline-none transition-colors';
const labelCls = 'block text-[12px] font-medium text-[#0A0A0A] mb-1.5';
---

<AppLayout title="Clauze contract — facturamea" activeTab="setari" breadcrumbTitle="Clauze contract">
  <div class="max-w-3xl">
    <PageHeader tagline="Setări" title="Clauze contract" subtitle="Configurează clauzele implicite care vor fi incluse în comenzile tale de transport." />

    <!-- Add clause -->
    <div class="bg-white border border-[#E8E8E4] rounded-xl p-6 mb-6">
      <h3 class="font-semibold text-[#0A0A0A] text-[14px] mb-4">Adaugă clauză</h3>
      <form id="add-clause-form" class="space-y-4">
        <div id="clause-error" class="hidden flex items-start gap-2 px-4 py-3 bg-white border border-[#B91C1C]/30 rounded-xl">
          <span class="w-1.5 h-1.5 rounded-full bg-[#B91C1C] mt-1.5 shrink-0"></span>
          <p id="clause-error-text" class="text-[13px] text-[#B91C1C]"></p>
        </div>

        <div>
          <label class={labelCls}>Titlu *</label>
          <input type="text" name="title" required class={inputCls} placeholder="ex: Termen de plată" />
        </div>
        <div>
          <label class={labelCls}>Conținut *</label>
          <textarea name="body" required rows="3" class={inputCls + ' resize-none'} placeholder="Textul clauzei..."></textarea>
        </div>
        <label class="flex items-center gap-2">
          <input type="checkbox" name="isDefault" value="true" class="w-4 h-4 accent-[#FF5C00]" />
          <span class="text-[13px] text-[#0A0A0A]">Include implicit în comenzi noi</span>
        </label>

        <button type="submit" class="px-5 py-2.5 bg-[#FF5C00] hover:bg-[#E04E00] text-white font-semibold rounded-xl text-[13px] transition-colors">
          Adaugă clauză
        </button>
      </form>
    </div>

    <!-- List -->
    {clauses.length === 0 ? (
      <div class="text-center py-10 text-[13px] text-[#6B6B68]">Nicio clauză definită.</div>
    ) : (
      <div class="space-y-3">
        {clauses.map((c) => (
          <div class="bg-white border border-[#E8E8E4] rounded-xl p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-semibold text-[#0A0A0A] text-[14px]">{c.title}</h3>
                  {c.isDefault && <span class="px-2 py-0.5 bg-[#FAFAF8] border border-[#E8E8E4] text-[#0A0A0A] text-[11px] rounded-xl uppercase tracking-wider">Implicită</span>}
                </div>
                <p class="text-[13px] text-[#6B6B68] mt-1.5 leading-relaxed">{c.body}</p>
              </div>
              <button
                data-clause-id={c.id}
                class="delete-clause-btn px-3 py-1.5 text-[12px] text-[#B91C1C] hover:bg-white border border-transparent hover:border-[#B91C1C]/30 rounded-xl transition-colors shrink-0"
              >
                Șterge
              </button>
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- Serie comandă transport -->
    <div class="mt-10">
      <h2 class="text-[15px] font-semibold text-[#0A0A0A] mb-1">Serie comandă de transport</h2>
      <p class="text-[13px] text-[#6B6B68] mb-4">Numerotarea comenzilor către transportatori (prefix + numerotare). Seria implicită se aplică automat la fiecare comandă nouă.</p>
      <SeriesManager client:load kinds={[{ id: 'comanda', label: 'Comandă transport' }]} />
    </div>
  </div>

  <script>
    document.getElementById('add-clause-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const errorEl = document.getElementById('clause-error')!;
      const errorText = document.getElementById('clause-error-text')!;
      const data = Object.fromEntries(new FormData(form));

      try {
        const res = await fetch('/api/settings/clauses', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: data.title,
            body: data.body,
            isDefault: data.isDefault === 'true',
          }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const result = await res.json();
          errorText.textContent = result.error || 'Eroare';
          errorEl.classList.remove('hidden');
        }
      } catch {
        errorText.textContent = 'Eroare de conectare';
        errorEl.classList.remove('hidden');
      }
    });

    document.querySelectorAll('.delete-clause-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const clauseId = (e.currentTarget as HTMLElement).dataset.clauseId;
        if (!confirm('Sigur vrei să ștergi această clauză?')) return;

        try {
          const res = await fetch(`/api/settings/clauses?id=${clauseId}`, { method: 'DELETE' });
          if (res.ok) window.location.reload();
          else alert('Eroare la ștergere');
        } catch {
          alert('Eroare de conectare');
        }
      });
    });
  </script>
</AppLayout>
