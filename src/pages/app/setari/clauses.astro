---
import AppLayout from '../../../layouts/AppLayout.astro';
import EmptyState from '../../../components/ui/EmptyState.astro';
import SeriesManager from '../../../components/invoicing/SeriesManager';
import { db } from '../../../db';
import { transportClauses } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;

if (user.userType !== 'intermediar' && user.userType !== 'client_direct') {
  return Astro.redirect('/app/setari');
}

const clauses = user.companyId
  ? await db.select().from(transportClauses).where(eq(transportClauses.companyId, user.companyId)).orderBy(transportClauses.sortOrder)
  : [];

const inputCls = 'w-full rounded-xl bg-white/5 px-4 py-2.5 text-[14px] text-white placeholder:text-[#8FA6BC] focus:outline-none';
const labelCls = 'block text-[13px] font-medium text-[#A8BED2] mb-1.5';
---

<AppLayout title="Clauze contract — facturamea" activeTab="setari" breadcrumbTitle="Clauze contract">
  <div class="max-w-3xl">
    <div class="mb-6 sm:mb-8">
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Clauze contract</h1>
      <p class="text-[13px] text-[#A8BED2] mt-2 max-w-2xl">Configurează clauzele implicite care vor fi incluse în comenzile tale de transport.</p>
    </div>

    <!-- Add clause -->
    <div class="rounded-2xl p-5 bg-white/5 mb-6">
      <h3 class="text-[18px] font-bold text-white mb-3">Adaugă clauză</h3>
      <form id="add-clause-form" class="space-y-4">
        <div id="clause-error" class="hidden flex items-start gap-2 px-4 py-3 rounded-xl bg-[#DC4B41]/15">
          <span class="w-1.5 h-1.5 rounded-full bg-[#DC4B41] mt-1.5 shrink-0"></span>
          <p id="clause-error-text" class="text-[13px] text-[#DC4B41]"></p>
        </div>

        <div>
          <label class={labelCls}>Titlu *</label>
          <input type="text" name="title" required class={inputCls} placeholder="ex: Termen de plată" />
        </div>
        <div>
          <label class={labelCls}>Conținut *</label>
          <textarea name="body" required rows="3" class={inputCls + ' resize-none'} placeholder="Textul clauzei..."></textarea>
        </div>
        <label class="flex items-center gap-2">
          <input type="checkbox" name="isDefault" value="true" class="w-4 h-4 accent-[#E1FB15]" />
          <span class="text-[13px] text-white">Include implicit în comenzi noi</span>
        </label>

        <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">
          Adaugă clauză
        </button>
      </form>
    </div>

    <!-- List -->
    {clauses.length === 0 ? (
      <EmptyState title="Nicio clauză definită" description="Adaugă clauze contractuale reutilizabile pe facturi.">
        <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      </EmptyState>
    ) : (
      <div class="space-y-3">
        {clauses.map((c) => (
          <div class="rounded-2xl p-5 bg-white/5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-semibold text-white text-[14px]">{c.title}</h3>
                  {c.isDefault && <span class="px-2 py-0.5 bg-white/10 text-[#C8DAE8] text-[11px] rounded-full uppercase tracking-wider">Implicită</span>}
                </div>
                <p class="text-[13px] text-[#A8BED2] mt-1.5 leading-relaxed">{c.body}</p>
              </div>
              <button
                data-clause-id={c.id}
                class="delete-clause-btn px-3 py-1.5 text-[12px] text-[#DC4B41] hover:bg-[#DC4B41]/10 rounded-full transition-colors shrink-0"
              >
                Șterge
              </button>
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- Serie comandă transport -->
    <div class="mt-10">
      <h2 class="text-[18px] font-bold text-white mb-3">Serie comandă de transport</h2>
      <p class="text-[13px] text-[#A8BED2] mb-4">Numerotarea comenzilor către transportatori (prefix + numerotare). Seria implicită se aplică automat la fiecare comandă nouă.</p>
      <SeriesManager client:load kinds={[{ id: 'comanda', label: 'Comandă transport' }]} />
    </div>
  </div>

  <script>
    document.getElementById('add-clause-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const errorEl = document.getElementById('clause-error')!;
      const errorText = document.getElementById('clause-error-text')!;
      const data = Object.fromEntries(new FormData(form));

      try {
        const res = await fetch('/api/settings/clauses', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: data.title,
            body: data.body,
            isDefault: data.isDefault === 'true',
          }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const result = await res.json();
          errorText.textContent = result.error || 'Eroare';
          errorEl.classList.remove('hidden');
        }
      } catch {
        errorText.textContent = 'Eroare de conectare';
        errorEl.classList.remove('hidden');
      }
    });

    document.querySelectorAll('.delete-clause-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const clauseId = (e.currentTarget as HTMLElement).dataset.clauseId;
        if (!confirm('Sigur vrei să ștergi această clauză?')) return;

        try {
          const res = await fetch(`/api/settings/clauses?id=${clauseId}`, { method: 'DELETE' });
          if (res.ok) window.location.reload();
          else alert('Eroare la ștergere');
        } catch {
          alert('Eroare de conectare');
        }
      });
    });
  </script>
</AppLayout>
