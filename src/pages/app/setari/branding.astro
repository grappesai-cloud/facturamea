---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { companies } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
// Only the primary account holder may modify branding. Sub-users get sent
// back to settings index.
if (user.parentUserId) return Astro.redirect('/app/setari');

const [company] = await db.select({
  name: companies.name,
  logoUrl: companies.logoUrl,
  description: companies.description,
  website: companies.website,
}).from(companies).where(eq(companies.id, user.companyId));
---

<AppLayout title="Branding companie" activeTab="setari">
  <div class="mb-6 sm:mb-8">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Branding companie</h1>
    <p class="text-[13px] text-[#A8BED2] mt-2 max-w-2xl">Logo, descriere, website — afișate pe profilul public al companiei.</p>
  </div>

  <div class="rounded-3xl p-5 sm:p-6 bg-white/5 max-w-2xl">
    <div class="mb-6">
      <p class="text-[18px] font-bold text-white mb-3">Logo</p>
      <div class="flex items-center gap-4">
        <div id="logo-preview" class="w-20 h-20 rounded-xl bg-white/5 flex items-center justify-center overflow-hidden">
          {company?.logoUrl ? (
            <img src={company.logoUrl} alt="Logo" class="w-full h-full object-contain" />
          ) : (
            <span class="text-[10px] text-[#8FA6BC]">fără logo</span>
          )}
        </div>
        <div class="flex-1">
          <input id="logo-file" type="file" accept="image/png,image/jpeg,image/webp" class="text-[12px] text-[#A8BED2]" />
          <p class="text-[11px] text-[#8FA6BC] mt-1">PNG / JPG / WebP — max 10 MB. Pătrat recomandat.</p>
        </div>
        {company?.logoUrl && (
          <button id="logo-remove" class="text-[12px] text-[#DC4B41] hover:underline">Scoate</button>
        )}
      </div>
      <p id="logo-status" class="text-[12px] text-[#8FA6BC] mt-2"></p>
    </div>

    <form id="branding-form" class="space-y-4 pt-6 border-t border-white/10">
      <input type="hidden" id="logo-url" name="logoUrl" value={company?.logoUrl ?? ''} />
      <div>
        <label class="block text-[13px] font-medium text-[#A8BED2] mb-1.5">Descriere companie</label>
        <textarea name="description" rows="4" class="w-full rounded-xl bg-white/5 border border-white/[0.12] px-4 py-2.5 text-[14px] text-white placeholder:text-[#8FA6BC] focus:outline-none focus:border-[#E1FB15]/50 focus:ring-2 focus:ring-[#E1FB15]/30 hover:border-white/25 transition">{company?.description ?? ''}</textarea>
      </div>
      <div>
        <label class="block text-[13px] font-medium text-[#A8BED2] mb-1.5">Website</label>
        <input name="website" type="url" placeholder="https://..." value={company?.website ?? ''} class="w-full rounded-xl bg-white/5 border border-white/[0.12] px-4 py-2.5 text-[14px] text-white placeholder:text-[#8FA6BC] focus:outline-none focus:border-[#E1FB15]/50 focus:ring-2 focus:ring-[#E1FB15]/30 hover:border-white/25 transition" />
      </div>
      <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">
        Salvează branding
      </button>
      <p id="branding-status" class="text-[12px] text-[#8FA6BC]"></p>
    </form>
  </div>

  <script>
    const fileInput  = document.getElementById('logo-file') as HTMLInputElement;
    const previewEl  = document.getElementById('logo-preview') as HTMLDivElement;
    const urlInput   = document.getElementById('logo-url') as HTMLInputElement;
    const statusEl   = document.getElementById('logo-status') as HTMLParagraphElement;
    const removeBtn  = document.getElementById('logo-remove') as HTMLButtonElement | null;
    const form       = document.getElementById('branding-form') as HTMLFormElement;
    const formStatus = document.getElementById('branding-status') as HTMLParagraphElement;

    async function uploadLogo(file: File) {
      statusEl.textContent = 'Se încarcă...';
      const fd = new FormData();
      fd.append('file', file);
      fd.append('purpose', 'image');
      const res = await fetch('/api/upload/document', { method: 'POST', body: fd });
      const data = await res.json();
      if (!res.ok) {
        statusEl.textContent = data.error || 'Eroare upload';
        return null;
      }
      return data.url as string;
    }

    fileInput?.addEventListener('change', async () => {
      const f = fileInput.files?.[0];
      if (!f) return;
      const url = await uploadLogo(f);
      if (!url) return;
      urlInput.value = url;
      // Set the src via DOM property (not innerHTML string interpolation) so a
      // crafted URL can't break out of the attribute / inject markup.
      previewEl.replaceChildren();
      const img = document.createElement('img');
      img.src = url;
      img.alt = 'Logo';
      img.className = 'w-full h-full object-contain';
      previewEl.appendChild(img);
      statusEl.textContent = 'Logo încărcat. Salvează formularul ca să devină public.';
    });

    removeBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      urlInput.value = '';
      previewEl.innerHTML = '<span class="text-[10px] text-[#8FA6BC]">fără logo</span>';
      statusEl.textContent = 'Logo scos. Salvează ca să confirmi.';
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const payload = {
        logoUrl: String(fd.get('logoUrl') || ''),
        description: String(fd.get('description') || ''),
        website: String(fd.get('website') || ''),
      };
      formStatus.textContent = 'Se salvează...';
      try {
        const res = await fetch('/api/companies/branding', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        formStatus.textContent = res.ok ? 'Salvat.' : 'Eroare la salvare.';
      } catch {
        formStatus.textContent = 'Eroare la salvare.';
      }
    });
  </script>
</AppLayout>
