---
import AppLayout from '../../../layouts/AppLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { db } from '../../../db';
import { companies } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
// Only the primary account holder may modify branding. Sub-users get sent
// back to settings index.
if (user.parentUserId) return Astro.redirect('/app/setari');

const [company] = await db.select({
  name: companies.name,
  logoUrl: companies.logoUrl,
  description: companies.description,
  website: companies.website,
}).from(companies).where(eq(companies.id, user.companyId));
---

<AppLayout title="Branding companie" activeTab="setari">
  <PageHeader tagline="Setări" title="Branding companie" subtitle="Logo, descriere, website — afișate pe profilul public al companiei." />

  <div class="bg-white border border-[#E8E8E4] rounded-xl p-6 max-w-2xl">
    <div class="mb-6">
      <p class="text-[12px] uppercase tracking-wider text-[#6B6B68] font-medium mb-2">Logo</p>
      <div class="flex items-center gap-4">
        <div id="logo-preview" class="w-20 h-20 border border-[#E8E8E4] rounded-xl bg-[#FAFAF8] flex items-center justify-center overflow-hidden">
          {company?.logoUrl ? (
            <img src={company.logoUrl} alt="Logo" class="w-full h-full object-contain" />
          ) : (
            <span class="text-[10px] text-[#A8A8A4]">fără logo</span>
          )}
        </div>
        <div class="flex-1">
          <input id="logo-file" type="file" accept="image/png,image/jpeg,image/webp" class="text-[12px]" />
          <p class="text-[11px] text-[#6B6B68] mt-1">PNG / JPG / WebP — max 10 MB. Pătrat recomandat.</p>
        </div>
        {company?.logoUrl && (
          <button id="logo-remove" class="text-[12px] text-[#B91C1C] hover:underline">Scoate</button>
        )}
      </div>
      <p id="logo-status" class="text-[12px] text-[#6B6B68] mt-2"></p>
    </div>

    <form id="branding-form" class="space-y-4 pt-6 border-t border-[#E8E8E4]">
      <input type="hidden" id="logo-url" name="logoUrl" value={company?.logoUrl ?? ''} />
      <div>
        <label class="block text-[12px] font-medium text-[#0A0A0A] mb-1.5">Descriere companie</label>
        <textarea name="description" rows="4" class="w-full px-4 py-2.5 bg-white border border-[#E8E8E4] rounded-xl text-[14px] focus:border-[#0A0A0A] focus:outline-none">{company?.description ?? ''}</textarea>
      </div>
      <div>
        <label class="block text-[12px] font-medium text-[#0A0A0A] mb-1.5">Website</label>
        <input name="website" type="url" placeholder="https://..." value={company?.website ?? ''} class="w-full px-4 py-2.5 bg-white border border-[#E8E8E4] rounded-xl text-[14px] focus:border-[#0A0A0A] focus:outline-none" />
      </div>
      <button type="submit" class="px-5 py-2.5 bg-[#0A0A0A] hover:bg-[#1A1A1A] text-white font-semibold rounded-xl text-[13px] transition-colors">
        Salvează branding
      </button>
      <p id="branding-status" class="text-[12px] text-[#6B6B68]"></p>
    </form>
  </div>

  <script>
    const fileInput  = document.getElementById('logo-file') as HTMLInputElement;
    const previewEl  = document.getElementById('logo-preview') as HTMLDivElement;
    const urlInput   = document.getElementById('logo-url') as HTMLInputElement;
    const statusEl   = document.getElementById('logo-status') as HTMLParagraphElement;
    const removeBtn  = document.getElementById('logo-remove') as HTMLButtonElement | null;
    const form       = document.getElementById('branding-form') as HTMLFormElement;
    const formStatus = document.getElementById('branding-status') as HTMLParagraphElement;

    async function uploadLogo(file: File) {
      statusEl.textContent = 'Se încarcă...';
      const fd = new FormData();
      fd.append('file', file);
      fd.append('purpose', 'image');
      const res = await fetch('/api/upload/document', { method: 'POST', body: fd });
      const data = await res.json();
      if (!res.ok) {
        statusEl.textContent = data.error || 'Eroare upload';
        return null;
      }
      return data.url as string;
    }

    fileInput?.addEventListener('change', async () => {
      const f = fileInput.files?.[0];
      if (!f) return;
      const url = await uploadLogo(f);
      if (!url) return;
      urlInput.value = url;
      previewEl.innerHTML = `<img src="${url}" alt="Logo" class="w-full h-full object-contain" />`;
      statusEl.textContent = 'Logo încărcat. Salvează formularul ca să devină public.';
    });

    removeBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      urlInput.value = '';
      previewEl.innerHTML = '<span class="text-[10px] text-[#A8A8A4]">fără logo</span>';
      statusEl.textContent = 'Logo scos. Salvează ca să confirmi.';
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const payload = {
        logoUrl: String(fd.get('logoUrl') || ''),
        description: String(fd.get('description') || ''),
        website: String(fd.get('website') || ''),
      };
      formStatus.textContent = 'Se salvează...';
      const res = await fetch('/api/companies/branding', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      formStatus.textContent = res.ok ? 'Salvat.' : 'Eroare la salvare.';
    });
  </script>
</AppLayout>
