---
import AppLayout from '../../../layouts/AppLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import ApiKeysManager from '../../../components/api/ApiKeysManager.tsx';
---

<AppLayout title="API & integrări" activeTab="api">
  <div class="max-w-3xl">
    <PageHeader tagline="Cont" title="API & integrări" subtitle="Generează chei API pentru a conecta facturamea la propriile aplicații și integrări." />

    <section class="mb-10">
      <h2 class="text-[11px] uppercase tracking-[0.16em] text-[#6B6B68] font-medium mb-4">Chei API</h2>
      <ApiKeysManager client:load />
    </section>

    <section class="mb-6">
      <h2 class="text-[11px] uppercase tracking-[0.16em] text-[#6B6B68] font-medium mb-4">Cum folosești API-ul</h2>
      <div class="bg-white border border-[#E8E8E4] rounded-2xl p-5 space-y-3">
        <p class="text-[13px] text-[#3D3D3A]">
          Trimite cererile către <code class="font-mono text-[#0A0A0A] bg-[#F0F0EC] px-1.5 py-0.5 rounded">https://facturamea.com/api/v1</code>
          și autentifică-te cu cheia ta în header-ul <code class="font-mono text-[#0A0A0A] bg-[#F0F0EC] px-1.5 py-0.5 rounded">Authorization</code>.
        </p>
        <pre class="bg-[#0A0A0A] text-[#E8E8E4] text-xs rounded-xl p-4 overflow-x-auto font-mono"><code>curl https://facturamea.com/api/v1/ping \
  -H "Authorization: Bearer fm_live_..."</code></pre>
        <p class="text-[13px] text-[#3D3D3A]">
          Poți crea facturi, clienți și produse. Vezi documentația completă cu toate endpoint-urile și exemplele.
        </p>
        <a href="/dezvoltatori" class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-[#FF5C00] hover:underline">
          Documentație dezvoltatori →
        </a>
      </div>
    </section>
  </div>
</AppLayout>
