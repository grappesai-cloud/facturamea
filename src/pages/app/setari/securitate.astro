---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { users } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
const [u] = await db.select({
  totpEnabled: users.totpEnabled,
  totpEnrolledAt: users.totpEnrolledAt,
}).from(users).where(eq(users.id, user.id));

const totpEnabled = !!u?.totpEnabled;
const totpEnrolledAt = u?.totpEnrolledAt ? new Date(u.totpEnrolledAt).toLocaleDateString('ro-RO', { timeZone: 'Europe/Bucharest' }) : null;

const inputCls = 'w-full rounded-xl bg-white/5 px-4 py-2.5 text-[14px] text-white placeholder:text-[#7C9AB4] focus:outline-none';
const labelCls = 'block text-[13px] font-medium text-[#9FB8CC] mb-1.5';
---

<AppLayout title="Securitate cont — facturamea" activeTab="setari">
  <div class="max-w-2xl">
    <div class="mb-6 sm:mb-8">
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Securitate</h1>
      <p class="text-[13px] text-[#9FB8CC] mt-2 max-w-2xl">Autentificare în 2 paşi şi datele tale personale (GDPR).</p>
    </div>

    <!-- ─── 2FA section ─── -->
    <section class="mb-12">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-[18px] font-bold text-white">Autentificare în 2 paşi</h2>
        {totpEnabled && (
          <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-[#2E9E6A]">
            <span class="w-1.5 h-1.5 rounded-full bg-[#2E9E6A]"></span>
            Activă
          </span>
        )}
      </div>

      {!totpEnabled && (
        <div id="totp-stage-prompt" class="rounded-2xl p-5 bg-white/5">
          <p class="text-[13px] text-[#9FB8CC] leading-relaxed">
            Adaugă un strat suplimentar de protecţie. Vei avea nevoie de o aplicaţie de autentificare gen <strong class="text-white">Google Authenticator</strong>, <strong class="text-white">1Password</strong> sau <strong class="text-white">Authy</strong>.
          </p>
          <button id="totp-enroll-start" class="mt-4 inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#0A2238] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">
            Activează 2FA
          </button>
        </div>
      )}

      <div id="totp-stage-setup" class="hidden rounded-2xl p-5 bg-white/5">
        <p class="text-[13px] text-[#9FB8CC] mb-4"><strong class="text-white">Pas 1.</strong> Scanează codul QR cu aplicaţia de autentificare:</p>
        <div class="flex flex-col sm:flex-row gap-6 items-center sm:items-start">
          <img id="totp-qr" alt="QR cod 2FA" class="w-40 h-40 rounded-xl bg-white" />
          <div class="flex-1 min-w-0">
            <p class="text-[12px] text-[#7C9AB4] mb-1">Sau introdu manual cheia:</p>
            <code id="totp-secret" class="block px-3 py-2 bg-white/5 rounded-xl text-[12px] font-mono text-white break-all"></code>
          </div>
        </div>

        <p class="text-[13px] text-[#9FB8CC] mt-6 mb-2"><strong class="text-white">Pas 2.</strong> Salvează aceste coduri de recuperare într-un loc sigur. Le poţi folosi dacă pierzi telefonul:</p>
        <div id="totp-recovery" class="grid grid-cols-2 sm:grid-cols-5 gap-2 p-4 bg-white/5 rounded-xl font-mono text-[12px] text-white mb-4"></div>
        <button id="totp-copy-codes" class="text-[12px] text-[#9FB8CC] hover:text-white transition-colors mb-6">Copiază toate codurile</button>

        <p class="text-[13px] text-[#9FB8CC] mb-2"><strong class="text-white">Pas 3.</strong> Tastează codul de 6 cifre din aplicaţie pentru a confirma:</p>
        <div class="flex gap-2 items-end">
          <div class="flex-1">
            <label for="totp-code" class={labelCls + ' sr-only'}>Cod 6 cifre</label>
            <input id="totp-code" type="text" inputmode="numeric" maxlength="6" placeholder="123456" class={inputCls + ' tabular-nums tracking-widest text-center text-[16px]'} />
          </div>
          <button id="totp-confirm" class="px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#0A2238] font-bold text-[14px] hover:bg-[#D2EA0E] disabled:opacity-60 transition-colors">Confirmă</button>
        </div>
        <p id="totp-confirm-error" class="hidden text-[12px] text-[#DC4B41] mt-2"></p>
      </div>

      {totpEnabled && (
        <div class="rounded-2xl p-5 bg-white/5">
          <p class="text-[13px] text-white">2FA este activ {totpEnrolledAt && <>din <strong>{totpEnrolledAt}</strong></>}.</p>
          <p class="text-[12px] text-[#7C9AB4] mt-2">La fiecare login vei tasta un cod de 6 cifre din aplicaţie după parolă.</p>
          <button id="totp-disable-show" class="mt-4 px-4 py-2.5 rounded-full bg-white/10 hover:bg-white/15 text-[#DC4B41] font-semibold text-[13px] transition-colors">
            Dezactivează 2FA
          </button>

          <div id="totp-disable-form" class="hidden mt-4 pt-4 border-t border-white/10">
            <p class="text-[12px] text-[#7C9AB4] mb-3">Confirmă cu un cod de 6 cifre actual sau cu parola contului:</p>
            <div class="flex gap-2">
              <input id="totp-disable-code" type="text" placeholder="123456 sau parolă" class={inputCls + ' flex-1'} />
              <button id="totp-disable-do" class="px-5 py-2.5 rounded-full bg-[#DC4B41] hover:bg-[#C43B32] text-white font-semibold text-[14px] transition-colors">Confirmă</button>
            </div>
            <p id="totp-disable-error" class="hidden text-[12px] text-[#DC4B41] mt-2"></p>
          </div>
        </div>
      )}

      <div id="totp-success" class="hidden rounded-2xl p-5 bg-[#2E9E6A]/15">
        <p class="text-[13px] font-semibold text-white">2FA activat cu succes</p>
        <p class="text-[12px] text-[#9FB8CC] mt-1">La următorul login vei avea nevoie de codul din aplicaţie.</p>
      </div>
    </section>

    <!-- ─── GDPR section ─── -->
    <section>
      <h2 class="text-[18px] font-bold text-white mb-3">Datele tale (GDPR)</h2>

      <div class="rounded-2xl p-5 bg-white/5 mb-3">
        <h3 class="font-semibold text-[14px] text-white">Descarcă datele mele</h3>
        <p class="text-[12px] text-[#9FB8CC] mt-1 leading-relaxed">Primeşti un fişier JSON cu toate datele asociate contului tău: profil, comenzi, mesaje, recenzii, documente. Drept garantat de GDPR Art. 20.</p>
        <button id="gdpr-export" class="mt-3 px-4 py-2 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">
          Descarcă JSON
        </button>
      </div>

      <div class="rounded-2xl p-5 bg-white/5">
        <h3 class="font-semibold text-[14px] text-white">Şterge contul</h3>
        <p class="text-[12px] text-[#9FB8CC] mt-1 leading-relaxed">Contul va fi marcat pentru ştergere imediat şi şters definitiv după 30 de zile. Drept garantat de GDPR Art. 17.</p>
        <p class="text-[12px] text-[#DC4B41] mt-2"><strong>Atenţie:</strong> comenzile şi facturile asociate companiei rămân pentru obligaţii legale (5 ani).</p>
        <button id="gdpr-delete-show" class="mt-3 px-4 py-2.5 rounded-full bg-white/10 hover:bg-white/15 text-[#DC4B41] font-semibold text-[13px] transition-colors">
          Şterge contul...
        </button>

        <div id="gdpr-delete-form" class="hidden mt-4 pt-4 border-t border-white/10 space-y-3">
          <div>
            <label class={labelCls}>Tastează exact <code class="font-mono bg-white/10 text-white px-1.5 py-0.5 rounded-full text-[11px]">STERG-CONTUL</code> pentru confirmare</label>
            <input id="gdpr-confirm" type="text" placeholder="STERG-CONTUL" class={inputCls} />
          </div>
          <div>
            <label class={labelCls}>Parolă curentă</label>
            <input id="gdpr-password" type="password" placeholder="Parola ta" class={inputCls} />
          </div>
          <div class="flex gap-2 pt-1">
            <button id="gdpr-delete-do" class="px-5 py-2.5 rounded-full bg-[#DC4B41] hover:bg-[#C43B32] text-white font-semibold text-[14px] transition-colors">
              Şterg contul definitiv
            </button>
            <button id="gdpr-delete-cancel" class="px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">
              Anulează
            </button>
          </div>
          <p id="gdpr-delete-error" class="hidden text-[12px] text-[#DC4B41]"></p>
        </div>
      </div>
    </section>
  </div>

  <script>
    const $ = (id: string) => document.getElementById(id);

    // ─── 2FA enrollment ──────────────────────────────
    let recoveryCodesPlain: string[] = [];
    $('totp-enroll-start')?.addEventListener('click', async () => {
      const res = await fetch('/api/auth/totp/enroll', { method: 'POST' });
      const data = await res.json();
      if (!res.ok) { alert(data.error || 'Eroare'); return; }
      ($('totp-stage-prompt') as HTMLElement)?.classList.add('hidden');
      ($('totp-stage-setup') as HTMLElement)?.classList.remove('hidden');
      ($('totp-qr') as HTMLImageElement).src = data.qrDataUrl;
      ($('totp-secret') as HTMLElement).textContent = data.secret;
      recoveryCodesPlain = data.recoveryCodes;
      const recDiv = $('totp-recovery')!;
      recDiv.innerHTML = '';
      data.recoveryCodes.forEach((c: string) => {
        const span = document.createElement('span');
        span.textContent = c;
        span.className = 'px-2 py-1.5 bg-white/10 rounded-lg text-center';
        recDiv.appendChild(span);
      });
    });

    $('totp-copy-codes')?.addEventListener('click', () => {
      navigator.clipboard.writeText(recoveryCodesPlain.join('\n'));
      const btn = $('totp-copy-codes')!;
      const original = btn.textContent;
      btn.textContent = 'Copiate ✓';
      setTimeout(() => { btn.textContent = original; }, 2000);
    });

    $('totp-confirm')?.addEventListener('click', async () => {
      const code = ($('totp-code') as HTMLInputElement).value.replace(/\s+/g, '');
      const errEl = $('totp-confirm-error')!;
      errEl.classList.add('hidden');
      const res = await fetch('/api/auth/totp/confirm', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });
      const data = await res.json();
      if (!res.ok) {
        errEl.textContent = data.error || 'Cod incorect';
        errEl.classList.remove('hidden');
        return;
      }
      ($('totp-stage-setup') as HTMLElement)?.classList.add('hidden');
      ($('totp-success') as HTMLElement)?.classList.remove('hidden');
      setTimeout(() => window.location.reload(), 2000);
    });

    // ─── 2FA disable ────────────────────────────────
    $('totp-disable-show')?.addEventListener('click', () => {
      ($('totp-disable-form') as HTMLElement)?.classList.remove('hidden');
    });
    $('totp-disable-do')?.addEventListener('click', async () => {
      const value = ($('totp-disable-code') as HTMLInputElement).value;
      const errEl = $('totp-disable-error')!;
      errEl.classList.add('hidden');
      const isCode = /^\d{6}$/.test(value.replace(/\s+/g, ''));
      const body = isCode ? { code: value } : { password: value };
      const res = await fetch('/api/auth/totp/disable', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok) {
        errEl.textContent = data.error || 'Eroare';
        errEl.classList.remove('hidden');
        return;
      }
      window.location.reload();
    });

    // ─── GDPR export ─────────────────────────────────
    $('gdpr-export')?.addEventListener('click', async () => {
      const password = prompt('Pentru securitate, introdu parola contului:');
      if (!password) return;
      const btn = $('gdpr-export') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Se pregăteşte...';
      try {
        const res = await fetch('/api/me/export', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password }),
        });
        if (!res.ok) { const j = await res.json().catch(() => ({})); alert(j.error || 'Eroare la export'); return; }
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `facturamea-data-${new Date().toISOString().slice(0,10)}.json`;
        a.click();
        URL.revokeObjectURL(url);
      } finally {
        btn.disabled = false; btn.textContent = 'Descarcă JSON';
      }
    });

    // ─── GDPR delete ─────────────────────────────────
    $('gdpr-delete-show')?.addEventListener('click', () => {
      ($('gdpr-delete-form') as HTMLElement)?.classList.remove('hidden');
    });
    $('gdpr-delete-cancel')?.addEventListener('click', () => {
      ($('gdpr-delete-form') as HTMLElement)?.classList.add('hidden');
    });
    $('gdpr-delete-do')?.addEventListener('click', async () => {
      const confirm = ($('gdpr-confirm') as HTMLInputElement).value;
      const password = ($('gdpr-password') as HTMLInputElement).value;
      const errEl = $('gdpr-delete-error')!;
      errEl.classList.add('hidden');
      if (confirm !== 'STERG-CONTUL') {
        errEl.textContent = 'Trebuie să tastezi exact STERG-CONTUL';
        errEl.classList.remove('hidden');
        return;
      }
      const res = await fetch('/api/me/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ confirm, password }),
      });
      const data = await res.json();
      if (!res.ok) {
        errEl.textContent = data.error || 'Eroare';
        errEl.classList.remove('hidden');
        return;
      }
      alert('Contul tău a fost marcat pentru ştergere. Vei fi delogat.');
      window.location.href = '/';
    });
  </script>
</AppLayout>
