---
import AppLayout from '../../../layouts/AppLayout.astro';

// Notification preferences arrive together with the mobile app (in-app
// notifications). Until then this is a "coming soon" placeholder so the link
// from the settings landing and the email footers doesn't 404.
const user = Astro.locals.user!;
void user;
---

<AppLayout title="Notificări — facturamea" activeTab="setari" breadcrumbTitle="Notificări">
  <div class="max-w-3xl">
    <div class="mb-6 sm:mb-8">
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Notificări</h1>
    </div>

    <div class="rounded-2xl p-8 sm:p-10 bg-white/5 text-center">
      <div class="mx-auto w-14 h-14 rounded-2xl bg-[#E1FB15]/15 grid place-items-center mb-5">
        <svg class="w-7 h-7 text-[#E1FB15]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.4-1.4A2 2 0 0118 14.2V11a6 6 0 10-12 0v3.2a2 2 0 01-.6 1.4L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      </div>
      <span class="inline-block px-3 py-1 rounded-full text-[12px] font-semibold bg-[#E1FB15]/15 text-[#E1FB15] mb-3">În curând</span>
      <h2 class="text-[20px] font-bold text-white">Setările de notificări vin în curând</h2>
      <p class="text-[14px] text-[#A8BED2] mt-2 max-w-md mx-auto leading-relaxed">
        Notificările în aplicație sosesc odată cu aplicația de mobil. Atunci vei putea alege aici ce alerte primești
        (scadențe, status e-Factura, plăți). Până atunci, alertele importante ajung pe e-mail.
      </p>
    </div>
  </div>
</AppLayout>
