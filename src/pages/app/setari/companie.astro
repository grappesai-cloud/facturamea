---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { companies, billingAddresses } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
let company: any = null;
let billing: any = null;
if (user.companyId) {
  [company] = await db.select().from(companies).where(eq(companies.id, user.companyId)).limit(1);
  [billing] = await db.select().from(billingAddresses)
    .where(eq(billingAddresses.companyId, user.companyId))
    .orderBy(desc(billingAddresses.isDefault))
    .limit(1);
}

const labelCls = 'block text-[13px] font-medium text-[#A8BED2] mb-1.5';
const inputDisabledCls = 'w-full rounded-xl bg-white/10 px-4 py-2.5 text-[14px] text-[#A8BED2]';
const inputCls = 'w-full rounded-xl bg-white/10 px-4 py-2.5 text-[14px] text-white placeholder:text-[#8FA6BC] focus:outline-none focus:ring-2 focus:ring-[#D9ED92]/40';
---

<AppLayout title="Setări companie — facturamea" activeTab="setari" breadcrumbTitle="Companie">
  <div class="max-w-3xl">
    <div class="mb-6 sm:mb-8">
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Companie</h1>
      <p class="text-[13px] text-[#A8BED2] mt-2 max-w-2xl">Datele companiei tale.</p>
    </div>

    {!company ? (
      <p class="text-[13px] text-[#A8BED2]">Niciun cont de companie asociat.</p>
    ) : (
      <section class="mb-10 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 rounded-2xl p-5 bg-white/5">
          <div><label class={labelCls}>Denumire</label><input type="text" value={company.name ?? ''} disabled class={inputDisabledCls} /></div>
          <div><label class={labelCls}>CUI</label><input type="text" value={company.cui ?? '—'} disabled class={inputDisabledCls} /></div>
          <div><label class={labelCls}>Țară</label><input type="text" value={company.country ?? '—'} disabled class={inputDisabledCls} /></div>
          <div><label class={labelCls}>Oraș</label><input type="text" value={company.city ?? '—'} disabled class={inputDisabledCls} /></div>
          <div><label class={labelCls}>Telefon</label><input type="text" value={company.phone ?? '—'} disabled class={inputDisabledCls} /></div>
        </div>

        <p class="text-[12px] text-[#8FA6BC]">
          Datele legale (denumire, CUI) sunt fixate la înregistrare. Pentru corecții, contactează suportul.
        </p>

        <form id="bank-form" class="rounded-2xl p-5 bg-white/5 space-y-3">
          <div>
            <p class="text-[16px] font-bold text-white">Cont bancar (apare pe facturi)</p>
            <p class="text-[12px] text-[#8FA6BC] mt-0.5">IBAN-ul se afișează automat pe orice factură emiți, la datele tale de emitent.</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div class="sm:col-span-2"><label class={labelCls}>IBAN</label><input id="iban" name="iban" type="text" value={billing?.iban ?? ''} placeholder="RO00 BANK 0000 0000 0000 0000" class={inputCls} /></div>
            <div><label class={labelCls}>Bancă</label><input id="bank" name="bank" type="text" value={billing?.bank ?? ''} placeholder="ex: Banca Transilvania" class={inputCls} /></div>
            <div><label class={labelCls}>Telefon</label><input id="phone" name="phone" type="text" value={company.phone ?? ''} placeholder="ex: 07xx xxx xxx" class={inputCls} /></div>
          </div>
          <div class="flex items-center gap-3 pt-1">
            <button type="submit" id="bank-save" class="px-5 py-2.5 rounded-full bg-[#D9ED92] text-[#07090f] font-semibold text-[14px] hover:bg-[#c9e06f] transition-colors">Salvează</button>
            <span id="bank-status" class="text-[13px] text-[#A8BED2]"></span>
          </div>
        </form>

        <div class="flex flex-wrap gap-2 pt-2">
          <a href="/app/setari/branding" class="px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">Logo & branding</a>
          <a href="/app/depozite" class="px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">Locații & depozite</a>
        </div>
      </section>
    )}
  </div>

  <script>
    const form = document.getElementById('bank-form') as HTMLFormElement | null;
    const statusEl = document.getElementById('bank-status');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const iban = (document.getElementById('iban') as HTMLInputElement).value;
      const bank = (document.getElementById('bank') as HTMLInputElement).value;
      const phone = (document.getElementById('phone') as HTMLInputElement).value;
      if (statusEl) statusEl.textContent = 'Se salvează...';
      try {
        const res = await fetch('/api/companies/profile', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ iban, bank, phone }),
        });
        const data = await res.json().catch(() => ({}));
        if (statusEl) statusEl.textContent = res.ok ? 'Salvat.' : (data.error || 'Eroare la salvare.');
      } catch {
        if (statusEl) statusEl.textContent = 'Eroare conexiune.';
      }
    });
  </script>
</AppLayout>
