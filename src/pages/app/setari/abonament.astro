---
import AppLayout from '../../../layouts/AppLayout.astro';
import { licenseState } from '../../../lib/license';

const user = Astro.locals.user!;
const companyId = user.companyId;
const status = Astro.url.searchParams.get('status');

let st = { plan: 'trial' as 'trial' | 'lifetime', active: false, trialDaysLeft: 0, status: 'active' };
if (companyId) {
  try { st = await licenseState(companyId) as any; } catch {}
}
const isLifetime = st.plan === 'lifetime' && st.active;

const features = [
  'Facturi, proforme, avize, chitanțe — nelimitat',
  'e-Factura (ANAF SPV) + e-Transport',
  'SAF-T D406',
  'Gestiune stocuri & NIR',
  'Cheltuieli & furnizori',
  'POS / casă de marcat',
  'Facturi recurente',
  'Rapoarte & export',
  'Aplicații iOS + Android',
  'Utilizatori și roluri',
];
---

<AppLayout title="Licență & plată" breadcrumbTitle="Licență & plată">
  <div class="max-w-2xl">
    <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Licență & plată</h1>
    <p class="text-[13px] text-[#6B6B68] mt-1">O singură plată. Acces pe viață, fără abonament lunar.</p>

    {status === 'success' && (
      <div class="mt-5 px-4 py-3 bg-[#E7F7EC] border border-[#15803D]/30 rounded-xl text-[13px] text-[#15803D]">
        Plata a fost primită. Licența pe viață se activează în câteva secunde — reîncarcă pagina.
      </div>
    )}
    {status === 'cancel' && (
      <div class="mt-5 px-4 py-3 bg-[#FFF7E6] border border-[#B45309]/30 rounded-xl text-[13px] text-[#B45309]">
        Plata a fost anulată. Poți reîncerca oricând.
      </div>
    )}

    {isLifetime ? (
      <div class="mt-6 bg-white border border-[#15803D]/30 rounded-2xl p-6">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-[#E7F7EC] text-[#15803D]">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4"/></svg>
          </span>
          <h2 class="text-[18px] font-bold text-[#0A0A0A]">Licență pe viață activă</h2>
        </div>
        <p class="text-[13px] text-[#6B6B68] mt-2">Ai acces complet la toate funcțiile facturamea. Mulțumim!</p>
      </div>
    ) : (
      <div class="mt-6 grid gap-4">
        <div class="bg-white border border-[#E8E8E4] rounded-2xl p-4 flex items-center justify-between gap-3">
          <div>
            <p class="text-[13px] font-semibold text-[#0A0A0A]">Perioadă de probă</p>
            <p class="text-[12px] text-[#6B6B68] mt-0.5">
              {st.active ? `Mai ai ${st.trialDaysLeft} ${st.trialDaysLeft === 1 ? 'zi' : 'zile'} de probă gratuită.` : 'Perioada de probă a expirat. Activează licența pentru a continua.'}
            </p>
          </div>
          <span class={`px-2.5 py-1 rounded-md text-[11px] font-semibold ${st.active ? 'bg-[#FFF7E6] text-[#B45309]' : 'bg-[#FDECEC] text-[#B91C1C]'}`}>
            {st.active ? 'Probă' : 'Expirat'}
          </span>
        </div>

        <div class="bg-[#0A0A0A] text-white rounded-2xl p-6 relative overflow-hidden">
          <div class="absolute top-4 right-4 px-2.5 py-1 rounded-full bg-[#FF5C00] text-white text-[11px] font-bold uppercase tracking-wider">Lifetime</div>
          <p class="text-[12px] uppercase tracking-[0.16em] text-white/60 font-medium">facturamea</p>
          <div class="flex items-end gap-2 mt-2">
            <span class="text-[44px] font-bold leading-none tracking-[-0.03em]">700</span>
            <span class="text-[16px] font-semibold mb-1">RON</span>
            <span class="text-[13px] text-white/60 mb-1.5">· o singură dată</span>
          </div>
          <ul class="mt-5 grid sm:grid-cols-2 gap-y-2 gap-x-4">
            {features.map((f) => (
              <li class="flex items-start gap-2 text-[13px] text-white/90">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-[#FF5C00]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <button id="buy-lifetime" class="mt-6 w-full py-3 bg-[#FF5C00] hover:bg-[#E04E00] disabled:opacity-60 text-white font-semibold rounded-xl text-[14px] transition-colors">
            Activează licența pe viață — 700 RON
          </button>
          <p id="buy-error" class="hidden mt-2 text-[12px] text-[#FFB4A2]"></p>
          <p class="mt-3 text-[11px] text-white/50 text-center">Plată securizată prin Stripe. Card bancar.</p>
        </div>
      </div>
    )}
  </div>

  <script>
    const btn = document.getElementById('buy-lifetime');
    const err = document.getElementById('buy-error');
    btn?.addEventListener('click', async () => {
      (btn as HTMLButtonElement).disabled = true;
      btn!.textContent = 'Se redirecționează…';
      err?.classList.add('hidden');
      try {
        const res = await fetch('/api/checkout/lifetime', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.url) { window.location.href = data.url; return; }
        if (err) { err.textContent = data.error || 'A apărut o eroare.'; err.classList.remove('hidden'); }
      } catch {
        if (err) { err.textContent = 'Eroare de rețea.'; err.classList.remove('hidden'); }
      }
      (btn as HTMLButtonElement).disabled = false;
      btn!.textContent = 'Activează licența pe viață — 700 RON';
    });
  </script>
</AppLayout>
