---
import AppLayout from '../../../layouts/AppLayout.astro';
import EfacturaInvoiceView from '../../../components/anaf/EfacturaInvoiceView.tsx';
import { db } from '../../../db';
import { expenses, efacturaInbox } from '../../../db/schema';
import { eq, and, desc, ne } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;
const { id } = Astro.params;

let exp: any = null;
let same: any[] = [];
let fromEfactura = false;
let efacturaInboxId: string | null = null;
try {
  const rows = await db.select().from(expenses)
    .where(and(eq(expenses.id, id!), eq(expenses.companyId, companyId)))
    .limit(1);
  exp = rows[0] ?? null;
  if (exp) {
    const supKey = exp.supplierId || null;
    if (supKey) {
      same = await db.select().from(expenses)
        .where(and(eq(expenses.companyId, companyId), eq(expenses.supplierId, supKey), ne(expenses.id, exp.id)))
        .orderBy(desc(expenses.issueDate))
        .limit(8);
    }
    const inb = await db.select({ id: efacturaInbox.id }).from(efacturaInbox)
      .where(and(eq(efacturaInbox.companyId, companyId), eq(efacturaInbox.importedExpenseId, exp.id)))
      .limit(1);
    fromEfactura = inb.length > 0;
    efacturaInboxId = inb[0]?.id ?? null;
  }
} catch (e) { /* DB not ready */ }

if (!exp) return Astro.redirect('/app/cheltuieli');

const ron = (c: number) => new Intl.NumberFormat('ro-RO', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format((c || 0) / 100) + ' ' + (exp.currency || 'RON');
const dt = (d: any) => d ? new Date(d).toLocaleDateString('ro-RO', { timeZone: 'Europe/Bucharest', day: '2-digit', month: 'long', year: 'numeric' }) : '—';

const CAT: Record<string, string> = { utilitati: 'Utilități', chirie: 'Chirie', combustibil: 'Combustibil', servicii: 'Servicii', marfa: 'Marfă', salarii: 'Salarii', taxe: 'Taxe', altele: 'Altele' };
const DOC: Record<string, string> = { factura: 'Factură', bon: 'Bon', chitanta: 'Chitanță', extras: 'Extras' };
const STATUS: Record<string, { label: string; cls: string }> = {
  paid: { label: 'Plătit', cls: 'bg-[#2E9E6A]/15 text-[#2E9E6A]' },
  partial: { label: 'Parțial', cls: 'bg-[#E8A33C]/15 text-[#E8A33C]' },
  unpaid: { label: 'Neplătit', cls: 'bg-[#DC4B41]/15 text-[#DC4B41]' },
};
const st = STATUS[exp.status] || STATUS.unpaid;
const supName = exp.supplierNameSnap || 'Furnizor';
const sameTotal = same.reduce((s, x) => s + (x.totalCents || 0), 0);

const rows: { k: string; v: string }[] = [
  { k: 'Document', v: `${DOC[exp.documentType] || exp.documentType}${exp.documentNumber ? ` · ${exp.documentNumber}` : ''}` },
  { k: 'Categorie', v: exp.category ? (CAT[exp.category] || exp.category) : '—' },
  { k: 'Data emiterii', v: dt(exp.issueDate) },
  { k: 'Scadență', v: dt(exp.dueDate) },
  { k: 'Bază (net)', v: ron(exp.netCents) },
  { k: 'TVA', v: ron(exp.vatCents) },
  { k: 'Plătit', v: ron(exp.paidCents) },
  { k: 'Deductibil', v: exp.deductible ? `Da${exp.deductiblePct != null && exp.deductiblePct !== 100 ? ` (${exp.deductiblePct}%)` : ''}` : 'Nu' },
  { k: 'Regim TVA', v: exp.vatScheme === 'reverse_charge' ? 'Taxare inversă' : 'Normal' },
];
---

<AppLayout title={`Cheltuială · ${supName}`} activeTab="cheltuieli">
  <div class="max-w-2xl">
    <div class="flex items-center gap-2 mb-2.5">
      <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-[12px] font-semibold ${st.cls}`}>{st.label}</span>
      {fromEfactura && <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[12px] font-semibold bg-[#34A0A4]/15 text-[#34A0A4] whitespace-nowrap">e-Factura</span>}
    </div>
    <div class="flex items-end justify-between gap-4 mb-6">
      <h1 class="text-[26px] sm:text-[34px] font-semibold tracking-[-0.02em] text-white leading-tight">{supName}</h1>
      <p class="text-[24px] sm:text-[30px] font-bold tabular-nums text-white shrink-0 whitespace-nowrap">{ron(exp.totalCents)}</p>
    </div>

    {efacturaInboxId && (
      <div class="mb-6">
        <EfacturaInvoiceView inboxId={efacturaInboxId} client:load />
      </div>
    )}

    <p class="text-[13px] font-semibold text-[#8FA6BC] mb-2.5">Detalii înregistrare</p>
    <div class="rounded-2xl bg-white/5 divide-y divide-white/5">
      {rows.map((r) => (
        <div class="flex items-start justify-between gap-4 px-4 sm:px-5 py-3.5">
          <span class="text-[14px] text-[#8FA6BC] shrink-0">{r.k}</span>
          <span class="text-[14px] text-white font-medium text-right break-words">{r.v}</span>
        </div>
      ))}
    </div>

    {exp.notes && (
      <div class="mt-4 rounded-2xl bg-white/5 px-4 sm:px-5 py-4">
        <p class="text-[12px] text-[#8FA6BC] mb-1.5">Notițe</p>
        <p class="text-[14px] text-white whitespace-pre-wrap">{exp.notes}</p>
      </div>
    )}

    {exp.attachmentUrl && (
      <a href={exp.attachmentUrl} target="_blank" rel="noopener" class="mt-4 flex items-center gap-3 rounded-2xl bg-white/5 hover:bg-white/10 px-4 sm:px-5 py-4 transition-colors">
        <svg class="w-5 h-5 text-[#A8BED2] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
        <span class="min-w-0 flex-1 text-[14px] font-medium text-white truncate">{exp.attachmentName || 'Atașament'}</span>
        <span class="text-[13px] font-semibold text-[#E1FB15] shrink-0">Deschide →</span>
      </a>
    )}

    {same.length > 0 && (
      <div class="mt-8">
        <h2 class="text-[16px] font-bold text-white mb-1">Alte cheltuieli de la {supName}</h2>
        <p class="text-[13px] text-[#8FA6BC] mb-3">{same.length} {same.length === 1 ? 'document' : 'documente'} · total {ron(sameTotal)}</p>
        <ul class="space-y-2.5">
          {same.map((x) => (
            <li>
              <a href={`/app/cheltuieli/${x.id}`} class="flex items-center gap-3 p-3.5 rounded-xl bg-white/5 hover:bg-white/10 transition-colors">
                <div class="min-w-0 flex-1">
                  <p class="text-[14px] font-semibold text-white truncate">{DOC[x.documentType] || x.documentType}{x.documentNumber ? ` · ${x.documentNumber}` : ''}</p>
                  <p class="text-[12px] text-[#8FA6BC] mt-0.5">{x.issueDate ? dt(x.issueDate) : '—'}</p>
                </div>
                <span class="text-[14px] font-bold tabular-nums text-white shrink-0 whitespace-nowrap">{ron(x.totalCents)}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</AppLayout>
