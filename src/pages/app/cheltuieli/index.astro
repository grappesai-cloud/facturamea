---
import AppLayout from '../../../layouts/AppLayout.astro';
import ExpensesManager from '../../../components/cheltuieli/ExpensesManager';
import { db } from '../../../db';
import { expenses } from '../../../db/schema';
import { and, eq, gte, sql } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().slice(0, 10);

let kpis = { monthTotal: 0, unpaid: 0, deductible: 0 };
try {
  const [mRow] = await db
    .select({ total: sql<number>`COALESCE(SUM(${expenses.totalCents}), 0)` })
    .from(expenses)
    .where(and(eq(expenses.companyId, companyId), gte(expenses.issueDate, monthStart)));
  kpis.monthTotal = Number(mRow?.total ?? 0);

  const [uRow] = await db
    .select({ unpaid: sql<number>`COALESCE(SUM(${expenses.totalCents} - ${expenses.paidCents}), 0)` })
    .from(expenses)
    .where(and(eq(expenses.companyId, companyId), sql`${expenses.status} <> 'paid'`));
  kpis.unpaid = Number(uRow?.unpaid ?? 0);

  const [dRow] = await db
    .select({ deductible: sql<number>`COALESCE(SUM(${expenses.totalCents}) FILTER (WHERE ${expenses.deductible} = true), 0)` })
    .from(expenses)
    .where(and(eq(expenses.companyId, companyId), gte(expenses.issueDate, monthStart)));
  kpis.deductible = Number(dRow?.deductible ?? 0);
} catch (e) {
  // DB not provisioned — render empty KPIs.
}

const cards = [
  { label: 'Total luna aceasta', value: ron(kpis.monthTotal), accent: 'text-[#0A0A0A]' },
  { label: 'Neplătit', value: ron(kpis.unpaid), accent: kpis.unpaid > 0 ? 'text-[#B91C1C]' : 'text-[#15803D]' },
  { label: 'Deductibil (luna)', value: ron(kpis.deductible), accent: 'text-[#0A0A0A]' },
];
---

<AppLayout title="Cheltuieli" activeTab="cheltuieli">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Cheltuieli</h1>
      <p class="text-[13px] text-[#6B6B68] mt-1">Facturile și documentele de la furnizori.</p>
    </div>
    <a href="/app/cheltuieli/furnizori" class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-[#E8E8E4] hover:border-[#0A0A0A] text-[#0A0A0A] text-[13px] font-semibold rounded-xl transition-colors">
      Furnizori
    </a>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
    {cards.map((c) => (
      <div class="bg-white border border-[#E8E8E4] rounded-2xl p-4">
        <p class="text-[11px] uppercase tracking-[0.12em] text-[#8A8A85] font-medium">{c.label}</p>
        <p class={`text-[22px] font-bold tracking-[-0.02em] mt-2 ${c.accent}`}>{c.value}</p>
      </div>
    ))}
  </div>

  <ExpensesManager client:load />
</AppLayout>
