---
import AppLayout from '../../../layouts/AppLayout.astro';
import ExpensesManager from '../../../components/cheltuieli/ExpensesManager';
import { db } from '../../../db';
import { efacturaInbox } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { getAnafStatus } from '../../../lib/anaf/tokens';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

// e-Factura inbox (SPV) — received supplier invoices shown in the SAME list below,
// tagged "e-Factura": new ones to confirm, plus which recorded expenses came from SPV.
const anaf = await getAnafStatus(companyId).catch(() => ({ connected: false, cif: null as string | null }));
let inboxRows: any[] = [];
try {
  inboxRows = await db.select().from(efacturaInbox)
    .where(eq(efacturaInbox.companyId, companyId))
    .orderBy(desc(efacturaInbox.receivedAt), desc(efacturaInbox.createdAt))
    .limit(300);
} catch (e) { /* DB not provisioned */ }
const inboxNew = inboxRows.filter((r) => r.status === 'nou');
const efacturaIds = inboxRows.filter((r) => r.importedExpenseId).map((r) => r.importedExpenseId);

// Document-type filter — mirrors the Facturare "kind" pattern.
// Picked via ?tip=… so deep-links keep working. Maps to expense.documentType.
const TIP_FILTERS = [
  { value: 'all', label: 'Toate' },
  { value: 'factura', label: 'Facturi' },
  { value: 'bon', label: 'Bonuri' },
  { value: 'chitanta', label: 'Chitanțe' },
  { value: 'extras', label: 'Extrase' },
] as const;
const rawTip = (Astro.url.searchParams.get('tip') || 'all').toLowerCase();
const activeTip = TIP_FILTERS.some((t) => t.value === rawTip) ? rawTip : 'all';
const activeTipLabel = TIP_FILTERS.find((t) => t.value === activeTip)?.label ?? 'Toate';

// Status filter — URL-based (?status=…), filters the list via the expenses API.
const STATUS_FILTERS = [
  { value: '', label: 'Toate' },
  { value: 'unpaid', label: 'Neplătit' },
  { value: 'partial', label: 'Parțial' },
  { value: 'paid', label: 'Plătit' },
] as const;
// Category filter — URL-based (?category=…). RO labels copied from ExpensesManager.
const CAT_FILTERS = [
  { value: '', label: 'Toate' },
  { value: 'utilitati', label: 'Utilități' },
  { value: 'chirie', label: 'Chirie' },
  { value: 'combustibil', label: 'Combustibil' },
  { value: 'servicii', label: 'Servicii' },
  { value: 'marfa', label: 'Marfă' },
  { value: 'salarii', label: 'Salarii' },
  { value: 'taxe', label: 'Taxe' },
  { value: 'altele', label: 'Altele' },
] as const;
const rawStatus = (Astro.url.searchParams.get('status') || '').toLowerCase();
const activeStatus = STATUS_FILTERS.some((s) => s.value === rawStatus) ? rawStatus : '';
const activeStatusLabel = STATUS_FILTERS.find((s) => s.value === activeStatus)?.label ?? 'Toate';
const rawCategory = (Astro.url.searchParams.get('category') || '').toLowerCase();
const activeCategory = CAT_FILTERS.some((c) => c.value === rawCategory) ? rawCategory : '';
const activeCategoryLabel = CAT_FILTERS.find((c) => c.value === activeCategory)?.label ?? 'Toate';

// Build a /app/cheltuieli URL preserving current filters, with overrides applied.
// An empty/'all' override removes that key so the link clears that filter.
const buildUrl = (overrides: Record<string, string>) => {
  const params = new URLSearchParams(Astro.url.searchParams);
  for (const [k, v] of Object.entries(overrides)) {
    if (v === '' || v === 'all') params.delete(k);
    else params.set(k, v);
  }
  const qs = params.toString();
  return qs ? `/app/cheltuieli?${qs}` : '/app/cheltuieli';
};
---

<AppLayout title="Cheltuieli" activeTab="cheltuieli">
  <div class="mb-6 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div class="min-w-0">
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Cheltuieli</h1>
      <p class="text-[14px] text-[#A8BED2] mt-2">Facturi primite din SPV, manual sau scanate — toate într-un loc.</p>
    </div>
    <button type="button" data-new-expense class="shrink-0 self-start sm:self-auto inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">+ Cheltuială nouă</button>
  </div>

  {!anaf.connected && inboxNew.length === 0 && (
    <a href="/app/setari/integrari-anaf" class="mb-6 flex flex-wrap items-center gap-3 rounded-2xl px-4 py-3 bg-white/5 hover:bg-white/[0.08] transition-colors">
      <span class="w-2 h-2 rounded-full bg-[#8FA6BC] shrink-0"></span>
      <p class="text-[13.5px] text-[#A8BED2] min-w-0">Conectează firma la <strong class="text-white">ANAF</strong> ca facturile primite din SPV să apară automat aici.</p>
      <span class="text-[13px] font-semibold text-[#E1FB15] ml-auto whitespace-nowrap">Conectează →</span>
    </a>
  )}

  <!-- Controls row — Secțiuni + Tip + Status + Categorie inline menus, all URL-based. -->
  <!-- On desktop (≥sm) all four pills sit on one row; they wrap on mobile. -->

  <div class="mb-6 sm:mb-8" data-filterbar>
    <div class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
      <button type="button" data-fb-toggle="sectiuni" aria-expanded="false" class="select-none inline-flex w-full sm:w-auto justify-between items-center gap-2 pl-3.5 pr-3 py-2 rounded-full bg-white/5 text-[13.5px] font-semibold text-[#A8BED2] hover:text-white hover:bg-white/10 transition-colors">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
        <span class="min-w-0 truncate">Secțiuni</span>
        <svg data-fb-chev class="w-4 h-4 shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
      </button>
      <button type="button" data-fb-toggle="tip" aria-expanded="false" class="select-none inline-flex w-full sm:w-auto justify-between items-center gap-2 pl-3.5 pr-3 py-2 rounded-full bg-white/5 text-[13.5px] font-semibold text-[#A8BED2] hover:text-white hover:bg-white/10 transition-colors">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/></svg>
        <span class="min-w-0 truncate">{activeTipLabel === 'Toate' ? 'Filtru' : `Filtru: ${activeTipLabel}`}</span>
        <svg data-fb-chev class="w-4 h-4 shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
      </button>
      <button type="button" data-fb-toggle="status" aria-expanded="false" class="select-none inline-flex w-full sm:w-auto justify-between items-center gap-2 pl-3.5 pr-3 py-2 rounded-full bg-white/5 text-[13.5px] font-semibold text-[#A8BED2] hover:text-white hover:bg-white/10 transition-colors">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/></svg>
        <span class="min-w-0 truncate">{activeStatusLabel === 'Toate' ? 'Status' : `Status: ${activeStatusLabel}`}</span>
        <svg data-fb-chev class="w-4 h-4 shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
      </button>
      <button type="button" data-fb-toggle="category" aria-expanded="false" class="select-none inline-flex w-full sm:w-auto justify-between items-center gap-2 pl-3.5 pr-3 py-2 rounded-full bg-white/5 text-[13.5px] font-semibold text-[#A8BED2] hover:text-white hover:bg-white/10 transition-colors">
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/></svg>
        <span class="min-w-0 truncate">{activeCategoryLabel === 'Toate' ? 'Categorie' : `Categorie: ${activeCategoryLabel}`}</span>
        <svg data-fb-chev class="w-4 h-4 shrink-0 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
      </button>
    </div>

    <nav aria-label="Secțiuni cheltuieli" data-fb-panel="sectiuni" hidden class="fm-reveal mt-2.5 grid grid-cols-2 sm:grid-cols-3 gap-2">
      {[
        { label: 'Scanează bon', href: '/app/cheltuieli/scan', icon: 'M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316zM16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z' },
        { label: 'Furnizori', href: '/app/cheltuieli/furnizori', icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z' },
      ].map((l) => (
        <a href={l.href} class="inline-flex items-center gap-2 pl-3 pr-4 py-2.5 rounded-xl bg-white/5 text-[13px] font-semibold text-[#A8BED2] hover:text-white hover:bg-white/10 transition-colors">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d={l.icon}/></svg>
          {l.label}
        </a>
      ))}
    </nav>

    <nav aria-label="Filtru tip document" data-fb-panel="tip" hidden class="fm-reveal mt-2.5 grid grid-cols-2 sm:grid-cols-3 gap-2">
      {TIP_FILTERS.map((t) => {
        const isActive = t.value === activeTip;
        return (
          <a
            href={buildUrl({ tip: t.value })}
            aria-current={isActive ? 'page' : undefined}
            class={`inline-flex items-center gap-2 pl-3 pr-4 py-2.5 rounded-xl text-[13px] font-semibold transition-colors ${isActive ? 'bg-[#E1FB15] text-[#07090f]' : 'bg-white/5 text-[#A8BED2] hover:text-white hover:bg-white/10'}`}
          >{t.label}</a>
        );
      })}
    </nav>

    <nav aria-label="Filtru status" data-fb-panel="status" hidden class="fm-reveal mt-2.5 grid grid-cols-2 sm:grid-cols-3 gap-2">
      {STATUS_FILTERS.map((s) => {
        const isActive = s.value === activeStatus;
        return (
          <a
            href={buildUrl({ status: s.value })}
            aria-current={isActive ? 'page' : undefined}
            class={`inline-flex items-center gap-2 pl-3 pr-4 py-2.5 rounded-xl text-[13px] font-semibold transition-colors ${isActive ? 'bg-[#E1FB15] text-[#07090f]' : 'bg-white/5 text-[#A8BED2] hover:text-white hover:bg-white/10'}`}
          >{s.label}</a>
        );
      })}
    </nav>

    <nav aria-label="Filtru categorie" data-fb-panel="category" hidden class="fm-reveal mt-2.5 grid grid-cols-2 sm:grid-cols-3 gap-2">
      {CAT_FILTERS.map((c) => {
        const isActive = c.value === activeCategory;
        return (
          <a
            href={buildUrl({ category: c.value })}
            aria-current={isActive ? 'page' : undefined}
            class={`inline-flex items-center gap-2 pl-3 pr-4 py-2.5 rounded-xl text-[13px] font-semibold transition-colors ${isActive ? 'bg-[#E1FB15] text-[#07090f]' : 'bg-white/5 text-[#A8BED2] hover:text-white hover:bg-white/10'}`}
          >{c.label}</a>
        );
      })}
    </nav>
  </div>

  <ExpensesManager inboxNew={inboxNew} efacturaIds={efacturaIds} anafConnected={anaf.connected} initialDocType={activeTip === 'all' ? '' : activeTip} initialStatus={activeStatus} initialCategory={activeCategory} client:load />
</AppLayout>

<script>
  // Inline filter menus: one panel open at a time, expands below the row, closes on
  // outside click. Registered once globally (guard) so it survives view-transition swaps.
  if (!(window as any).__fmFilterbar) {
    (window as any).__fmFilterbar = true;
    const closeBar = (bar: Element) => {
      bar.querySelectorAll('[data-fb-panel]').forEach((p) => ((p as HTMLElement).hidden = true));
      bar.querySelectorAll('[data-fb-toggle]').forEach((t) => {
        t.setAttribute('aria-expanded', 'false');
        t.querySelector('[data-fb-chev]')?.classList.remove('rotate-180');
      });
    };
    document.addEventListener('click', (e) => {
      const toggle = (e.target as HTMLElement).closest('[data-fb-toggle]');
      if (toggle) {
        const bar = toggle.closest('[data-filterbar]');
        if (!bar) return;
        const key = toggle.getAttribute('data-fb-toggle');
        const panel = bar.querySelector(`[data-fb-panel="${key}"]`) as HTMLElement | null;
        const willOpen = !!panel?.hidden;
        closeBar(bar);
        if (panel && willOpen) {
          panel.hidden = false;
          toggle.setAttribute('aria-expanded', 'true');
          toggle.querySelector('[data-fb-chev]')?.classList.add('rotate-180');
        }
        return;
      }
      document.querySelectorAll('[data-filterbar]').forEach((bar) => {
        if (!bar.contains(e.target as Node)) closeBar(bar);
      });
    });
  }
</script>
