---
import AppLayout from '../../../layouts/AppLayout.astro';
import SuppliersManager from '../../../components/cheltuieli/SuppliersManager';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
---

<AppLayout title="Furnizori" activeTab="cheltuieli">
  <div class="mb-4">
    <a href="/app/cheltuieli" class="text-sm text-[#6B6B68] hover:text-[#0A0A0A]">← Înapoi la cheltuieli</a>
  </div>
  <h1 class="text-2xl font-bold text-[#0A0A0A] mb-1">Furnizori</h1>
  <p class="text-sm text-[#6B6B68] mb-6">Furnizorii de la care primești facturi și marfă. Poți prelua datele din ANAF după CUI.</p>

  <div class="max-w-5xl">
    <SuppliersManager client:load />
  </div>
</AppLayout>
