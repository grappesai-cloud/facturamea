---
import AppLayout from '../../../layouts/AppLayout.astro';
import PeriodFilter from '../../../components/contabilitate/PeriodFilter';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { accountLedger, listAccounts } from '../../../lib/accounting';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

const now = new Date();
const yearStart = `${now.getFullYear()}-01-01`;
const yearEnd = `${now.getFullYear()}-12-31`;
const code = Astro.url.searchParams.get('cont') || '';
const from = Astro.url.searchParams.get('from') || yearStart;
const to = Astro.url.searchParams.get('to') || yearEnd;

const accounts = await listAccounts(companyId).catch(() => []);
const data = code
  ? await accountLedger(companyId, code, from, to).catch(() => ({ name: code, lines: [], opening: 0 }))
  : { name: '', lines: [], opening: 0 };

const balanceLabel = (cents: number) =>
  cents > 0 ? `${ron(cents)} (debitor)` : cents < 0 ? `${ron(-cents)} (creditor)` : ron(0);
---

<AppLayout title="Fișa contului" activeTab="contabilitate">
  <div class="mb-8 sm:mb-10">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Fișa contului</h1>
    <p class="text-[15px] text-[#A8BED2] mt-2">Mișcările și soldul unui cont, pe perioadă.</p>
  </div>

  <PeriodFilter client:load from={from} to={to} cont={code} accounts={accounts.map((a) => ({ code: a.code, name: a.name }))} submitLabel="Afișează" />

  {!code ? (
    <EmptyState title="Alege un cont" description="Selectează un cont din listă pentru a-i vedea mișcările și soldul pe perioada aleasă.">
      <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
    </EmptyState>
  ) : (
    <>
      <div class="mb-5 rounded-2xl p-5 bg-white/5 flex flex-wrap items-center gap-6">
        <div>
          <p class="text-[13px] text-[#A8BED2]">Cont</p>
          <p class="text-[20px] font-bold text-white mt-1"><span class="font-mono">{code}</span> · {data.name}</p>
        </div>
        <div class="sm:ml-auto sm:text-right">
          <p class="text-[13px] text-[#A8BED2]">Sold inițial</p>
          <p class="text-[20px] font-bold tabular-nums text-white mt-1">{balanceLabel(data.opening)}</p>
        </div>
      </div>

      <div class="rounded-2xl bg-white/5 p-4 sm:p-5">
        {data.lines.length === 0 ? (
          <EmptyState title="Nicio mișcare" description="Contul nu are înregistrări în perioada aleasă.">
            <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
          </EmptyState>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-[14px]">
              <thead>
                <tr class="text-left text-[11px] uppercase tracking-wide text-[#8FA6BC]">
                  <th class="px-4 py-3 font-medium">Nr.</th>
                  <th class="px-4 py-3 font-medium">Data</th>
                  <th class="px-4 py-3 font-medium">Explicație</th>
                  <th class="px-4 py-3 font-medium text-right">Debit</th>
                  <th class="px-4 py-3 font-medium text-right">Credit</th>
                  <th class="px-4 py-3 font-medium text-right">Sold</th>
                </tr>
                <tr><th colspan="6" class="p-0"><div class="h-px bg-white/10"></div></th></tr>
              </thead>
              <tbody>
                {data.lines.slice(0, 3).map((l) => (
                  <tr class="hover:bg-white/5 transition-colors">
                    <td class="px-4 py-2.5 font-mono font-semibold text-white">{l.entryNumber}</td>
                    <td class="px-4 py-2.5 tabular-nums text-[#A8BED2]">{l.entryDate}</td>
                    <td class="px-4 py-2.5 text-[#A8BED2] max-w-[280px] truncate">{l.note || l.description || ''}</td>
                    <td class="px-4 py-2.5 text-right tabular-nums text-white">{l.debitCents ? ron(l.debitCents) : ''}</td>
                    <td class="px-4 py-2.5 text-right tabular-nums text-white">{l.creditCents ? ron(l.creditCents) : ''}</td>
                    <td class="px-4 py-2.5 text-right tabular-nums text-white font-semibold">{balanceLabel(l.runningBalance)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            {data.lines.length > 3 && (
              <details class="mt-2.5">
                <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({data.lines.length})</summary>
                <table class="w-full text-[14px] mt-2.5">
                  <tbody>
                    {data.lines.slice(3).map((l) => (
                      <tr class="hover:bg-white/5 transition-colors">
                        <td class="px-4 py-2.5 font-mono font-semibold text-white">{l.entryNumber}</td>
                        <td class="px-4 py-2.5 tabular-nums text-[#A8BED2]">{l.entryDate}</td>
                        <td class="px-4 py-2.5 text-[#A8BED2] max-w-[280px] truncate">{l.note || l.description || ''}</td>
                        <td class="px-4 py-2.5 text-right tabular-nums text-white">{l.debitCents ? ron(l.debitCents) : ''}</td>
                        <td class="px-4 py-2.5 text-right tabular-nums text-white">{l.creditCents ? ron(l.creditCents) : ''}</td>
                        <td class="px-4 py-2.5 text-right tabular-nums text-white font-semibold">{balanceLabel(l.runningBalance)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </details>
            )}
          </div>
        )}
      </div>
    </>
  )}
</AppLayout>
