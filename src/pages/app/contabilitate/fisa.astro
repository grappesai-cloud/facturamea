---
import AppLayout from '../../../layouts/AppLayout.astro';
import { accountLedger, listAccounts } from '../../../lib/accounting';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

const now = new Date();
const yearStart = `${now.getFullYear()}-01-01`;
const yearEnd = `${now.getFullYear()}-12-31`;
const code = Astro.url.searchParams.get('cont') || '';
const from = Astro.url.searchParams.get('from') || yearStart;
const to = Astro.url.searchParams.get('to') || yearEnd;

const accounts = await listAccounts(companyId).catch(() => []);
const data = code
  ? await accountLedger(companyId, code, from, to).catch(() => ({ name: code, lines: [], opening: 0 }))
  : { name: '', lines: [], opening: 0 };

const balanceLabel = (cents: number) =>
  cents > 0 ? `${ron(cents)} (debitor)` : cents < 0 ? `${ron(-cents)} (creditor)` : ron(0);
---

<AppLayout title="Fișa contului" activeTab="contabilitate">
  <div class="mb-6">
    <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Fișa contului</h1>
    <p class="text-[15px] text-[#6B6B68] mt-1">Toate mișcările unui cont, cu sold curent.</p>
  </div>

  <form method="GET" class="flex flex-wrap items-end gap-3 mb-6 px-5 py-4 bg-white border border-[#E8E8E4] rounded-2xl">
    <div>
      <label class="block text-[13px] font-medium text-[#6B6B68] mb-1.5">Cont</label>
      <select name="cont" class="h-11 px-3 rounded-xl border border-[#E0E0DA] bg-white text-[15px] focus:outline-none focus:border-[#FF5C00] min-w-[200px]">
        <option value="">Alege contul</option>
        {accounts.map((a) => (
          <option value={a.code} selected={a.code === code}>{a.code} · {a.name}</option>
        ))}
      </select>
    </div>
    <div>
      <label class="block text-[13px] font-medium text-[#6B6B68] mb-1.5">De la</label>
      <input type="date" name="from" value={from} class="h-11 px-3 rounded-xl border border-[#E0E0DA] bg-white text-[15px] focus:outline-none focus:border-[#FF5C00]" />
    </div>
    <div>
      <label class="block text-[13px] font-medium text-[#6B6B68] mb-1.5">Până la</label>
      <input type="date" name="to" value={to} class="h-11 px-3 rounded-xl border border-[#E0E0DA] bg-white text-[15px] focus:outline-none focus:border-[#FF5C00]" />
    </div>
    <button type="submit" class="px-5 h-11 rounded-xl bg-[#0A0A0A] text-white text-[15px] font-semibold hover:bg-[#1a1a1a] transition-colors">Afișează</button>
  </form>

  {!code ? (
    <div class="bg-white border border-[#E8E8E4] rounded-2xl px-5 py-14 text-center text-[15px] text-[#6B6B68]">Alege un cont pentru a vedea fișa.</div>
  ) : (
    <>
      <div class="mb-4 px-5 py-4 bg-white border border-[#E8E8E4] rounded-2xl flex flex-wrap items-center gap-4">
        <div>
          <p class="text-[13px] text-[#8A8A85] uppercase tracking-wide">Cont</p>
          <p class="text-[18px] font-bold"><span class="font-mono">{code}</span> · {data.name}</p>
        </div>
        <div class="sm:ml-auto">
          <p class="text-[13px] text-[#8A8A85] uppercase tracking-wide">Sold inițial</p>
          <p class="text-[16px] font-bold tabular-nums">{balanceLabel(data.opening)}</p>
        </div>
      </div>

      <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
        {data.lines.length === 0 ? (
          <div class="px-5 py-14 text-center text-[15px] text-[#6B6B68]">Nicio mișcare în perioada selectată.</div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-[14px]">
              <thead>
                <tr class="text-left text-[12px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC] bg-[#FAFAF8]">
                  <th class="px-4 py-3 font-medium">Nr.</th>
                  <th class="px-4 py-3 font-medium">Data</th>
                  <th class="px-4 py-3 font-medium">Explicație</th>
                  <th class="px-4 py-3 font-medium text-right">Debit</th>
                  <th class="px-4 py-3 font-medium text-right">Credit</th>
                  <th class="px-4 py-3 font-medium text-right">Sold</th>
                </tr>
              </thead>
              <tbody>
                {data.lines.map((l) => (
                  <tr class="border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors">
                    <td class="px-4 py-2.5 font-mono font-semibold text-[#0A0A0A]">{l.entryNumber}</td>
                    <td class="px-4 py-2.5 tabular-nums text-[#6B6B68]">{l.entryDate}</td>
                    <td class="px-4 py-2.5 text-[#3D3D3A] max-w-[280px] truncate">{l.note || l.description || ''}</td>
                    <td class="px-4 py-2.5 text-right tabular-nums">{l.debitCents ? ron(l.debitCents) : ''}</td>
                    <td class="px-4 py-2.5 text-right tabular-nums">{l.creditCents ? ron(l.creditCents) : ''}</td>
                    <td class="px-4 py-2.5 text-right tabular-nums font-semibold">{balanceLabel(l.runningBalance)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </>
  )}
</AppLayout>
