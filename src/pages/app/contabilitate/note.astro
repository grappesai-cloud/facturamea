---
import AppLayout from '../../../layouts/AppLayout.astro';
import EntryForm from '../../../components/contabilitate/EntryForm';
import { db } from '../../../db';
import { journalEntries, journalLines } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

const SOURCE_LABELS: Record<string, string> = {
  manual: 'Manuală', invoice: 'Factură', expense: 'Cheltuială',
  payment: 'Încasare', bank: 'Bancă', depreciation: 'Amortizare',
};

let entries: any[] = [];
const linesByEntry = new Map<string, any[]>();
try {
  entries = await db
    .select()
    .from(journalEntries)
    .where(eq(journalEntries.companyId, companyId))
    .orderBy(desc(journalEntries.entryDate), desc(journalEntries.entryNumber))
    .limit(200);

  const ids = new Set(entries.map((e) => e.id));
  if (ids.size > 0) {
    const allLines = await db.select().from(journalLines).where(eq(journalLines.companyId, companyId));
    for (const l of allLines) {
      if (!ids.has(l.entryId)) continue;
      const arr = linesByEntry.get(l.entryId) || [];
      arr.push(l);
      linesByEntry.set(l.entryId, arr);
    }
  }
} catch (e) {
  // DB not provisioned.
}
---

<AppLayout title="Note contabile" activeTab="contabilitate">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Note contabile</h1>
      <p class="text-[15px] text-[#6B6B68] mt-1">Înregistrări în partidă dublă, manuale și generate automat.</p>
    </div>
  </div>

  <div class="mb-6">
    <EntryForm client:load />
  </div>

  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    {entries.length === 0 ? (
      <div class="px-5 py-14 text-center">
        <p class="text-[16px] text-[#6B6B68]">Nicio notă contabilă încă.</p>
        <p class="text-[14px] text-[#8A8A85] mt-1.5">Adaugă una manual mai sus sau generează note din facturi și cheltuieli.</p>
      </div>
    ) : (
      <div class="divide-y divide-[#F0F0EC]">
        {entries.map((e) => {
          const lines = linesByEntry.get(e.id) || [];
          return (
            <details class="group">
              <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer hover:bg-[#FAFAF8] transition-colors list-none">
                <span class="font-mono font-semibold text-[15px] w-[110px] shrink-0">{e.entryNumber}</span>
                <span class="text-[14px] text-[#6B6B68] w-[100px] shrink-0 tabular-nums">{e.entryDate}</span>
                <span class="flex-1 min-w-0 text-[15px] text-[#3D3D3A] truncate">{e.description || 'Fără descriere'}</span>
                <span class="hidden sm:inline-block px-2.5 py-1 rounded-lg text-[12px] font-medium bg-[#F0F0EC] text-[#6B6B68] shrink-0">{SOURCE_LABELS[e.source] || e.source}</span>
                <span class="text-[15px] font-bold tabular-nums shrink-0 w-[120px] text-right">{ron(e.totalDebitCents)}</span>
                <svg class="w-5 h-5 text-[#8A8A85] shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-4 bg-[#FAFAF8]">
                <table class="w-full text-[14px] mt-1">
                  <thead>
                    <tr class="text-left text-[12px] uppercase tracking-wide text-[#8A8A85]">
                      <th class="py-2 font-medium">Cont</th>
                      <th class="py-2 font-medium">Explicație</th>
                      <th class="py-2 font-medium text-right">Debit</th>
                      <th class="py-2 font-medium text-right">Credit</th>
                    </tr>
                  </thead>
                  <tbody>
                    {lines.map((l: any) => (
                      <tr class="border-t border-[#E8E8E4]">
                        <td class="py-2 font-mono font-semibold text-[#0A0A0A]">{l.accountCode}</td>
                        <td class="py-2 text-[#6B6B68]">{l.note || '·'}</td>
                        <td class="py-2 text-right tabular-nums">{l.debitCents ? ron(l.debitCents) : '·'}</td>
                        <td class="py-2 text-right tabular-nums">{l.creditCents ? ron(l.creditCents) : '·'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </details>
          );
        })}
      </div>
    )}
  </div>
</AppLayout>
