---
import AppLayout from '../../../layouts/AppLayout.astro';
import EntryForm from '../../../components/contabilitate/EntryForm';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { db } from '../../../db';
import { journalEntries, journalLines } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

let entries: any[] = [];
const linesByEntry = new Map<string, any[]>();
try {
  entries = await db
    .select()
    .from(journalEntries)
    .where(eq(journalEntries.companyId, companyId))
    .orderBy(desc(journalEntries.entryDate), desc(journalEntries.entryNumber))
    .limit(200);

  const ids = new Set(entries.map((e) => e.id));
  if (ids.size > 0) {
    const allLines = await db.select().from(journalLines).where(eq(journalLines.companyId, companyId));
    for (const l of allLines) {
      if (!ids.has(l.entryId)) continue;
      const arr = linesByEntry.get(l.entryId) || [];
      arr.push(l);
      linesByEntry.set(l.entryId, arr);
    }
  }
} catch (e) {
  // DB not provisioned.
}
---

<AppLayout title="Note contabile" activeTab="contabilitate">
  <div class="mb-8 sm:mb-10 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Note contabile</h1>
      <p class="text-[15px] text-[#A8BED2] mt-2">Înregistrări manuale și note generate automat.</p>
    </div>
  </div>

  <div class="mb-6">
    <EntryForm client:load />
  </div>

  <div class={entries.length === 0 ? '' : 'rounded-2xl bg-white/5'}>
    {entries.length === 0 ? (
      <EmptyState title="Nicio notă contabilă încă" description="Adaugă una manual mai sus sau generează note automat din facturi și cheltuieli.">
        <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m.75 12l2.25 2.25L15 12m-6.75 5.25h7.5M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      </EmptyState>
    ) : (
      <div>
        {entries.slice(0, 3).map((e) => {
          const lines = linesByEntry.get(e.id) || [];
          return (
            <details class="group">
              <summary class="flex items-center gap-3 px-4 sm:px-5 py-4 cursor-pointer hover:bg-white/5 transition-colors list-none">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2.5">
                    <span class="font-mono font-semibold text-[15px] text-white shrink-0">{e.entryNumber}</span>
                    <span class="text-[13px] text-[#A8BED2] shrink-0 tabular-nums">{e.entryDate}</span>
                  </div>
                  <div class="text-[14px] text-[#A8BED2] truncate mt-0.5">{e.description || 'Fără descriere'}</div>
                </div>
                <span class="text-[15px] font-bold tabular-nums text-white shrink-0 text-right">{ron(e.totalDebitCents)}</span>
                <svg class="w-5 h-5 text-[#8FA6BC] shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-4 sm:px-5 pb-4">
                <!-- Desktop table -->
                <table class="hidden sm:table w-full text-[14px] mt-1">
                  <thead>
                    <tr class="text-left text-[11px] uppercase tracking-wide text-[#8FA6BC]">
                      <th class="py-2 font-medium">Cont</th>
                      <th class="py-2 font-medium">Explicație</th>
                      <th class="py-2 font-medium text-right">Debit</th>
                      <th class="py-2 font-medium text-right">Credit</th>
                    </tr>
                    <tr><th colspan="4" class="p-0"><div class="h-px bg-white/10"></div></th></tr>
                  </thead>
                  <tbody>
                    {lines.map((l: any) => (
                      <tr class="hover:bg-white/5">
                        <td class="py-2 pr-3 font-mono font-semibold text-white whitespace-nowrap">{l.accountCode}</td>
                        <td class="py-2 pr-3 text-[#A8BED2]">{l.note || '·'}</td>
                        <td class="py-2 pl-3 text-right tabular-nums text-white whitespace-nowrap">{l.debitCents ? ron(l.debitCents) : '·'}</td>
                        <td class="py-2 pl-3 text-right tabular-nums text-white whitespace-nowrap">{l.creditCents ? ron(l.creditCents) : '·'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                <!-- Mobile cards -->
                <div class="sm:hidden mt-1 divide-y divide-white/[0.06]">
                  {lines.map((l: any) => (
                    <div class="py-2.5">
                      <div class="flex items-center gap-2">
                        <span class="font-mono font-semibold text-[14px] text-white shrink-0">{l.accountCode}</span>
                        <span class={`shrink-0 px-1.5 py-0.5 rounded text-[11px] font-medium ${l.debitCents ? 'bg-white/10 text-[#A8BED2]' : 'bg-white/10 text-[#8FA6BC]'}`}>{l.debitCents ? 'D' : 'C'}</span>
                        <span class="flex-1"></span>
                        <span class="tabular-nums text-[14px] text-white whitespace-nowrap">{ron(l.debitCents || l.creditCents)}</span>
                      </div>
                      {l.note && <p class="text-[13px] text-[#A8BED2] mt-1 break-words">{l.note}</p>}
                    </div>
                  ))}
                </div>
                {e.source === 'manual' && (
                  <button type="button" data-del-entry={e.id} class="mt-3 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-medium text-[#DC4B41] bg-[#DC4B41]/10 hover:bg-[#DC4B41]/20 transition-colors">Șterge nota</button>
                )}
              </div>
            </details>
          );
        })}
        {entries.length > 3 && (
          <details class="mt-2.5">
            <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({entries.length})</summary>
            <div class="mt-2.5">
              {entries.slice(3).map((e) => {
                const lines = linesByEntry.get(e.id) || [];
                return (
                  <details class="group">
                    <summary class="flex items-center gap-3 px-4 sm:px-5 py-4 cursor-pointer hover:bg-white/5 transition-colors list-none">
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2.5">
                          <span class="font-mono font-semibold text-[15px] text-white shrink-0">{e.entryNumber}</span>
                          <span class="text-[13px] text-[#A8BED2] shrink-0 tabular-nums">{e.entryDate}</span>
                        </div>
                        <div class="text-[14px] text-[#A8BED2] truncate mt-0.5">{e.description || 'Fără descriere'}</div>
                      </div>
                      <span class="text-[15px] font-bold tabular-nums text-white shrink-0 text-right">{ron(e.totalDebitCents)}</span>
                      <svg class="w-5 h-5 text-[#8FA6BC] shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="px-4 sm:px-5 pb-4">
                      <!-- Desktop table -->
                      <table class="hidden sm:table w-full text-[14px] mt-1">
                        <thead>
                          <tr class="text-left text-[11px] uppercase tracking-wide text-[#8FA6BC]">
                            <th class="py-2 font-medium">Cont</th>
                            <th class="py-2 font-medium">Explicație</th>
                            <th class="py-2 font-medium text-right">Debit</th>
                            <th class="py-2 font-medium text-right">Credit</th>
                          </tr>
                          <tr><th colspan="4" class="p-0"><div class="h-px bg-white/10"></div></th></tr>
                        </thead>
                        <tbody>
                          {lines.map((l: any) => (
                            <tr class="hover:bg-white/5">
                              <td class="py-2 pr-3 font-mono font-semibold text-white whitespace-nowrap">{l.accountCode}</td>
                              <td class="py-2 pr-3 text-[#A8BED2]">{l.note || '·'}</td>
                              <td class="py-2 pl-3 text-right tabular-nums text-white whitespace-nowrap">{l.debitCents ? ron(l.debitCents) : '·'}</td>
                              <td class="py-2 pl-3 text-right tabular-nums text-white whitespace-nowrap">{l.creditCents ? ron(l.creditCents) : '·'}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                      <!-- Mobile cards -->
                      <div class="sm:hidden mt-1 divide-y divide-white/[0.06]">
                        {lines.map((l: any) => (
                          <div class="py-2.5">
                            <div class="flex items-center gap-2">
                              <span class="font-mono font-semibold text-[14px] text-white shrink-0">{l.accountCode}</span>
                              <span class={`shrink-0 px-1.5 py-0.5 rounded text-[11px] font-medium ${l.debitCents ? 'bg-white/10 text-[#A8BED2]' : 'bg-white/10 text-[#8FA6BC]'}`}>{l.debitCents ? 'D' : 'C'}</span>
                              <span class="flex-1"></span>
                              <span class="tabular-nums text-[14px] text-white whitespace-nowrap">{ron(l.debitCents || l.creditCents)}</span>
                            </div>
                            {l.note && <p class="text-[13px] text-[#A8BED2] mt-1 break-words">{l.note}</p>}
                          </div>
                        ))}
                      </div>
                      {e.source === 'manual' && (
                        <button type="button" data-del-entry={e.id} class="mt-3 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-medium text-[#DC4B41] bg-[#DC4B41]/10 hover:bg-[#DC4B41]/20 transition-colors">Șterge nota</button>
                      )}
                    </div>
                  </details>
                );
              })}
            </div>
          </details>
        )}
      </div>
    )}
  </div>

  <script is:inline>
    document.addEventListener('astro:page-load', function () {
      if (document.documentElement.dataset.noteDelBound) return;
      document.documentElement.dataset.noteDelBound = '1';
      document.addEventListener('click', function (ev) {
        var btn = ev.target.closest ? ev.target.closest('[data-del-entry]') : null;
        if (!btn) return;
        ev.preventDefault();
        var id = btn.getAttribute('data-del-entry');
        if (!confirm('Ștergi definitiv această notă contabilă manuală?')) return;
        btn.disabled = true;
        fetch('/api/contabilitate/entries?id=' + encodeURIComponent(id), { method: 'DELETE' })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
          .then(function (res) { if (res.ok) window.location.reload(); else { alert(res.d.error || 'Eroare'); btn.disabled = false; } })
          .catch(function () { btn.disabled = false; });
      });
    });
  </script>
</AppLayout>
