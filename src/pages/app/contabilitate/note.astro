---
import AppLayout from '../../../layouts/AppLayout.astro';
import EntryForm from '../../../components/contabilitate/EntryForm';
import { db } from '../../../db';
import { journalEntries, journalLines } from '../../../db/schema';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

const SOURCE_LABELS: Record<string, string> = {
  manual: 'Manuală', invoice: 'Factură', expense: 'Cheltuială',
  payment: 'Încasare', bank: 'Bancă', depreciation: 'Amortizare',
};

let entries: any[] = [];
const linesByEntry = new Map<string, any[]>();
try {
  entries = await db
    .select()
    .from(journalEntries)
    .where(eq(journalEntries.companyId, companyId))
    .orderBy(desc(journalEntries.entryDate), desc(journalEntries.entryNumber))
    .limit(200);

  const ids = new Set(entries.map((e) => e.id));
  if (ids.size > 0) {
    const allLines = await db.select().from(journalLines).where(eq(journalLines.companyId, companyId));
    for (const l of allLines) {
      if (!ids.has(l.entryId)) continue;
      const arr = linesByEntry.get(l.entryId) || [];
      arr.push(l);
      linesByEntry.set(l.entryId, arr);
    }
  }
} catch (e) {
  // DB not provisioned.
}
---

<AppLayout title="Note contabile" activeTab="contabilitate">
  <a href="/app/contabilitate" class="inline-flex items-center gap-1.5 mb-4 text-[14px] font-medium text-[#A8BED2] hover:text-white transition-colors">← Contabilitate</a>
  <div class="mb-8 sm:mb-10 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Note contabile</h1>
      <p class="text-[15px] text-[#A8BED2] mt-2">Înregistrări manuale și note generate automat.</p>
    </div>
  </div>

  <div class="mb-6">
    <EntryForm client:load />
  </div>

  <div class="rounded-2xl bg-white/5 overflow-x-auto">
    {entries.length === 0 ? (
      <div class="px-5 py-14 text-center">
        <p class="text-[15px] text-white">Nicio notă contabilă încă.</p>
        <p class="text-[14px] text-[#A8BED2] mt-1.5">Adaugă una manual mai sus sau generează note din facturi și cheltuieli.</p>
      </div>
    ) : (
      <div>
        {entries.slice(0, 3).map((e) => {
          const lines = linesByEntry.get(e.id) || [];
          return (
            <details class="group">
              <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer hover:bg-white/5 transition-colors list-none">
                <span class="font-mono font-semibold text-[15px] text-white w-[110px] shrink-0">{e.entryNumber}</span>
                <span class="text-[14px] text-[#A8BED2] w-[100px] shrink-0 tabular-nums">{e.entryDate}</span>
                <span class="flex-1 min-w-0 text-[15px] text-white truncate">{e.description || 'Fără descriere'}</span>
                <span class="hidden sm:inline-block px-2.5 py-1 rounded-lg text-[12px] font-medium bg-white/10 text-[#A8BED2] shrink-0">{SOURCE_LABELS[e.source] || e.source}</span>
                <span class="text-[15px] font-bold tabular-nums text-white shrink-0 w-[120px] text-right">{ron(e.totalDebitCents)}</span>
                <svg class="w-5 h-5 text-[#8FA6BC] shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-4">
                <table class="w-full text-[14px] mt-1">
                  <thead>
                    <tr class="text-left text-[11px] uppercase tracking-wide text-[#8FA6BC]">
                      <th class="py-2 font-medium">Cont</th>
                      <th class="py-2 font-medium">Explicație</th>
                      <th class="py-2 font-medium text-right">Debit</th>
                      <th class="py-2 font-medium text-right">Credit</th>
                    </tr>
                    <tr><th colspan="4" class="p-0"><div class="h-px bg-white/10"></div></th></tr>
                  </thead>
                  <tbody>
                    {lines.map((l: any) => (
                      <tr class="hover:bg-white/5">
                        <td class="py-2 font-mono font-semibold text-white">{l.accountCode}</td>
                        <td class="py-2 text-[#A8BED2]">{l.note || '·'}</td>
                        <td class="py-2 text-right tabular-nums text-white">{l.debitCents ? ron(l.debitCents) : '·'}</td>
                        <td class="py-2 text-right tabular-nums text-white">{l.creditCents ? ron(l.creditCents) : '·'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                {e.source === 'manual' && (
                  <button type="button" data-del-entry={e.id} class="mt-3 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-medium text-[#DC4B41] bg-[#DC4B41]/10 hover:bg-[#DC4B41]/20 transition-colors">Șterge nota</button>
                )}
              </div>
            </details>
          );
        })}
        {entries.length > 3 && (
          <details class="mt-2.5">
            <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({entries.length})</summary>
            <div class="mt-2.5">
              {entries.slice(3).map((e) => {
                const lines = linesByEntry.get(e.id) || [];
                return (
                  <details class="group">
                    <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer hover:bg-white/5 transition-colors list-none">
                      <span class="font-mono font-semibold text-[15px] text-white w-[110px] shrink-0">{e.entryNumber}</span>
                      <span class="text-[14px] text-[#A8BED2] w-[100px] shrink-0 tabular-nums">{e.entryDate}</span>
                      <span class="flex-1 min-w-0 text-[15px] text-white truncate">{e.description || 'Fără descriere'}</span>
                      <span class="hidden sm:inline-block px-2.5 py-1 rounded-lg text-[12px] font-medium bg-white/10 text-[#A8BED2] shrink-0">{SOURCE_LABELS[e.source] || e.source}</span>
                      <span class="text-[15px] font-bold tabular-nums text-white shrink-0 w-[120px] text-right">{ron(e.totalDebitCents)}</span>
                      <svg class="w-5 h-5 text-[#8FA6BC] shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="px-5 pb-4">
                      <table class="w-full text-[14px] mt-1">
                        <thead>
                          <tr class="text-left text-[11px] uppercase tracking-wide text-[#8FA6BC]">
                            <th class="py-2 font-medium">Cont</th>
                            <th class="py-2 font-medium">Explicație</th>
                            <th class="py-2 font-medium text-right">Debit</th>
                            <th class="py-2 font-medium text-right">Credit</th>
                          </tr>
                          <tr><th colspan="4" class="p-0"><div class="h-px bg-white/10"></div></th></tr>
                        </thead>
                        <tbody>
                          {lines.map((l: any) => (
                            <tr class="hover:bg-white/5">
                              <td class="py-2 font-mono font-semibold text-white">{l.accountCode}</td>
                              <td class="py-2 text-[#A8BED2]">{l.note || '·'}</td>
                              <td class="py-2 text-right tabular-nums text-white">{l.debitCents ? ron(l.debitCents) : '·'}</td>
                              <td class="py-2 text-right tabular-nums text-white">{l.creditCents ? ron(l.creditCents) : '·'}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                      {e.source === 'manual' && (
                        <button type="button" data-del-entry={e.id} class="mt-3 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-medium text-[#DC4B41] bg-[#DC4B41]/10 hover:bg-[#DC4B41]/20 transition-colors">Șterge nota</button>
                      )}
                    </div>
                  </details>
                );
              })}
            </div>
          </details>
        )}
      </div>
    )}
  </div>

  <script is:inline>
    document.addEventListener('astro:page-load', function () {
      if (document.documentElement.dataset.noteDelBound) return;
      document.documentElement.dataset.noteDelBound = '1';
      document.addEventListener('click', function (ev) {
        var btn = ev.target.closest ? ev.target.closest('[data-del-entry]') : null;
        if (!btn) return;
        ev.preventDefault();
        var id = btn.getAttribute('data-del-entry');
        if (!confirm('Ștergi definitiv această notă contabilă manuală?')) return;
        btn.disabled = true;
        fetch('/api/contabilitate/entries?id=' + encodeURIComponent(id), { method: 'DELETE' })
          .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
          .then(function (res) { if (res.ok) window.location.reload(); else { alert(res.d.error || 'Eroare'); btn.disabled = false; } })
          .catch(function () { btn.disabled = false; });
      });
    });
  </script>
</AppLayout>
