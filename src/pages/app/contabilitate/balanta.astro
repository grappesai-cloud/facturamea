---
import AppLayout from '../../../layouts/AppLayout.astro';
import { trialBalance } from '../../../lib/accounting';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

// Default period: current year.
const now = new Date();
const yearStart = `${now.getFullYear()}-01-01`;
const yearEnd = `${now.getFullYear()}-12-31`;
const from = Astro.url.searchParams.get('from') || yearStart;
const to = Astro.url.searchParams.get('to') || yearEnd;

const rows = await trialBalance(companyId, from, to).catch(() => []);

const totals = rows.reduce(
  (acc, r) => {
    acc.openingDebit += r.openingDebit;
    acc.openingCredit += r.openingCredit;
    acc.periodDebit += r.periodDebit;
    acc.periodCredit += r.periodCredit;
    acc.closingDebit += r.closingDebit;
    acc.closingCredit += r.closingCredit;
    return acc;
  },
  { openingDebit: 0, openingCredit: 0, periodDebit: 0, periodCredit: 0, closingDebit: 0, closingCredit: 0 },
);
---

<AppLayout title="Balanță de verificare" activeTab="contabilitate">
  <div class="mb-6">
    <h1 class="text-[24px] font-bold tracking-[-0.02em] text-[#0A0A0A]">Balanță de verificare</h1>
    <p class="text-[15px] text-[#6B6B68] mt-1">Solduri inițiale, rulaje și solduri finale pe fiecare cont.</p>
  </div>

  <form method="GET" class="flex flex-wrap items-end gap-3 mb-6 px-5 py-4 bg-white border border-[#E8E8E4] rounded-2xl">
    <div>
      <label class="block text-[13px] font-medium text-[#6B6B68] mb-1.5">De la</label>
      <input type="date" name="from" value={from} class="h-11 px-3 rounded-xl border border-[#E0E0DA] bg-white text-[15px] focus:outline-none focus:border-[#FF5C00]" />
    </div>
    <div>
      <label class="block text-[13px] font-medium text-[#6B6B68] mb-1.5">Până la</label>
      <input type="date" name="to" value={to} class="h-11 px-3 rounded-xl border border-[#E0E0DA] bg-white text-[15px] focus:outline-none focus:border-[#FF5C00]" />
    </div>
    <button type="submit" class="px-5 h-11 rounded-xl bg-[#0A0A0A] text-white text-[15px] font-semibold hover:bg-[#1a1a1a] transition-colors">Calculează</button>
  </form>

  <div class="bg-white border border-[#E8E8E4] rounded-2xl overflow-hidden">
    {rows.length === 0 ? (
      <div class="px-5 py-14 text-center text-[15px] text-[#6B6B68]">Nicio mișcare contabilă în perioada selectată.</div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-[14px]">
          <thead>
            <tr class="text-[12px] uppercase tracking-wider text-[#8A8A85] border-b border-[#F0F0EC] bg-[#FAFAF8]">
              <th class="px-3 py-3 font-medium text-left" rowspan="2">Cont</th>
              <th class="px-3 py-3 font-medium text-left" rowspan="2">Denumire</th>
              <th class="px-3 py-2 font-medium text-center border-l border-[#E8E8E4]" colspan="2">Sold inițial</th>
              <th class="px-3 py-2 font-medium text-center border-l border-[#E8E8E4]" colspan="2">Rulaj perioadă</th>
              <th class="px-3 py-2 font-medium text-center border-l border-[#E8E8E4]" colspan="2">Sold final</th>
            </tr>
            <tr class="text-[11px] uppercase tracking-wide text-[#8A8A85] border-b border-[#F0F0EC] bg-[#FAFAF8]">
              <th class="px-3 py-2 font-medium text-right border-l border-[#E8E8E4]">Debit</th>
              <th class="px-3 py-2 font-medium text-right">Credit</th>
              <th class="px-3 py-2 font-medium text-right border-l border-[#E8E8E4]">Debit</th>
              <th class="px-3 py-2 font-medium text-right">Credit</th>
              <th class="px-3 py-2 font-medium text-right border-l border-[#E8E8E4]">Debit</th>
              <th class="px-3 py-2 font-medium text-right">Credit</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr class="border-b border-[#F6F6F2] hover:bg-[#FAFAF8] transition-colors">
                <td class="px-3 py-2.5 font-mono font-semibold text-[#0A0A0A]">
                  <a href={`/app/contabilitate/fisa?cont=${r.code}`} class="hover:text-[#FF5C00]">{r.code}</a>
                </td>
                <td class="px-3 py-2.5 text-[#3D3D3A] max-w-[240px] truncate">{r.name}</td>
                <td class="px-3 py-2.5 text-right tabular-nums border-l border-[#F6F6F2]">{r.openingDebit ? ron(r.openingDebit) : ''}</td>
                <td class="px-3 py-2.5 text-right tabular-nums">{r.openingCredit ? ron(r.openingCredit) : ''}</td>
                <td class="px-3 py-2.5 text-right tabular-nums border-l border-[#F6F6F2]">{r.periodDebit ? ron(r.periodDebit) : ''}</td>
                <td class="px-3 py-2.5 text-right tabular-nums">{r.periodCredit ? ron(r.periodCredit) : ''}</td>
                <td class="px-3 py-2.5 text-right tabular-nums border-l border-[#F6F6F2] font-semibold">{r.closingDebit ? ron(r.closingDebit) : ''}</td>
                <td class="px-3 py-2.5 text-right tabular-nums font-semibold">{r.closingCredit ? ron(r.closingCredit) : ''}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="border-t-2 border-[#E8E8E4] font-bold bg-[#FAFAF8]">
              <td class="px-3 py-3" colspan="2">Total</td>
              <td class="px-3 py-3 text-right tabular-nums border-l border-[#E8E8E4]">{ron(totals.openingDebit)}</td>
              <td class="px-3 py-3 text-right tabular-nums">{ron(totals.openingCredit)}</td>
              <td class="px-3 py-3 text-right tabular-nums border-l border-[#E8E8E4]">{ron(totals.periodDebit)}</td>
              <td class="px-3 py-3 text-right tabular-nums">{ron(totals.periodCredit)}</td>
              <td class="px-3 py-3 text-right tabular-nums border-l border-[#E8E8E4]">{ron(totals.closingDebit)}</td>
              <td class="px-3 py-3 text-right tabular-nums">{ron(totals.closingCredit)}</td>
            </tr>
          </tfoot>
        </table>
      </div>
    )}
  </div>

  {rows.length > 0 && (totals.periodDebit !== totals.periodCredit) && (
    <p class="mt-3 text-[14px] text-[#B91C1C]">Atenție: rulajul debitor nu este egal cu cel creditor. Verifică notele contabile.</p>
  )}
</AppLayout>
