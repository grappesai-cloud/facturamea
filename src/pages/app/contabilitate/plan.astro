---
import AppLayout from '../../../layouts/AppLayout.astro';
import { db } from '../../../db';
import { ledgerAccounts } from '../../../db/schema';
import { eq, asc } from 'drizzle-orm';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const TYPE_LABELS: Record<string, string> = {
  A: 'Activ', P: 'Pasiv', B: 'Bifuncțional', V: 'Venit', C: 'Cheltuială',
};

let accounts: any[] = [];
try {
  accounts = await db
    .select()
    .from(ledgerAccounts)
    .where(eq(ledgerAccounts.companyId, companyId))
    .orderBy(asc(ledgerAccounts.code));
} catch (e) {
  // DB not provisioned.
}
---

<AppLayout title="Plan de conturi" activeTab="contabilitate">
  <a href="/app/contabilitate" class="inline-flex items-center gap-1.5 mb-4 text-[14px] font-medium text-[#A8BED2] hover:text-white transition-colors">← Contabilitate</a>
  <div class="mb-8 sm:mb-10 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Plan de conturi</h1>
      <p class="text-[15px] text-[#A8BED2] mt-2">Conturile firmei tale și tipul fiecăruia.</p>
    </div>
    <button id="add-btn" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      Cont nou
    </button>
  </div>

  <!-- Add/edit form -->
  <div id="form-card" class="hidden rounded-2xl p-5 sm:p-6 mb-6 bg-white/5">
    <div class="flex items-center justify-between mb-4">
      <h2 id="form-title" class="text-[18px] font-bold text-white">Cont nou</h2>
      <button id="form-close" class="w-9 h-9 rounded-lg hover:bg-white/10 text-[#A8BED2] flex items-center justify-center" aria-label="Închide">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <input type="hidden" id="f-id" />
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
      <div>
        <label class="block text-[13px] text-[#A8BED2] mb-1.5">Cod</label>
        <input id="f-code" type="text" placeholder="Ex: 5121" class="w-full rounded-xl bg-white/5 px-4 py-2.5 text-[14px] text-white placeholder:text-[#8FA6BC] focus:outline-none" />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-[13px] text-[#A8BED2] mb-1.5">Denumire</label>
        <input id="f-name" type="text" placeholder="Ex: Conturi la bănci în lei" class="w-full rounded-xl bg-white/5 px-4 py-2.5 text-[14px] text-white placeholder:text-[#8FA6BC] focus:outline-none" />
      </div>
      <div>
        <label class="block text-[13px] text-[#A8BED2] mb-1.5">Tip</label>
        <select id="f-type" class="w-full rounded-xl bg-white/5 px-4 py-2.5 text-[14px] text-white focus:outline-none">
          <option value="A">Activ</option>
          <option value="P">Pasiv</option>
          <option value="B">Bifuncțional</option>
          <option value="V">Venit</option>
          <option value="C">Cheltuială</option>
        </select>
      </div>
    </div>
    <p id="f-error" class="text-[14px] text-[#DC4B41] mt-3 hidden"></p>
    <div class="mt-4 flex items-center gap-3">
      <button id="f-save" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">Salvează</button>
      <button id="f-cancel" class="px-4 py-2.5 rounded-full bg-white/10 text-white font-semibold text-[14px] hover:bg-white/15 transition-colors">Renunță</button>
    </div>
  </div>

  <div class="rounded-2xl bg-white/5 p-4 sm:p-5">
    {accounts.length === 0 ? (
      <div class="px-5 py-14 text-center">
        <p class="text-[15px] text-[#A8BED2]">Planul de conturi nu este inițializat.</p>
        <a href="/app/contabilitate" class="inline-block mt-3 text-[15px] font-semibold text-[#E1FB15] hover:underline">Inițializează planul →</a>
      </div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-[14px]">
          <thead>
            <tr class="text-left text-[11px] uppercase tracking-wide text-[#8FA6BC]">
              <th class="px-4 py-3 font-medium">Cod</th>
              <th class="px-4 py-3 font-medium">Denumire</th>
              <th class="px-4 py-3 font-medium">Tip</th>
              <th class="px-4 py-3 font-medium">Stare</th>
              <th class="px-4 py-3 font-medium text-right">Acțiuni</th>
            </tr>
            <tr><th colspan="5" class="p-0"><div class="h-px bg-white/10"></div></th></tr>
          </thead>
          <tbody>
            {accounts.slice(0, 3).map((a) => (
              <tr class="hover:bg-white/5 transition-colors"
                data-id={a.id} data-code={a.code} data-name={a.name} data-type={a.type} data-active={a.isActive ? '1' : '0'}>
                <td class="px-4 py-3 font-mono font-semibold text-white">{a.code}</td>
                <td class="px-4 py-3 text-[#A8BED2]">{a.name}</td>
                <td class="px-4 py-3"><span class="px-2 py-0.5 rounded-lg text-[12px] font-medium bg-white/10 text-[#A8BED2]">{TYPE_LABELS[a.type] || a.type}</span></td>
                <td class="px-4 py-3">
                  {a.isActive
                    ? <span class="inline-block px-2.5 py-0.5 rounded-full text-[12px] font-medium bg-[#2E9E6A]/15 text-[#2E9E6A]">Activ</span>
                    : <span class="inline-block px-2.5 py-0.5 rounded-full text-[12px] font-medium bg-white/10 text-[#8FA6BC]">Inactiv</span>}
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <a href={`/app/contabilitate/fisa?cont=${a.code}`} class="inline-block px-3 py-1.5 rounded-full bg-white/10 text-white text-[13px] font-semibold hover:bg-white/15 transition-colors mr-1.5">Fișă</a>
                  <button class="edit-btn inline-block px-3 py-1.5 rounded-full bg-white/10 text-white text-[13px] font-semibold hover:bg-white/15 transition-colors">Editează</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        {accounts.length > 3 && (
          <details class="mt-2.5">
            <summary class="cursor-pointer list-none mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({accounts.length})</summary>
            <table class="w-full text-[14px] mt-2.5">
              <tbody>
                {accounts.slice(3).map((a) => (
                  <tr class="hover:bg-white/5 transition-colors"
                    data-id={a.id} data-code={a.code} data-name={a.name} data-type={a.type} data-active={a.isActive ? '1' : '0'}>
                    <td class="px-4 py-3 font-mono font-semibold text-white">{a.code}</td>
                    <td class="px-4 py-3 text-[#A8BED2]">{a.name}</td>
                    <td class="px-4 py-3"><span class="px-2 py-0.5 rounded-lg text-[12px] font-medium bg-white/10 text-[#A8BED2]">{TYPE_LABELS[a.type] || a.type}</span></td>
                    <td class="px-4 py-3">
                      {a.isActive
                        ? <span class="inline-block px-2.5 py-0.5 rounded-full text-[12px] font-medium bg-[#2E9E6A]/15 text-[#2E9E6A]">Activ</span>
                        : <span class="inline-block px-2.5 py-0.5 rounded-full text-[12px] font-medium bg-white/10 text-[#8FA6BC]">Inactiv</span>}
                    </td>
                    <td class="px-4 py-3 text-right whitespace-nowrap">
                      <a href={`/app/contabilitate/fisa?cont=${a.code}`} class="inline-block px-3 py-1.5 rounded-full bg-white/10 text-white text-[13px] font-semibold hover:bg-white/15 transition-colors mr-1.5">Fișă</a>
                      <button class="edit-btn inline-block px-3 py-1.5 rounded-full bg-white/10 text-white text-[13px] font-semibold hover:bg-white/15 transition-colors">Editează</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </details>
        )}
      </div>
    )}
  </div>

  <script>
    const card = document.getElementById('form-card');
    const title = document.getElementById('form-title');
    const fId = document.getElementById('f-id') as HTMLInputElement;
    const fCode = document.getElementById('f-code') as HTMLInputElement;
    const fName = document.getElementById('f-name') as HTMLInputElement;
    const fType = document.getElementById('f-type') as HTMLSelectElement;
    const fError = document.getElementById('f-error');
    const fSave = document.getElementById('f-save') as HTMLButtonElement;

    function showError(m: string) { if (fError) { fError.textContent = m; fError.classList.remove('hidden'); } }
    function clearError() { fError?.classList.add('hidden'); }

    function openForm(mode: 'add' | 'edit', data?: { id: string; code: string; name: string; type: string }) {
      clearError();
      card?.classList.remove('hidden');
      if (mode === 'add') {
        if (title) title.textContent = 'Cont nou';
        fId.value = ''; fCode.value = ''; fName.value = ''; fType.value = 'A';
        fCode.disabled = false;
      } else if (data) {
        if (title) title.textContent = `Editează ${data.code}`;
        fId.value = data.id; fCode.value = data.code; fName.value = data.name; fType.value = data.type;
        fCode.disabled = true; // code is immutable once created
      }
      card?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      fName.focus();
    }
    function closeForm() { card?.classList.add('hidden'); }

    document.getElementById('add-btn')?.addEventListener('click', () => openForm('add'));
    document.getElementById('form-close')?.addEventListener('click', closeForm);
    document.getElementById('f-cancel')?.addEventListener('click', closeForm);

    document.querySelectorAll('.edit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const row = btn.closest('tr');
        if (!row) return;
        openForm('edit', {
          id: row.getAttribute('data-id') || '',
          code: row.getAttribute('data-code') || '',
          name: row.getAttribute('data-name') || '',
          type: row.getAttribute('data-type') || 'A',
        });
      });
    });

    fSave?.addEventListener('click', async () => {
      clearError();
      const code = fCode.value.trim();
      const name = fName.value.trim();
      const type = fType.value;
      if (!name) { showError('Denumirea este obligatorie.'); return; }
      if (!fId.value && !code) { showError('Codul este obligatoriu.'); return; }
      fSave.disabled = true; fSave.textContent = 'Se salvează...';
      try {
        const isEdit = !!fId.value;
        const res = await fetch('/api/contabilitate/accounts', {
          method: isEdit ? 'PATCH' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(isEdit ? { id: fId.value, name, type } : { code, name, type }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) { showError(data.error || 'Eroare la salvare.'); fSave.disabled = false; fSave.textContent = 'Salvează'; return; }
        window.location.reload();
      } catch {
        showError('Eroare de conexiune.'); fSave.disabled = false; fSave.textContent = 'Salvează';
      }
    });
  </script>
</AppLayout>
