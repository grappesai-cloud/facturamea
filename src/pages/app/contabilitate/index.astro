---

<AppLayout title="Contabilitate" activeTab="contabilitate">
  <div class="mb-6 sm:mb-8">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Contabilitate</h1>
    <p class="text-[15px] text-[#A8BED2] mt-1.5">Note, jurnal, balanță și planul de conturi.</p>
  </div>

  {!hasChart ? (
    <div class="rounded-2xl p-6 sm:p-8 bg-white/5 text-center">
      <div class="w-14 h-14 rounded-2xl bg-[#E1FB15]/15 text-[#E1FB15] flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>
      </div>
      <h2 class="text-[19px] font-bold text-white">Pornește contabilitatea</h2>
      <p class="text-[14px] text-[#A8BED2] mt-1.5 max-w-[460px] mx-auto">Adăugăm planul de conturi românesc (conturi uzuale pentru vânzări, cheltuieli, TVA și trezorerie). Îl poți ajusta oricând.</p>
      <button id="setup-btn" class="mt-5 inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors">
        Inițializează planul de conturi
      </button>
      <p id="setup-msg" class="text-[14px] text-[#DC4B41] mt-3 hidden"></p>
    </div>
  ) : (
    <>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        {cards.map((c) => (
          <div class="rounded-2xl p-5 bg-white/5">
            <p class="text-[13px] text-[#A8BED2]">{c.label}</p>
            <p class={`text-[26px] sm:text-[30px] font-bold tracking-[-0.03em] mt-3 tabular-nums ${c.accent}`}>{c.value}</p>
          </div>
        ))}
      </div>

      <div class="flex flex-wrap items-center gap-4 mb-6 rounded-2xl p-5 bg-white/5">
        <div class="flex-1 min-w-[220px]">
          <p class="text-[16px] font-semibold text-white">Generează note din facturi și cheltuieli</p>
          <p class="text-[14px] text-[#A8BED2] mt-1">Creează automat note contabile pentru facturile emise, cheltuieli și încasări neînregistrate.</p>
        </div>
        <button id="autopost-btn" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E] transition-colors shrink-0">
          Generează note
        </button>
      </div>
      <p id="autopost-msg" class="text-[14px] mb-4 hidden"></p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 auto-rows-fr">
        {links.map((m) => (
          <a href={m.href} class="group flex items-start gap-4 rounded-2xl p-5 bg-white/5 hover:bg-white/[0.07] transition-colors">
            <span class="shrink-0 w-12 h-12 rounded-xl bg-[#E1FB15]/15 text-[#E1FB15] flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d={m.icon}/></svg>
            </span>
            <span class="min-w-0">
              <span class="block text-[17px] font-semibold leading-tight text-white">{m.label}</span>
              <span class="block text-[14px] text-[#A8BED2] mt-1">{m.desc}</span>
            </span>
          </a>
        ))}
      </div>
    </>
  )}

  <script>
    const setupBtn = document.getElementById('setup-btn');
    setupBtn?.addEventListener('click', async () => {
      const msg = document.getElementById('setup-msg');
      (setupBtn as HTMLButtonElement).disabled = true;
      setupBtn.textContent = 'Se inițializează...';
      try {
        const res = await fetch('/api/contabilitate/setup', { method: 'POST' });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) { window.location.reload(); return; }
        if (msg) { msg.textContent = data.error || 'Eroare la inițializare.'; msg.classList.remove('hidden'); }
        setupBtn.textContent = 'Inițializează planul de conturi';
        (setupBtn as HTMLButtonElement).disabled = false;
      } catch {
        if (msg) { msg.textContent = 'Eroare de conexiune.'; msg.classList.remove('hidden'); }
        setupBtn.textContent = 'Inițializează planul de conturi';
        (setupBtn as HTMLButtonElement).disabled = false;
      }
    });

    const autopostBtn = document.getElementById('autopost-btn');
    autopostBtn?.addEventListener('click', async () => {
      const msg = document.getElementById('autopost-msg');
      (autopostBtn as HTMLButtonElement).disabled = true;
      autopostBtn.textContent = 'Se generează...';
      try {
        const res = await fetch('/api/contabilitate/auto-post', { method: 'POST' });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          if (msg) {
            const total = (data.invoices || 0) + (data.expenses || 0) + (data.payments || 0);
            msg.textContent = total > 0
              ? `Am generat ${total} note (${data.invoices} facturi, ${data.expenses} cheltuieli, ${data.payments} încasări). Se reîncarcă...`
              : 'Toate documentele erau deja înregistrate.';
            msg.className = 'text-[14px] mb-4 text-[#2E9E6A]';
          }
          setTimeout(() => window.location.reload(), 900);
          return;
        }
        if (msg) { msg.textContent = data.error || 'Eroare la generare.'; msg.className = 'text-[14px] mb-4 text-[#DC4B41]'; }
        autopostBtn.textContent = 'Generează note';
        (autopostBtn as HTMLButtonElement).disabled = false;
      } catch {
        if (msg) { msg.textContent = 'Eroare de conexiune.'; msg.className = 'text-[14px] mb-4 text-[#DC4B41]'; }
        autopostBtn.textContent = 'Generează note';
        (autopostBtn as HTMLButtonElement).disabled = false;
      }
    });
  </script>
</AppLayout>
