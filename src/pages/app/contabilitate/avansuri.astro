---
import AppLayout from '../../../layouts/AppLayout.astro';
import { listAdvances } from '../../../lib/treasury-advances';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) => new Intl.NumberFormat('ro-RO', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format((cents || 0) / 100);
const advances = await listAdvances(companyId).catch(() => []);
const today = new Date().toISOString().slice(0, 10);

const totalOutstanding = advances.filter((a) => a.status === 'open').reduce((s, a) => s + a.balanceCents, 0);
const totalGranted = advances.reduce((s, a) => s + a.grantedCents, 0);
const inputCls = 'w-full rounded-xl bg-white/10 px-3 py-2 text-[14px] text-white placeholder:text-[#8FA6BC] focus:outline-none focus:ring-2 focus:ring-[#E1FB15]/40';
---

<AppLayout title="Avansuri de trezorerie" activeTab="contabilitate" breadcrumbTitle="Avansuri trezorerie">
  <div class="max-w-[1180px] mx-auto">
    <div class="mb-6">
      <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Avansuri de trezorerie</h1>
      <p class="text-[13px] text-[#A8BED2] mt-2">Avansuri date angajaților (cont 542). Acordare, apoi decont: justificat prin cheltuieli + rest restituit.</p>
    </div>

    <div class="grid grid-cols-2 gap-3 mb-6">
      <div class="rounded-2xl bg-white/5 p-4"><div class="text-[12px] text-[#A8BED2]">Sold nejustificat</div><div class="text-[24px] font-bold text-white tabular-nums">{ron(totalOutstanding)} <span class="text-[13px] text-[#A8BED2]">RON</span></div></div>
      <div class="rounded-2xl bg-white/5 p-4"><div class="text-[12px] text-[#A8BED2]">Total acordat</div><div class="text-[24px] font-bold text-white tabular-nums">{ron(totalGranted)} <span class="text-[13px] text-[#A8BED2]">RON</span></div></div>
    </div>

    <form id="grant-form" class="rounded-2xl bg-white/5 p-5 mb-8 grid grid-cols-1 sm:grid-cols-5 gap-3 items-end">
      <div class="sm:col-span-2"><label class="block text-[12px] text-[#A8BED2] mb-1">Angajat</label><input name="employeeName" required class={inputCls} placeholder="Nume angajat" /></div>
      <div><label class="block text-[12px] text-[#A8BED2] mb-1">Sumă (RON)</label><input name="amountRon" type="number" step="0.01" min="0" required class={inputCls} placeholder="0,00" /></div>
      <div><label class="block text-[12px] text-[#A8BED2] mb-1">Data</label><input name="grantedDate" type="date" value={today} required class={inputCls} /></div>
      <div><label class="block text-[12px] text-[#A8BED2] mb-1">Din</label>
        <select name="method" class={inputCls}><option value="cash">Casă</option><option value="bank">Bancă</option></select>
      </div>
      <div class="sm:col-span-5 flex items-center gap-3">
        <button type="submit" class="px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[14px] hover:bg-[#D2EA0E]">Acordă avans</button>
        <span id="grant-status" class="text-[13px] text-[#A8BED2]"></span>
      </div>
    </form>

    <div class="overflow-x-auto rounded-2xl bg-white/5">
      <table class="w-full text-[13px] text-white border-collapse">
        <thead>
          <tr class="text-[#A8BED2] text-left">
            <th class="px-3 py-2.5 font-semibold">Angajat</th>
            <th class="px-3 py-2.5 font-semibold">Data</th>
            <th class="px-3 py-2.5 font-semibold text-right">Acordat</th>
            <th class="px-3 py-2.5 font-semibold text-right">Justificat</th>
            <th class="px-3 py-2.5 font-semibold text-right">Restituit</th>
            <th class="px-3 py-2.5 font-semibold text-right">Sold</th>
            <th class="px-3 py-2.5 font-semibold">Status</th>
            <th class="px-3 py-2.5 font-semibold"></th>
          </tr>
        </thead>
        <tbody>
          {advances.length === 0 ? (
            <tr><td colspan={8} class="px-3 py-6 text-center text-[#A8BED2]">Niciun avans înregistrat.</td></tr>
          ) : advances.map((a) => (
            <Fragment>
              <tr class="border-t border-white/10" data-adv-row={a.id}>
                <td class="px-3 py-2">{a.employeeName}</td>
                <td class="px-3 py-2 whitespace-nowrap">{a.grantedDate}</td>
                <td class="px-3 py-2 text-right tabular-nums">{ron(a.grantedCents)}</td>
                <td class="px-3 py-2 text-right tabular-nums text-[#A8BED2]">{ron(a.settledCents)}</td>
                <td class="px-3 py-2 text-right tabular-nums text-[#A8BED2]">{ron(a.returnedCents)}</td>
                <td class="px-3 py-2 text-right tabular-nums font-semibold">{ron(a.balanceCents)}</td>
                <td class="px-3 py-2">{a.status === 'settled' ? <span class="text-[#52B788]">decontat</span> : <span class="text-[#E8A33C]">deschis</span>}</td>
                <td class="px-3 py-2 text-right whitespace-nowrap">
                  {a.status !== 'settled' && <button type="button" data-settle-toggle={a.id} class="text-[12px] font-semibold text-[#34A0A4] hover:text-[#52B788]">Decontează</button>}
                  <button type="button" data-del={a.id} class="ml-3 text-[12px] text-[#DC4B41]/80 hover:text-[#DC4B41]">Șterge</button>
                </td>
              </tr>
              <tr class="hidden border-t border-white/[0.06] bg-white/[0.03]" data-settle-row={a.id}>
                <td colspan={8} class="px-3 py-3">
                  <form data-settle-form={a.id} class="flex flex-wrap items-end gap-3">
                    <div><label class="block text-[11px] text-[#A8BED2] mb-1">Justificat (cheltuieli)</label><input name="settledRon" type="number" step="0.01" min="0" value={(a.settledCents / 100).toFixed(2)} class="rounded-lg bg-white/10 px-3 py-1.5 text-[13px] text-white w-32" /></div>
                    <div><label class="block text-[11px] text-[#A8BED2] mb-1">Restituit (rest)</label><input name="returnedRon" type="number" step="0.01" min="0" value={(a.returnedCents / 100).toFixed(2)} class="rounded-lg bg-white/10 px-3 py-1.5 text-[13px] text-white w-32" /></div>
                    <button type="submit" class="px-4 py-1.5 rounded-full bg-[#E1FB15] text-[#07090f] font-bold text-[13px]">Salvează decont</button>
                    <span class="text-[12px] text-[#8FA6BC]">Avans acordat: {ron(a.grantedCents)} · sold = acordat − justificat − restituit</span>
                  </form>
                </td>
              </tr>
            </Fragment>
          ))}
        </tbody>
      </table>
    </div>

    <p class="text-[12px] text-[#8FA6BC] mt-4 max-w-2xl">Contabil: acordare 542 = 5311/5121; decont 6xx/4426 = 542 (justificat) și 5311 = 542 (rest restituit) sau 542 = 5311 (supliment).</p>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const grant = document.getElementById('grant-form') as HTMLFormElement | null;
      const gStatus = document.getElementById('grant-status');
      grant?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const fd = new FormData(grant);
        if (gStatus) gStatus.textContent = 'Se salvează...';
        try {
          const res = await fetch('/api/contabilitate/avansuri', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(fd)) });
          const d = await res.json().catch(() => ({}));
          if (res.ok) location.reload(); else if (gStatus) gStatus.textContent = d.error || 'Eroare.';
        } catch { if (gStatus) gStatus.textContent = 'Eroare conexiune.'; }
      });

      document.querySelectorAll('[data-settle-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-settle-toggle');
          document.querySelector(`[data-settle-row="${id}"]`)?.classList.toggle('hidden');
        });
      });
      document.querySelectorAll('[data-settle-form]').forEach((form) => {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const id = form.getAttribute('data-settle-form');
          const fd = new FormData(form as HTMLFormElement);
          const res = await fetch(`/api/contabilitate/avansuri/${id}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(fd)) });
          if (res.ok) location.reload();
          else { const d = await res.json().catch(() => ({})); alert(d.error || 'Eroare la decont.'); }
        });
      });
      document.querySelectorAll('[data-del]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          if (!confirm('Ștergi acest avans?')) return;
          const id = btn.getAttribute('data-del');
          const res = await fetch(`/api/contabilitate/avansuri/${id}`, { method: 'DELETE' });
          if (res.ok) location.reload();
        });
      });
    });
  </script>
</AppLayout>
