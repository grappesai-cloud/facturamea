---
import AppLayout from '../../../layouts/AppLayout.astro';
import PeriodFilter from '../../../components/contabilitate/PeriodFilter';
import EmptyState from '../../../components/ui/EmptyState.astro';
import { journalRegister } from '../../../lib/accounting';

const user = Astro.locals.user!;
if (!user.companyId) return Astro.redirect('/app/setari');
const companyId = user.companyId;

const ron = (cents: number) =>
  new Intl.NumberFormat('ro-RO', { style: 'currency', currency: 'RON' }).format((cents || 0) / 100);

const SOURCE_LABELS: Record<string, string> = {
  manual: 'Manuală', invoice: 'Factură', expense: 'Cheltuială',
  payment: 'Încasare', bank: 'Bancă', depreciation: 'Amortizare',
};

// Default period: current year.
const now = new Date();
const yearStart = `${now.getFullYear()}-01-01`;
const yearEnd = `${now.getFullYear()}-12-31`;
const from = Astro.url.searchParams.get('from') || yearStart;
const to = Astro.url.searchParams.get('to') || yearEnd;

const entries = await journalRegister(companyId, from, to).catch(() => []);
const totalDebit = entries.reduce((s, e) => s + (e.totalDebitCents || 0), 0);
const totalCredit = entries.reduce((s, e) => s + (e.totalCreditCents || 0), 0);
---

<AppLayout title="Registru jurnal" activeTab="contabilitate">
  <div class="mb-8 sm:mb-10">
    <h1 class="text-[30px] sm:text-[40px] font-semibold tracking-[-0.03em] text-white">Registru jurnal</h1>
    <p class="text-[15px] text-[#A8BED2] mt-2">Toate operațiunile contabile, cronologic.</p>
  </div>

  <PeriodFilter client:load from={from} to={to} submitLabel="Filtrează" />

  <div class="rounded-2xl bg-white/5 p-4 sm:p-5">
    {entries.length === 0 ? (
      <EmptyState title="Nicio operațiune" description="Operațiunile contabile din perioadă apar aici.">
        <svg slot="icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
      </EmptyState>
    ) : (
      <div>
        <!-- Desktop table -->
        <div class="hidden sm:block overflow-x-auto">
          <table class="w-full text-[14px]">
            <thead>
              <tr class="text-left text-[11px] uppercase tracking-wide text-[#8FA6BC]">
                <th class="px-4 py-3 font-medium whitespace-nowrap">Nr.</th>
                <th class="px-4 py-3 font-medium whitespace-nowrap">Data</th>
                <th class="px-4 py-3 font-medium">Explicație</th>
                <th class="px-4 py-3 font-medium">Cont D</th>
                <th class="px-4 py-3 font-medium">Cont C</th>
                <th class="px-4 py-3 font-medium text-right">Debit</th>
                <th class="px-4 py-3 font-medium text-right">Credit</th>
              </tr>
              <tr><th colspan="7" class="p-0"><div class="h-px bg-white/10"></div></th></tr>
            </thead>
            <tbody>
              {entries.map((e) => (
                e.lines.map((l, idx) => (
                  <tr class={`hover:bg-white/5 transition-colors ${idx === 0 ? 'border-t border-white/10' : ''}`}>
                    <td class="px-4 py-2.5 font-mono font-semibold text-white whitespace-nowrap">{idx === 0 ? e.entryNumber : ''}</td>
                    <td class="px-4 py-2.5 tabular-nums text-[#A8BED2] whitespace-nowrap">{idx === 0 ? e.entryDate : ''}</td>
                    <td class="px-4 py-2.5 text-[#A8BED2] max-w-[280px] truncate">{idx === 0 ? (e.description || SOURCE_LABELS[e.source || 'manual'] || '') : (l.note || '')}</td>
                    <td class="px-4 py-2.5 font-mono text-white">{l.debitCents ? l.accountCode : ''}</td>
                    <td class="px-4 py-2.5 font-mono text-white">{l.creditCents ? l.accountCode : ''}</td>
                    <td class="px-4 py-2.5 text-right tabular-nums text-white whitespace-nowrap">{l.debitCents ? ron(l.debitCents) : ''}</td>
                    <td class="px-4 py-2.5 text-right tabular-nums text-white whitespace-nowrap">{l.creditCents ? ron(l.creditCents) : ''}</td>
                  </tr>
                ))
              ))}
            </tbody>
            <tfoot>
              <tr><td colspan="7" class="p-0"><div class="h-px bg-white/10"></div></td></tr>
              <tr class="font-bold text-[15px]">
                <td class="px-4 py-3.5 text-white" colspan="5">Total perioadă</td>
                <td class="px-4 py-3.5 text-right tabular-nums text-white whitespace-nowrap">{ron(totalDebit)}</td>
                <td class="px-4 py-3.5 text-right tabular-nums text-white whitespace-nowrap">{ron(totalCredit)}</td>
              </tr>
            </tfoot>
          </table>
        </div>

        <!-- Mobile cards -->
        <div class="sm:hidden divide-y divide-white/10">
          {entries.map((e, i) => (
            <div class={`jrn-card py-4 ${i >= 4 ? 'jrn-extra hidden' : ''}`}>
              <div class="flex items-baseline gap-2.5">
                <span class="font-mono font-semibold text-[15px] text-white shrink-0">{e.entryNumber}</span>
                <span class="text-[13px] tabular-nums text-[#A8BED2] shrink-0">{e.entryDate}</span>
              </div>
              <div class="text-[14px] text-[#A8BED2] mt-0.5 break-words">{e.description || SOURCE_LABELS[e.source || 'manual'] || ''}</div>
              <div class="mt-2.5 space-y-1.5">
                {e.lines.map((l) => (
                  <div class="flex items-center gap-2 text-[13.5px]">
                    <span class="font-mono text-white shrink-0 w-[52px]">{l.accountCode}</span>
                    <span class={`shrink-0 px-1.5 py-0.5 rounded text-[11px] font-medium ${l.debitCents ? 'bg-white/10 text-[#A8BED2]' : 'bg-white/10 text-[#8FA6BC]'}`}>{l.debitCents ? 'D' : 'C'}</span>
                    <span class="flex-1"></span>
                    <span class="tabular-nums text-white whitespace-nowrap">{ron(l.debitCents || l.creditCents)}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
          {entries.length > 4 && (
            <div class="pt-4">
              <button id="jrn-show-all" class="mx-auto w-fit flex items-center px-5 py-2.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[13.5px] font-semibold hover:bg-[#D2EA0E] transition-colors">Vezi toate ({entries.length})</button>
            </div>
          )}
          <div class="pt-4 flex items-center justify-between font-bold text-[15px]">
            <span class="text-white">Total perioadă</span>
            <span class="tabular-nums text-white whitespace-nowrap">{ron(totalDebit)}</span>
          </div>
        </div>
      </div>
      <script is:inline>
        document.getElementById('jrn-show-all')?.addEventListener('click', (ev) => {
          document.querySelectorAll('.jrn-extra').forEach((el) => el.classList.remove('hidden'));
          ev.currentTarget.parentElement?.remove();
        });
      </script>
    )}
  </div>
</AppLayout>
