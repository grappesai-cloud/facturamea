---
import AuthLayout from '../../layouts/AuthLayout.astro';
import { tFn } from '../../lib/i18n';

if (Astro.locals.user) {
  return Astro.redirect('/app');
}

const t = tFn(Astro.locals.locale);
---

<AuthLayout title={t('pages.auth.forgot_page_title')} tagline={t('pages.auth.forgot_tagline')}>
  <div class="space-y-6">
    <div>
      <h1 class="text-[26px] font-bold tracking-[-0.02em] text-[#0A2238] leading-tight">{t('pages.auth.forgot_title')}</h1>
      <p class="text-[13px] text-[#46627A] mt-1.5">{t('pages.auth.forgot_desc')}</p>
    </div>

    <div id="error-banner" class="hidden flex items-start gap-2 px-4 py-3 bg-white border border-[#DC4B41]/30 rounded-md">
      <span class="w-1.5 h-1.5 rounded-full bg-[#DC4B41] mt-1.5 shrink-0"></span>
      <p id="error-text" class="text-[13px] text-[#DC4B41]"></p>
    </div>

    <div id="success-banner" class="hidden px-5 py-4 bg-white border border-[#2E9E6A]/30 rounded-md">
      <div class="flex items-start gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-[#2E9E6A] mt-1.5 shrink-0"></span>
        <div>
          <p class="text-[13px] text-[#0A2238] font-semibold">{t('pages.auth.forgot_success_title')}</p>
          <p class="text-[12px] text-[#46627A] mt-1">{t('pages.auth.forgot_success_text')}</p>
        </div>
      </div>
    </div>

    <form id="forgot-form" class="space-y-4">
      <div>
        <label for="email" class="block text-[12px] font-medium text-[#0A2238] mb-1.5">{t('pages.auth.forgot_email_label')}</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder={t('pages.auth.forgot_email_placeholder')}
          class="w-full px-4 py-2.5 bg-white border border-[#E2E8EF] rounded-md text-[14px] text-[#0A2238] placeholder:text-[#7C9AB4] focus:border-[#0A2238] focus:outline-none transition-colors"
        />
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full py-3 bg-[#0A2238] hover:bg-[#14304b] disabled:bg-[#0A2238]/60 disabled:cursor-not-allowed text-white font-semibold rounded-md text-[14px] transition-colors"
      >
        {t('pages.auth.forgot_submit')}
      </button>
    </form>

    <p class="text-center text-[13px] text-[#46627A]">
      {t('pages.auth.forgot_back_prompt')}{' '}
      <a href="/auth/login" class="text-[#0A2238] font-semibold hover:text-[#1A759F] transition-colors">
        {t('pages.auth.forgot_back_link')}
      </a>
    </p>
  </div>
</AuthLayout>

<script>
  const form = document.getElementById('forgot-form') as HTMLFormElement;
  const errBanner = document.getElementById('error-banner')!;
  const errText = document.getElementById('error-text')!;
  const okBanner = document.getElementById('success-banner')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errBanner.classList.add('hidden');
    okBanner.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Se trimite...';
    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: emailInput.value.trim().toLowerCase() }),
      });
      const data = await res.json();
      if (!res.ok) {
        errText.textContent = data.error || 'A apărut o eroare. Încearcă din nou în câteva minute.';
        errBanner.classList.remove('hidden');
      } else {
        form.classList.add('hidden');
        okBanner.classList.remove('hidden');
      }
    } catch {
      errText.textContent = 'Eroare de reţea. Verifică conexiunea.';
      errBanner.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Trimite linkul de resetare';
    }
  });
</script>
