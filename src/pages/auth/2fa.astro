---
import AuthLayout from '../../layouts/AuthLayout.astro';

// 2FA step for OAuth (Google/Apple) logins. The provider callback issues a
// short-lived `handle` and sends the user here; they enter their TOTP (or a
// recovery) code, which /api/auth/totp/verify exchanges for a full session.
const handle = Astro.url.searchParams.get('handle') || '';
if (!handle) return Astro.redirect('/auth/login');
---

<AuthLayout title="Verificare în doi pași">
  <div class="space-y-6">
    <div>
      <h1 class="text-[26px] font-bold tracking-[-0.02em] text-[#07090f] leading-tight">Verificare în doi pași</h1>
      <p class="text-[13px] text-[#46627A] mt-1.5">Introdu codul din aplicația ta de autentificare (Google Authenticator, Authy etc.).</p>
    </div>

    <div id="tfa-error" class="hidden flex items-start gap-2 px-4 py-3 bg-white border border-[#DC4B41]/30 rounded-xl">
      <span class="w-1.5 h-1.5 rounded-full bg-[#DC4B41] mt-1.5 shrink-0"></span>
      <p id="tfa-error-text" class="text-[13px] text-[#DC4B41]"></p>
    </div>

    <form id="tfa-form" class="space-y-4">
      <input type="hidden" id="tfa-handle" value={handle} />
      <div>
        <label id="tfa-label" class="block text-[12px] font-medium text-[#07090f] mb-1.5">Cod de 6 cifre</label>
        <input id="tfa-code" inputmode="numeric" autocomplete="one-time-code" autofocus
          class="w-full px-4 py-3 bg-white border border-[#E2E8EF] rounded-xl text-[18px] tracking-[6px] text-center font-mono text-[#07090f] focus:border-[#07090f] focus:outline-none transition-colors"
          placeholder="000000" />
      </div>
      <button type="submit" id="tfa-submit"
        class="w-full py-3 bg-[#07090f] hover:bg-[#14304b] disabled:bg-[#07090f]/60 text-white font-semibold rounded-xl text-[14px] transition-colors">
        Confirmă
      </button>
    </form>

    <button id="tfa-toggle" class="text-[13px] text-[#46627A] hover:text-[#07090f] transition-colors">
      Nu ai acces la aplicație? Folosește un cod de recuperare
    </button>
  </div>
</AuthLayout>

<script>
  const form = document.getElementById('tfa-form') as HTMLFormElement;
  const codeEl = document.getElementById('tfa-code') as HTMLInputElement;
  const labelEl = document.getElementById('tfa-label')!;
  const toggle = document.getElementById('tfa-toggle')!;
  const submit = document.getElementById('tfa-submit') as HTMLButtonElement;
  const errBox = document.getElementById('tfa-error')!;
  const errText = document.getElementById('tfa-error-text')!;
  const handle = (document.getElementById('tfa-handle') as HTMLInputElement).value;
  let recovery = false;

  toggle.addEventListener('click', () => {
    recovery = !recovery;
    if (recovery) {
      labelEl.textContent = 'Cod de recuperare';
      codeEl.placeholder = 'XXXXXXXX';
      codeEl.classList.remove('tracking-[6px]', 'text-center');
      toggle.textContent = 'Înapoi la codul din aplicație';
    } else {
      labelEl.textContent = 'Cod de 6 cifre';
      codeEl.placeholder = '000000';
      codeEl.classList.add('tracking-[6px]', 'text-center');
      toggle.textContent = 'Nu ai acces la aplicație? Folosește un cod de recuperare';
    }
    codeEl.value = '';
    codeEl.focus();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errBox.classList.add('hidden');
    const value = codeEl.value.trim();
    if (!value) return;
    submit.disabled = true; submit.textContent = 'Se verifică…';
    try {
      const res = await fetch('/api/auth/totp/verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(recovery ? { handle, recoveryCode: value } : { handle, code: value }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok && data.success) { window.location.href = '/app'; return; }
      errText.textContent = data.error || 'Cod incorect. Încearcă din nou.';
      errBox.classList.remove('hidden');
    } catch {
      errText.textContent = 'Eroare de rețea. Încearcă din nou.';
      errBox.classList.remove('hidden');
    } finally {
      submit.disabled = false; submit.textContent = 'Confirmă';
    }
  });
</script>
