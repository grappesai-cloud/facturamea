---
import PublicLayout from '../layouts/PublicLayout.astro';
import { tFn } from '../lib/i18n';

const t = tFn(Astro.locals.locale);
---

<PublicLayout title="404 · Pagina nu a fost găsită">
  <div class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="max-w-md w-full text-center">
      <div class="text-[120px] leading-none font-bold text-[#ECEBE5] select-none">404</div>
      <h1 class="text-[28px] font-bold text-[#0A0A0A] mt-4 tracking-tight">{t('app.errors.404_title')}</h1>
      <p class="text-[#6B6B68] mt-2">{t('app.errors.404_description')}</p>
      <div class="flex gap-3 justify-center mt-6">
        <a href="/" class="px-5 py-2.5 rounded-xl bg-[#0A0A0A] text-white text-sm font-semibold hover:bg-[#2E2E2C] transition-colors">
          {t('app.errors.back_home')}
        </a>
        <a href="/contact" class="px-5 py-2.5 rounded-xl border border-[#ECEBE5] text-[#0A0A0A] text-sm font-semibold hover:bg-[#FAFAF8] transition-colors">
          {t('app.errors.contact')}
        </a>
      </div>
    </div>
  </div>
</PublicLayout>
