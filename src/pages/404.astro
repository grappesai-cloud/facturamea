---
import PublicLayout from '../layouts/PublicLayout.astro';
import { tFn } from '../lib/i18n';

const t = tFn(Astro.locals.locale);
---

<PublicLayout title="404 · Pagina nu a fost găsită">
  <section class="relative min-h-[80vh] flex items-center justify-center px-4 overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_50%_at_50%_28%,rgba(26,117,159,0.10),transparent)]"></div>
    <div class="max-w-lg w-full text-center">
      <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-[#07090f]/[0.04] ring-1 ring-[#07090f]/10 text-[12px] font-semibold text-[#1A759F] uppercase tracking-wider">Eroare 404</span>
      <div class="mt-6 text-[clamp(92px,22vw,180px)] leading-[0.88] font-extrabold tracking-[-0.05em] text-transparent bg-clip-text bg-gradient-to-b from-[#07090f] via-[#1A759F] to-[#34A0A4] select-none">404</div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-[#07090f] tracking-[-0.02em] mt-5">{t('app.errors.404_title')}</h1>
      <p class="text-[#46627A] mt-3 text-[15px] leading-relaxed max-w-md mx-auto">{t('app.errors.404_description')}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center mt-8">
        <a href="/" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-[#E1FB15] text-[#07090f] text-[14px] font-bold hover:bg-[#D2EA0E] transition-colors shadow-[0_12px_30px_-12px_rgba(225,251,21,0.6)]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8M5 10v10h14V10"/></svg>
          {t('app.errors.back_home')}
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-6 py-3.5 rounded-full ring-1 ring-[#07090f]/15 text-[#07090f] text-[14px] font-semibold hover:bg-[#07090f]/[0.04] transition-colors">
          {t('app.errors.contact')}
        </a>
      </div>
    </div>
  </section>
</PublicLayout>
