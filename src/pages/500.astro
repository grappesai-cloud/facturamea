---
import PublicLayout from '../layouts/PublicLayout.astro';
import { tFn } from '../lib/i18n';

const t = tFn(Astro.locals.locale);
---

<PublicLayout title="500 · Eroare server">
  <section class="relative min-h-[80vh] flex items-center justify-center px-4 overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_50%_at_50%_28%,rgba(232,163,60,0.10),transparent)]"></div>
    <div class="max-w-lg w-full text-center">
      <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-[#0A2238]/[0.04] ring-1 ring-[#0A2238]/10 text-[12px] font-semibold text-[#E8A33C] uppercase tracking-wider">Eroare 500</span>
      <div class="mt-6 text-[clamp(92px,22vw,180px)] leading-[0.88] font-extrabold tracking-[-0.05em] text-transparent bg-clip-text bg-gradient-to-b from-[#0A2238] via-[#1A759F] to-[#34A0A4] select-none">500</div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-[#0A2238] tracking-[-0.02em] mt-5">{t('app.errors.500_title')}</h1>
      <p class="text-[#46627A] mt-3 text-[15px] leading-relaxed max-w-md mx-auto">{t('app.errors.500_description')}</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center mt-8">
        <button onclick="window.location.reload()" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-[#E1FB15] text-[#0A2238] text-[14px] font-bold hover:bg-[#D2EA0E] transition-colors shadow-[0_12px_30px_-12px_rgba(225,251,21,0.6)]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8m0-5v5h5"/></svg>
          {t('app.errors.retry')}
        </button>
        <a href="/" class="inline-flex items-center justify-center px-6 py-3.5 rounded-full ring-1 ring-[#0A2238]/15 text-[#0A2238] text-[14px] font-semibold hover:bg-[#0A2238]/[0.04] transition-colors">
          {t('app.errors.back_home')}
        </a>
      </div>
    </div>
  </section>
</PublicLayout>
