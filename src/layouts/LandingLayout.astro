---
// Light landing shell — floating glass navbar, smooth scroll (GSAP ScrollSmoother), light footer.
import BaseLayout from './BaseLayout.astro';
import PhoneFrame from '../components/PhoneFrame.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, ogImage, ogType, structuredData } = Astro.props;
const path = Astro.url.pathname;
const user = Astro.locals.user;
const homeHref = user ? '/app' : '/';


---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType={ogType} structuredData={structuredData} themeColor="#EDF1F5">
  <div
    data-landing
    class="relative text-[#0A2238] antialiased selection:bg-[#E1FB15] selection:text-[#0A2238]"
    style="font-family:'Outfit',ui-sans-serif,system-ui,sans-serif"
  >
    <!-- solid light background plate -->
    <div class="fixed inset-0 -z-10 bg-[#EDF1F5]" aria-hidden="true"></div>

    <!-- ═══ FLOATING GLASS NAVBAR ═══ -->
    <header id="lp-nav" class="fixed top-3 sm:top-4 inset-x-0 z-[60] px-3 sm:px-4 will-change-transform">
      <div class="mx-auto max-w-[1180px]">
        <div id="lp-nav-bar" class="flex items-center justify-between gap-3 transition-colors">
          <!-- Block 1 — logo (its own pill) -->
          <a href={homeHref} class="group shrink-0 flex items-center gap-2.5 h-14 sm:h-16 pl-3 pr-5 sm:pl-4 sm:pr-7 rounded-full bg-white/50 backdrop-blur-xl ring-1 ring-white/50 shadow-[0_8px_32px_-14px_rgba(16,42,67,0.22)]">
            <img src="/logo.png" alt="facturamea" width="60" height="60" class="w-14 h-14 sm:w-[60px] sm:h-[60px] transition-transform group-hover:rotate-6" />
          </a>

          <!-- Block 2 — actions (its own pill) -->
          <div class="flex items-center gap-2 h-14 sm:h-16 px-2 sm:px-2.5 rounded-full bg-white/50 backdrop-blur-xl ring-1 ring-white/50 shadow-[0_8px_32px_-14px_rgba(16,42,67,0.22)]">
            {user ? (
              <a href="/app" class="inline-flex items-center px-4 sm:px-6 h-10 sm:h-11 rounded-full bg-[#0A2238] text-white text-[14px] font-bold hover:bg-[#14304b] transition-colors" data-magnetic>Dashboard</a>
            ) : (
              <>
                <a href="/auth/login" class="inline-flex items-center px-4 sm:px-5 h-10 sm:h-11 rounded-full ring-1 ring-[#0A2238]/15 text-[#0A2238] text-[14px] font-semibold hover:bg-black/[0.04] transition-colors">Autentifică-te</a>
                <a href="/api/demo" class="inline-flex items-center px-4 sm:px-6 h-10 sm:h-11 rounded-full bg-[#0A2238] text-white text-[14px] font-bold hover:bg-[#14304b] transition-colors" data-magnetic>Intră în demo</a>
              </>
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- ═══ SMOOTH-SCROLL WRAPPER (navbar + progress stay outside) ═══ -->
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <main class="relative z-10">
          <slot />
        </main>

        <!-- ═══ FOOTER — full-width CTA card with a tilted, peeking phone ═══ -->
        <footer class="relative z-10 px-4 sm:px-6 pt-8 pb-8">
          <div class="mx-auto max-w-[1180px]">
            <div data-anim="scale" class="relative overflow-hidden rounded-[32px] bg-[#E0EFEA] px-7 py-10 sm:px-12 sm:py-12 lg:px-16 lg:py-10">
              <!-- decorative flowing script line -->
              <svg class="pointer-events-none absolute inset-x-0 bottom-0 w-full h-[72%] opacity-50" viewBox="0 0 1000 320" fill="none" preserveAspectRatio="xMidYMax meet" aria-hidden="true">
                <path d="M-30 230 C 200 120, 360 320, 560 210 S 820 60, 1060 190" stroke="#B7DCD0" stroke-width="4" stroke-linecap="round"/>
              </svg>

              <!-- LEFT: copy + CTA + app icons (constrained so it doesn't run under the phone) -->
              <div class="relative lg:max-w-[60%]">
                <p class="text-2xl sm:text-3xl lg:text-[2rem] font-bold text-[#0A2238] tracking-[-0.025em] leading-[1.16] max-w-xl">
                  Tot ce ai nevoie ca să facturezi, într-o singură aplicație. O singură plată, fără abonament.
                </p>
                <a href="/auth/register" data-magnetic class="inline-flex items-center mt-7 px-9 py-4 rounded-full bg-[#0A2238] text-white font-bold hover:bg-[#14304b] transition-colors">
                  Cumpără acces pe viață
                </a>
                <div class="mt-8 flex items-center gap-4">
                  <p class="text-sm text-[#46627A] font-medium leading-tight">Aplicația mobilă<br />e disponibilă acum</p>
                  <a href="/auth/register" aria-label="App Store" class="w-12 h-12 rounded-full ring-2 ring-[#0A2238]/25 grid place-items-center text-[#0A2238] hover:bg-[#0A2238] hover:text-white transition-colors">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16.4 12.9c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.8-1.4-.1-2.8.9-3.5.9s-1.8-.9-3-.8c-1.5 0-2.9.9-3.7 2.3-1.6 2.7-.4 6.8 1.1 9 .7 1.1 1.6 2.3 2.8 2.2 1.1 0 1.5-.7 2.9-.7s1.7.7 2.9.7 2-1.1 2.7-2.1c.9-1.2 1.2-2.4 1.2-2.5-.1 0-2.3-.9-2.3-3.4zM14.1 5.9c.6-.8 1-1.8.9-2.9-.9 0-2 .6-2.6 1.3-.6.7-1.1 1.7-1 2.7 1 .1 2-.5 2.7-1.1z"/></svg>
                  </a>
                  <a href="/auth/register" aria-label="Google Play" class="w-12 h-12 rounded-full ring-2 ring-[#0A2238]/25 grid place-items-center text-[#0A2238] hover:bg-[#0A2238] hover:text-white transition-colors">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M4 3.5v17a1 1 0 0 0 1.5.87l13-8.5a1 1 0 0 0 0-1.74l-13-8.5A1 1 0 0 0 4 3.5z"/></svg>
                  </a>
                </div>
              </div>

              <!-- DESKTOP phone: absolute (out of flow → card stays short), tilted, peeking from the bottom -->
              <div class="hidden lg:block absolute right-12 xl:right-20 top-8 w-[250px] rotate-[7deg]" aria-hidden="true">
                <PhoneFrame class="w-full aspect-[250/520]">
                  <div class="absolute inset-0 flex flex-col">
                    <div class="flex items-center justify-between px-7 pt-3 text-[11px] font-semibold text-[#0A2238]">
                      <span>9:41</span>
                      <span class="flex items-center gap-1 text-[#46627A]">
                        <svg width="15" height="11" viewBox="0 0 18 12" fill="currentColor"><rect x="0" y="7" width="3" height="5" rx="1"/><rect x="5" y="4" width="3" height="8" rx="1"/><rect x="10" y="1.5" width="3" height="10.5" rx="1"/><rect x="15" y="0" width="3" height="12" rx="1" opacity="0.4"/></svg>
                        <svg width="22" height="11" viewBox="0 0 26 13" fill="none"><rect x="0.6" y="0.6" width="21" height="11.8" rx="3" stroke="currentColor" stroke-opacity="0.5"/><rect x="2" y="2" width="16" height="9" rx="1.5" fill="currentColor"/><rect x="23" y="4" width="2" height="5" rx="1" fill="currentColor" fill-opacity="0.6"/></svg>
                      </span>
                    </div>
                    <div class="flex-1 px-4 pt-3 overflow-hidden">
                      <div class="flex items-center justify-between">
                        <span class="text-base font-bold text-[#0A2238]">factura<span class="text-[#1A759F]">mea</span></span>
                        <span class="w-8 h-8 rounded-full bg-[#EDF1F5] grid place-items-center"><span class="w-2 h-2 rounded-full bg-[#1A759F]"></span></span>
                      </div>
                      <div class="mt-3 rounded-2xl bg-[#0A2238] p-4 text-white">
                        <p class="text-[11px] text-[#9FB8CC]">Încasat luna asta</p>
                        <p class="text-2xl font-extrabold tabular-nums mt-0.5">48.250 <span class="text-base text-[#E1FB15]">lei</span></p>
                        <div class="mt-3 flex items-end gap-1 h-12">
                          {[40, 62, 48, 78, 58, 90, 70].map((h, i) => (
                            <div class="flex-1 rounded-t" style={`height:${h}%;background:${i === 5 ? '#E1FB15' : 'rgba(255,255,255,0.22)'}`}></div>
                          ))}
                        </div>
                      </div>
                      <div class="mt-3 grid grid-cols-2 gap-2.5">
                        <div class="rounded-2xl bg-[#E1FB15] p-3.5">
                          <p class="text-[12px] font-bold text-[#0A2238] leading-tight">Emite<br/>factură</p>
                          <span class="mt-4 inline-grid place-items-center w-7 h-7 rounded-full bg-[#0A2238] text-white">↗</span>
                        </div>
                        <div class="rounded-2xl bg-white ring-1 ring-black/[0.05] p-3.5">
                          <p class="text-[12px] font-bold text-[#0A2238] leading-tight">Trimite<br/>în SPV</p>
                          <span class="mt-4 inline-grid place-items-center w-7 h-7 rounded-full bg-[#F0F4F8] text-[#0A2238]">↗</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </PhoneFrame>
              </div>
            </div>

            <!-- slim legal bar -->
            <div class="mt-8 px-2 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-[#7C9AB4]">
              <a href={homeHref} class="flex items-center gap-2 font-semibold text-[#46627A] hover:text-[#0A2238] transition-colors">
                © {new Date().getFullYear()} facturamea
              </a>
              <div class="flex items-center gap-5">
                <a href="/#preturi" class="hover:text-[#1A759F] transition-colors">Prețuri</a>
                <a href="/blog" class="hover:text-[#1A759F] transition-colors">Blog</a>
                <a href="/#faq" class="hover:text-[#1A759F] transition-colors">Întrebări</a>
                <a href="/termeni" class="hover:text-[#1A759F] transition-colors">Termeni</a>
                <a href="/confidentialitate" class="hover:text-[#1A759F] transition-colors">Confidențialitate</a>
              </div>
            </div>
          </div>
        </footer>
      </div>
    </div>
  </div>

  <style>
    /* Pre-hide animated elements only when JS+motion are on, to avoid FOUC. */
    html.lp-anim [data-anim],
    html.lp-anim [data-anim-stagger] > *,
    html.lp-anim .hero-title,
    html.lp-anim .hero-line { opacity: 0; }
    @media (prefers-reduced-motion: reduce) {
      html.lp-anim [data-anim],
      html.lp-anim [data-anim-stagger] > *,
      html.lp-anim .hero-title,
      html.lp-anim .hero-line { opacity: 1 !important; }
    }
  </style>

  <!-- Enable pre-hide ASAP (skipped under reduced-motion); failsafe reveals if GSAP never boots. -->
  <script is:inline>
    (function () {
      try {
        var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!rm) document.documentElement.classList.add('lp-anim');
        setTimeout(function () {
          if (!window.__lpAnimReady) document.documentElement.classList.remove('lp-anim');
        }, 2600);
      } catch (e) {}
    })();
  </script>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { ScrollSmoother } from 'gsap/ScrollSmoother';
    import { SplitText } from 'gsap/SplitText';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    (window as any).__lpAnimReady = true;

    if (reduce) {
      document.documentElement.classList.remove('lp-anim');
    } else {
      gsap.registerPlugin(ScrollTrigger, ScrollSmoother, SplitText);

      const isMobile = window.matchMedia('(max-width: 1023px)').matches;
      const START = isMobile ? 'top 92%' : 'top 84%';
      const START_GROUP = isMobile ? 'top 90%' : 'top 82%';

      // ── Smooth scroll ────────────────────────────────────────────────────
      let smoother: ScrollSmoother | null = null;
      try {
        smoother = ScrollSmoother.create({
          wrapper: '#smooth-wrapper',
          content: '#smooth-content',
          smooth: 1.4,
          smoothTouch: 0,
          normalizeScroll: true,
          ignoreMobileResize: true,
          effects: false,
        });
      } catch (e) { smoother = null; }

      // Let overlays (e.g. the cookie modal) lock the smooth-scrolled background.
      // normalizeScroll hijacks wheel/touch globally, so a fixed modal can't
      // scroll on its own unless we pause the smoother + release normalizeScroll.
      (window as any).__lpScrollLock = (lock: boolean) => {
        try {
          if (smoother) smoother.paused(lock);
          ScrollTrigger.normalizeScroll(!lock);
        } catch (e) {}
      };

      // ── Navbar stays transparent (no tint) ───────────────────────────────

      // ── HERO entrance timeline (on load) ─────────────────────────────────
      const heroTitle = document.querySelector('.hero-title');
      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      if (heroTitle) {
        const split = new SplitText(heroTitle, { type: 'lines,chars', linesClass: 'overflow-hidden' });
        gsap.set(heroTitle, { opacity: 1 });
        tl.from(split.chars, { yPercent: 120, opacity: 0, stagger: 0.016, duration: 0.8, ease: 'power4.out' });
      }
      tl.fromTo('.hero-line', { y: 24, opacity: 0 }, { y: 0, opacity: 1, stagger: 0.1, duration: 0.6 }, heroTitle ? '-=0.45' : 0);
      gsap.fromTo('.hero-visual', { y: 50, opacity: 0, scale: 0.97 }, { y: 0, opacity: 1, scale: 1, duration: 1, ease: 'power3.out', delay: 0.2 });


      // ── HERO CHART: bars rise on reveal ──────────────────────────────────
      const chart = document.querySelector<HTMLElement>('[data-chart]');
      if (chart) {
        gsap.from(chart.querySelectorAll('.hero-bar'), {
          scaleY: 0, transformOrigin: 'bottom', opacity: 0, stagger: 0.06, duration: 0.75, ease: 'power3.out',
          scrollTrigger: { trigger: chart, start: isMobile ? 'top 92%' : 'top 82%', once: true },
        });
      }

      // ── Generic scroll reveals ───────────────────────────────────────────
      gsap.utils.toArray<HTMLElement>('[data-anim]').forEach((el) => {
        const dir = el.getAttribute('data-anim');
        const from: gsap.TweenVars = { opacity: 0 };
        if (dir === 'left') from.x = isMobile ? -24 : -48; else if (dir === 'right') from.x = isMobile ? 24 : 48;
        else if (dir === 'scale') { from.scale = 0.92; }
        else from.y = 44;
        gsap.fromTo(el, from, {
          opacity: 1, x: 0, y: 0, scale: 1, duration: 0.85, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: START },
        });
      });

      // ── Staggered groups (lists) ─────────────────────────────────────────
      gsap.utils.toArray<HTMLElement>('[data-anim-stagger]').forEach((group) => {
        gsap.fromTo(group.children,
          { y: 40, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.65, ease: 'power3.out', stagger: 0.08,
            scrollTrigger: { trigger: group, start: START_GROUP } });
      });

      // ── Section headings: word-by-word reveal ────────────────────────────
      gsap.utils.toArray<HTMLElement>('[data-split]').forEach((el) => {
        const s = new SplitText(el, { type: 'words' });
        gsap.fromTo(s.words, { y: 36, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.75, ease: 'power3.out', stagger: 0.05,
            scrollTrigger: { trigger: el, start: START } });
      });

      // ── Count-up stats ───────────────────────────────────────────────────
      gsap.utils.toArray<HTMLElement>('[data-count]').forEach((el) => {
        const end = parseFloat(el.getAttribute('data-count') || '0');
        const suffix = el.getAttribute('data-suffix') || '';
        ScrollTrigger.create({
          trigger: el, start: isMobile ? 'top 95%' : 'top 88%', once: true,
          onEnter: () => {
            const o = { v: 0 };
            gsap.to(o, { v: end, duration: 1.6, ease: 'power2.out',
              onUpdate: () => { el.textContent = Math.round(o.v).toLocaleString('ro-RO') + suffix; } });
          },
        });
      });

      // ── FAQ accordion — smooth height open/close ─────────────────────────
      document.querySelectorAll<HTMLDetailsElement>('[data-faq]').forEach((item) => {
        const summary = item.querySelector<HTMLElement>('summary');
        const panel = item.querySelector<HTMLElement>('[data-faq-panel]');
        if (!summary || !panel) return;
        let animating = false;
        summary.addEventListener('click', (e) => {
          e.preventDefault();
          if (animating) return;
          animating = true;
          if (item.open) {
            gsap.to(panel, { height: 0, opacity: 0, duration: 0.38, ease: 'power2.inOut',
              onComplete: () => { item.open = false; gsap.set(panel, { clearProps: 'height,opacity' }); animating = false; } });
          } else {
            item.open = true;
            gsap.set(panel, { height: 'auto', opacity: 1 });
            gsap.from(panel, { height: 0, opacity: 0, duration: 0.42, ease: 'power2.out',
              onComplete: () => { gsap.set(panel, { clearProps: 'height' }); animating = false; } });
          }
        });
      });

      // ── SHOWCASE: pin the section; swap text/phone-screen/feature as you scroll ──
      const stage = document.querySelector<HTMLElement>('[data-journey]');
      if (stage && !isMobile) {
        const steps = gsap.utils.toArray<HTMLElement>('[data-jstep]', stage);
        const screens = gsap.utils.toArray<HTMLElement>('[data-jscreen]', stage);
        const navs = gsap.utils.toArray<HTMLElement>('[data-jnav]', stage);
        const N = steps.length;

        if (N) {
          stage.classList.add('is-journey');

          // Per-step videos (screenshots/clips). Only the active one is fetched
          // + played; the rest stay paused — cheap, and the HTML mockup shows as
          // a fallback until a real file loads.
          const videos = gsap.utils.toArray<HTMLVideoElement>('[data-jvid]', stage);
          videos.forEach((v) => {
            v.addEventListener('loadeddata', () => v.classList.add('is-ready'), { once: false });
            v.addEventListener('error', () => v.classList.remove('is-ready'));
          });
          let inView = true;
          const playActive = (i: number) => {
            videos.forEach((v, k) => {
              if (k === i && inView) {
                if (v.preload !== 'auto') { v.preload = 'auto'; try { v.load(); } catch (e) {} }
                v.play?.().catch(() => {});
              } else {
                v.pause?.();
              }
            });
          };

          let current = -1;
          const setStep = (i: number) => {
            if (i === current) return;
            current = i;
            steps.forEach((s, k) => s.classList.toggle('is-active', k === i));
            screens.forEach((s, k) => s.classList.toggle('is-active', k === i));
            navs.forEach((n, k) => n.classList.toggle('is-active', k === i));
            playActive(i);
          };
          setStep(0);

          ScrollTrigger.create({
            trigger: stage,
            start: 'top top',
            // one viewport of scroll per step, plus a little dwell at the end
            end: () => '+=' + window.innerHeight * (N + 0.4),
            pin: true,
            invalidateOnRefresh: true,
            // pause every clip while the section is off-screen (saves CPU/battery)
            onToggle: (self) => { inView = self.isActive; if (!inView) videos.forEach((v) => v.pause?.()); else playActive(current); },
            onUpdate: (self) => {
              setStep(gsap.utils.clamp(0, N - 1, Math.floor(self.progress * N)));
            },
          });
        }
      }

      // ── Magnetic buttons (pointer-fine only) ─────────────────────────────
      if (window.matchMedia('(pointer: fine)').matches) {
        gsap.utils.toArray<HTMLElement>('[data-magnetic]').forEach((btn) => {
          btn.addEventListener('pointermove', (e: PointerEvent) => {
            const r = btn.getBoundingClientRect();
            gsap.to(btn, { x: (e.clientX - r.left - r.width / 2) * 0.3, y: (e.clientY - r.top - r.height / 2) * 0.45, duration: 0.4, ease: 'power3.out' });
          });
          btn.addEventListener('pointerleave', () => gsap.to(btn, { x: 0, y: 0, duration: 0.6, ease: 'elastic.out(1,0.4)' }));
        });
      }

      // ── Anchor smooth-scroll (offset for floating nav) ───────────────────
      document.querySelectorAll<HTMLAnchorElement>('a[href^="/#"], a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const href = a.getAttribute('href');
          const id = href ? href.split('#')[1] : '';
          const target = id ? document.getElementById(id) : null;
          if (target) {
            e.preventDefault();
            if (smoother) {
              smoother.scrollTo(target, true, 'top 96px');
            } else {
              const top = target.getBoundingClientRect().top + window.scrollY - 96;
              window.scrollTo({ top, behavior: 'smooth' });
            }
          }
        });
      });

      ScrollTrigger.refresh();
    }
  </script>
</BaseLayout>
