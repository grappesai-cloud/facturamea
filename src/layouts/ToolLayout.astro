---
// Wrapper for /instrumente/* pages.
//
// Logged-in users get the dashboard chrome (sidebar + breadcrumbs, no
// marketing footer) so tools feel native to the app. Visitors still get
// the public marketing chrome for SEO and a coherent landing experience.
import AppLayout from './AppLayout.astro';
import PublicLayout from './PublicLayout.astro';

interface Props {
  title: string;
  description?: string;
  appBreadcrumb?: string;
}

const { title, description, appBreadcrumb } = Astro.props;
const user = Astro.locals.user;
---

{user ? (
  <AppLayout title={title} breadcrumbTitle={appBreadcrumb ?? title} hideFooter>
    <slot />
  </AppLayout>
) : (
  <PublicLayout title={title} description={description}>
    <slot />
  </PublicLayout>
)}
