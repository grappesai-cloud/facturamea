              return (
                <div class="relative h-full">
                  <a href={m.href} class={`group relative overflow-hidden flex h-full items-center gap-3 p-4 ${canPin ? 'pr-12' : ''} rounded-2xl transition-transform hover:-translate-y-0.5`} style={`background:${t.bg}`}>
                    <span class="absolute inset-0 bg-black/25 pointer-events-none"></span>
                    <svg class="relative w-7 h-7 shrink-0 text-[#ffffff]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d={m.icon}/></svg>
                    <span class="relative min-w-0 flex-1">
                      <span class="block text-[15.5px] font-semibold leading-tight truncate text-[#ffffff]">{m.label}</span>
                      <span class="block text-[12.5px] mt-0.5 leading-snug line-clamp-2 text-[#ffffff]/75">{m.desc}</span>
                    </span>
                  </a>
                  {canPin && (
                    <button type="button" class="dash-pin absolute top-2 right-2 w-8 h-8 grid place-items-center rounded-full bg-[#0A2238]/75 backdrop-blur text-white hover:bg-[#0A2238] transition-colors" data-pin={m.key} data-pinned={pinned.has(m.key) ? 'true' : 'false'} aria-label={`Adaugă ${m.label} pe pagina principală`} title="Adaugă pe pagina principală">
                      <svg class="pin-add w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                      <svg class="pin-on w-4 h-4 text-[#E1FB15]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </button>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      ))}
      </div>
    </div>
  </div>

  <!-- ───────── Ajutor sheet ───────── -->
  <div id="help-modal" class="app-sheet hidden fixed inset-0 z-[90] flex items-end sm:items-center justify-center p-0 sm:p-4 bg-black/60 backdrop-blur-sm" style="font-family:'Outfit',ui-sans-serif,system-ui,sans-serif">
    <div id="help-card" class="app-sheet-card w-full sm:max-w-[520px] max-h-[92vh] sm:max-h-[88vh] overflow-y-auto bg-[#123455] rounded-t-[28px] sm:rounded-[28px] ring-1 ring-white/15 shadow-[0_-12px_60px_-12px_rgba(0,0,0,0.7)] sm:shadow-[0_30px_80px_-20px_rgba(0,0,0,0.85)]">
      <div id="help-handle" class="flex justify-center pt-3.5 pb-1 touch-none select-none cursor-grab active:cursor-grabbing"><span class="w-10 h-1.5 rounded-full fm-grab"></span></div>
      <div class="px-5 pt-3 sm:pt-6 pb-1">
        <h3 class="text-[20px] font-bold text-white">Ajutor</h3>
      </div>
      <div class="sheet-content px-5 pt-3 pb-6 space-y-5 text-[15px] leading-relaxed text-[#C8DAE8]">
        <div>
          <p class="font-semibold text-white mb-2">Cum începi în 3 pași</p>
          <ol class="space-y-2 list-decimal list-inside">
            <li>Adaugă-ți firma în <a href="/app/setari/companie" class="text-[#76C893] font-medium underline">Date firmă</a>.</li>
            <li>Adaugă un client în <a href="/app/facturare/clienti" class="text-[#76C893] font-medium underline">Clienți</a>.</li>
            <li>Apasă <a href="/app/facturare/emite" class="text-[#76C893] font-medium underline">Emite factură</a> și gata.</li>
          </ol>
        </div>
        <div>
          <p class="font-semibold text-white mb-1">Ai date în Oblio sau SmartBill?</p>
          <p>Le aduci automat din <a href="/app/import" class="text-[#76C893] font-medium underline">Import date</a>.</p>
        </div>
        <div class="rounded-xl bg-[#0A2238] border border-white/10 p-4">
          <p class="font-semibold text-white mb-1">Ai nevoie de un om?</p>
          <p>Scrie-ne la <a href="mailto:contact@facturamea.com" class="text-[#76C893] font-medium underline">contact@facturamea.com</a> și te ajutăm.</p>
        </div>
        <p class="text-[13px] text-[#7C9AB4]">Sfat: din meniul cu setări (colțul dreapta sus) poți comuta între tema deschisă și întunecată.</p>
      </div>
    </div>
  </div>

  <script>
    function bind(id: string, fn: () => void) { document.getElementById(id)?.addEventListener('click', fn); }

    // Generic sheet — bottom-sheet on mobile / centered modal on desktop. Smooth
    // open + close, backdrop & Esc to dismiss, and drag-down on the grab handle.
    function setupSheet(overlayId: string, cardId: string, handleId: string) {
      const overlay = document.getElementById(overlayId);
      const card = document.getElementById(cardId);
      const handle = document.getElementById(handleId);
      let hideTimer = 0;
      const open = () => {
        if (!overlay) return;
        window.clearTimeout(hideTimer);
        overlay.classList.remove('hidden');
        if (card) card.style.transform = '';
        document.documentElement.classList.add('sheet-lock');
        // Paint the closed state first, THEN flip to open so the enter transition
        // actually runs (double rAF is more reliable than a reflow on mobile).
        requestAnimationFrame(() => requestAnimationFrame(() => overlay.classList.add('is-open')));
      };
      const close = () => {
        if (!overlay || overlay.classList.contains('hidden')) return;
        overlay.classList.remove('is-open');
        card?.classList.remove('dragging');
        if (card) card.style.transform = '';
        document.documentElement.classList.remove('sheet-lock');
        window.clearTimeout(hideTimer);
        hideTimer = window.setTimeout(() => overlay.classList.add('hidden'), 440);
      };
      const isOpen = () => !!overlay && overlay.classList.contains('is-open');
      const toggle = () => (isOpen() ? close() : open());
      overlay?.addEventListener('click', (e) => { if (e.target === overlay) close(); });

      const dismissThreshold = () => Math.min(110, (card ? card.offsetHeight : 600) * 0.2);

      // (1) Drag the grab handle — works with mouse AND touch, because the handle
      //     has touch-action:none so the browser never steals the gesture.
      if (handle && card) {
        let dragging = false, hSy = 0, hDy = 0;
        handle.addEventListener('pointerdown', (e: PointerEvent) => {
          dragging = true; hSy = e.clientY; hDy = 0;
          card.classList.add('dragging');
          handle.setPointerCapture?.(e.pointerId);
        });
        handle.addEventListener('pointermove', (e: PointerEvent) => {
          if (!dragging) return;
          hDy = Math.max(0, e.clientY - hSy);
          card.style.transform = `translateY(${hDy}px)`;
        });
        const endHandle = () => {
          if (!dragging) return;
          dragging = false;
          card.classList.remove('dragging');
          if (hDy > dismissThreshold()) close(); else card.style.transform = '';
        };
        handle.addEventListener('pointerup', endHandle);
        handle.addEventListener('pointercancel', endHandle);
      }

      // (2) Pull-to-dismiss: when scrolled to the very top, keep pulling down on
      //     the content (touch) and it closes. Pulling up scrolls normally.
      if (card) {
        let sy = 0, sScroll = 0, active = false, dy = 0, onHandle = false;
        card.addEventListener('touchstart', (e: TouchEvent) => {
          if (e.touches.length !== 1) return;
          onHandle = !!handle && handle.contains(e.target as Node);
          sy = e.touches[0].clientY;
          sScroll = card.scrollTop;
          active = false; dy = 0;
        }, { passive: true });
        card.addEventListener('touchmove', (e: TouchEvent) => {
          if (onHandle || e.touches.length !== 1) return;
          const delta = e.touches[0].clientY - sy;
          if (!active) {
            if (sScroll <= 0 && delta > 6) { active = true; card.classList.add('dragging'); }
            else return; // let the content scroll normally
          }
          dy = Math.max(0, delta);
          card.style.transform = `translateY(${dy}px)`;
          if (e.cancelable) e.preventDefault();
        }, { passive: false });
        const endTouch = () => {
          if (!active) return;
          active = false;
          card.classList.remove('dragging');
          if (dy > dismissThreshold()) close(); else card.style.transform = '';
        };
        card.addEventListener('touchend', endTouch);
        card.addEventListener('touchcancel', endTouch);
      }

      // (3) Wheel / trackpad smooth close — ONLY in the mobile sheet layout
      //     (< 640px, incl. the device sandbox). Overscroll past the top drags the
      //     sheet and animates it closed. 'dragging' is toggled ONCE per gesture and
      //     we preventDefault while we own it, so there's no transition flip-flop or
      //     competing native scroll — i.e. no jitter.
      if (card) {
        const mqMobile = window.matchMedia('(max-width: 639px)');
        let dist = 0, wTimer = 0;
        const snapBack = () => { dist = 0; card.classList.remove('dragging'); card.style.transform = ''; };
        card.addEventListener('wheel', (e: WheelEvent) => {
          if (!mqMobile.matches) return; // desktop layout: no scroll-to-close
          const atTop = card.scrollTop <= 0;
          const noScroll = card.scrollHeight <= card.clientHeight + 2;
          // Dismiss by swiping the sheet down (negative deltaY w/ natural scroll) at the top.
          if (!(e.deltaY < 0 && (atTop || noScroll))) { if (dist > 0) snapBack(); return; }
          e.preventDefault();                              // own the gesture (no native scroll)
          if (dist === 0) card.classList.add('dragging');  // start once → smooth follow
          dist += Math.abs(e.deltaY);
          card.style.transform = `translateY(${Math.min(dist * 0.5, 220)}px)`;
          window.clearTimeout(wTimer);
          if (dist > 150) { dist = 0; close(); return; }
          wTimer = window.setTimeout(snapBack, 160);
        }, { passive: false });
      }
      return { open, close, toggle, isOpen };
    }

    const settingsBtn = document.getElementById('settings-btn');
    const settings = setupSheet('settings-menu', 'settings-card', 'settings-handle');
    const menu = setupSheet('menu-overlay', 'menu-card', 'menu-handle');
    const help = setupSheet('help-modal', 'help-card', 'help-handle');

    // Stylish back button → previous page (falls back to the dashboard).
    document.getElementById('app-back')?.addEventListener('click', () => {
      if (history.length > 1 && document.referrer && new URL(document.referrer).origin === location.origin) history.back();
      else if (history.length > 1) history.back();
      else location.href = '/app';
    });

    bind('menu-open', menu.open); bind('menu-open-bottom', menu.open);
    bind('help-open', help.open); bind('help-open-2', help.open);
    bind('help-open-settings', () => { settings.close(); setTimeout(() => help.open(), 120); });
    settingsBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      settings.toggle();
      settingsBtn.setAttribute('aria-expanded', settings.isOpen() ? 'true' : 'false');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { menu.close(); help.close(); settings.close(); }
    });

    // Light ↔ dark theme. Binary: th-light (soft light) or th-app-dark (near-black).
    // Default = dark. Persisted as 'app-theme-light'.
    const LIGHT_KEY = 'app-theme-light';
    const themeBtn = document.getElementById('th-dark-btn');
    const moon = document.getElementById('th-moon'); const sun = document.getElementById('th-sun');
    function applyTheme(light: boolean) {
      const el = document.documentElement;
      el.classList.toggle('th-light', light);
      el.classList.toggle('th-app-dark', !light);
      el.classList.toggle('th-dark', !light); // existing dark theme for the secondary pages
      themeBtn?.setAttribute('aria-pressed', light ? 'true' : 'false');
      moon?.classList.toggle('hidden', light);   // moon shows in dark mode
      sun?.classList.toggle('hidden', !light);   // sun shows in light mode
    }
    applyTheme(localStorage.getItem(LIGHT_KEY) === '1');
    themeBtn?.addEventListener('click', () => {
      const next = !document.documentElement.classList.contains('th-light');
      localStorage.setItem(LIGHT_KEY, next ? '1' : '0');
      applyTheme(next);
    });

    // ── Dashboard pins from the Acțiuni overlay ──
    const SYNC_EVENT = 'dashboard-modules-changed';
    const pinBtns = Array.from(document.querySelectorAll('.dash-pin'));
    const currentPins = () =>
      Array.from(document.querySelectorAll('.dash-pin[data-pinned="true"]'))
        .map((b) => b.getAttribute('data-pin'))
        .filter((k): k is string => !!k);
    async function savePins(list: string[]) {
      try {
        await fetch('/api/me/dashboard', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ modules: list }),
        });
      } catch { /* keep optimistic state */ }
    }
    pinBtns.forEach((b) => b.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      const now = b.getAttribute('data-pinned') === 'true';
      b.setAttribute('data-pinned', now ? 'false' : 'true');
      // restart the little pop animation on the button
      b.classList.remove('pin-pop'); void (b as HTMLElement).offsetWidth; b.classList.add('pin-pop');
      const list = currentPins();
      savePins(list);
      window.dispatchEvent(new CustomEvent(SYNC_EVENT, { detail: { modules: list, source: 'overlay' } }));
    }));
    // Keep the pin buttons in sync when the dashboard island changes things.
    window.addEventListener(SYNC_EVENT, (e) => {
      const detail = (e as CustomEvent).detail as { modules?: string[]; source?: string } | undefined;
      if (!detail || detail.source === 'overlay') return;
      const set = new Set(detail.modules || []);
      pinBtns.forEach((b) => b.setAttribute('data-pinned', set.has(b.getAttribute('data-pin') || '') ? 'true' : 'false'));
    });
  </script>
</BaseLayout>
