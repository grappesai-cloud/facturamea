---
import BaseLayout from './BaseLayout.astro';
import CompanySwitcher from '../components/CompanySwitcher';
import { NAV_MODULES } from '../lib/nav-modules';

interface Props {
  title: string;
  activeTab?: string;
  hideBreadcrumbs?: boolean;
  breadcrumbTitle?: string;
  breadcrumbParent?: { label: string; href: string };
  hideFooter?: boolean;
}

const { title, hideFooter } = Astro.props;
const user = Astro.locals.user;
const company = Astro.locals.company;
const license = Astro.locals.license;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/app';
const showTrialBanner = license && license.plan === 'trial' && license.status === 'active';

const groups: { label: string; items: typeof NAV_MODULES }[] = [
  { label: 'Facturare', items: NAV_MODULES.filter((m) => m.group === 'Facturare') },
  { label: 'Vânzări', items: NAV_MODULES.filter((m) => m.group === 'Vanzari') },
  { label: 'Gestiune', items: NAV_MODULES.filter((m) => m.group === 'Gestiune') },
  { label: 'Cont', items: NAV_MODULES.filter((m) => m.group === 'Cont') },
];
---

<BaseLayout title={title} themeColor="#FAFAF8">
  <div class="min-h-screen bg-[#FAFAF8] text-[#0A0A0A] flex flex-col" style="font-family:'Inter',ui-sans-serif,system-ui,sans-serif">

    <!-- ───────── Top bar ───────── -->
    <header class="sticky top-0 z-40 bg-[#FAFAF8]/90 backdrop-blur border-b border-[#E5E4DD]">
      <div class="max-w-[1180px] mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-3">
        <div class="flex items-center gap-3 min-w-0">
          <a href="/app" class="flex items-center gap-2 shrink-0">
            <span class="w-8 h-8 rounded-xl bg-[#FF5C00] flex items-center justify-center text-white font-bold text-[15px]">f</span>
            <span class="text-[17px] font-bold tracking-[-0.02em] hidden sm:inline">factura<span class="text-[#FF5C00]">mea</span></span>
          </a>
          {!isHome && (
            <>
              <span class="text-[#D4D4CE] hidden sm:inline">/</span>
              <span class="text-[16px] font-semibold text-[#3D3D3A] truncate">{title}</span>
            </>
          )}
        </div>

        <div class="flex items-center gap-2">
          <button id="menu-open" class="inline-flex items-center gap-2 px-3.5 sm:px-4 h-11 rounded-xl bg-white border border-[#E0E0DA] hover:border-[#0A0A0A] text-[15px] font-semibold transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
            <span class="hidden sm:inline">Meniu</span>
          </button>
          <button id="help-open" class="inline-flex items-center gap-2 px-3.5 sm:px-4 h-11 rounded-xl bg-white border border-[#E0E0DA] hover:border-[#0A0A0A] text-[15px] font-semibold transition-colors" title="Ajutor">
            <svg class="w-5 h-5 text-[#FF5C00]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M12 17.25h.007v.008H12v-.008zM21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="hidden sm:inline">Ajutor</span>
          </button>

          {user && (
            <div class="relative">
              <button id="user-btn" aria-haspopup="menu" aria-expanded="false" class="flex items-center gap-2 pl-2 pr-3 h-11 rounded-xl bg-white border border-[#E0E0DA] hover:border-[#0A0A0A] transition-colors">
                <span class="w-7 h-7 rounded-lg bg-[#0A0A0A] text-white flex items-center justify-center text-[14px] font-semibold">{user.name?.charAt(0)?.toUpperCase() || '?'}</span>
                <span class="text-[15px] font-semibold max-w-[120px] truncate hidden sm:inline">{user.name?.split(' ')[0]}</span>
                <svg class="w-4 h-4 text-[#8A8A85]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </button>

              <div id="user-menu" class="hidden absolute right-0 top-full mt-2 w-[280px] bg-white rounded-2xl shadow-[0_20px_60px_-20px_rgba(0,0,0,0.30)] border border-[#E8E8E4] z-50 overflow-hidden">
                <div class="px-4 py-3 border-b border-[#F0F0EC]">
                  <p class="text-[15px] font-semibold truncate">{user.name}</p>
                  <p class="text-[13px] text-[#6B6B68] truncate">{user.email}</p>
                </div>
                {company && (
                  <div class="px-4 py-3 border-b border-[#F0F0EC]">
                    <p class="text-[12px] uppercase tracking-[0.12em] text-[#8A8A85] font-semibold mb-1.5">Companie</p>
                    <CompanySwitcher client:load currentCompanyId={company.id} currentCompanyName={company.name} />
                  </div>
                )}
                <nav class="py-2">
                  <a href="/app/setari/companie" class="flex items-center gap-3 px-4 py-2.5 text-[15px] hover:bg-[#FAFAF8]"><span class="w-2 h-2 rounded-full bg-[#0A0A0A]/35"></span>Date firmă</a>
                  <a href="/app/setari/sub-users" class="flex items-center gap-3 px-4 py-2.5 text-[15px] hover:bg-[#FAFAF8]"><span class="w-2 h-2 rounded-full bg-[#0A0A0A]/35"></span>Echipă și roluri</a>
                  <a href="/app/setari/integrari-anaf" class="flex items-center gap-3 px-4 py-2.5 text-[15px] hover:bg-[#FAFAF8]"><span class="w-2 h-2 rounded-full bg-[#0A0A0A]/35"></span>Integrare ANAF</a>
                  <a href="/app/setari/abonament" class="flex items-center gap-3 px-4 py-2.5 text-[15px] hover:bg-[#FAFAF8]"><span class="w-2 h-2 rounded-full bg-[#0A0A0A]/35"></span>Licență și plată</a>
                  <a href="/app/setari" class="flex items-center gap-3 px-4 py-2.5 text-[15px] hover:bg-[#FAFAF8]"><span class="w-2 h-2 rounded-full bg-[#0A0A0A]/35"></span>Toate setările</a>
                </nav>
                <div class="px-4 py-3 border-t border-[#F0F0EC] flex items-center justify-between gap-2">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[13px] text-[#6B6B68] mr-1">Text</span>
                    <button class="th-fs-btn w-8 h-8 rounded-lg border border-[#E0E0DA] text-[13px] font-bold hover:bg-[#F0F0EC]" data-fs="100">A</button>
                    <button class="th-fs-btn w-8 h-8 rounded-lg border border-[#E0E0DA] text-[16px] font-bold hover:bg-[#F0F0EC]" data-fs="125">A+</button>
                  </div>
                  <button id="th-dark-btn" class="w-9 h-9 rounded-lg border border-[#E0E0DA] flex items-center justify-center hover:bg-[#F0F0EC]" aria-pressed="false" title="Mod întunecat">
                    <svg id="th-moon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
                    <svg id="th-sun" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
                  </button>
                </div>
                <form method="POST" action="/api/auth/logout" class="border-t border-[#F0F0EC]">
                  <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 text-[15px] font-semibold text-[#B91C1C] hover:bg-[#FFF5F5]">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/></svg>
                    Deconectare
                  </button>
                </form>
              </div>
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- ───────── Content ───────── -->
    <main class="flex-1 w-full">
      <div class="max-w-[1180px] mx-auto px-4 sm:px-6 py-6 sm:py-8">
        {showTrialBanner && (
          <a href="/app/setari/abonament" class="mb-6 flex flex-wrap items-center gap-2.5 px-5 py-3.5 bg-[#FFF3E9] border border-[#FF5C00]/30 rounded-2xl text-[15px] hover:bg-[#FFEBDB] transition-colors">
            <span class="w-2.5 h-2.5 rounded-full bg-[#FF5C00]"></span>
            <span><strong>Perioadă de probă</strong> · mai ai {license!.trialDaysLeft} {license!.trialDaysLeft === 1 ? 'zi' : 'zile'}.</span>
            <span class="ml-auto font-semibold text-[#FF5C00]">Activează licența pe viață (700 RON) →</span>
          </a>
        )}
        {!isHome && (
          <a href="/app" class="inline-flex items-center gap-1.5 mb-4 text-[15px] font-medium text-[#6B6B68] hover:text-[#0A0A0A] transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Înapoi la meniu
          </a>
        )}
        <slot />
      </div>
    </main>

    {!hideFooter && (
      <footer class="border-t border-[#E5E4DD] mt-8">
        <div class="max-w-[1180px] mx-auto px-4 sm:px-6 py-5 flex flex-wrap items-center justify-between gap-2 text-[13px] text-[#8A8A85]">
          <span>© {new Date().getFullYear()} facturamea</span>
          <div class="flex items-center gap-4">
            <button id="help-open-2" class="hover:text-[#0A0A0A] transition-colors">Ajutor</button>
            <a href="/termeni" class="hover:text-[#0A0A0A] transition-colors">Termeni</a>
            <a href="/contact" class="hover:text-[#0A0A0A] transition-colors">Contact</a>
          </div>
        </div>
      </footer>
    )}
  </div>

  <!-- ───────── Meniu overlay ───────── -->
  <div id="menu-overlay" class="hidden fixed inset-0 z-[80] bg-[#FAFAF8] overflow-y-auto">
    <div class="max-w-[1180px] mx-auto px-4 sm:px-6 py-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-[24px] sm:text-[28px] font-bold tracking-[-0.02em]">Ce vrei să faci?</h2>
        <button id="menu-close" class="inline-flex items-center gap-2 px-4 h-11 rounded-xl bg-white border border-[#E0E0DA] hover:border-[#0A0A0A] text-[15px] font-semibold">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          Închide
        </button>
      </div>
      {groups.map((g) => g.items.length > 0 && (
        <div class="mb-7">
          <p class="text-[13px] uppercase tracking-[0.14em] text-[#8A8A85] font-semibold mb-3">{g.label}</p>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            {g.items.map((m) => (
              <a href={m.href} class:list={['group flex items-start gap-3 p-4 rounded-2xl border transition-all hover:-translate-y-0.5', m.primary ? 'bg-[#0A0A0A] text-white border-[#0A0A0A]' : 'bg-white border-[#E8E8E4] hover:border-[#0A0A0A]']}>
                <span class:list={['shrink-0 w-11 h-11 rounded-xl flex items-center justify-center', m.primary ? 'bg-[#FF5C00] text-white' : 'bg-[#FFF3E9] text-[#FF5C00]']}>
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7"><path stroke-linecap="round" stroke-linejoin="round" d={m.icon}/></svg>
                </span>
                <span class="min-w-0">
                  <span class="block text-[16px] font-semibold leading-tight">{m.label}</span>
                  <span class:list={['block text-[13px] mt-0.5', m.primary ? 'text-white/60' : 'text-[#6B6B68]']}>{m.desc}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ───────── Ajutor modal ───────── -->
  <div id="help-modal" class="hidden fixed inset-0 z-[90] bg-[#0A0A0A]/50 flex items-end sm:items-center justify-center p-0 sm:p-4">
    <div class="bg-white w-full sm:max-w-[520px] sm:rounded-2xl rounded-t-2xl shadow-2xl max-h-[88vh] overflow-y-auto">
      <div class="flex items-center justify-between px-5 py-4 border-b border-[#F0F0EC] sticky top-0 bg-white">
        <h3 class="text-[18px] font-bold">Ajutor</h3>
        <button id="help-close" class="w-9 h-9 rounded-lg hover:bg-[#F0F0EC] flex items-center justify-center" aria-label="Închide">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="px-5 py-4 space-y-5 text-[15px] leading-relaxed text-[#3D3D3A]">
        <div>
          <p class="font-semibold text-[#0A0A0A] mb-2">Cum începi în 3 pași</p>
          <ol class="space-y-2 list-decimal list-inside">
            <li>Adaugă-ți firma în <a href="/app/setari/companie" class="text-[#FF5C00] font-medium underline">Date firmă</a>.</li>
            <li>Adaugă un client în <a href="/app/facturare/clienti" class="text-[#FF5C00] font-medium underline">Clienți</a>.</li>
            <li>Apasă <a href="/app/facturare/emite" class="text-[#FF5C00] font-medium underline">Emite factură</a> și gata.</li>
          </ol>
        </div>
        <div>
          <p class="font-semibold text-[#0A0A0A] mb-1">Ai date în Oblio sau SmartBill?</p>
          <p>Le aduci automat din <a href="/app/import" class="text-[#FF5C00] font-medium underline">Import date</a>.</p>
        </div>
        <div class="rounded-xl bg-[#FAFAF8] border border-[#E8E8E4] p-4">
          <p class="font-semibold text-[#0A0A0A] mb-1">Ai nevoie de un om?</p>
          <p>Scrie-ne la <a href="mailto:contact@facturamea.com" class="text-[#FF5C00] font-medium underline">contact@facturamea.com</a> și te ajutăm.</p>
        </div>
        <p class="text-[13px] text-[#8A8A85]">Sfat: din colțul dreapta sus poți mări textul (A+) sau porni modul întunecat.</p>
      </div>
    </div>
  </div>

  <script>
    function bind(id: string, fn: () => void) { document.getElementById(id)?.addEventListener('click', fn); }
    const menu = document.getElementById('menu-overlay');
    const help = document.getElementById('help-modal');
    const userMenu = document.getElementById('user-menu');
    const userBtn = document.getElementById('user-btn');
    const openMenu = () => menu?.classList.remove('hidden');
    const closeMenu = () => menu?.classList.add('hidden');
    const openHelp = () => help?.classList.remove('hidden');
    const closeHelp = () => help?.classList.add('hidden');
    bind('menu-open', openMenu); bind('menu-close', closeMenu);
    bind('help-open', openHelp); bind('help-open-2', openHelp); bind('help-close', closeHelp);
    help?.addEventListener('click', (e) => { if (e.target === help) closeHelp(); });

    userBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      userMenu?.classList.toggle('hidden');
      userBtn.setAttribute('aria-expanded', userMenu && !userMenu.classList.contains('hidden') ? 'true' : 'false');
    });
    document.addEventListener('click', (e) => {
      if (!userMenu || userMenu.classList.contains('hidden')) return;
      const t = e.target as Node;
      if (userMenu.contains(t) || userBtn?.contains(t)) return;
      userMenu.classList.add('hidden'); userBtn?.setAttribute('aria-expanded', 'false');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { closeMenu(); closeHelp(); userMenu?.classList.add('hidden'); }
    });

    // Text size (data-fs) + dark mode
    const FS_KEY = 'th-font-scale';
    const fsBtns = Array.from(document.querySelectorAll('.th-fs-btn'));
    function applyFs(s: string) {
      if (s === '100') document.documentElement.removeAttribute('data-fs');
      else document.documentElement.setAttribute('data-fs', s);
      fsBtns.forEach((b) => b.setAttribute('data-active', b.getAttribute('data-fs') === s ? 'true' : 'false'));
    }
    applyFs(localStorage.getItem(FS_KEY) === '125' ? '125' : '100');
    fsBtns.forEach((b) => b.addEventListener('click', () => { const s = b.getAttribute('data-fs') || '100'; localStorage.setItem(FS_KEY, s); applyFs(s); }));

    const DM_KEY = 'th-dark';
    const darkBtn = document.getElementById('th-dark-btn');
    const moon = document.getElementById('th-moon'); const sun = document.getElementById('th-sun');
    function applyDark(dm: boolean) {
      document.documentElement.classList.toggle('th-dark', dm);
      darkBtn?.setAttribute('aria-pressed', dm ? 'true' : 'false');
      moon?.classList.toggle('hidden', dm); sun?.classList.toggle('hidden', !dm);
    }
    applyDark(localStorage.getItem(DM_KEY) === '1');
    darkBtn?.addEventListener('click', () => { const next = !document.documentElement.classList.contains('th-dark'); localStorage.setItem(DM_KEY, next ? '1' : '0'); applyDark(next); });
  </script>
</BaseLayout>
