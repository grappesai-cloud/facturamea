---
// Glassmorphic app shell — floating navbar, dock, sheets and theming.
import BaseLayout from './BaseLayout.astro';
import CompanySwitcher from '../components/CompanySwitcher';
import { NAV_MODULES } from '../lib/nav-modules';
import { db } from '../db';
import { users } from '../db/schema';
import { eq } from 'drizzle-orm';

interface Props {
  title: string;
  activeTab?: string;
  hideBreadcrumbs?: boolean;
  breadcrumbTitle?: string;
  breadcrumbParent?: { label: string; href: string };
  hideFooter?: boolean;
}

const { title, hideFooter } = Astro.props;
const user = Astro.locals.user;
const company = Astro.locals.company;
const license = Astro.locals.license;
const anafConnected = Astro.locals.anafConnected;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/app';
// No trial anymore: unpaid accounts are gated to /app/onboarding by middleware,
// so the in-app trial banner is never shown.
const showTrialBanner = false;

const groups: { label: string; items: typeof NAV_MODULES }[] = [
  { label: 'Facturare', items: NAV_MODULES.filter((m) => m.group === 'Facturare') },
  { label: 'Vânzări', items: NAV_MODULES.filter((m) => m.group === 'Vanzari') },
  { label: 'Gestiune', items: NAV_MODULES.filter((m) => m.group === 'Gestiune') },
  { label: 'Cont', items: NAV_MODULES.filter((m) => m.group === 'Cont') },
];

// Flat solid card colours from the Meadow ramp. fg = heading text, sub = description.
const TILE = [
  { bg: '#D9ED92', fg: '#1C3A22', sub: '#3C5A33' },              // Lime Cream
  { bg: '#B5E48C', fg: '#1B3A24', sub: '#395A33' },              // Light Green
  { bg: '#99D98C', fg: '#163A26', sub: '#2F5638' },              // Willow
  { bg: '#76C893', fg: '#0F3A28', sub: '#235340' },              // Emerald
  { bg: '#52B69A', fg: '#06322A', sub: '#0F4A3C' },              // Ocean Mist
  { bg: '#34A0A4', fg: '#06272B', sub: '#0C3E44' },              // Tropical Teal
  { bg: '#168AAD', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.82)' }, // Bondi Blue
  { bg: '#1A759F', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.82)' }, // Cerulean
  { bg: '#1E6091', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.82)' }, // Baltic Blue
];
const tileFor = (key: string) => TILE[Math.max(0, NAV_MODULES.findIndex((m) => m.key === key)) % TILE.length];

// Which modules can be pinned to the dashboard launcher (same rule as /api/me/dashboard).
const isPinnable = (key: string, primary?: boolean) => !primary && key !== 'setari' && key !== 'import';

// The user's current dashboard pins, so the overlay shows the right pin state.
let pinnedKeys: string[] = [];
if (user) {
  try {
    const [r] = await db.select({ dm: users.dashboardModules }).from(users).where(eq(users.id, user.id));
    if (r?.dm) {
      const a = JSON.parse(r.dm);
      if (Array.isArray(a)) pinnedKeys = a.filter((k) => typeof k === 'string');
    }
  } catch { /* column may not exist yet / DB not ready */ }
}
const pinned = new Set(pinnedKeys);

// Primary navigation — always-visible sections (desktop bar + mobile bottom nav).
const p = currentPath;
const navSections = [
  { label: 'Acasă', href: '/app', mobile: true,
    active: p === '/app',
    icon: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75' },
  { label: 'Facturare', href: '/app/facturare', mobile: true,
    active: p.startsWith('/app/facturare') && !p.startsWith('/app/facturare/rapoarte'),
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z' },
  { label: 'Cheltuieli', href: '/app/cheltuieli', mobile: true,
    active: p.startsWith('/app/cheltuieli'),
    icon: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z' },
  { label: 'Gestiune', href: '/app/gestiune', mobile: false,
    active: p.startsWith('/app/gestiune'),
    icon: 'M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z' },
  { label: 'Rapoarte', href: '/app/facturare/rapoarte', mobile: true,
    active: p.startsWith('/app/facturare/rapoarte') || p.startsWith('/app/rapoarte'),
    icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z' },
];
const navMobile = navSections.filter((s) => s.mobile);
---

<BaseLayout title={title} themeColor="#0A2238">
  <style is:global>
    /* App shell: lock the page to the viewport width so it can never be dragged
       sideways. `clip` (not hidden) avoids creating a scroll container, so the
       fixed navbar and any sticky elements keep working. */
    html, body { overflow-x: clip; max-width: 100%; }
    /* No rubber-band / "pull past the content" overscroll. */
    html { overscroll-behavior-y: none; }
    body { background-color: #0A2238; overscroll-behavior-y: none; }

    /* Form fields always get a visible border — fixes inputs that were styled
       bg-white/5 with no ring (invisible on the dark shell). :where() = zero
       specificity, so any explicit ring/border utility on the field still wins. */
    :where([data-app-shell] input:not([type=checkbox]):not([type=radio]):not([type=range]):not([type=file]):not([type=color]):not([type=hidden])),
    :where([data-app-shell] textarea),
    :where([data-app-shell] select) {
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.16);
    }
    :where(html.th-light [data-app-shell] input:not([type=checkbox]):not([type=radio]):not([type=range]):not([type=file]):not([type=color]):not([type=hidden])),
    :where(html.th-light [data-app-shell] textarea),
    :where(html.th-light [data-app-shell] select) {
      box-shadow: inset 0 0 0 1px rgba(16, 42, 67, 0.16);
    }
    /* Hide scrollbars app-wide (content still scrolls). */
    html, body, .no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }
    html::-webkit-scrollbar, body::-webkit-scrollbar, .no-scrollbar::-webkit-scrollbar { width: 0; height: 0; display: none; }
    /* Lock the page behind an open sheet so the background can't scroll. */
    html.sheet-lock, html.sheet-lock body { overflow: hidden !important; }

    /* Dashboard pin toggle inside the Acțiuni overlay: "+" when not pinned, a
       check when pinned. The two icons stack (grid) and crossfade with a pop. */
    .dash-pin .pin-add, .dash-pin .pin-on {
      grid-area: 1 / 1;
      transition: opacity .2s ease, transform .3s cubic-bezier(.34,1.56,.64,1);
    }
    .dash-pin .pin-add { opacity: 1; transform: scale(1) rotate(0); }
    .dash-pin .pin-on  { opacity: 0; transform: scale(.3) rotate(-50deg); }
    .dash-pin[data-pinned="true"] .pin-add { opacity: 0; transform: scale(.3) rotate(50deg); }
    .dash-pin[data-pinned="true"] .pin-on  { opacity: 1; transform: scale(1) rotate(0); }
    .dash-pin[data-pinned="true"] { background: #102D49; }
    .dash-pin.pin-pop { animation: pinPop .34s cubic-bezier(.34,1.56,.64,1); }
    @keyframes pinPop { 0% { transform: scale(1); } 42% { transform: scale(1.22); } 100% { transform: scale(1); } }
    @media (prefers-reduced-motion: reduce) {
      .dash-pin .pin-add, .dash-pin .pin-on { transition: none; }
      .dash-pin.pin-pop { animation: none; }
    }

    /* Settings menu — active text-size button */
    .th-fs-btn { transition: background-color .15s, border-color .15s, color .15s; }
    .th-fs-btn[data-active="true"] { background: #D9ED92; border-color: #D9ED92; color: #1C3A22; }

    /* Reusable sheet (settings, Acțiuni, Ajutor): backdrop fades; the card rises
       (mobile) or scale-fades in (desktop). Drag-to-dismiss via the grab handle. */
    .app-sheet { opacity: 0; transition: opacity .28s ease; }
    .app-sheet.is-open { opacity: 1; }
    .app-sheet-card { transform: translateY(100%); transition: transform .42s cubic-bezier(.22,1,.36,1); will-change: transform; overscroll-behavior: contain; scrollbar-width: none; }
    .app-sheet-card::-webkit-scrollbar { width: 0; height: 0; display: none; }
    .app-sheet.is-open .app-sheet-card { transform: translateY(0); }
    .app-sheet-card.dragging { transition: none; }
    @media (min-width: 640px) {
      .app-sheet-card { transform: translateY(14px) scale(.96); opacity: 0; transition: transform .32s cubic-bezier(.22,1,.36,1), opacity .28s ease; }
      .app-sheet.is-open .app-sheet-card { transform: translateY(0) scale(1); opacity: 1; }
    }
    /* Opening animation — the sheet's content rises & fades in, staggered. */
    .app-sheet .sheet-content > * { opacity: 0; transform: translateY(12px); }
    .app-sheet.is-open .sheet-content > * { opacity: 1; transform: none; transition: opacity .45s ease, transform .5s cubic-bezier(.22,1,.36,1); }
    .app-sheet.is-open .sheet-content > *:nth-child(1) { transition-delay: .10s; }
    .app-sheet.is-open .sheet-content > *:nth-child(2) { transition-delay: .16s; }
    .app-sheet.is-open .sheet-content > *:nth-child(3) { transition-delay: .22s; }
    .app-sheet.is-open .sheet-content > *:nth-child(4) { transition-delay: .28s; }
    .app-sheet.is-open .sheet-content > *:nth-child(n+5) { transition-delay: .33s; }
    @media (prefers-reduced-motion: reduce) {
      .app-sheet, .app-sheet-card { transition: none; }
      .app-sheet .sheet-content > * { opacity: 1; transform: none; }
    }

    /* ── App theming: light ↔ darker dark, with a smooth crossfade ──────────
       Binary: html.th-light (soft light) or html.th-app-dark (near-black).
       Card text set via inline styles is untouched, so meadow/lime tiles stay
       on-brand in both themes. */

    /* Smooth transition of theme-driven properties only (avoids the chart SVG). */
    [data-app-shell],
    [data-app-shell] .text-white, [data-app-shell] .text-\[\#EAF2F8\], [data-app-shell] .text-\[\#C8DAE8\],
    [data-app-shell] .text-\[\#9FB8CC\], [data-app-shell] .text-\[\#7C9AB4\],
    [data-app-shell] .border-white\/10, [data-app-shell] .border-white\/20,
    [data-app-nav] .bg-white\/10, [data-app-nav] .text-white, [data-app-nav] .text-\[\#C8DAE8\], [data-app-nav] .text-\[\#D9ED92\],
    #settings-card, #settings-card *, #menu-card, #menu-card *, #help-card, #help-card *,
    .dash-pin {
      transition: background-color .35s ease, color .35s ease, border-color .35s ease;
    }

    /* ── Darker dark mode (near-black) ── */
    html.th-app-dark [data-app-shell] { background-color: #06090F !important; }
    /* Neutral, minimal cards: a warm charcoal (NOT washed-out blue), borderless.
       Color is used selectively (lime CTA, lively status), never on every card. */
    html.th-app-dark [data-app-shell] .bg-white\/5 { background-color: #15171C !important; border-color: transparent !important; }
    html.th-app-dark [data-app-shell] .bg-white\/10 { background-color: #212430 !important; }
    html.th-app-dark [data-app-shell] .border-white\/10 { border-color: transparent !important; }

    /* Lively, intuitive semantic colors (the old green was too blue, red too dark). */
    [data-app-shell] .text-\[\#2E9E6A\], [data-app-shell] .hover\:text-\[\#2E9E6A\]:hover { color: #5FD06A !important; }
    [data-app-shell] .bg-\[\#2E9E6A\]\/15 { background-color: rgba(120,201,76,0.16) !important; }
    [data-app-shell] .text-\[\#DC4B41\], [data-app-shell] .hover\:text-\[\#DC4B41\]:hover { color: #FF6B5C !important; }
    [data-app-shell] .bg-\[\#DC4B41\]\/15 { background-color: rgba(255,107,92,0.15) !important; }
    [data-app-shell] .text-\[\#E8A33C\] { color: #F2B33D !important; }
    [data-app-shell] .bg-\[\#E8A33C\]\/15 { background-color: rgba(242,179,61,0.15) !important; }
    /* Retire the washed-out teal-blue accent for a warmer lime-green. */
    [data-app-shell] .text-\[\#34A0A4\] { color: #5FD06A !important; }
    [data-app-shell] .bg-\[\#34A0A4\]\/15 { background-color: rgba(120,201,76,0.16) !important; }

    /* Buttons: subtle hover-lift + press, matching the menu feel. */
    [data-app-shell] .bg-\[\#E1FB15\] { transition: transform .16s cubic-bezier(.34,1.56,.64,1), background-color .16s ease, box-shadow .2s ease; }
    [data-app-shell] .bg-\[\#E1FB15\]:hover { transform: translateY(-1px); }
    [data-app-shell] .bg-\[\#E1FB15\]:active { transform: scale(.97); }
    @media (prefers-reduced-motion: reduce) { [data-app-shell] .bg-\[\#E1FB15\] { transition: background-color .16s ease; } [data-app-shell] .bg-\[\#E1FB15\]:hover, [data-app-shell] .bg-\[\#E1FB15\]:active { transform: none; } }
    html.th-app-dark #settings-card { background-color: #0C1118 !important; }
    html.th-app-dark #menu-card     { background-color: #0A0D14 !important; }
    html.th-app-dark #help-card     { background-color: #0E1620 !important; }

    /* ── Soft light mode ── */
    /* App shell + content */
    html.th-light [data-app-shell] { background-color: #EEF2F6 !important; color: #11253A; }
    html.th-light [data-app-shell] .text-white, html.th-light [data-app-shell] .text-\[\#EAF2F8\] { color: #11253A !important; }
    html.th-light [data-app-shell] .text-\[\#C8DAE8\] { color: #3A4F63 !important; }
    html.th-light [data-app-shell] .text-\[\#9FB8CC\] { color: #4F6478 !important; }
    html.th-light [data-app-shell] .text-\[\#7C9AB4\] { color: #5E7385 !important; }
    html.th-light [data-app-shell] .border-white\/10  { border-color: rgba(17,37,58,0.10) !important; }
    html.th-light [data-app-shell] .border-white\/20  { border-color: rgba(17,37,58,0.18) !important; }
    html.th-light [data-app-shell] .bg-white\/5 { background-color: #FFFFFF !important; border-color: transparent !important; box-shadow: 0 1px 2px rgba(16,32,56,0.05), 0 12px 32px -18px rgba(16,32,56,0.20) !important; }
    html.th-light [data-app-shell] .bg-white\/10      { background-color: #E7ECF3 !important; }
    html.th-light [data-app-shell] .border-white\/10  { border-color: transparent !important; }
    /* "Adaugă o acțiune" picker (rendered inside the shell) */
    html.th-light [data-app-shell] .bg-\[\#0A2238\]   { background-color: #FFFFFF !important; }
    html.th-light [data-app-shell] .border-white\/15  { border-color: rgba(17,37,58,0.12) !important; }

    /* Floating navbar — light glass with dark text. Kept translucent (not solid)
       so the frosted backdrop-blur reads as glass in light mode too. */
    html.th-light [data-app-nav] .bg-white\/10        { background-color: rgba(255,255,255,0.55) !important; }
    html.th-light [data-app-nav] .text-white          { color: #11253A !important; }
    html.th-light [data-app-nav] .text-\[\#C8DAE8\]   { color: #3A4F63 !important; }
    html.th-light [data-app-nav] .text-\[\#D9ED92\]   { color: #6FA021 !important; }
    html.th-light [data-app-nav] .text-\[\#9FB8CC\]   { color: #3A4F63 !important; }
    html.th-light [data-app-nav] .text-\[\#E1FB15\]   { color: #5FA320 !important; }
    html.th-light [data-app-nav] .hover\:bg-white\/15:hover { background-color: rgba(17,37,58,0.06) !important; }

    /* Settings modal — light card */
    html.th-light #settings-card { background-color: #FFFFFF !important; }
    html.th-light #settings-card .text-white          { color: #11253A !important; }
    html.th-light #settings-card .text-\[\#D7E5F0\]   { color: #1F3346 !important; }
    html.th-light #settings-card .text-\[\#7E97AC\]   { color: #5E7385 !important; }
    html.th-light #settings-card .text-\[\#8AA0B4\]   { color: #6B7E90 !important; }
    html.th-light #settings-card .text-\[\#FF9A8F\]   { color: #D8473C !important; }
    html.th-light #settings-card .bg-white\/10        { background-color: rgba(17,37,58,0.06) !important; }
    html.th-light #settings-card .bg-white\/25        { background-color: rgba(17,37,58,0.20) !important; }
    html.th-light #settings-card .border-white\/10    { border-color: rgba(17,37,58,0.10) !important; }
    html.th-light #settings-card .hover\:bg-white\/20:hover { background-color: rgba(17,37,58,0.08) !important; }

    /* Acțiuni sheet — light */
    html.th-light #menu-card { background-color: #EEF2F6 !important; }
    html.th-light #menu-card .text-white         { color: #11253A !important; }
    html.th-light #menu-card .text-\[\#7C9AB4\]  { color: #5E7385 !important; }
    html.th-light #menu-card .bg-white\/25       { background-color: rgba(17,37,58,0.18) !important; }

    /* Ajutor sheet — light */
    html.th-light #help-card { background-color: #FFFFFF !important; }
    html.th-light #help-card .text-white        { color: #11253A !important; }
    html.th-light #help-card .text-\[\#C8DAE8\] { color: #3A4F63 !important; }
    html.th-light #help-card .text-\[\#7C9AB4\] { color: #5E7385 !important; }
    html.th-light #help-card .bg-\[\#0A2238\]   { background-color: #E7ECF1 !important; }
    html.th-light #help-card .bg-white\/25      { background-color: rgba(17,37,58,0.18) !important; }
    html.th-light #help-card .border-white\/10  { border-color: rgba(17,37,58,0.10) !important; }

    /* Pin toggle buttons (on the meadow tiles) — light */
    html.th-light .dash-pin { background-color: rgba(255,255,255,0.92) !important; color: #1C3A22 !important; }
    html.th-light .dash-pin:hover { background-color: #FFFFFF !important; }
    html.th-light .dash-pin[data-pinned="true"] { background-color: #1C3A22 !important; }

    /* ── Brand accent unification ──────────────────────────────────────────
       The secondary /app pages were built with an orange accent (#1A759F). Retire
       it across the app and use the site's meadow lime/green so everything matches.
       Scoped to the app shell so the marketing site is untouched. */
    html [data-app-shell] .bg-\[\#1A759F\],
    html [data-app-shell] .bg-\[\#168AAD\] { background-color: #E1FB15 !important; color: #0A2238 !important; }
    html [data-app-shell] .hover\:bg-\[\#1A759F\]:hover,
    html [data-app-shell] .hover\:bg-\[\#168AAD\]:hover { background-color: #C6DE0C !important; }
    html [data-app-shell] .text-\[\#1A759F\] { color: #2E9E6A !important; }
    html [data-app-shell] .border-\[\#1A759F\] { border-color: #E1FB15 !important; }
    html [data-app-shell] .ring-\[\#1A759F\] { --tw-ring-color: #E1FB15 !important; }
    html.th-app-dark [data-app-shell] .text-\[\#1A759F\] { color: #9FE6B5 !important; }
  </style>

  <!-- ───────── Floating navbar (glass) — body-level so nothing can break `fixed` ───────── -->
  <div data-app-nav class="fixed inset-x-0 top-0 z-50 px-4 sm:px-6 pt-3 pointer-events-none" style="font-family:'Outfit',ui-sans-serif,system-ui,sans-serif">
    <div class="max-w-[1180px] mx-auto flex items-center justify-between gap-2">

      <!-- Primary nav (desktop) + actions -->
      <div class="pointer-events-auto lg:flex-1 h-14 flex items-center gap-1 px-1.5 rounded-full bg-white/10 backdrop-blur-xl shadow-[0_8px_32px_-8px_rgba(0,0,0,0.5)]">
        {navSections.map((s) => (
          <a href={s.href} class:list={['nav-pill hidden lg:inline-flex items-center gap-2 px-3.5 h-11 rounded-full text-[15px] font-semibold transition-colors', s.active ? 'bg-white/15 text-white' : 'text-[#C8DAE8] hover:bg-white/10 hover:text-white']}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/></svg>
            <span>{s.label}</span>
          </a>
        ))}
        <button id="menu-open" class="hidden lg:inline-flex items-center gap-2 px-3.5 h-11 rounded-full text-white text-[15px] font-semibold hover:bg-white/15 transition-colors">
