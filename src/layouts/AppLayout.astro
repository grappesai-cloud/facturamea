---
// Glassmorphic app shell — floating navbar, dock, sheets and theming.
// route-map integrity (sha2-512): a8896f90025e8be2277bb2fc03378afd77cec0783794e39d27b4831be5e6e63775065454b729202ec82bcf94641cb10970b94505252ee9b6202db1210e35b623
import BaseLayout from './BaseLayout.astro';
import CompanySwitcher from '../components/CompanySwitcher';
import SupportSheet from '../components/SupportSheet';
import { NAV_MODULES } from '../lib/nav-modules';
import { db } from '../db';
import { users } from '../db/schema';
import { eq } from 'drizzle-orm';

interface Props {
  title: string;
  activeTab?: string;
  hideBreadcrumbs?: boolean;
  breadcrumbTitle?: string;
  breadcrumbParent?: { label: string; href: string };
  hideFooter?: boolean;
}

const { title, hideFooter } = Astro.props;
const user = Astro.locals.user;
const company = Astro.locals.company;
const license = Astro.locals.license;
const anafConnected = Astro.locals.anafConnected;
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/app';
// No trial anymore: unpaid accounts are gated to /app/onboarding by middleware,
// so the in-app trial banner is never shown.
const showTrialBanner = false;
const isImpersonating = !!(Astro.locals as any).impersonating;

// Pages already reachable from the bottom-nav tabs (Facturare /app/facturare,
// Cheltuieli /app/cheltuieli, Rapoarte /app/facturare/rapoarte) or the contextual
// "Secțiuni" dropdown on the Facturare page (Clienți/Produse/Recurente/e-Factura) are
// NOT repeated in the full Meniu — avoids the same choice appearing twice.
const MENU_HIDE = new Set(['facturi', 'cheltuieli', 'rapoarte', 'clienti', 'produse', 'recurente', 'efactura']);
const groups: { label: string; items: typeof NAV_MODULES }[] = [
  { label: 'Facturare', items: NAV_MODULES.filter((m) => m.group === 'Facturare' && !MENU_HIDE.has(m.key)) },
  { label: 'Vânzări', items: NAV_MODULES.filter((m) => m.group === 'Vanzari' && !MENU_HIDE.has(m.key)) },
  { label: 'Gestiune', items: NAV_MODULES.filter((m) => m.group === 'Gestiune' && !MENU_HIDE.has(m.key)) },
  { label: 'Cont', items: NAV_MODULES.filter((m) => m.group === 'Cont' && !MENU_HIDE.has(m.key)) },
];

// Flat solid card colours from the Meadow ramp. fg = heading text, sub = description.
// Medium-dark tiles so the WHITE title + subtitle read crisply on every card,
// consistent with the dashboard quick-access cards.
// One cohesive teal→sea-green→green ramp that flows toward the lime accent
// (instead of cool blues fighting it). White text reads crisply on all of them.
const TILE = [
  { bg: '#1C7A8C', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // deep teal
  { bg: '#1E8C93', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // teal
  { bg: '#239A8A', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // sea green
  { bg: '#2BA67E', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // jade
  { bg: '#33A86E', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // green
  { bg: '#2E9A75', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // pine
  { bg: '#258F88', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // deep sea
  { bg: '#1F8497', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // cerulean-teal
  { bg: '#187C8E', fg: '#FFFFFF', sub: 'rgba(255,255,255,0.85)' }, // dark teal
];
const tileFor = (key: string) => TILE[Math.max(0, NAV_MODULES.findIndex((m) => m.key === key)) % TILE.length];

// Which modules can be pinned to the dashboard launcher (same rule as /api/me/dashboard).
const isPinnable = (key: string, primary?: boolean) => !primary && key !== 'setari' && key !== 'import';

// The user's current dashboard pins, so the overlay shows the right pin state.
let pinnedKeys: string[] = [];
if (user) {
  try {
    const [r] = await db.select({ dm: users.dashboardModules }).from(users).where(eq(users.id, user.id));
    if (r?.dm) {
      const a = JSON.parse(r.dm);
      if (Array.isArray(a)) pinnedKeys = a.filter((k) => typeof k === 'string');
    }
  } catch { /* column may not exist yet / DB not ready */ }
}
const pinned = new Set(pinnedKeys);

// Primary navigation — always-visible sections (desktop bar + mobile bottom nav).
const p = currentPath;
const navSections = [
  { label: 'Acasă', href: '/app', mobile: true,
    active: p === '/app',
    icon: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75' },
  { label: 'Facturare', href: '/app/facturare', mobile: true,
    active: p.startsWith('/app/facturare') && !p.startsWith('/app/facturare/rapoarte'),
    icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z' },
  { label: 'Cheltuieli', href: '/app/cheltuieli', mobile: true,
    active: p.startsWith('/app/cheltuieli'),
    icon: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z' },
  { label: 'Gestiune', href: '/app/gestiune', mobile: true,
    active: p.startsWith('/app/gestiune'),
    icon: 'M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z' },
  { label: 'Rapoarte', href: '/app/facturare/rapoarte', mobile: true,
    active: p.startsWith('/app/facturare/rapoarte') || p.startsWith('/app/rapoarte'),
    icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z' },
];
const navMobile = navSections.filter((s) => s.mobile);
// A "hub" page is a top-level nav/dock destination — there's nothing to go back
// to from it, so the back button is hidden there (shown only on deeper pages).
const isHub = navSections.some((s) => s.href === currentPath.replace(/\/+$/, ''));
const showAdminMark = !!user?.isAdmin && !isImpersonating && (currentPath === '/app' || currentPath.startsWith('/app/setari'));
---

<BaseLayout title={title} themeColor="#07090f" clientRouter>
  <style is:global>
    /* App shell: lock the page to the viewport width so it can never be dragged
       sideways. `clip` (not hidden) avoids creating a scroll container, so the
       fixed navbar and any sticky elements keep working. */
    html, body { overflow-x: clip; max-width: 100%; }
    /* Stop the browser from re-anchoring scroll (which shifted sticky panels like
       the invoice "Sumar" upward) when a portalled dropdown/calendar mounts. */
    html { overflow-anchor: none; }
    /* No rubber-band / "pull past the content" overscroll. */
    html { overscroll-behavior-y: none; }
    /* Set BOTH html and body so the notch / status-bar / overscroll area is the
       app's background — never white or a stray color on iPhone/Android. The bg
       follows the theme so the rubber-band/overscroll area (and the white bar at
       max scroll in the standalone/native build) matches light or dark. */
    html { background-color: #07090f; overscroll-behavior: none; }
    body { background-color: #07090f; overscroll-behavior: none; }
    html.th-light, html.th-light body { background-color: #EEF2F6; }

    /* Form fields always get a visible border — fixes inputs that were styled
       bg-white/5 with no ring (invisible on the dark shell). :where() = zero
       specificity, so any explicit ring/border utility on the field still wins. */
    :where([data-app-shell] input:not([type=checkbox]):not([type=radio]):not([type=range]):not([type=file]):not([type=color]):not([type=hidden])),
    :where([data-app-shell] textarea),
    :where([data-app-shell] select) {
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.22);
    }
    :where(html.th-light [data-app-shell] input:not([type=checkbox]):not([type=radio]):not([type=range]):not([type=file]):not([type=color]):not([type=hidden])),
    :where(html.th-light [data-app-shell] textarea),
    :where(html.th-light [data-app-shell] select) {
      box-shadow: inset 0 0 0 1px rgba(16, 42, 67, 0.30);
    }
    /* Hide scrollbars app-wide (content still scrolls). */
    html, body, .no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }
    html::-webkit-scrollbar, body::-webkit-scrollbar, .no-scrollbar::-webkit-scrollbar { width: 0; height: 0; display: none; }
    /* Lock the page behind an open sheet so the background can't scroll. */
    html.sheet-lock, html.sheet-lock body { overflow: hidden !important; }

    /* Dashboard pin toggle inside the Acțiuni overlay: "+" when not pinned, a
       check when pinned. The two icons stack (grid) and crossfade with a pop. */
    .dash-pin .pin-add, .dash-pin .pin-on {
      grid-area: 1 / 1;
      transition: opacity .2s ease, transform .3s cubic-bezier(.34,1.56,.64,1);
    }
    .dash-pin .pin-add { opacity: 1; transform: scale(1) rotate(0); }
    .dash-pin .pin-on  { opacity: 0; transform: scale(.3) rotate(-50deg); }
    .dash-pin[data-pinned="true"] .pin-add { opacity: 0; transform: scale(.3) rotate(50deg); }
    .dash-pin[data-pinned="true"] .pin-on  { opacity: 1; transform: scale(1) rotate(0); }
    .dash-pin[data-pinned="true"] { background: #102D49; }
    .dash-pin.pin-pop { animation: pinPop .34s cubic-bezier(.34,1.56,.64,1); }
    @keyframes pinPop { 0% { transform: scale(1); } 42% { transform: scale(1.22); } 100% { transform: scale(1); } }
    @media (prefers-reduced-motion: reduce) {
      .dash-pin .pin-add, .dash-pin .pin-on { transition: none; }
      .dash-pin.pin-pop { animation: none; }
    }

    /* Settings menu — active text-size button */
    .th-fs-btn { transition: background-color .15s, border-color .15s, color .15s; }
    .th-fs-btn[data-active="true"] { background: #D9ED92; border-color: #D9ED92; color: #1C3A22; }

    /* Reusable sheet (settings, Acțiuni, Ajutor): backdrop fades; the card rises
       (mobile) or scale-fades in (desktop). Drag-to-dismiss via the grab handle. */
    .app-sheet { opacity: 0; transition: opacity .28s ease; }
    .app-sheet.is-open { opacity: 1; }
    .app-sheet-card { transform: translateY(100%); transition: transform .42s cubic-bezier(.22,1,.36,1); will-change: transform; overscroll-behavior: contain; scrollbar-width: none; }
    .app-sheet-card::-webkit-scrollbar { width: 0; height: 0; display: none; }
    .app-sheet.is-open .app-sheet-card { transform: translateY(0); }
    .app-sheet-card.dragging { transition: none; }
    /* Drag-to-close pill — neutral gray visible on any background */
    .grab-pill { background-color: rgba(128,128,128,0.45); }
    html.th-light .grab-pill { background-color: rgba(0,0,0,0.2); }

    /* ── Unified close (X) button — ONE style for every popup/sheet/modal,
       everywhere. Uses a fixed background (not the bg-white/10 utility, which is
       rewritten differently inside vs outside [data-app-shell]) so it renders
       identically in any context. Add positioning (shrink-0 / absolute…) on top. */
    .fm-close-btn {
      display: grid; place-items: center;
      width: 2.25rem; height: 2.25rem; border-radius: 9999px;
      background-color: rgba(255,255,255,0.10); color: #A8BED2;
      transition: background-color .15s ease, color .15s ease, transform .12s ease;
    }
    .fm-close-btn:hover { background-color: rgba(220,75,65,0.18); color: #FF6B5C; }
    .fm-close-btn:active { transform: scale(.92); }
    html.th-light .fm-close-btn { background-color: rgba(17,37,58,0.08); color: #5E7385; }
    html.th-light .fm-close-btn:hover { background-color: rgba(220,75,65,0.14); color: #DC4B41; }

    /* ── View Transitions: keep the persisted dock/navbar glass rock-solid and
       load page content smoothly. The default root crossfade snapshots the whole
       page into a top layer, which makes the dock's backdrop-filter sample across
       the layer boundary and flicker ("the glass disappears for a bit"). Disable
       that root animation (the chrome is persisted anyway) and instead fade the
       content area up — so navigation is smooth and the dock never blinks. */
    ::view-transition-group(root) { animation-duration: 0s; }
    ::view-transition-old(root), ::view-transition-new(root) { animation: none; mix-blend-mode: normal; }
    @media (prefers-reduced-motion: no-preference) {
      .fm-page { animation: fmPageIn .26s cubic-bezier(.22,1,.36,1) both; }
      @keyframes fmPageIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
    }

    /* ── Safe-area insets (fullscreen standalone / native with a transparent
       status bar). env() is 0 on normal web, so these are no-ops there. Higher
       specificity than the Tailwind pt-3/bottom-0 utilities, so they win. */
    [data-app-nav].top-0 { padding-top: calc(env(safe-area-inset-top, 0px) + 0.75rem); }
    [data-app-nav].bottom-0 { padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 0.25rem); }
    [data-app-shell] .fm-page { padding-top: calc(env(safe-area-inset-top, 0px) + 6rem); }
    @media (min-width: 640px) { [data-app-shell] .fm-page { padding-top: calc(env(safe-area-inset-top, 0px) + 7rem); } }

    /* ── Micro-interactions: tasteful entrance + press feedback ── */
    @keyframes fmRise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
    @keyframes fmFadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
    .fm-rise { animation: fmRise .42s cubic-bezier(.22,1,.36,1) both; }
    .fm-page { animation: fmFadeUp .42s cubic-bezier(.22,1,.36,1) both; }
    /* Subtle press feedback for any interactive element opting in. */
    .fm-press { transition: transform .12s ease; }
    .fm-press:active:not(:disabled) { transform: scale(.97); }
    @media (prefers-reduced-motion: reduce) {
      .fm-rise, .fm-page { animation: none; }
      .fm-press:active:not(:disabled) { transform: none; }
    }

    /* ── "Ce vrei să faci?" menu: layer the shared subtle reveal on the panel's
       inner content so it matches every other popup surface (Select, calendar,
       filterbar). The card itself still slides/scale-fades via setupSheet's
       Web Animations entrance; this adds the consistent fm-reveal feel on top.
       Scoped to the menu so settings/help sheets are untouched. The backdrop
       already soft-fades via .app-sheet opacity. */
    #menu-overlay.is-open #menu-card .sheet-content {
      animation: fmMenuReveal 165ms cubic-bezier(.16, 1, .3, 1) both;
      transform-origin: top center;
    }
    @keyframes fmMenuReveal {
      from { opacity: 0; transform: translateY(-6px) scale(.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    @media (prefers-reduced-motion: reduce) {
      #menu-overlay.is-open #menu-card .sheet-content { animation: none; }
    }

    /* Sliding active-page indicator (desktop nav + mobile bottom nav). The pill
       glides between items: it follows hover on desktop and animates from the
       previous page's position to the new one on navigation (sessionStorage). */
    .nav-slider {
      transition: left .34s cubic-bezier(.34,1.3,.5,1), width .34s cubic-bezier(.34,1.3,.5,1), opacity .2s ease;
      will-change: left, width;
    }
    .nav-slider.no-anim { transition: none; }
    html.th-light #nav-pill-d { background-color: rgba(17,37,58,0.10); }
    /* Dock (mobile bottom nav): keep the active selection lime in light mode —
       a lime pill with dark icon/label so it reads as the brand selection. */
    html.th-light #nav-pill-m { background-color: #E1FB15; }
    html.th-light [data-app-nav] a[data-nav-pill][data-active="true"] { color: #07090f !important; }
    @media (prefers-reduced-motion: reduce) { .nav-slider { transition: opacity .2s ease; } }

    /* ───────────────────────────────────────────────────────────────────────
       GLOBAL SURFACE TOKENS — one design profile for EVERY sheet, menu,
       dropdown, popover and select popup, in both light and dark mode. Use
       `fm-surface` for any floating panel; `fm-pop` adds the shared border +
       shadow. Never hardcode a per-panel background again. */
    .fm-surface { background-color: #07090f !important; }
    html.th-light .fm-surface { background-color: #FFFFFF !important; }
    .fm-pop {
      background-color: #07090f !important;
      border: 1px solid rgba(255,255,255,0.10) !important;
      box-shadow: 0 16px 48px -12px rgba(0,0,0,0.7) !important;
      color: #EAF2F8;
    }
    html.th-light .fm-pop {
      background-color: #FFFFFF !important;
      border-color: rgba(17,37,58,0.10) !important;
      box-shadow: 0 16px 40px -12px rgba(16,32,56,0.18) !important;
      color: #11253A;
    }

    /* Custom <Select> popup (Radix, portalled to <body> so it lives OUTSIDE the
       app-shell — must theme itself). One look for every dropdown, no OS chrome. */
    .fm-select-content {
      background-color: #07090f;
      border: 1px solid rgba(255,255,255,0.10);
      box-shadow: 0 16px 48px -12px rgba(0,0,0,0.7);
    }
    html.th-light .fm-select-content {
      background-color: #FFFFFF;
      border-color: rgba(17,37,58,0.10);
      box-shadow: 0 16px 40px -12px rgba(16,32,56,0.18);
    }
    .fm-select-trigger {
      background-color: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.22);
      color: #EAF2F8;
    }
    .fm-select-trigger:hover { border-color: rgba(255,255,255,0.38); }
    html.th-light .fm-select-trigger {
      background-color: #FFFFFF;
      border-color: rgba(17,42,67,0.22);
      color: #11253A;
    }
    html.th-light .fm-select-trigger:hover { border-color: rgba(17,42,67,0.38); }
    .fm-select-item { color: #C8DCE8; }
    html.th-light .fm-select-item { color: #2B3F52; }
    .fm-select-item[data-highlighted] { background-color: rgba(255,255,255,0.08); color: #FFFFFF; }
    html.th-light .fm-select-item[data-highlighted] { background-color: rgba(17,37,58,0.06); color: #11253A; }
    .fm-select-item[data-state="checked"] { color: #4D8A1A; }
    html.th-app-dark .fm-select-item[data-state="checked"], .fm-select-item[data-state="checked"] { color: #E1FB15; }
    html.th-light .fm-select-item[data-state="checked"] { color: #4D8A1A; }
    .fm-select-muted { color: #8FA6BC; }
    @media (min-width: 640px) {
      .app-sheet-card { transform: translateY(14px) scale(.96); opacity: 0; transition: transform .32s cubic-bezier(.22,1,.36,1), opacity .28s ease; }
      .app-sheet.is-open .app-sheet-card { transform: translateY(0) scale(1); opacity: 1; }
    }
    /* Opening animation — the sheet's content rises & fades in, staggered. */
    .app-sheet .sheet-content > * { opacity: 0; transform: translateY(12px); }
    .app-sheet.is-open .sheet-content > * { opacity: 1; transform: none; transition: opacity .45s ease, transform .5s cubic-bezier(.22,1,.36,1); }
    .app-sheet.is-open .sheet-content > *:nth-child(1) { transition-delay: .10s; }
    .app-sheet.is-open .sheet-content > *:nth-child(2) { transition-delay: .16s; }
    .app-sheet.is-open .sheet-content > *:nth-child(3) { transition-delay: .22s; }
    .app-sheet.is-open .sheet-content > *:nth-child(4) { transition-delay: .28s; }
    .app-sheet.is-open .sheet-content > *:nth-child(n+5) { transition-delay: .33s; }
    @media (prefers-reduced-motion: reduce) {
      .app-sheet, .app-sheet-card { transition: none; }
      .app-sheet .sheet-content > * { opacity: 1; transform: none; }
    }

    /* ── App theming: light ↔ darker dark, with a smooth crossfade ──────────
       Binary: html.th-light (soft light) or html.th-app-dark (near-black).
       Card text set via inline styles is untouched, so meadow/lime tiles stay
       on-brand in both themes. */

    /* Smooth transition of theme-driven properties only (avoids the chart SVG). */
    [data-app-shell],
    [data-app-shell] .text-white, [data-app-shell] .text-\[\#EAF2F8\], [data-app-shell] .text-\[\#C8DAE8\],
    [data-app-shell] .text-\[\#A8BED2\], [data-app-shell] .text-\[\#8FA6BC\],
    [data-app-shell] .border-white\/10, [data-app-shell] .border-white\/20,
    [data-app-nav] .bg-white\/10, [data-app-nav] .text-white, [data-app-nav] .text-\[\#C8DAE8\], [data-app-nav] .text-\[\#D9ED92\],
    #settings-card, #settings-card *, #menu-card, #menu-card *, #help-card, #help-card *,
    .dash-pin {
      transition: background-color .35s ease, color .35s ease, border-color .35s ease;
    }

    /* On a light/dark TOGGLE, force ONE uniform transition on everything so all
       text/icons/surfaces change together (otherwise some use .35s, some the
       Tailwind .15s hover transition, some snap instantly → staggered look). The
       class is added only for the duration of the switch, so normal fast hovers
       are untouched the rest of the time. */
    html.theme-transitioning * , html.theme-transitioning *::before, html.theme-transitioning *::after {
      transition: background-color .3s ease, color .3s ease, border-color .3s ease, fill .3s ease, stroke .3s ease, box-shadow .3s ease !important;
    }
    @media (prefers-reduced-motion: reduce) { html.theme-transitioning * { transition: none !important; } }

    /* ── Darker dark mode (near-black) ── */
    html.th-app-dark [data-app-shell] { background-color: #06090F !important; }
    /* Neutral, minimal cards: a warm charcoal (NOT washed-out blue), borderless.
       Color is used selectively (lime CTA, lively status), never on every card. */
