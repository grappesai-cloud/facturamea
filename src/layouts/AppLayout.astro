              <a href="/admin" class="inline-flex items-center gap-2 pl-2.5 pr-3.5 py-1.5 bg-white/5 hover:bg-white/10 rounded-full text-[12.5px] font-medium text-[#A8BED2] hover:text-white transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-[#34A0A4]"></span>
                Cont de administrator
                <span class="text-[#34A0A4]">→</span>
              </a>
            )}
          </div>
        )}
        <slot />
      </div>
    </main>

    {!hideFooter && (
      <footer class="hidden lg:block border-t border-white/10 mt-8">
        <div class="max-w-[1180px] mx-auto px-4 sm:px-6 py-5 flex flex-wrap items-center justify-between gap-2 text-[13px] text-[#8FA6BC]">
          <span>© {new Date().getFullYear()} facturamea</span>
          <div class="flex items-center gap-4">
            <button id="help-open-2" class="hover:text-[#52B69A] transition-colors">Ajutor</button>
            <a href="/termeni" class="hover:text-[#52B69A] transition-colors">Termeni</a>
            <button type="button" data-support-open class="hover:text-[#52B69A] transition-colors">Contact</button>
          </div>
        </div>
      </footer>
    )}
  </div>

  <!-- ───────── Meniu overlay (quick actions) ───────── -->
  <div id="menu-overlay" transition:persist="app-menu" class="app-sheet hidden fixed inset-0 z-[80] flex items-end sm:items-center justify-center p-0 sm:p-4 bg-black/70" style="font-family:'Outfit',ui-sans-serif,system-ui,sans-serif">
    <div id="menu-card" class="app-sheet-card w-full sm:max-w-[820px] max-h-[80vh] sm:max-h-[86vh] overflow-y-auto bg-[#07090f] rounded-t-[28px] sm:rounded-[28px] ring-1 ring-white/10 shadow-[0_-12px_60px_-12px_rgba(0,0,0,0.7)] sm:shadow-[0_30px_80px_-20px_rgba(0,0,0,0.85)]">
      <div class="sheet-content px-4 sm:px-7 pt-5 sm:pt-7 pb-7">
      <div class="mb-6 flex items-start justify-between gap-3">
        <h2 class="text-[24px] sm:text-[28px] font-bold tracking-[-0.02em] text-white">Ce vrei să faci?</h2>
        <button id="menu-close-btn" type="button" aria-label="Închide" class="shrink-0 fm-close-btn">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      {groups.map((g) => g.items.length > 0 && (
        <div class="mb-7">
          <p class="text-[13px] uppercase tracking-[0.14em] text-[#8FA6BC] font-semibold mb-3">{g.label}</p>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 auto-rows-fr gap-3">
            {g.items.map((m) => {
              const t = m.primary ? { bg: '#E1FB15', fg: '#07090f', sub: '#3F4D12' } : tileFor(m.key);
              const canPin = isPinnable(m.key, m.primary);
              return (
                <div class="group/tile relative h-full">
                  <a href={m.href} class={`relative overflow-hidden flex flex-col justify-between h-full min-h-[104px] p-4 rounded-2xl transition-transform group-hover/tile:-translate-y-0.5`} style={`background:${t.bg}`}>
                    {/* small icon, top-left */}
                    <span class="relative z-10 inline-flex" aria-hidden="true">
                      <svg class="w-7 h-7 sm:w-8 sm:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" style={`color:${t.fg}`}><path stroke-linecap="round" stroke-linejoin="round" d={m.icon}/></svg>
                    </span>
                    {/* title + subtitle — use inline colour so CSS overrides can't invert them */}
                    <span class="tile-text relative z-10 w-full">
                      <span class="block w-full text-[15.5px] font-bold leading-tight" style={`color:${t.fg}`}>{m.label}</span>
                      <span class="block w-full text-[12.5px] mt-1 leading-snug line-clamp-2" style={`color:${t.sub}`}>{m.desc}</span>
                    </span>
                  </a>
                  {canPin && (
                    <button type="button" class="dash-pin absolute top-2 right-2 w-8 h-8 grid place-items-center rounded-full bg-[#07090f]/75 backdrop-blur text-white hover:bg-[#07090f] transition-all duration-150 opacity-0 lg:group-hover/tile:opacity-100" data-pin={m.key} data-pinned={pinned.has(m.key) ? 'true' : 'false'} aria-label={`Adaugă ${m.label} pe pagina principală`} title="Adaugă pe pagina principală">
                      <svg class="pin-add w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                      <svg class="pin-on w-4 h-4 text-[#E1FB15]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    </button>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      ))}
      </div>
    </div>
  </div>

  <!-- ───────── Ajutor sheet ───────── -->
  <div id="help-modal" transition:persist="app-help" class="app-sheet hidden fixed inset-0 z-[90] flex items-end sm:items-center justify-center p-0 sm:p-4 bg-black/70" style="font-family:'Outfit',ui-sans-serif,system-ui,sans-serif">
    <div id="help-card" class="app-sheet-card w-full sm:max-w-[520px] max-h-[92vh] sm:max-h-[88vh] overflow-y-auto bg-[#07090f] rounded-t-[28px] sm:rounded-[28px] ring-1 ring-white/15 shadow-[0_-12px_60px_-12px_rgba(0,0,0,0.7)] sm:shadow-[0_30px_80px_-20px_rgba(0,0,0,0.85)]">
      <div class="flex items-center justify-between gap-3 px-5 pt-5 sm:pt-6 pb-1">
        <h3 class="text-[20px] font-bold text-white">Ajutor</h3>
        <button id="help-close-btn" type="button" aria-label="Închide" class="shrink-0 fm-close-btn">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="sheet-content px-5 pt-3 pb-6 space-y-5 text-[15px] leading-relaxed text-[#C8DAE8]">
        <div>
          <p class="font-semibold text-white mb-2">Cum începi în 3 pași</p>
          <ol class="space-y-2 list-decimal list-inside">
            <li>Adaugă-ți firma în <a href="/app/setari/companie" class="text-[#76C893] font-medium underline">Date firmă</a>.</li>
            <li>Adaugă un client în <a href="/app/facturare/clienti" class="text-[#76C893] font-medium underline">Clienți</a>.</li>
            <li>Apasă <a href="/app/facturare/emite" class="text-[#76C893] font-medium underline">Emite factură</a> și gata.</li>
          </ol>
        </div>
        <div>
          <p class="font-semibold text-white mb-1">Ai date în Oblio sau SmartBill?</p>
          <p>Le aduci automat din <a href="/app/import" class="text-[#76C893] font-medium underline">Import date</a>.</p>
        </div>
        <div class="rounded-xl bg-[#07090f] border border-white/10 p-4">
          <p class="font-semibold text-white mb-1">Ai nevoie de un om?</p>
          <p>Scrie-ne la <a href="mailto:contact@facturamea.com" class="text-[#76C893] font-medium underline">contact@facturamea.com</a> și te ajutăm.</p>
        </div>
        <p class="text-[13px] text-[#8FA6BC]">Sfat: din meniul cu setări (colțul dreapta sus) poți comuta între tema deschisă și întunecată.</p>
      </div>
    </div>
  </div>

  {user && <SupportSheet client:load userEmail={user.email} transition:persist="app-support" />}

  <script>
    function bind(id: string, fn: () => void) { document.getElementById(id)?.addEventListener('click', fn); }

    // Generic sheet — bottom-sheet on mobile / centered modal on desktop. Smooth
    // open + close, backdrop & Esc to dismiss, and drag-down on the grab handle.
    function setupSheet(overlayId: string, cardId: string, handleId: string) {
      const overlay = document.getElementById(overlayId);
      const card = document.getElementById(cardId);
      const handle = document.getElementById(handleId);
      let hideTimer = 0;
      const open = () => {
        if (!overlay) return;
        window.clearTimeout(hideTimer);
        overlay.classList.remove('hidden');
        if (card) card.style.transform = '';
        document.documentElement.classList.add('sheet-lock');
        overlay.classList.add('is-open');
        // Explicitly play the entrance with the Web Animations API. A CSS
        // transition can't fire here because the sheet starts at display:none
        // (the .hidden toggle), so there is no painted "from" frame to animate
        // from — the card would snap straight open. .animate() has no such
        // limitation: it slides up (mobile) / scale-fades (desktop) every time.
        if (card && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          const mobile = window.matchMedia('(max-width: 639.5px)').matches;
          overlay.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 260, easing: 'ease' });
          card.animate(
            mobile
              ? [{ transform: 'translateY(100%)' }, { transform: 'translateY(0)' }]
              : [{ transform: 'translateY(16px) scale(.96)', opacity: 0 }, { transform: 'translateY(0) scale(1)', opacity: 1 }],
            { duration: mobile ? 440 : 340, easing: 'cubic-bezier(.22,1,.36,1)' },
          );
        }
      };
      const close = () => {
        if (!overlay || overlay.classList.contains('hidden')) return;
        overlay.classList.remove('is-open');
        card?.classList.remove('dragging');
        if (card) card.style.transform = '';
        document.documentElement.classList.remove('sheet-lock');
        window.clearTimeout(hideTimer);
        hideTimer = window.setTimeout(() => overlay.classList.add('hidden'), 440);
      };
      const isOpen = () => !!overlay && overlay.classList.contains('is-open');
      const toggle = () => (isOpen() ? close() : open());
      overlay?.addEventListener('click', (e) => { if (e.target === overlay) close(); });
      // Close via the X button (all screen sizes) + backdrop + Esc. No swipe.
      void handle;

      return { open, close, toggle, isOpen };
    }

    // ── Sliding active-page pill (desktop nav + mobile bottom nav) ──
    function setupNavSlider(containerId: string, pillId: string, memKey: string) {
      const container = document.getElementById(containerId);
      const pill = document.getElementById(pillId);
      if (!container || !pill) return null;
      const items = Array.from(container.querySelectorAll<HTMLElement>('[data-nav-pill]'));
      if (!items.length) return null;
      // The menu button is a pill target but never the resting "active" one.
      let active = items.find((i) => i.dataset.active === 'true') || null;
      // Active text colors differ per bar (desktop = white, mobile dock = lime).
      const cOn = containerId === 'nav-mobile' ? 'text-[#E1FB15]' : 'text-white';
      const cOff = containerId === 'nav-mobile' ? 'text-[#A8BED2]' : 'text-[#C8DAE8]';
      const place = (el: HTMLElement | null, animate: boolean) => {
        if (!el) { pill.style.opacity = '0'; return; }
        if (!animate) pill.classList.add('no-anim');
        pill.style.left = el.offsetLeft + 'px';
        pill.style.width = el.offsetWidth + 'px';
        pill.style.opacity = '1';
        if (!animate) { void pill.offsetWidth; pill.classList.remove('no-anim'); }
      };
      const reset = () => place(active, true);
      if (active) {
        // Slide in from the previously-visited section's slot (if different).
        let prevEl: HTMLElement | null = null;
        try {
          const prevHref = sessionStorage.getItem(memKey);
          if (prevHref) prevEl = items.find((i) => i.getAttribute('href') === prevHref) || null;
        } catch {}
        place(prevEl && prevEl !== active ? prevEl : active, false);
        if (prevEl && prevEl !== active) requestAnimationFrame(() => requestAnimationFrame(() => place(active, true)));
        try { sessionStorage.setItem(memKey, active.getAttribute('href') || ''); } catch {}
      } else {
        place(null, false);
      }
      // Slide to an item the moment it's pressed (feels click-driven on mobile
      // and desktop), before the page navigates / the menu opens.
      items.forEach((i) => {
        i.addEventListener('pointerdown', () => place(i, true));
        i.addEventListener('mouseenter', () => place(i, true)); // desktop hover-follow
      });
      container.addEventListener('mouseleave', () => place(active, true));
      window.addEventListener('resize', () => place(active, false));

      // Re-detect the active section from the current URL and glide the pill —
      // used after a View-Transition navigation, since the dock is persisted and
      // keeps the previous page's active state.
      const syncActive = () => {
        const path = (location.pathname.replace(/\/+$/, '') || '/');
        let best: HTMLElement | null = null, bestLen = -1;
        for (const i of items) {
          const href = i.getAttribute('href'); if (!href) continue;
          const h = href.replace(/\/+$/, '') || '/';
          if ((path === h || path.startsWith(h + '/')) && h.length > bestLen) { best = i; bestLen = h.length; }
        }
        active = best;
        for (const i of items) {
          if (!i.getAttribute('href')) continue; // skip the menu button
          const on = i === active;
          i.dataset.active = on ? 'true' : 'false';
          i.classList.toggle(cOn, on);
          i.classList.toggle(cOff, !on);
        }
        place(active, true);
        try { if (active) sessionStorage.setItem(memKey, active.getAttribute('href') || ''); } catch {}
      };
      return { reset, syncActive };
    }
    const navSliderD = setupNavSlider('nav-desktop', 'nav-pill-d', 'fm-nav-active');
    const navSliderM = setupNavSlider('nav-mobile', 'nav-pill-m', 'fm-nav-active-m');
    // Recompute once the webfont has loaded (text width changes the pill size).
    if ((document as any).fonts?.ready) (document as any).fonts.ready.then(() => window.dispatchEvent(new Event('resize')));

    // ── View-Transitions glue: the navbar/dock/sheets are persisted, so on each
    // SPA navigation re-sync the active dock pill to the new page. Old content
    // stays visible until the new page is ready, then crossfades — no blank frame.
    // Sync on after-swap (fires right after the DOM swap) AND page-load (after assets)
    // so the persisted dock never shows the previous page's active tab, even briefly.
    document.addEventListener('astro:after-swap', () => {
      navSliderD?.syncActive?.(); navSliderM?.syncActive?.();
    });
    document.addEventListener('astro:page-load', () => {
      navSliderD?.syncActive?.(); navSliderM?.syncActive?.();
    });

    // The menu button slides the pill to itself on press; when the menu sheet
    // closes again, glide the pill back to the real active page.
    const menuOverlayEl = document.getElementById('menu-overlay');
    if (menuOverlayEl) {
      new MutationObserver(() => {
        if (!menuOverlayEl.classList.contains('is-open')) { navSliderD?.reset(); navSliderM?.reset(); }
      }).observe(menuOverlayEl, { attributes: true, attributeFilter: ['class'] });
    }

    const settingsBtn = document.getElementById('settings-btn');
    const settings = setupSheet('settings-menu', 'settings-card', 'settings-handle');
    const menu = setupSheet('menu-overlay', 'menu-card', 'menu-handle');
    const help = setupSheet('help-modal', 'help-card', 'help-handle');

    // Tapping a tile in the "Ce vrei să faci?" menu (or any sheet link) navigates
    // via SPA; the overlay is transition:persist so it survives the swap. Close it
    // on every page-load so the user lands on the new page without a manual close.
    document.addEventListener('astro:page-load', () => {
      if (menu?.isOpen?.()) menu.close();
      if (settings?.isOpen?.()) settings.close();
      if (help?.isOpen?.()) help.close();
    });

    // Stylish back button → previous page (falls back to the dashboard).
    // Event-delegated: the back button lives in swapped page content, so a direct
    // listener bound once would be lost after the first SPA navigation.
    document.addEventListener('click', (e) => {
      if (!(e.target as Element)?.closest?.('#app-back')) return;
      if (history.length > 1) history.back();
      else location.href = '/app';
    });

    bind('menu-open', menu.open); bind('menu-open-bottom', menu.open); bind('menu-open-top', menu.open);
    bind('help-open', help.open); bind('help-open-2', help.open);
    bind('help-open-settings', () => { settings.close(); setTimeout(() => help.open(), 120); });
    // Desktop X close buttons (mobile closes by swipe/backdrop instead).
    document.getElementById('menu-close-btn')?.addEventListener('click', menu.close);
    document.getElementById('settings-close-btn')?.addEventListener('click', settings.close);
    document.getElementById('help-close-btn')?.addEventListener('click', help.close);
    // Auto-close the quick-actions menu + settings sheet when a link inside them is
    // tapped — otherwise (the sheets are persisted across View-Transition navigation)
    // they'd stay open on top of the page you just navigated to.
    document.getElementById('menu-overlay')?.addEventListener('click', (e) => {
      if ((e.target as Element)?.closest?.('a[href]')) menu.close();
    });
    document.getElementById('settings-menu')?.addEventListener('click', (e) => {
      if ((e.target as Element)?.closest?.('a[href]')) settings.close();
    });
    settingsBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      settings.toggle();
      settingsBtn.setAttribute('aria-expanded', settings.isOpen() ? 'true' : 'false');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { menu.close(); help.close(); settings.close(); }
    });

    // Light ↔ dark theme. Binary: th-light (soft light) or th-app-dark (near-black).
    // Default = dark. Persisted as 'app-theme-light'.
    const LIGHT_KEY = 'app-theme-light';
    const themeBtn = document.getElementById('th-dark-btn');
    const moon = document.getElementById('th-moon'); const sun = document.getElementById('th-sun');
    function applyTheme(light: boolean) {
      const el = document.documentElement;
      el.classList.toggle('th-light', light);
      el.classList.toggle('th-app-dark', !light);
      el.classList.toggle('th-dark', !light); // existing dark theme for the secondary pages
      themeBtn?.setAttribute('aria-pressed', light ? 'true' : 'false');
      moon?.classList.toggle('hidden', light);   // moon shows in dark mode
      sun?.classList.toggle('hidden', !light);   // sun shows in light mode
      // Keep the status-bar / notch color in sync with the theme (live on toggle).
      document.querySelector('meta[name="theme-color"]')?.setAttribute('content', light ? '#EEF2F6' : '#07090f');
    }
    applyTheme(localStorage.getItem(LIGHT_KEY) === '1');
    let themeTrTimer = 0;
    themeBtn?.addEventListener('click', () => {
      const next = !document.documentElement.classList.contains('th-light');
      localStorage.setItem(LIGHT_KEY, next ? '1' : '0');
      // Uniform transition: everything changes together for the duration of the swap.
      document.documentElement.classList.add('theme-transitioning');
      window.clearTimeout(themeTrTimer);
      themeTrTimer = window.setTimeout(() => document.documentElement.classList.remove('theme-transitioning'), 340);
      applyTheme(next);
    });

    // ── Dashboard pins from the Acțiuni overlay ──
    const SYNC_EVENT = 'dashboard-modules-changed';
    const pinBtns = Array.from(document.querySelectorAll('.dash-pin'));
    const currentPins = () =>
      Array.from(document.querySelectorAll('.dash-pin[data-pinned="true"]'))
        .map((b) => b.getAttribute('data-pin'))
        .filter((k): k is string => !!k);
    async function savePins(list: string[]) {
      try {
        await fetch('/api/me/dashboard', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ modules: list }),
        });
      } catch { /* keep optimistic state */ }
    }
    pinBtns.forEach((b) => b.addEventListener('click', (e) => {
      e.preventDefault(); e.stopPropagation();
      const now = b.getAttribute('data-pinned') === 'true';
      b.setAttribute('data-pinned', now ? 'false' : 'true');
      // restart the little pop animation on the button
      b.classList.remove('pin-pop'); void (b as HTMLElement).offsetWidth; b.classList.add('pin-pop');
      const list = currentPins();
      savePins(list);
      window.dispatchEvent(new CustomEvent(SYNC_EVENT, { detail: { modules: list, source: 'overlay' } }));
    }));
    // Keep the pin buttons in sync when the dashboard island changes things.
    window.addEventListener(SYNC_EVENT, (e) => {
      const detail = (e as CustomEvent).detail as { modules?: string[]; source?: string } | undefined;
      if (!detail || detail.source === 'overlay') return;
      const set = new Set(detail.modules || []);
      pinBtns.forEach((b) => b.setAttribute('data-pinned', set.has(b.getAttribute('data-pin') || '') ? 'true' : 'false'));
    });
  </script>
</BaseLayout>
