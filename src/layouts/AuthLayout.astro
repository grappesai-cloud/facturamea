---
import BaseLayout from './BaseLayout.astro';
import { tFn } from '../lib/i18n';

interface Props {
  title: string;
  // Optional one-line tagline shown above the form (e.g. "Acces cont")
  tagline?: string;
}

const { title, tagline } = Astro.props;
const t = tFn(Astro.locals.locale);
---

<BaseLayout title={title} themeColor="#FAFAF8">
  <div class="min-h-screen bg-[#FAFAF8] text-[#0A0A0A] flex flex-col" style="font-family:'Inter',ui-sans-serif,system-ui,sans-serif">
    <!-- Top bar with logo + back to landing -->
    <header class="px-6 lg:px-10 py-5 flex items-center justify-between border-b border-[#E8E8E4]">
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-7 h-7 bg-[#FF5C00] rounded-xl flex items-center justify-center">
          <span class="text-white font-bold text-[12px] tracking-tight">f</span>
        </div>
        <span class="text-[15px] font-bold tracking-[-0.02em]">factura<span class="text-[#FF5C00]">mea</span></span>
      </a>
      <a href="/" class="text-[12px] text-[#6B6B68] hover:text-[#0A0A0A] transition-colors">{t('pages.auth.back_to_site')}</a>
    </header>

    <!-- Centered content -->
    <main class="flex-1 flex items-center justify-center px-6 py-12">
      <div class="w-full max-w-[440px]">
        {tagline && (
          <p class="text-[11px] uppercase tracking-[0.18em] text-[#6B6B68] font-medium text-center mb-2">{tagline}</p>
        )}
        <slot />
      </div>
    </main>

    <!-- Trust footer -->
    <footer class="px-6 lg:px-10 py-5 border-t border-[#E8E8E4] flex flex-col sm:flex-row items-center justify-between gap-2 text-[11px] text-[#6B6B68]">
      <p>© {new Date().getFullYear()} facturamea. Facturare cu licență pe viață.</p>
      <div class="flex items-center gap-4">
        <a href="/termeni" class="hover:text-[#0A0A0A] transition-colors">Termeni</a>
        <a href="/confidentialitate" class="hover:text-[#0A0A0A] transition-colors">Confidenţialitate</a>
        <a href="/contact" class="hover:text-[#0A0A0A] transition-colors">Contact</a>
      </div>
    </footer>
  </div>
</BaseLayout>
