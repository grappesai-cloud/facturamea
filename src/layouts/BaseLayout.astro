    <script is:inline>
      if ('serviceWorker' in navigator && location.protocol === 'https:') {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      } else if ('serviceWorker' in navigator && /^(localhost$|127\.|10\.|192\.168\.|172\.(1[6-9]|2[0-9]|3[01])\.)/.test(location.hostname)) {
        // Dev self-heal: a leftover service worker from a previous app on this
        // origin can serve stale cached assets ("my changes don't show up").
        // Covers localhost AND `--host` LAN access. Unregister + clear caches,
        // then reload once so the page drops the old controlling worker.
        navigator.serviceWorker.getRegistrations().then((regs) => {
          const had = regs.length > 0;
          regs.forEach((r) => r.unregister());
          if (window.caches && caches.keys) caches.keys().then((keys) => keys.forEach((k) => caches.delete(k)));
          // A stale worker still controls THIS page until reload — drop it once
          // (sessionStorage guard prevents any reload loop).
          if (had && navigator.serviceWorker.controller && !sessionStorage.getItem('sw-healed')) {
            sessionStorage.setItem('sw-healed', '1');
            location.reload();
          }
        }).catch(() => {});
      }
    </script>
