---
import BaseLayout from './BaseLayout.astro';

interface Props { title: string; }
const { title } = Astro.props;
const user = Astro.locals.user;
---

<BaseLayout title={title} themeColor="#FF5C00">
  <div class="min-h-screen bg-[#FAFAF8] text-[#0A0A0A]" style="font-family:'Inter',sans-serif">
    <header class="px-4 py-3 bg-[#0A0A0A] text-white flex items-center justify-between sticky top-0 z-30">
      <a href="/app/driver" class="flex items-center gap-2">
        <div class="w-7 h-7 bg-[#FF5C00] rounded-xl flex items-center justify-center">
          <span class="font-bold text-[11px]">TH</span>
        </div>
        <span class="text-[14px] font-bold">Driver</span>
      </a>
      <div class="text-right">
        <p class="text-[11px] leading-tight">{user?.name}</p>
        <p class="text-[10px] text-white/60 leading-tight">{user?.platformId}</p>
      </div>
    </header>

    <main class="max-w-md mx-auto px-4 py-5 pb-24">
      <slot />
    </main>

    <nav class="fixed bottom-0 inset-x-0 bg-white border-t border-[#E8E8E4] flex items-stretch z-20">
      <a href="/app/driver" class="flex-1 flex flex-col items-center justify-center py-3 text-[#0A0A0A]">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg>
        <span class="text-[10px] font-medium mt-1">Curse</span>
      </a>
      <a href="/app/driver/hours" class="flex-1 flex flex-col items-center justify-center py-3 text-[#6B6B68]">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 2"/></svg>
        <span class="text-[10px] font-medium mt-1">Ore</span>
      </a>
      <a href="/app/setari" class="flex-1 flex flex-col items-center justify-center py-3 text-[#6B6B68]">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/></svg>
        <span class="text-[10px] font-medium mt-1">Setări</span>
      </a>
    </nav>
  </div>
</BaseLayout>
