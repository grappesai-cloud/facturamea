---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = Astro.locals?.locale ?? 'ro';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} | facturamea</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#EDF1F5] print:bg-white" style="font-family:'Outfit',ui-sans-serif,system-ui,sans-serif">
    <div class="no-print bg-white border-b border-[#E3EAF1] sticky top-0 z-10 print:hidden">
      <div class="max-w-[210mm] mx-auto px-4 py-3 flex items-center justify-between gap-3">
        <div class="text-[13px] text-[#46627A] truncate">{title}</div>
        <div class="flex gap-2 shrink-0">
          <button onclick="window.print()" class="px-4 py-2 rounded-full bg-[#E1FB15] hover:bg-[#D2EA0E] text-[#07090f] text-[13px] font-bold transition-colors">
            Tipăreşte / Salvează PDF
          </button>
          <button onclick="window.close() || history.back()" class="px-4 py-2 rounded-full bg-white ring-1 ring-[#07090f]/15 hover:bg-[#07090f]/[0.04] text-[#07090f] text-[13px] font-semibold transition-colors">
            Închide
          </button>
        </div>
      </div>
    </div>
    <main class="print-doc">
      <slot />
    </main>
    <!-- PDF-ul oficial al documentului fiscal este generat de backend (server,
         vectorial). Aici se folosește exclusiv tipărirea nativă a browserului
         (Print → Salvează ca PDF), pentru a nu genera documente fiscale pe client. -->
  </body>
</html>
