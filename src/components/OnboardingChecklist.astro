---
// Action-driven onboarding pe dashboard. Detectează ce-i lipseşte profilului
// userului şi îi dă call-to-action concret. Se ascunde automat când toate
// item-urile sunt bifate (sau când userul închide explicit cu „Termină mai
// târziu"), persistat prin POST /api/users/onboarding-dismiss → onboarding_seen_at.
import { db } from '../db';
import { availableTrucks, freight, routeAlerts, users } from '../db/schema';
import { eq, sql, and } from 'drizzle-orm';
import { canCarryFreight } from '../lib/permissions';

interface Props { dismissed: boolean }
const { dismissed } = Astro.props;

const user = Astro.locals.user!;

async function safeCount(p: any): Promise<number> {
  try { const [r] = await p; return r?.count ?? 0; } catch { return 0; }
}

const isCarrier = canCarryFreight(user.userType as any);
const isPoster  = user.userType === 'intermediar' || user.userType === 'client_direct';

// Detect what's done
const [u] = await db.select({ totpEnabled: users.totpEnabled }).from(users).where(eq(users.id, user.id));
const has2fa = !!u?.totpEnabled;
const hasPhone = !!user.phone;
const hasCompany = !!user.companyId;

const [routeAlertsCount, myTrucksCount, myFreightCount] = await Promise.all([
  safeCount(db.select({ count: sql<number>`COUNT(*)` }).from(routeAlerts).where(eq(routeAlerts.userId, user.id))),
  hasCompany ? safeCount(db.select({ count: sql<number>`COUNT(*)` }).from(availableTrucks).where(eq(availableTrucks.companyId, user.companyId!))) : 0,
  hasCompany ? safeCount(db.select({ count: sql<number>`COUNT(*)` }).from(freight).where(eq(freight.companyId, user.companyId!))) : 0,
]);

const hasFirstAction = isCarrier ? (myTrucksCount > 0 || routeAlertsCount > 0) : (myFreightCount > 0 || routeAlertsCount > 0);

// Build checklist
type Item = { done: boolean; title: string; desc: string; cta: { label: string; href: string } | null };
const items: Item[] = [
  { done: hasPhone,    title: 'Adaugă numărul de telefon',
    desc: 'Brokerii şi clienţii te pot contacta rapid pentru oferte.',
    cta: hasPhone ? null : { label: 'Adaugă telefon', href: '/app/setari' } },
  { done: hasCompany,  title: 'Asociază o companie',
    desc: 'Profilul public al companiei e cum te văd partenerii înainte să facă business cu tine.',
    cta: hasCompany ? null : { label: 'Asociază companie', href: '/app/companie' } },
  { done: has2fa,      title: 'Activează autentificarea în 2 paşi',
    desc: 'Conturile fără 2FA sunt cele compromise — pierdere de bani şi reputaţie.',
    cta: has2fa ? null : { label: 'Activează 2FA', href: '/app/setari/securitate' } },
  isCarrier
    ? { done: hasFirstAction, title: 'Postează primul camion liber sau setează o alertă de rută',
        desc: 'Brokerii vor şti pe ce rute eşti disponibil, vei primi notificări la marfă potrivită.',
        cta: hasFirstAction ? null : { label: 'Postează camion', href: '/app/camioane/post' } }
    : { done: hasFirstAction, title: 'Postează prima marfă sau setează o alertă de rută',
        desc: 'Începe să primeşti oferte de la transportatori care lucrează pe rutele tale.',
        cta: hasFirstAction ? null : { label: 'Postează marfă', href: '/app/marfa/post' } },
];

const doneCount = items.filter((i) => i.done).length;
const totalCount = items.length;
const allDone = doneCount === totalCount;

// Hide if dismissed, or all done — show 1x final celebration when first hits "all done" but
// then user reloads and we hide. Persisted via API after celebration.
const shouldRender = !dismissed && !allDone;
---

{shouldRender && (
  <div class="th-card th-card-lg th-card-yellow mb-8">
    <div class="flex items-start justify-between gap-4 flex-wrap mb-5">
      <div>
        <p class="th-eyebrow">Onboarding</p>
        <h2 class="th-h2 mt-1">Pune profilul la punct ({doneCount}/{totalCount})</h2>
        <p class="text-[12px] text-[#3D3D3A] mt-1.5">5 minute acum = mai puţin haos peste 3 luni.</p>
      </div>
      <button
        type="button"
        id="onboarding-skip-btn"
        class="text-[12px] text-[#3D3D3A] hover:text-[#0A0A0A] font-medium transition-colors"
      >
        Termină mai târziu
      </button>
    </div>

    {/* Progress bar */}
    <div class="w-full h-1.5 bg-white/60 rounded-full overflow-hidden mb-5">
      <div class="h-full bg-[#0A0A0A] transition-all duration-500" style={`width: ${(doneCount / totalCount) * 100}%`}></div>
    </div>

    <ul class="space-y-2">
      {items.map((it) => (
        <li class:list={['flex items-center gap-3 p-4 rounded-xl', it.done ? 'bg-white/40' : 'bg-white/80']}>
          <span class:list={['w-7 h-7 rounded-full flex items-center justify-center shrink-0', it.done ? 'bg-[#0A0A0A] text-white' : 'border-2 border-[#0A0A0A]/30']}>
            {it.done ? (
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            ) : null}
          </span>
          <div class="min-w-0 flex-1">
            <p class:list={['text-[13px] font-semibold', it.done ? 'text-[#3D3D3A] line-through' : 'text-[#0A0A0A]']}>{it.title}</p>
            {!it.done && <p class="text-[11px] text-[#3D3D3A] mt-0.5">{it.desc}</p>}
          </div>
          {it.cta && (
            <a href={it.cta.href} class="px-3.5 py-1.5 bg-[#0A0A0A] hover:bg-[#2E2E2C] text-white text-[12px] font-semibold rounded-xl transition-colors shrink-0">
              {it.cta.label} →
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>

  <script>
    document.getElementById('onboarding-skip-btn')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const card = btn.closest('.th-card');
      try { await fetch('/api/users/onboarding-dismiss', { method: 'POST' }); } catch {}
      if (card) (card as HTMLElement).style.display = 'none';
    });
  </script>
)}
