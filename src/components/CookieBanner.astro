---
// facturamea uses ONLY strictly-necessary cookies (login session, language
// preference, CSRF/rate-limit security). No analytics, no marketing/ad
// tracking, no third-party chat — so the banner is a short honest notice, not
// a consent manager. If tracking is added later, reintroduce categories here
// and gate the scripts on consent.
---

<div id="cookie-banner" class="hidden fixed bottom-5 left-4 right-4 md:left-auto md:right-6 md:max-w-md z-[80] bg-white rounded-[22px] ring-1 ring-black/[0.06] shadow-[0_24px_60px_-28px_rgba(16,42,67,0.45)] p-6" style="font-family:'Outfit',ui-sans-serif,system-ui,sans-serif">
  <h4 class="font-bold text-[15px] text-[#0A2238] tracking-[-0.01em]">Folosim cookies</h4>
  <p class="text-[13px] text-[#46627A] leading-relaxed mt-2 mb-5">
    Folosim doar cookies strict necesare pentru funcţionarea platformei (sesiune de login, limbă, securitate). Nu folosim tracking publicitar şi nu partajăm date cu terţi.
    <a href="/confidentialitate" class="text-[#1A759F] font-semibold underline-offset-2 hover:underline transition-colors">Politica de confidenţialitate</a>.
  </p>
  <button id="cookie-accept" class="w-full px-5 py-3 rounded-full bg-[#E1FB15] hover:bg-[#D2EA0E] text-[#0A2238] text-[13px] font-bold transition-colors">
    Am înţeles
  </button>
</div>

<script>
  const STORAGE_KEY = 'th-cookie-consent';
  const banner = document.getElementById('cookie-banner');

  function loadConsent() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      return (typeof parsed === 'object' && parsed.decidedAt) ? parsed : null;
    } catch { return null; }
  }

  function acknowledge() {
    // Only necessary cookies are used; this just records that the notice was seen.
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ necessary: true, decidedAt: new Date().toISOString() }));
    banner?.classList.add('hidden');
  }

  document.getElementById('cookie-accept')?.addEventListener('click', acknowledge);

  // Synchronous query helper kept for compatibility.
  (window as any).__thCookieConsent = () => loadConsent();

  if (!loadConsent()) setTimeout(() => banner?.classList.remove('hidden'), 600);
</script>
