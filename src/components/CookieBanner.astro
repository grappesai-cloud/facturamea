---
import { tFn } from '../lib/i18n';
const t = tFn(Astro.locals?.locale ?? 'ro');
---

<!-- Slim banner: shown until user makes a choice -->
<div id="cookie-banner" class="hidden fixed bottom-6 left-6 right-6 md:left-auto md:right-6 md:max-w-lg z-50 bg-white border border-[#E8E8E4] rounded-xl shadow-[0_8px_32px_-4px_rgba(0,0,0,0.12)] p-7">
  <h4 class="font-semibold text-[13px] text-[#0A0A0A]">{t('cookies.title')}</h4>
  <p class="text-[11px] text-[#6B6B68] leading-relaxed mt-2 mb-5">
    {t('cookies.text')} <a href="/confidentialitate" class="text-[#0A0A0A] underline hover:text-[#FF5C00] transition-colors">{t('cookies.link')}</a>.
  </p>
  <div class="flex flex-col gap-2.5">
    <button id="cookie-accept-all" class="w-full px-4 py-2 bg-[#FF5C00] hover:bg-[#E04E00] text-white text-[12px] font-semibold rounded-xl transition-colors">
      Accept toate
    </button>
    <div class="flex gap-2">
      <button id="cookie-reject-all" class="flex-1 min-w-0 px-3 py-2 bg-white border border-[#E8E8E4] hover:border-[#0A0A0A] text-[#0A0A0A] text-[12px] font-medium rounded-xl transition-colors">
        Doar necesare
      </button>
      <button id="cookie-customize" class="flex-1 min-w-0 px-3 py-2 bg-white border border-[#E8E8E4] hover:border-[#0A0A0A] text-[#0A0A0A] text-[12px] font-medium rounded-xl transition-colors">
        Personalizează
      </button>
    </div>
  </div>
</div>

<!-- Detailed modal: only shown when user clicks "Personalizează" -->
<div id="cookie-modal" class="hidden fixed inset-0 z-[60] bg-[#0A0A0A]/40 flex items-end md:items-center justify-center p-0 md:p-6">
  <div class="bg-white w-full md:max-w-lg rounded-t-2xl md:rounded-xl shadow-2xl border border-[#E8E8E4] max-h-[90vh] overflow-y-auto">
    <div class="px-6 py-5 border-b border-[#E8E8E4] flex items-center justify-between">
      <h3 class="font-bold text-[#0A0A0A]">Preferinţe cookies</h3>
      <button id="cookie-modal-close" class="text-[#6B6B68] hover:text-[#0A0A0A] transition-colors" aria-label="Închide">✕</button>
    </div>

    <div class="px-6 py-5 space-y-5">
      <p class="text-[12px] text-[#6B6B68] leading-relaxed">
        Folosim cookies pentru funcţionare, măsurare şi îmbunătăţire. Alege ce categorii accepţi. Le poţi schimba oricând din această pagină.
      </p>

      <!-- Necessary -->
      <div class="p-4 bg-[#FAFAF8] border border-[#E8E8E4] rounded-xl">
        <div class="flex items-center justify-between mb-1">
          <h4 class="font-semibold text-[13px] text-[#0A0A0A]">Necesare</h4>
          <span class="text-[11px] text-[#6B6B68] uppercase tracking-wider">Mereu activ</span>
        </div>
        <p class="text-[12px] text-[#6B6B68] leading-relaxed">Sesiune login, preferinţe limbă, securitate (CSRF, rate-limit). Fără ele, platforma nu funcţionează.</p>
      </div>

      <!-- Analytics -->
      <label class="block p-4 bg-white border border-[#E8E8E4] rounded-xl cursor-pointer hover:border-[#A8A8A4] transition-colors">
        <div class="flex items-center justify-between mb-1">
          <h4 class="font-semibold text-[13px] text-[#0A0A0A]">Analytics</h4>
          <input type="checkbox" id="cookie-analytics" class="w-4 h-4 accent-[#FF5C00]" />
        </div>
        <p class="text-[12px] text-[#6B6B68] leading-relaxed">Vercel Analytics, statistici de utilizare anonime. Ne ajută să prioritizăm îmbunătăţiri.</p>
      </label>

      <!-- Marketing -->
      <label class="block p-4 bg-white border border-[#E8E8E4] rounded-xl cursor-pointer hover:border-[#A8A8A4] transition-colors">
        <div class="flex items-center justify-between mb-1">
          <h4 class="font-semibold text-[13px] text-[#0A0A0A]">Marketing</h4>
          <input type="checkbox" id="cookie-marketing" class="w-4 h-4 accent-[#FF5C00]" />
        </div>
        <p class="text-[12px] text-[#6B6B68] leading-relaxed">Tracking pentru remarketing şi conversii (campanii Google Ads / Meta). Necesar pentru reclame personalizate.</p>
      </label>

      <!-- Support chat -->
      <label class="block p-4 bg-white border border-[#E8E8E4] rounded-xl cursor-pointer hover:border-[#A8A8A4] transition-colors">
        <div class="flex items-center justify-between mb-1">
          <h4 class="font-semibold text-[13px] text-[#0A0A0A]">Chat asistenţă</h4>
          <input type="checkbox" id="cookie-support" class="w-4 h-4 accent-[#FF5C00]" />
        </div>
        <p class="text-[12px] text-[#6B6B68] leading-relaxed">Widget Crisp pentru asistenţă în timp real. Activează-l doar dacă vrei să poţi vorbi cu noi din browser.</p>
      </label>
    </div>

    <div class="px-6 py-4 border-t border-[#E8E8E4] flex flex-wrap gap-2 justify-end">
      <button id="cookie-modal-reject" class="px-4 py-2 bg-white border border-[#E8E8E4] hover:border-[#0A0A0A] text-[#0A0A0A] text-[13px] font-medium rounded-xl transition-colors">
        Doar necesare
      </button>
      <button id="cookie-modal-save" class="px-5 py-2 bg-[#FF5C00] hover:bg-[#E04E00] text-white text-[13px] font-semibold rounded-xl transition-colors">
        Salvează preferinţele
      </button>
    </div>
  </div>
</div>

<script>
  // Persisted shape: { necessary: true, analytics: bool, marketing: bool, support: bool, decidedAt: ISO }
  const STORAGE_KEY = 'th-cookie-consent';
  const banner = document.getElementById('cookie-banner');
  const modal = document.getElementById('cookie-modal');

  type Consent = { necessary: true; analytics: boolean; marketing: boolean; support: boolean; decidedAt: string };

  function loadConsent(): Consent | null {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      if (typeof parsed !== 'object' || !parsed.decidedAt) return null;
      return parsed as Consent;
    } catch { return null; }
  }

  function saveConsent(c: Omit<Consent, 'necessary' | 'decidedAt'>) {
    const final: Consent = { necessary: true, ...c, decidedAt: new Date().toISOString() };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(final));
    document.dispatchEvent(new CustomEvent('cookie-consent-updated', { detail: final }));
    banner?.classList.add('hidden');
    modal?.classList.add('hidden');
  }

  function showBannerIfNeeded() {
    if (!loadConsent()) {
      setTimeout(() => banner?.classList.remove('hidden'), 600);
    }
  }

  function openModal() {
    const current = loadConsent();
    (document.getElementById('cookie-analytics') as HTMLInputElement).checked = !!current?.analytics;
    (document.getElementById('cookie-marketing') as HTMLInputElement).checked = !!current?.marketing;
    (document.getElementById('cookie-support') as HTMLInputElement).checked = !!current?.support;
    banner?.classList.add('hidden');
    modal?.classList.remove('hidden');
  }

  document.getElementById('cookie-accept-all')?.addEventListener('click', () =>
    saveConsent({ analytics: true, marketing: true, support: true })
  );
  document.getElementById('cookie-reject-all')?.addEventListener('click', () =>
    saveConsent({ analytics: false, marketing: false, support: false })
  );
  document.getElementById('cookie-customize')?.addEventListener('click', openModal);
  document.getElementById('cookie-modal-close')?.addEventListener('click', () => {
    modal?.classList.add('hidden');
    banner?.classList.remove('hidden');
  });
  document.getElementById('cookie-modal-reject')?.addEventListener('click', () =>
    saveConsent({ analytics: false, marketing: false, support: false })
  );
  document.getElementById('cookie-modal-save')?.addEventListener('click', () => {
    saveConsent({
      analytics: (document.getElementById('cookie-analytics') as HTMLInputElement).checked,
      marketing: (document.getElementById('cookie-marketing') as HTMLInputElement).checked,
      support: (document.getElementById('cookie-support') as HTMLInputElement).checked,
    });
  });

  // Allow other scripts to query the consent state synchronously
  (window as any).__thCookieConsent = () => loadConsent();
  (window as any).__thOpenCookieModal = openModal;

  showBannerIfNeeded();
</script>
