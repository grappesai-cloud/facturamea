---
// Shared, self-contained invoice document body. Rendered inside both the
// authenticated print view (/app/facturare/[id]/print) and the public share
// view (/factura/[token]). Respects per-model display toggles + the chosen
// template (layoutKey): classic · modern · minimal · bold · elegant.
interface Props {
  inv: any;
  lines: any[];
  issuer: any;
  model?: any;
  qrDataUrl?: string | null;
}
const { inv, lines, issuer, model = null, qrDataUrl = null } = Astro.props;

const isEn = inv.language === 'en';
const t = (ro: string, en: string) => (isEn ? en : ro);
const prec = Number.isInteger(inv.precision) ? inv.precision : 2;
const fmt = (cents: number) => (cents / 100).toLocaleString(isEn ? 'en-US' : 'ro-RO', { minimumFractionDigits: prec, maximumFractionDigits: prec });

const kindLabel: Record<string, string> = {
  factura: t('Factură fiscală', 'Invoice'),
  proforma: t('Factură proformă', 'Proforma invoice'),
  storno: t('Factură storno', 'Credit note'),
  chitanta: t('Chitanță', 'Receipt'),
  aviz: t('Aviz de însoțire a mărfii', 'Delivery note'),
};

// ── Template ──
const LAYOUTS = ['classic', 'modern', 'minimal', 'bold', 'elegant'] as const;
const rawKey = model?.layoutKey === 'accent' ? 'elegant' : (model?.layoutKey ?? 'classic');
const layout = (LAYOUTS as readonly string[]).includes(rawKey) ? rawKey : 'classic';
const cfg = ({
  classic: { topBar: true, band: false, stripe: false, tableFill: true, totalFill: false, panel: false },
  modern: { topBar: false, band: true, stripe: false, tableFill: true, totalFill: true, panel: false },
  minimal: { topBar: false, band: false, stripe: false, tableFill: false, totalFill: false, panel: false },
  bold: { topBar: false, band: false, stripe: true, tableFill: true, totalFill: true, panel: false },
  elegant: { topBar: false, band: false, stripe: false, tableFill: true, totalFill: false, panel: true },
} as Record<string, any>)[layout];

// On-brand defaults (navy) — overridden by the user's chosen brand colour.
const brand = model?.brandColor && model.brandColor !== '#0A0A0A' ? model.brandColor : '#07090f';
const logoUrl = model?.logoUrl ?? issuer?.invoiceLogoUrl ?? null;
const stampUrl = issuer?.invoiceStampUrl ?? null;
const signatureUrl = issuer?.invoiceSignatureUrl ?? null;
const footerText = issuer?.invoiceFooterText ?? model?.footerText ?? '';
const showShipping = model?.showShipping !== false && !!inv.shippingText;
const showEmittedWith = !!model?.showEmittedWith;

// Site palette
const INK = '#07090f';
const MUTED = '#46627A';
const FAINT = '#8FA6BC';
const LINE = '#E3EAF1';
const LINE2 = '#EFF3F7';

const shellStyle = [
  `max-width:210mm; min-height:297mm;`,
  cfg.topBar ? `border-top:8px solid ${brand};` : '',
  cfg.stripe ? `border-left:10px solid ${brand}; padding-left:2.5rem;` : '',
].join(' ');
---

<div class="fm-invoice-paper doc-shell mx-auto p-10" style={shellStyle}>
  {cfg.band ? (
    <div class="-mx-10 -mt-10 mb-7 px-10 py-7 text-white" style={`background:${brand}`}>
      <div class="flex items-start justify-between gap-6">
        <div>
          {logoUrl && <img src={logoUrl} alt={issuer?.name ?? ''} style="max-height: 52px; margin-bottom: 10px;" />}
          <p class="text-[10px] uppercase tracking-wider text-white/70">{t('Furnizor', 'Supplier')}</p>
          <p class="font-bold mt-1 text-lg">{issuer?.name ?? '—'}</p>
          {issuer?.cui && <p class="text-xs mt-0.5 text-white/75">CUI: {issuer.cui}</p>}
          {issuer?.regCom && <p class="text-xs mt-0.5 text-white/75">Reg. com.: {issuer.regCom}</p>}
          {issuer?.address && <p class="text-xs mt-0.5 text-white/75">{issuer.address}</p>}
          {issuer?.iban && <p class="text-xs mt-0.5 text-white/75">IBAN: {issuer.iban}</p>}
        </div>
        <div class="text-right">
          <p class="text-[10px] uppercase tracking-wider text-white/70">{kindLabel[inv.kind] ?? 'Document'}</p>
          <p class={`${layout === 'bold' ? 'text-4xl' : 'text-3xl'} font-bold mt-1 font-mono tabular-nums`}>{inv.fullNumber}</p>
          <p class="text-xs mt-2 text-white/75">{t('Data emitere', 'Issue date')}: {inv.issuedAt ? new Date(inv.issuedAt).toLocaleDateString(isEn ? 'en-GB' : 'ro-RO') : '—'}</p>
          {inv.dueAt && <p class="text-xs mt-0.5 text-white/75">{t('Scadență', 'Due date')}: {new Date(inv.dueAt).toLocaleDateString(isEn ? 'en-GB' : 'ro-RO')}</p>}
        </div>
      </div>
    </div>
  ) : (
    <div class={`flex items-start justify-between gap-6 pb-6 ${cfg.panel ? 'rounded-2xl p-6 mb-2' : 'border-b'}`} style={cfg.panel ? `background:${brand}0A` : `border-color:${LINE}`}>
      <div>
        {logoUrl && <img src={logoUrl} alt={issuer?.name ?? ''} style="max-height: 60px; margin-bottom: 12px;" />}
        <p class="text-[10px] uppercase tracking-wider" style={`color:${FAINT}`}>{t('Furnizor', 'Supplier')}</p>
        <p class="font-bold mt-1 text-lg" style={`color:${INK}`}>{issuer?.name ?? '—'}</p>
        {issuer?.cui && <p class="text-xs mt-0.5" style={`color:${MUTED}`}>CUI: {issuer.cui}</p>}
        {issuer?.regCom && <p class="text-xs mt-0.5" style={`color:${MUTED}`}>Reg. com.: {issuer.regCom}</p>}
        {issuer?.address && <p class="text-xs mt-0.5" style={`color:${MUTED}`}>{issuer.address}</p>}
        {issuer?.iban && <p class="text-xs mt-0.5" style={`color:${MUTED}`}>IBAN: {issuer.iban}</p>}
      </div>
      <div class="text-right">
        {layout === 'minimal' ? (
          <p class="text-[11px] uppercase tracking-[0.2em]" style={`color:${MUTED}`}>{kindLabel[inv.kind] ?? 'Document'}</p>
        ) : (
          <span class="inline-block text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full text-white" style={`background:${brand}`}>{kindLabel[inv.kind] ?? 'Document'}</span>
        )}
        <p class="text-3xl font-bold mt-2 font-mono tabular-nums" style={`color:${brand}`}>{inv.fullNumber}</p>
        <p class="text-xs mt-2" style={`color:${MUTED}`}>{t('Data emitere', 'Issue date')}: {inv.issuedAt ? new Date(inv.issuedAt).toLocaleDateString(isEn ? 'en-GB' : 'ro-RO') : '—'}</p>
        {inv.dueAt && <p class="text-xs mt-0.5" style={`color:${MUTED}`}>{t('Scadență', 'Due date')}: {new Date(inv.dueAt).toLocaleDateString(isEn ? 'en-GB' : 'ro-RO')}</p>}
      </div>
    </div>
  )}

  <div class="py-6 border-b" style={`border-color:${LINE}`}>
    <p class="text-[10px] uppercase tracking-wider" style={`color:${FAINT}`}>{t('Cumpărător', 'Buyer')}</p>
    <p class="font-bold mt-1 text-lg" style={`color:${INK}`}>{inv.clientNameSnap}</p>
    {inv.clientTaxIdSnap && <p class="text-xs mt-0.5" style={`color:${MUTED}`}>CUI: {inv.clientTaxIdSnap}</p>}
    {inv.clientAddressSnap && <p class="text-xs mt-0.5" style={`color:${MUTED}`}>{inv.clientAddressSnap}</p>}
  </div>

  <div class="py-6">
    <table class="w-full text-sm">
      <thead>
        {cfg.tableFill ? (
          <tr class="text-left text-[10px] uppercase tracking-wider text-white" style={`background:${brand}`}>
            <th class="py-2.5 px-3 rounded-l-lg">#</th>
            <th class="py-2.5 pl-2 pr-3">{t('Descriere', 'Description')}</th>
            <th class="py-2.5 px-2 text-right w-16">{t('Cant.', 'Qty')}</th>
            <th class="py-2.5 px-2 w-12">{t('UM', 'UoM')}</th>
            <th class="py-2.5 px-2 text-right w-24">{t('Preț unit.', 'Unit price')}</th>
            <th class="py-2.5 px-2 text-right w-16">{t('TVA', 'VAT')}</th>
            <th class="py-2.5 px-3 text-right w-28 rounded-r-lg">{t('Total', 'Total')}</th>
          </tr>
        ) : (
          <tr class="text-left text-[10px] uppercase tracking-[0.12em] border-b-2" style={`color:${brand}; border-color:${brand}`}>
            <th class="py-2.5 px-3">#</th>
            <th class="py-2.5 pl-2 pr-3">{t('Descriere', 'Description')}</th>
            <th class="py-2.5 px-2 text-right w-16">{t('Cant.', 'Qty')}</th>
            <th class="py-2.5 px-2 w-12">{t('UM', 'UoM')}</th>
            <th class="py-2.5 px-2 text-right w-24">{t('Preț unit.', 'Unit price')}</th>
            <th class="py-2.5 px-2 text-right w-16">{t('TVA', 'VAT')}</th>
            <th class="py-2.5 px-3 text-right w-28">{t('Total', 'Total')}</th>
          </tr>
        )}
      </thead>
      <tbody>
        {lines.map((l: any, i: number) => (
          <tr class="border-b" style={`border-color:${LINE2}`}>
            <td class="py-3 px-3 align-top" style={`color:${FAINT}`}>{i + 1}</td>
            <td class="py-3 pl-2 pr-3 align-top" style={`color:${INK}`}>{l.code && <span class="font-mono text-xs mr-1" style={`color:${FAINT}`}>{l.code}</span>}{l.description}</td>
            <td class="py-3 px-2 text-right tabular-nums align-top">{l.quantity}</td>
            <td class="py-3 px-2 align-top" style={`color:${MUTED}`}>{l.unit}</td>
            <td class="py-3 px-2 text-right tabular-nums align-top">{fmt(l.unitPriceCents)}</td>
            <td class="py-3 px-2 text-right tabular-nums align-top">{l.vatRate}%</td>
            <td class="py-3 px-3 text-right tabular-nums font-semibold align-top">{fmt(l.lineTotalCents)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="flex justify-end pt-4">
    {cfg.totalFill ? (
      <div class="w-1/2 rounded-xl p-5 text-white" style={`background:${brand}`}>
        <div class="space-y-1 text-sm">
          <div class="flex justify-between text-white/80"><span>{t('Subtotal', 'Subtotal')}</span><span class="tabular-nums">{fmt(inv.subtotalCents)} {inv.currency}</span></div>
          <div class="flex justify-between text-white/80"><span>{t('TVA', 'VAT')} ({inv.vatRegime ?? 'standard'})</span><span class="tabular-nums">{fmt(inv.vatCents)} {inv.currency}</span></div>
          <div class="flex justify-between text-lg font-bold border-t border-white/25 pt-2 mt-2">
            <span>{t('Total de plată', 'Amount due')}</span>
            <span class="tabular-nums">{fmt(inv.totalCents)} {inv.currency}</span>
          </div>
          {inv.paidCents > 0 && (
            <div class="flex justify-between text-xs text-white/80"><span>{t('Încasat', 'Paid')}</span><span class="tabular-nums">{fmt(inv.paidCents)} {inv.currency}</span></div>
          )}
        </div>
      </div>
    ) : (
      <div class={`w-1/2 text-sm ${cfg.panel ? 'rounded-xl p-4' : ''}`} style={cfg.panel ? `background:${brand}0A` : ''}>
        <div class="space-y-1">
          <div class="flex justify-between"><span style={`color:${MUTED}`}>{t('Subtotal', 'Subtotal')}</span><span class="tabular-nums">{fmt(inv.subtotalCents)} {inv.currency}</span></div>
          <div class="flex justify-between"><span style={`color:${MUTED}`}>{t('TVA', 'VAT')} ({inv.vatRegime ?? 'standard'})</span><span class="tabular-nums">{fmt(inv.vatCents)} {inv.currency}</span></div>
          <div class="flex justify-between text-base font-bold border-t pt-2 mt-2" style={`color:${brand}; border-color:${brand}33`}>
            <span>{t('Total de plată', 'Amount due')}</span>
            <span class="tabular-nums">{fmt(inv.totalCents)} {inv.currency}</span>
          </div>
          {inv.paidCents > 0 && (
            <div class="flex justify-between text-xs" style="color:#2E9E6A"><span>{t('Încasat', 'Paid')}</span><span class="tabular-nums">{fmt(inv.paidCents)} {inv.currency}</span></div>
          )}
        </div>
      </div>
    )}
  </div>

  {inv.bnrRate && inv.bnrRateDate && (inv.currency ?? 'RON') !== 'RON' && (
    <div class="mt-4 text-xs flex justify-end" style={`color:${MUTED}`}>
      <span>{t('Curs BNR', 'NBR rate')} {inv.bnrRateDate}: 1 {inv.currency} = {inv.bnrRate.toFixed(4)} RON
        {' · '}{t('Echivalent total', 'Total equiv.')}: <strong style={`color:${INK}`}>{(inv.totalCents * inv.bnrRate / 100).toLocaleString('ro-RO', { minimumFractionDigits: 2 })} RON</strong>
      </span>
    </div>
  )}

  {inv.vatAtCollection && (
    <div class="mt-4 text-[11px] italic px-3 py-2 rounded-lg" style="color:#9A6A12; background:#FBF4E6">
      {t('TVA la încasare — exigibilitatea TVA intervine la data încasării contravalorii facturii (art. 282 Cod fiscal).',
         'VAT on collection — VAT becomes chargeable upon receipt of payment (art. 282 Fiscal Code).')}
    </div>
  )}

  {showShipping && (
    <div class="mt-6 px-3 py-2.5 border rounded-lg" style={`border-color:${LINE}`}>
      <p class="text-[10px] uppercase tracking-wider mb-1" style={`color:${FAINT}`}>{t('Date privind expediția', 'Shipping details')}</p>
      <p class="text-sm whitespace-pre-wrap" style={`color:${MUTED}`}>{inv.shippingText}</p>
    </div>
  )}

  {inv.notes && (
    <div class="mt-8 pt-6 border-t" style={`border-color:${LINE}`}>
      <p class="text-[10px] uppercase tracking-wider mb-1" style={`color:${FAINT}`}>{t('Mențiuni', 'Notes')}</p>
      <p class="text-sm whitespace-pre-wrap" style={`color:${MUTED}`}>{inv.notes}</p>
    </div>
  )}

  <div class="mt-12 flex justify-between items-end gap-8">
    <div></div>
    {(stampUrl || signatureUrl) && (
      <div class="flex justify-end gap-8 items-end">
        {signatureUrl && (
          <div class="text-center">
            <img src={signatureUrl} alt="Semnătură" style="max-height: 60px; max-width: 180px;" />
            <p class="text-[10px] mt-1 border-t pt-1" style={`color:${FAINT}; border-color:${LINE}`}>{t('Semnătură emitent', 'Issuer signature')}</p>
          </div>
        )}
        {stampUrl && (
          <div class="text-center">
            <img src={stampUrl} alt="Ștampilă" style="max-height: 90px; max-width: 150px; opacity: 0.85;" />
          </div>
        )}
      </div>
    )}
  </div>

  {footerText && (
    <div class="mt-12 pt-4 border-t" style={`border-color:${LINE}`}>
      <p class="text-[10px] whitespace-pre-wrap text-center" style={`color:${FAINT}`}>{footerText}</p>
    </div>
  )}
  {showEmittedWith && (
    <p class="mt-4 text-[9px] text-center" style={`color:${FAINT}`}>{t('Emis cu', 'Issued with')} facturamea · facturamea.com</p>
  )}
</div>

<style is:global>
  /* The invoice is paper: always a white sheet with dark ink, in BOTH the
     light and dark app themes, and in print. We deliberately scope every
     paper colour to this dedicated class with !important so the global
     `html.th-dark .bg-white { … }` (and friends) in BaseLayout / AppLayout
     can never reach inside the rendered document and make text illegible. */
  .fm-invoice-paper,
  /* Out-specify the dark-theme overrides in BaseLayout / AppLayout, including
     the inline-style attribute catch-all `html.th-dark [style*="background:#fff"]`.
     Doubling the class raises specificity so the sheet always wins. */
  html.th-dark .fm-invoice-paper.fm-invoice-paper,
  html.th-app-dark .fm-invoice-paper.fm-invoice-paper,
  html.th-light .fm-invoice-paper.fm-invoice-paper {
    background: #ffffff !important;
    color: #07090f !important;
    color-scheme: light;
  }
  /* Default ink for any descendant that relies on inheritance (e.g. table
     cells with no inline colour). Elements with their own inline `style`
     colour keep it — inline styles outrank this selector. */
  .fm-invoice-paper, .fm-invoice-paper * {
    border-color: inherit;
  }
  .fm-invoice-paper td,
  .fm-invoice-paper th,
  .fm-invoice-paper p,
  .fm-invoice-paper span,
  .fm-invoice-paper div {
    color: inherit;
  }
  /* White text on coloured bands/headers/totals must stay white. */
  .fm-invoice-paper .text-white,
  .fm-invoice-paper .text-white * {
    color: #ffffff !important;
  }
</style>
