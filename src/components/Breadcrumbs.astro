---
// Pages can override the last crumb's label via the `currentTitle` prop —
// useful for /app/licitatii/[id], /app/incidente/[id], /app/comenzi/[id] etc.
// where the dynamic ID otherwise leaks into the UI.
interface Props {
  currentTitle?: string;
  // Swap the first non-/app crumb's label + href. Useful when a page
  // physically lives under /setari but the user arrived from a
  // different section (e.g. ?from=camioane on /setari/fleet) — we want
  // breadcrumbs to read "Acasă / Camioane / Flotă" instead of
  // "Acasă / Setări / Flotă".
  parentLabel?: string;
  parentHref?: string;
  // Pre-built leading crumbs derived from the sidebar's active leaf (incl.
  // "Acasă") so the breadcrumb mirrors the menu trail exactly, e.g.
  // "Acasă / Marfă / Caut marfă". `basePath` is the leaf's href — any deeper
  // URL segments past it are appended as tail crumbs (detail pages / IDs).
  baseTrail?: { label: string; href?: string }[];
  basePath?: string;
}
const { currentTitle, parentLabel, parentHref, baseTrail, basePath } = Astro.props;
const path = Astro.url.pathname;
const segments = path.split('/').filter(Boolean);

const labels: Record<string, string> = {
  app: 'Acasă',
  marfa: 'Marfă',
  camioane: 'Camioane',
  licitatii: 'Licitații',
  comenzi: 'Comenzi',
  companii: 'Companii',
  companie: 'Companie',
  incidente: 'Incidente',
  forum: 'Forum',
  setari: 'Setări',
  notificari: 'Notificări',
  mesaje: 'Mesaje',
  'mica-publicitate': 'Mică publicitate',
  post: 'Postează',
  new: 'Nou',
  mele: 'Ale mele',
  fleet: 'Flotă',
  clauses: 'Clauze',
  'sub-users': 'Sub-utilizatori',
  subscription: 'Abonament',
  notifications: 'Preferințe notificări',
  blacklist: 'Listă neagră',
  'route-alerts': 'Alerte rute',
};

// Detect IDs: hex-only ≥8, all digits, OR nanoid-style (mixed case + digits + -, length ≥10).
function isIdSegment(s: string): boolean {
  if (/^[0-9a-f]{8,}$/i.test(s)) return true;
  if (/^\d+$/.test(s)) return true;
  if (s.length >= 10 && /^[A-Za-z0-9_-]+$/.test(s) && /[A-Z]/.test(s) && /\d/.test(s)) return true;
  return false;
}

const crumbs: { href?: string; label: string }[] = [];

if (baseTrail && baseTrail.length) {
  // Menu-derived trail. Seed with the prebuilt crumbs, then append any URL
  // segments deeper than the leaf's own path (e.g. a detail-page [id]).
  crumbs.push(...baseTrail.map((c) => ({ href: c.href, label: c.label })));
  const baseSegCount = (basePath || '').split('/').filter(Boolean).length;
  let acc = basePath || '';
  for (let i = baseSegCount; i < segments.length; i++) {
    const seg = segments[i];
    acc += '/' + seg;
    const isId = isIdSegment(seg);
    const label = labels[seg] ?? (isId ? '#' + seg.slice(0, 6) : seg.charAt(0).toUpperCase() + seg.slice(1));
    crumbs.push({ href: acc, label });
  }
} else {
  let acc = '';
  for (let i = 0; i < segments.length; i++) {
    const seg = segments[i];
    acc += '/' + seg;
    const isId = isIdSegment(seg);
    const label = labels[seg] ?? (isId ? '#' + seg.slice(0, 6) : seg.charAt(0).toUpperCase() + seg.slice(1));
    crumbs.push({ href: acc, label });
  }
  // Override the first non-/app crumb if the page asked for it.
  if (parentLabel && crumbs.length > 1) {
    crumbs[1].label = parentLabel;
    if (parentHref) crumbs[1].href = parentHref;
  }
}

// Override last crumb with the entity title if provided
if (currentTitle && crumbs.length > 0) {
  crumbs[crumbs.length - 1].label = currentTitle;
}
---

{crumbs.length > 1 && (
  <nav aria-label="breadcrumb" class="text-[12px] text-[#46627A] mb-4">
    <ol class="flex items-center flex-wrap gap-1.5">
      {crumbs.map((c, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && <span class="text-[#A8BED2]">/</span>}
          {i === crumbs.length - 1 ? (
            <span class="text-[#07090f] font-medium truncate max-w-[40ch]">{c.label}</span>
          ) : c.href ? (
            <a href={c.href} class="hover:text-[#07090f] transition-colors">{c.label}</a>
          ) : (
            <span class="truncate max-w-[40ch]">{c.label}</span>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}
