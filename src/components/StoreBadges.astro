---
// App Store + Google Play badge buttons (dark pills, work on light backgrounds).
interface Props {
  class?: string;
  href?: string;
}
const { class: cls = '', href = '/auth/register' } = Astro.props;
---
<div class:list={['flex flex-col sm:flex-row items-center gap-3', cls]}>
  <a href={href} data-magnetic class="flex items-center gap-3 pl-5 pr-7 py-3 rounded-2xl bg-[#07090f] text-white hover:bg-[#14304b] transition-colors">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.4 12.9c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.8-1.4-.1-2.8.9-3.5.9s-1.8-.9-3-.8c-1.5 0-2.9.9-3.7 2.3-1.6 2.7-.4 6.8 1.1 9 .7 1.1 1.6 2.3 2.8 2.2 1.1 0 1.5-.7 2.9-.7s1.7.7 2.9.7 2-1.1 2.7-2.1c.9-1.2 1.2-2.4 1.2-2.5-.1 0-2.3-.9-2.3-3.4zM14.1 5.9c.6-.8 1-1.8.9-2.9-.9 0-2 .6-2.6 1.3-.6.7-1.1 1.7-1 2.7 1 .1 2-.5 2.7-1.1z"/></svg>
    <span class="text-left leading-tight"><span class="block text-[10px] text-[#A8BED2]">Descarcă pe</span><span class="block text-[15px] font-bold">App Store</span></span>
  </a>
  <a href={href} data-magnetic class="flex items-center gap-3 pl-5 pr-7 py-3 rounded-2xl bg-[#07090f] text-white hover:bg-[#14304b] transition-colors">
    <svg width="20" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 2.5v19l10.5-9.5L3 2.5z" fill="#34A0A4"/><path d="M3 2.5l10.5 9.5 3-2.7L4.6 1.6A1.7 1.7 0 0 0 3 2.5z" fill="#76C893"/><path d="M3 21.5l10.5-9.5 3 2.7-11.9 7.7a1.7 1.7 0 0 1-1.6-.9z" fill="#168AAD"/><path d="M16.5 9.3l-3 2.7 3 2.7 3.6-2a1.5 1.5 0 0 0 0-1.4l-3.6-2z" fill="#E1FB15"/></svg>
    <span class="text-left leading-tight"><span class="block text-[10px] text-[#A8BED2]">Disponibil pe</span><span class="block text-[15px] font-bold">Google Play</span></span>
  </a>
</div>
