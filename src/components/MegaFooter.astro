---
const year = new Date().getFullYear();

const sections = [
  {
    title: 'PRODUS',
    items: [
      { label: 'Funcții', href: '/#functii' },
      { label: 'Prețuri', href: '/#preturi' },
      { label: 'e-Factura', href: '/#e-factura' },
      { label: 'Aplicații mobile', href: '/#aplicatii' },
    ],
  },
  {
    title: 'RESURSE',
    items: [
      { label: 'Blog', href: '/blog' },
      { label: 'Întrebări frecvente', href: '/#faq' },
      { label: 'Ghid e-Factura', href: '/#e-factura' },
      { label: 'Contact', href: '/#contact' },
    ],
  },
  {
    title: 'LEGAL',
    items: [
      { label: 'Termeni', href: '/termeni' },
      { label: 'Confidențialitate', href: '/confidentialitate' },
      { label: 'Politica cookies', href: '/confidentialitate#cookies' },
    ],
  },
];
---

<footer class="bg-[#0A0A0A] text-[#A8A8A4] print:hidden">
  <div class="max-w-[1400px] mx-auto px-4 lg:px-6 py-14">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-x-6 gap-y-10 text-sm">
      <div class="col-span-2 md:col-span-1 md:pr-4">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <img src="/logo.png" alt="facturamea" width="36" height="36" class="w-9 h-9" />
          <span class="text-lg font-bold text-white tracking-[-0.02em]">factura<span class="text-[#34A0A4]">mea</span></span>
        </a>
        <p class="text-sm text-[#A8A8A4] leading-relaxed max-w-xs">
          Facturare completă pentru firme din România. O singură plată, licență pe viață.
        </p>
      </div>

      {sections.map((s) => (
        <div>
          <h4 class="text-white font-semibold mb-3 text-xs uppercase tracking-wider">{s.title}</h4>
          <ul class="space-y-2">
            {s.items.map((it) => (
              <li><a href={it.href} class="hover:text-white transition-colors text-[#A8A8A4]">{it.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-[#6B6B68]">
      <p>&copy; {year} facturamea. Toate drepturile rezervate.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <span>Conform ANAF e-Factura</span>
        <span>SAF-T D406</span>
        <span>e-Transport</span>
      </div>
    </div>
  </div>
</footer>
