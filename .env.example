# facturamea — Environment variables
# Copy to .env.local (dev) or set in Coolify → Environment Variables (prod).
# Deploy target is the self-hosted Node/Coolify server, NOT Vercel.
# Never commit real values.
#
# Legend: [REQUIRED] app crashes/breaks without it · [OPTIONAL] feature is degraded but app boots
# Source of truth for what the code reads:
#   grep -rohE "(import\.meta\.env|process\.env)\.[A-Z_][A-Z0-9_]+" src/ scripts/

# ─── Database [REQUIRED] ───────────────────────────────────
# Neon Postgres pooled URL. Auto-injected on Vercel via the Neon Marketplace integration.
# Local dev: Neon console → Connect → copy "Pooled connection".
# Without this, app throws on boot ("DATABASE_URL is not set").
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require

# Direct (non-pooled) URL — only needed by drizzle-kit when running migrations.
# Local-only; not needed at runtime.
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require

# ─── Email — Resend [OPTIONAL but strongly recommended] ────
# Used by: waitlist thank-you, password reset, document expiry, auction bid/award,
# freight bid, order created, new message notifications.
# Without it, sendEmail() throws and the calling try/catch logs the failure —
# the in-app action still completes.
# Get from https://resend.com → API Keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Override the "From:" address. Default: TransportHub <no-reply@send.transporthub.ro>
# Set this once you've verified your sending domain in Resend (SPF + DKIM + DMARC).
RESEND_FROM=TransportHub <no-reply@send.transporthub.ro>

# ─── Cron jobs [REQUIRED if vercel.json crons are enabled] ─
# Bearer token Vercel Cron sends as `Authorization: Bearer ${CRON_SECRET}`.
# `/api/cron/daily` and `/api/cron/hourly` reject requests without a matching token.
# Generate: openssl rand -hex 32
CRON_SECRET=replace-with-64-hex-char-random-string

# ─── ANAF OAuth (e-Factura + e-Transport) [OPTIONAL] ───────
# Required only if you want users to connect their company to ANAF SPV.
# CUI verification at registration works without these (uses the public
# webservicesp.anaf.ro endpoint).
#
# Register an OAuth app at https://logincert.anaf.ro/anaf-oauth2/v1/ with
# a qualified digital certificate. ANAF approves apps in 5-15 days.
# Callback URL must match ANAF_REDIRECT_URI exactly.
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=
ANAF_REDIRECT_URI=https://transporthub.ro/api/anaf/callback
# 'test' uses api.anaf.ro/test/... (sandbox, no fiscal effect).
# 'prod' goes to api.anaf.ro/prod/... — real submissions.
ANAF_API_MODE=test
# 32-byte hex (64 chars) for AES-256-GCM token-at-rest encryption.
# Generate: openssl rand -hex 32
# Rotating this key invalidates all stored ANAF connections — users reconnect.
ANAF_ENCRYPTION_KEY=

# ─── Local seed script [OPTIONAL] ──────────────────────────
# Set to "1" to make scripts/seed-demo.ts exit immediately (used to skip seeding
# in CI or when DATABASE_URL points at production).
# SKIP_SEED=1

# ─── Reserved / future (NOT read by current code) ──────────
# Listed so future contributors know naming conventions when these features land.
#
# BETTER_AUTH_SECRET=...        # if migrating auth from custom sessions to better-auth
# BETTER_AUTH_URL=...
# BLOB_READ_WRITE_TOKEN=...     # Vercel Blob — for CMR/document uploads (auto-injected)
# ANAF_API_BASE=https://webservicesp.anaf.ro/PlatitorTvaRest/api/v8
# ARR_API_KEY=...               # ARR licenses lookup
# OPENAI_API_KEY=...            # AI assistance
# STRIPE_SECRET_KEY=...         # credits checkout
# SENTRY_DSN=...                # error reporting

# [RECOMMENDED] Web Push (VAPID). Generate keys once locally with:
#   npx web-push generate-vapid-keys
# Public key MUST be prefixed PUBLIC_ so Vite/Astro exposes it to the
# client; private key stays server-side.
# PUBLIC_VAPID_PUBLIC_KEY=B...
# VAPID_PRIVATE_KEY=...
# VAPID_CONTACT=mailto:contact@transporthub.ro

# [RECOMMENDED in prod] Upstash Redis for rate-limit + lockout. Without
# these, both fall back to in-memory which is ineffective on Vercel
# serverless (counters reset per cold container). Create a free DB at
# https://console.upstash.com/redis and copy the REST URL + token.
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# ── File storage (uploads, logos, expense docs) ─────────────────────────────
# S3-compatible, provider-agnostic. No monthly fee / no lock-in. Use ONE of:
#  • Cloudflare R2 (recommended): 10 GB free, no egress fee. Create a bucket +
#    API token at dash.cloudflare.com → R2. Endpoint = https://<accountid>.r2.cloudflarestorage.com
#  • Self-hosted MinIO on the same Coolify server (fully free). Set S3_FORCE_PATH_STYLE=true.
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_BUCKET=facturamea
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_REGION=auto            # 'auto' for R2; real region for AWS S3
# S3_FORCE_PATH_STYLE=true  # required for MinIO; harmless for R2
# (Legacy fallback: BLOB_READ_WRITE_TOKEN for Vercel Blob — not needed if S3_* set.)

# ── Email (transactional: invoices sent, dunning, verification) ─────────────
# SMTP, provider-agnostic, pay-per-use / free-tier (no monthly lock-in). Pick one:
#  • Brevo: 300 emails/day free forever (smtp-relay.brevo.com:587)
#  • Amazon SES: ~$0.10 / 1000 emails, no monthly (email-smtp.<region>.amazonaws.com:587)
#  • Zoho ZeptoMail: ~$2.5 / 10k emails, no monthly
# EMAIL_FROM=facturamea <no-reply@facturamea.com>
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# (Legacy fallback: RESEND_API_KEY + RESEND_FROM — used only if SMTP_HOST unset.)

# ── OAuth social login (Google / Apple) ─────────────────────────────────────
# Google: console.cloud.google.com → APIs & Services → Credentials → OAuth client
#   (Web). Authorized redirect URI: https://facturamea.com/api/auth/google/callback
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# Apple: developer.apple.com → Identifiers (Services ID) + Key (Sign in with Apple).
#   Return URL: https://facturamea.com/api/auth/apple/callback
# APPLE_CLIENT_ID=com.facturamea.signin   # the Services ID
# APPLE_TEAM_ID=...
# APPLE_KEY_ID=...
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
